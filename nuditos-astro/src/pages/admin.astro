---
/**
 * Panel de administración — Nuditos Tejidos
 * URL: /admin
 * No usa el Layout principal — tiene su propio diseño
 * noindex para que Google no lo indexe
 */
export const prerender = false;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nuditos — Panel Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet" />
  <style>
    :root {
      --lila:#8b5cf6;--lila-light:#ede9fe;--lila-dark:#6d28d9;--lila-xlight:#f5f3ff;
      --mint:#10b981;--mint-light:#d1fae5;--mint-dark:#059669;
      --red:#ef4444;--red-light:#fee2e2;
      --orange:#f59e0b;--orange-light:#fef3c7;
      --blue:#3b82f6;--blue-light:#dbeafe;
      --yellow:#eab308;--yellow-light:#fef9c3;
      --bg:#f5f3ef;--panel:#fff;
      --sidebar:#0f0e17;--sidebar2:#1a1830;
      --text:#1a1a1a;--soft:#6b7280;
      --border:#e5e0d8;--nav-h:52px;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);height:100vh;overflow:hidden}

    #loginScreen{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0f0e17,#1a1830,#0f0e17);z-index:999;}
    .login-card{background:#fff;border-radius:24px;padding:2.6rem 2.2rem;width:100%;max-width:340px;text-align:center;box-shadow:0 40px 80px rgba(0,0,0,.4);}
    .login-logo{font-family:'Playfair Display',serif;font-size:2.2rem;color:var(--lila);margin-bottom:.2rem}
    .login-sub{font-size:.8rem;color:var(--soft);margin-bottom:1.8rem}
    .login-input{width:100%;padding:.85rem 1rem;border:1.5px solid var(--border);border-radius:14px;font-family:'Outfit',sans-serif;font-size:1rem;outline:none;margin-bottom:.8rem;text-align:center;letter-spacing:4px;transition:border-color .2s;}
    .login-input:focus{border-color:var(--lila)}
    .login-btn{width:100%;padding:.85rem;background:var(--lila);color:#fff;border:none;border-radius:14px;font-family:'Outfit',sans-serif;font-size:.95rem;font-weight:600;cursor:pointer;transition:all .2s;}
    .login-btn:hover{background:var(--lila-dark);transform:translateY(-1px)}
    .login-err{color:var(--red);font-size:.78rem;margin-top:.6rem;display:none}

    #adminPanel{display:none;height:100vh;flex-direction:column}

    .admin-nav{height:var(--nav-h);background:linear-gradient(90deg,var(--sidebar),var(--sidebar2));display:flex;align-items:center;gap:.5rem;padding:0 1rem;flex-shrink:0;z-index:50;border-bottom:1px solid rgba(255,255,255,.05);}
    .nav-hamburger{display:none;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);color:#fff;width:36px;height:36px;border-radius:10px;cursor:pointer;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0;}
    .admin-logo{font-family:'Playfair Display',serif;font-size:1.1rem;color:#fff;flex-shrink:0;margin-right:.3rem}
    .admin-logo span{font-family:'Outfit',sans-serif;font-size:.62rem;color:rgba(255,255,255,.35);font-weight:400}
    .admin-tabs{display:flex;gap:.3rem;flex:1;overflow-x:auto;scrollbar-width:none}
    .admin-tabs::-webkit-scrollbar{display:none}
    .a-tab{background:rgba(255,255,255,.06);color:rgba(255,255,255,.5);border:1px solid rgba(255,255,255,.08);padding:.32rem .78rem;border-radius:50px;cursor:pointer;font-family:'Outfit',sans-serif;font-size:.73rem;transition:all .2s;white-space:nowrap;flex-shrink:0;}
    .a-tab:hover{background:rgba(255,255,255,.12);color:#fff}
    .a-tab.active{background:var(--lila);color:#fff;border-color:var(--lila)}
    .nav-right-actions{display:flex;gap:.4rem;flex-shrink:0;align-items:center}
    .preview-btn{background:rgba(16,185,129,.15);color:#6ee7b7;border:1px solid rgba(16,185,129,.3);padding:.32rem .75rem;border-radius:50px;font-size:.7rem;cursor:pointer;font-family:'Outfit',sans-serif;transition:all .2s;display:flex;align-items:center;gap:.3rem;}
    .preview-btn:hover{background:var(--mint);color:#fff;border-color:var(--mint)}
    .logout-btn{background:rgba(255,255,255,.06);color:rgba(255,255,255,.4);border:1px solid rgba(255,255,255,.08);padding:.32rem .7rem;border-radius:50px;cursor:pointer;font-family:'Outfit',sans-serif;font-size:.7rem;transition:all .2s;}
    .logout-btn:hover{background:rgba(239,68,68,.25);color:#fca5a5;border-color:rgba(239,68,68,.3)}

    .workspace{flex:1;display:flex;overflow:hidden;height:calc(100vh - var(--nav-h))}

    .left-col{width:270px;flex-shrink:0;background:var(--sidebar);display:flex;flex-direction:column;overflow:hidden;border-right:1px solid rgba(255,255,255,.05);transition:transform .35s cubic-bezier(.4,0,.2,1);}
    .left-header{padding:.85rem .9rem .6rem;border-bottom:1px solid rgba(255,255,255,.06)}
    .left-title{color:#fff;font-size:.72rem;font-weight:700;letter-spacing:.5px;text-transform:uppercase;margin-bottom:.5rem}
    .left-search{width:100%;padding:.44rem .75rem;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.09);border-radius:8px;color:#fff;font-family:'Outfit',sans-serif;font-size:.78rem;outline:none;}
    .left-search::placeholder{color:rgba(255,255,255,.3)}
    .left-search:focus{border-color:var(--lila);background:rgba(255,255,255,.11)}
    .left-filters{display:flex;gap:.3rem;margin-top:.45rem;flex-wrap:wrap}
    .lf-chip{font-size:.63rem;padding:.16rem .5rem;border-radius:20px;cursor:pointer;border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.45);background:rgba(255,255,255,.04);transition:all .18s;white-space:nowrap;}
    .lf-chip.active{background:var(--lila);border-color:var(--lila);color:#fff}
    .left-stats{display:flex;border-bottom:1px solid rgba(255,255,255,.06)}
    .ls-stat{flex:1;text-align:center;padding:.4rem .2rem;border-right:1px solid rgba(255,255,255,.06)}
    .ls-stat:last-child{border-right:none}
    .ls-num{font-size:.88rem;font-weight:700;color:var(--lila)}
    .ls-num.red{color:#f87171}.ls-num.green{color:#6ee7b7}
    .ls-label{font-size:.54rem;color:rgba(255,255,255,.3);text-transform:uppercase}
    .btn-add-prod{margin:.65rem .75rem .3rem;padding:.58rem;background:var(--lila);color:#fff;border:none;border-radius:9px;font-family:'Outfit',sans-serif;font-size:.78rem;font-weight:600;cursor:pointer;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:.4rem;}
    .btn-add-prod:hover{background:var(--lila-dark)}
    .prod-list-scroll{flex:1;overflow-y:auto;padding:.25rem .35rem .4rem}
    .prod-list-scroll::-webkit-scrollbar{width:3px}
    .prod-list-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:4px}
    .cat-group-label{font-size:.58rem;font-weight:700;color:rgba(255,255,255,.25);text-transform:uppercase;letter-spacing:.8px;padding:.5rem .45rem .22rem}
    .prod-item{display:flex;align-items:center;gap:.55rem;padding:.45rem .55rem;border-radius:8px;cursor:pointer;transition:all .18s;margin-bottom:1px;border:1px solid transparent;}
    .prod-item:hover{background:rgba(255,255,255,.06)}
    .prod-item.selected{background:rgba(139,92,246,.18);border-color:rgba(139,92,246,.35)}
    .prod-item.inactive{opacity:.35}
    .pi-thumb{width:32px;height:32px;border-radius:7px;overflow:hidden;flex-shrink:0;background:rgba(255,255,255,.09);display:flex;align-items:center;justify-content:center;font-size:1rem;}
    .pi-thumb img{width:100%;height:100%;object-fit:cover}
    .pi-info{flex:1;min-width:0}
    .pi-name{font-size:.73rem;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .pi-meta{font-size:.6rem;color:rgba(255,255,255,.35);margin-top:.06rem}
    .pi-tags{display:flex;gap:.2rem;margin-top:.15rem;flex-wrap:wrap}
    .pi-tag{font-size:.51rem;padding:.05rem .3rem;border-radius:20px;font-weight:600}
    .pit-oferta{background:rgba(245,158,11,.18);color:#fcd34d}
    .pit-envio{background:rgba(16,185,129,.18);color:#6ee7b7}
    .pit-oculto{background:rgba(255,255,255,.06);color:rgba(255,255,255,.28)}
    .pit-badge{background:rgba(139,92,246,.22);color:#c4b5fd}
    .pit-stock{background:rgba(239,68,68,.18);color:#fca5a5}
    .pi-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
    .pi-dot.on{background:var(--mint)}.pi-dot.off{background:#374151}

    .sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:199;}
    .sidebar-overlay.open{display:block}

    .right-col{flex:1;overflow-y:auto;padding:1.4rem 1.6rem 6rem;background:var(--bg)}
    .right-col::-webkit-scrollbar{width:4px}
    .right-col::-webkit-scrollbar-thumb{background:#d1d5db;border-radius:4px}

    .tab-content{display:none;flex:1;overflow-y:auto;padding:1.4rem 1.6rem 6rem;background:var(--bg)}
    .tab-content.active{display:block}
    .tab-content::-webkit-scrollbar{width:4px}
    .tab-content::-webkit-scrollbar-thumb{background:#d1d5db;border-radius:4px}

    .editor-empty{height:calc(100vh - var(--nav-h) - 4rem);min-height:280px;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--soft);text-align:center;gap:.6rem;}
    .editor-empty-icon{font-size:3rem}
    .editor-empty h3{font-size:1rem;font-weight:600;color:var(--text)}
    .editor-empty p{font-size:.8rem;max-width:220px;line-height:1.5}

    .editor-card{background:var(--panel);border-radius:16px;padding:1.3rem;border:1px solid var(--border);box-shadow:0 2px 12px rgba(0,0,0,.04);margin-bottom:1.1rem}
    .ec-header{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1.1rem;flex-wrap:wrap}
    .ec-title{font-family:'Playfair Display',serif;font-size:1.05rem}
    .ec-sub{font-size:.72rem;color:var(--soft);margin-top:.15rem}
    .ec-actions{display:flex;gap:.4rem;flex-shrink:0;flex-wrap:wrap}

    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:.7rem .9rem;margin-bottom:.85rem}
    .field-full{grid-column:1/-1}
    .field label{display:block;font-size:.68rem;font-weight:600;color:var(--soft);margin-bottom:.26rem;text-transform:uppercase;letter-spacing:.5px}
    .field input,.field select,.field textarea{width:100%;padding:.55rem .8rem;border:1.5px solid var(--border);border-radius:10px;font-family:'Outfit',sans-serif;font-size:.83rem;outline:none;background:var(--bg);color:var(--text);transition:border-color .2s;}
    .field input:focus,.field select:focus,.field textarea:focus{border-color:var(--lila);background:#fff}
    .field textarea{resize:vertical;min-height:58px}

    .img-upload-section{border:1.5px dashed var(--border);border-radius:12px;padding:1rem;background:var(--bg);margin-bottom:.85rem}
    .img-upload-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem;flex-wrap:wrap;gap:.5rem}
    .img-upload-title{font-size:.72rem;font-weight:700;color:var(--soft);text-transform:uppercase;letter-spacing:.5px}
    .upload-zone{border:2px dashed var(--lila-light);border-radius:10px;padding:1.2rem;text-align:center;cursor:pointer;background:var(--lila-xlight);transition:all .2s;margin-bottom:.65rem;position:relative;}
    .upload-zone:hover{border-color:var(--lila);background:#eee9fe}
    .upload-zone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
    .upload-zone-icon{font-size:1.6rem;margin-bottom:.3rem}
    .upload-zone-text{font-size:.78rem;color:var(--lila-dark);font-weight:600}
    .upload-zone-sub{font-size:.68rem;color:var(--soft);margin-top:.18rem}
    .upload-progress{height:4px;background:var(--lila-light);border-radius:2px;overflow:hidden;margin:.4rem 0;display:none;}
    .upload-progress-bar{height:100%;background:var(--lila);border-radius:2px;transition:width .3s;width:0}
    .cloudinary-config{background:var(--lila-xlight);border:1px solid var(--lila-light);border-radius:10px;padding:.8rem;margin-bottom:.7rem;}
    .cc-title{font-size:.7rem;font-weight:700;color:var(--lila-dark);margin-bottom:.55rem;display:flex;align-items:center;gap:.3rem}
    .cc-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
    .cc-field label{font-size:.63rem;font-weight:600;color:var(--soft);text-transform:uppercase;display:block;margin-bottom:.22rem}
    .cc-field input{width:100%;padding:.44rem .7rem;border:1.5px solid var(--border);border-radius:8px;font-family:'Outfit',sans-serif;font-size:.78rem;outline:none;background:#fff;}
    .cc-field input:focus{border-color:var(--lila)}
    .cc-save{margin-top:.55rem;width:100%;background:var(--lila);color:#fff;border:none;padding:.5rem;border-radius:8px;font-family:'Outfit',sans-serif;font-size:.78rem;font-weight:600;cursor:pointer;transition:background .2s;}
    .cc-save:hover{background:var(--lila-dark)}
    .img-preview-row{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.35rem}
    .img-thumb-wrap{position:relative;display:inline-block}
    .img-thumb{width:68px;height:68px;border-radius:9px;object-fit:cover;border:2px solid var(--border);display:block}
    .img-thumb-rm{position:absolute;top:-5px;right:-5px;width:18px;height:18px;background:var(--red);color:#fff;border:none;border-radius:50%;cursor:pointer;font-size:.65rem;display:flex;align-items:center;justify-content:center;line-height:1;}
    .img-url-input{width:100%;padding:.48rem .75rem;border:1.5px solid var(--border);border-radius:8px;font-family:'Outfit',sans-serif;font-size:.78rem;outline:none;background:var(--bg);margin-bottom:.45rem;}
    .img-url-input:focus{border-color:var(--lila);background:#fff}

    .preview-panel{background:var(--panel);border-radius:16px;padding:1.1rem;border:1px solid var(--border);margin-bottom:1.1rem;box-shadow:0 2px 12px rgba(0,0,0,.04);}
    .preview-label{font-size:.68rem;font-weight:700;color:var(--soft);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.8rem;display:flex;align-items:center;gap:.4rem}
    .preview-label::before{content:'';flex:1;height:1px;background:var(--border)}
    .preview-label::after{content:'';flex:1;height:1px;background:var(--border)}
    .preview-card-wrap{display:flex;justify-content:center}
    .preview-card{width:160px;border-radius:16px;overflow:hidden;background:#fff;box-shadow:0 4px 20px rgba(0,0,0,.1);}
    .preview-img{aspect-ratio:3/4;background:var(--lila-xlight);display:flex;align-items:center;justify-content:center;font-size:3.5rem;position:relative;overflow:hidden;}
    .preview-img img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}
    .preview-badge{position:absolute;top:.5rem;left:.5rem;background:var(--text);color:#fff;font-size:.52rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;padding:.15rem .45rem;border-radius:3px;}
    .preview-badge.nuevo{background:var(--mint-dark)}
    .preview-badge.popular{background:var(--red)}
    .preview-badge.especial{background:var(--lila-dark)}
    .preview-badge.agotado{background:#6b7280}
    .preview-info{padding:.65rem .7rem .75rem}
    .preview-cat{font-size:.55rem;color:var(--soft);text-transform:uppercase;letter-spacing:1px;margin-bottom:.2rem}
    .preview-name{font-size:.78rem;font-weight:700;color:var(--text);line-height:1.25;margin-bottom:.3rem}
    .preview-price{font-family:'Playfair Display',serif;font-size:.92rem;color:#6d28d9;font-weight:700}
    .preview-price .orig{font-family:'Outfit',sans-serif;font-size:.65rem;color:#9ca3af;text-decoration:line-through;font-weight:400;margin-right:.2rem}

    .stock-row{display:flex;align-items:center;gap:.7rem;padding:.65rem .85rem;background:var(--bg);border:1.5px solid var(--border);border-radius:10px;margin-bottom:.7rem}
    .stock-icon{font-size:1.2rem}
    .stock-info{flex:1}
    .stock-label{font-size:.78rem;font-weight:600}
    .stock-sub{font-size:.68rem;color:var(--soft)}
    .stock-input-wrap{display:flex;align-items:center;gap:.4rem}
    .stock-num{width:64px;padding:.42rem .6rem;border:1.5px solid var(--border);border-radius:8px;font-family:'Outfit',sans-serif;font-size:.85rem;font-weight:700;text-align:center;outline:none;background:#fff;}
    .stock-num:focus{border-color:var(--lila)}
    .stock-unlimited{font-size:.68rem;color:var(--soft);display:flex;align-items:center;gap:.3rem;cursor:pointer}
    .stock-unlimited input{cursor:pointer}

    .tags-label{font-size:.68rem;font-weight:700;color:var(--soft);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.42rem}
    .chips-row{display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.9rem}
    .chip-check{display:flex;align-items:center;gap:.3rem;padding:.32rem .75rem;border:1.5px solid var(--border);border-radius:50px;cursor:pointer;font-size:.74rem;font-weight:500;transition:all .18s;user-select:none;background:#fff;}
    .chip-check input{display:none}
    .chip-check:has(input:checked){border-color:var(--lila);background:var(--lila-light);color:var(--lila)}
    .chip-oferta:has(input:checked){border-color:var(--orange);background:var(--orange-light);color:#92400e}
    .chip-envio:has(input:checked){border-color:var(--mint);background:var(--mint-light);color:#065f46}
    .chip-popular:has(input:checked){border-color:var(--red);background:var(--red-light);color:#991b1b}
    .chip-especial:has(input:checked){border-color:#d97706;background:var(--orange-light);color:#92400e}

    .btn-save{background:var(--lila);color:#fff;border:none;padding:.62rem 1.35rem;border-radius:50px;font-family:'Outfit',sans-serif;font-size:.82rem;font-weight:600;cursor:pointer;transition:all .2s;display:inline-flex;align-items:center;gap:.38rem}
    .btn-save:hover{background:var(--lila-dark)}
    .btn-save.saved{background:var(--mint)}
    .btn-cancel{background:none;border:1.5px solid var(--border);color:var(--soft);padding:.62rem 1.1rem;border-radius:50px;font-family:'Outfit',sans-serif;font-size:.8rem;cursor:pointer;transition:all .2s}
    .btn-cancel:hover{border-color:var(--lila);color:var(--lila)}
    .btn-delete{background:none;border:1.5px solid var(--red-light);color:var(--red);padding:.4rem .82rem;border-radius:50px;font-family:'Outfit',sans-serif;font-size:.74rem;cursor:pointer;transition:all .2s}
    .btn-delete:hover{background:var(--red);color:#fff;border-color:var(--red)}
    .btn-vis{padding:.4rem .82rem;border-radius:50px;font-family:'Outfit',sans-serif;font-size:.74rem;font-weight:600;cursor:pointer;transition:all .2s;border:none}
    .btn-vis.on{background:var(--mint-light);color:#065f46}
    .btn-vis.on:hover{background:var(--mint);color:#fff}
    .btn-vis.off{background:var(--red-light);color:var(--red)}
    .btn-vis.off:hover{background:var(--red);color:#fff}

    .t-card{background:var(--panel);border-radius:16px;padding:1.2rem;margin-bottom:1rem;border:1px solid var(--border);box-shadow:0 2px 12px rgba(0,0,0,.04)}
    .t-title{font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:.2rem}
    .t-sub{font-size:.72rem;color:var(--soft);margin-bottom:.85rem}
    .t-field{margin-bottom:.72rem}
    .t-field label{display:block;font-size:.68rem;font-weight:600;color:var(--soft);margin-bottom:.26rem;text-transform:uppercase;letter-spacing:.5px}
    .t-field input,.t-field select{width:100%;padding:.55rem .8rem;border:1.5px solid var(--border);border-radius:10px;font-family:'Outfit',sans-serif;font-size:.83rem;outline:none;background:var(--bg)}
    .t-field input:focus,.t-field select:focus{border-color:var(--lila);background:#fff}

    .dash-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:.8rem;margin-bottom:1rem}
    .dash-stat{background:var(--panel);border-radius:14px;padding:1rem;border:1px solid var(--border);text-align:center}
    .dash-num{font-size:1.7rem;font-weight:700;font-family:'Playfair Display',serif;color:var(--lila)}
    .dash-num.green{color:var(--mint-dark)}.dash-num.orange{color:var(--orange)}.dash-num.red{color:var(--red)}
    .dash-label{font-size:.7rem;color:var(--soft);margin-top:.15rem}
    .dash-chart{background:var(--panel);border-radius:14px;padding:1.1rem;border:1px solid var(--border);margin-bottom:1rem}
    .dash-chart-title{font-size:.78rem;font-weight:700;margin-bottom:.9rem;display:flex;align-items:center;gap:.4rem}
    .bar-row{display:flex;align-items:center;gap:.7rem;margin-bottom:.45rem}
    .bar-name{font-size:.72rem;width:130px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex-shrink:0}
    .bar-track{flex:1;height:8px;background:var(--bg);border-radius:4px;overflow:hidden}
    .bar-fill{height:100%;background:var(--lila);border-radius:4px;transition:width .6s ease}
    .bar-val{font-size:.68rem;color:var(--soft);flex-shrink:0;min-width:24px;text-align:right}

    .pedidos-toolbar{display:flex;gap:.5rem;align-items:center;margin-bottom:.9rem;flex-wrap:wrap}
    .pedido-filter{padding:.3rem .75rem;border-radius:50px;font-size:.72rem;font-family:'Outfit',sans-serif;cursor:pointer;border:1.5px solid var(--border);background:#fff;transition:all .18s;}
    .pedido-filter.active{background:var(--lila);color:#fff;border-color:var(--lila)}
    .btn-new-pedido{margin-left:auto;background:var(--mint);color:#fff;border:none;padding:.38rem .9rem;border-radius:50px;font-family:'Outfit',sans-serif;font-size:.74rem;font-weight:600;cursor:pointer;transition:background .2s;display:flex;align-items:center;gap:.3rem;}
    .btn-new-pedido:hover{background:var(--mint-dark)}
    .pedido-card{background:#fff;border:1.5px solid var(--border);border-radius:14px;padding:.9rem 1rem;margin-bottom:.6rem;cursor:pointer;transition:all .2s;}
    .pedido-card:hover{border-color:var(--lila);box-shadow:0 4px 16px rgba(139,92,246,.1)}
    .pedido-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:.45rem}
    .pedido-id{font-size:.65rem;font-weight:700;color:var(--soft);letter-spacing:.5px}
    .pedido-estado{font-size:.63rem;font-weight:700;padding:.18rem .55rem;border-radius:20px;}
    .estado-pendiente{background:#fef3c7;color:#92400e}
    .estado-proceso{background:#dbeafe;color:#1e40af}
    .estado-entregado{background:#d1fae5;color:#065f46}
    .estado-cancelado{background:#fee2e2;color:#991b1b}
    .pedido-cliente{font-size:.85rem;font-weight:600;margin-bottom:.2rem}
    .pedido-items{font-size:.72rem;color:var(--soft);margin-bottom:.3rem}
    .pedido-bottom{display:flex;align-items:center;justify-content:space-between}
    .pedido-total{font-family:'Playfair Display',serif;font-size:.95rem;font-weight:700;color:var(--lila-dark)}
    .pedido-fecha{font-size:.64rem;color:var(--soft)}
    .pedido-actions{display:flex;gap:.35rem;margin-top:.55rem;flex-wrap:wrap}
    .p-action-btn{font-size:.68rem;padding:.26rem .65rem;border-radius:50px;cursor:pointer;font-family:'Outfit',sans-serif;font-weight:600;border:1.5px solid var(--border);background:#fff;transition:all .18s;}
    .p-action-btn:hover{border-color:var(--lila);color:var(--lila)}
    .p-action-btn.primary{background:var(--lila);color:#fff;border-color:var(--lila)}
    .p-action-btn.primary:hover{background:var(--lila-dark)}

    .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:998;align-items:center;justify-content:center}
    .modal-overlay.open{display:flex}
    .modal-box{background:#fff;border-radius:20px;padding:1.8rem;max-width:420px;width:92%;max-height:90vh;overflow-y:auto;box-shadow:0 30px 70px rgba(0,0,0,.2)}
    .modal-title{font-family:'Playfair Display',serif;font-size:1.15rem;margin-bottom:.3rem}
    .modal-sub{font-size:.76rem;color:var(--soft);margin-bottom:1.3rem}
    .modal-field{margin-bottom:.8rem}
    .modal-field label{display:block;font-size:.7rem;font-weight:600;color:var(--soft);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.28rem}
    .modal-field input,.modal-field select,.modal-field textarea{width:100%;padding:.58rem .85rem;border:1.5px solid var(--border);border-radius:10px;font-family:'Outfit',sans-serif;font-size:.84rem;outline:none;background:var(--bg)}
    .modal-field input:focus,.modal-field select:focus,.modal-field textarea:focus{border-color:var(--lila);background:#fff}
    .modal-field textarea{resize:vertical;min-height:70px}
    .modal-btns{display:flex;gap:.5rem;justify-content:flex-end;margin-top:1.2rem}

    .selected-tag{font-weight:600;color:var(--lila);font-size:.82rem;margin-bottom:.65rem;min-height:1rem}
    .v-search{width:100%;padding:.46rem .8rem;border:1.5px solid var(--border);border-radius:8px;font-family:'Outfit',sans-serif;font-size:.78rem;outline:none;background:var(--bg);margin-bottom:.55rem}
    .v-search:focus{border-color:var(--lila)}
    .v-prod-list{display:flex;flex-direction:column;gap:.35rem}
    .v-prod-row{display:flex;align-items:center;gap:.7rem;padding:.52rem .72rem;border:1px solid var(--border);border-radius:10px;background:var(--bg)}
    .v-thumb{width:34px;height:34px;border-radius:7px;overflow:hidden;background:#eee;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1rem}
    .v-thumb img{width:100%;height:100%;object-fit:cover}
    .v-info{flex:1;min-width:0}
    .v-name{font-size:.78rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .v-price{font-size:.65rem;color:var(--soft)}
    .btn-select{background:var(--bg);color:var(--soft);border:1px solid var(--border);padding:.26rem .62rem;border-radius:50px;cursor:pointer;font-size:.67rem;font-family:'Outfit',sans-serif;font-weight:600;transition:all .2s;flex-shrink:0}
    .btn-select:hover{background:var(--lila-light);color:var(--lila)}
    .btn-select.sel{background:var(--lila);color:#fff;border-color:var(--lila)}
    .hero-slots{display:flex;gap:.5rem;margin-bottom:.85rem;flex-wrap:wrap}
    .hero-slot{width:82px;height:82px;border-radius:10px;border:2px dashed var(--border);background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:.65rem;color:var(--soft);text-align:center}
    .hero-slot.filled{border-style:solid;border-color:var(--lila-light);padding:.28rem;background:#fff}
    .hero-slot-name{font-size:.56rem;font-weight:600;margin-top:.2rem;text-align:center;line-height:1.2;color:var(--text)}

    .toggle{width:42px;height:23px;border-radius:50px;background:#d1d5db;border:none;cursor:pointer;position:relative;transition:background .25s;flex-shrink:0}
    .toggle::after{content:'';position:absolute;top:2.5px;left:2.5px;width:18px;height:18px;background:#fff;border-radius:50%;transition:transform .25s;box-shadow:0 1px 4px rgba(0,0,0,.15)}
    .toggle.on{background:var(--mint)}
    .toggle.on::after{transform:translateX(19px)}
    .toggle-row{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.65rem 0;border-bottom:1px solid var(--border)}
    .toggle-row:last-child{border-bottom:none}
    .toggle-label{font-size:.82rem;font-weight:600}
    .toggle-desc{font-size:.68rem;color:var(--soft);margin-top:.08rem}
    .view-select{padding:.3rem .65rem;border:1.5px solid var(--lila-light);border-radius:50px;font-family:'Outfit',sans-serif;font-size:.72rem;outline:none;background:var(--bg);cursor:pointer}

    .banner-item{border:1.5px solid var(--border);border-radius:12px;padding:.85rem;background:var(--bg);display:flex;gap:.75rem;align-items:flex-start;flex-wrap:wrap;margin-bottom:.55rem}
    .banner-preview{width:100px;height:56px;border-radius:8px;overflow:hidden;flex-shrink:0;border:1px solid var(--border)}
    .banner-preview img{width:100%;height:100%;object-fit:cover}
    .banner-preview-ph{width:100%;height:100%;background:linear-gradient(135deg,#e9d5ff,#ddd6fe);display:flex;align-items:center;justify-content:center;font-size:1.5rem}
    .banner-fields{display:flex;flex-direction:column;gap:.42rem;flex:1;min-width:160px}
    .bf-label{font-size:.65rem;font-weight:600;color:var(--soft);display:block;margin-bottom:.16rem}
    .bf-input{width:100%;padding:.4rem .68rem;border:1.5px solid var(--border);border-radius:8px;font-family:'Outfit',sans-serif;font-size:.76rem;outline:none;background:#fff}
    .bf-input:focus{border-color:var(--lila)}
    .bf-select{padding:.4rem .68rem;border:1.5px solid var(--border);border-radius:8px;font-family:'Outfit',sans-serif;font-size:.76rem;outline:none;background:#fff}
    .btn-rm{background:var(--red-light);color:var(--red);border:none;border-radius:50px;padding:.24rem .55rem;cursor:pointer;font-size:.64rem;font-family:'Outfit',sans-serif;align-self:flex-start;transition:all .2s}
    .btn-rm:hover{background:var(--red);color:#fff}
    .btn-add-banner{background:var(--lila-light);color:var(--lila);border:none;border-radius:50px;padding:.5rem .95rem;cursor:pointer;font-size:.76rem;font-family:'Outfit',sans-serif;font-weight:600;transition:all .2s;display:inline-flex;align-items:center;gap:.32rem}
    .btn-add-banner:hover{background:var(--lila);color:#fff}

    .save-bar{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid var(--border);padding:.62rem 1.2rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;z-index:90;box-shadow:0 -3px 16px rgba(0,0,0,.06)}
    .save-bar-msg{font-size:.72rem;color:var(--soft)}

    .confirm-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:999;align-items:center;justify-content:center}
    .confirm-overlay.open{display:flex}
    .confirm-box{background:#fff;border-radius:16px;padding:1.7rem;max-width:300px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.2)}
    .confirm-icon{font-size:2.2rem;margin-bottom:.6rem}
    .confirm-title{font-family:'Playfair Display',serif;font-size:.98rem;margin-bottom:.35rem}
    .confirm-msg{font-size:.76rem;color:var(--soft);margin-bottom:1.1rem}
    .confirm-btns{display:flex;gap:.5rem;justify-content:center}
    .conf-cancel{padding:.55rem 1.1rem;background:var(--bg);border:1.5px solid var(--border);border-radius:50px;cursor:pointer;font-family:'Outfit',sans-serif;font-size:.8rem}
    .conf-ok{padding:.55rem 1.1rem;background:var(--red);color:#fff;border:none;border-radius:50px;cursor:pointer;font-family:'Outfit',sans-serif;font-size:.8rem;font-weight:600}

    .toast-admin{position:fixed;bottom:4.5rem;left:50%;transform:translateX(-50%) translateY(10px);background:#0f0e17;color:#fff;padding:.44rem 1.1rem;border-radius:50px;font-size:.73rem;font-weight:500;opacity:0;transition:opacity .25s,transform .25s;pointer-events:none;white-space:nowrap;z-index:9999;max-width:88vw;width:max-content;box-shadow:0 3px 16px rgba(0,0,0,.25)}
    .toast-admin.show{opacity:1;transform:translateX(-50%) translateY(0)}

    #ofertaFields{display:none;margin-bottom:.75rem}

    .hist-item{display:flex;align-items:flex-start;gap:.75rem;padding:.7rem 0;border-bottom:1px solid var(--border)}
    .hist-item:last-child{border-bottom:none}
    .hist-dot{width:8px;height:8px;border-radius:50%;background:var(--lila);margin-top:.35rem;flex-shrink:0}
    .hist-action{font-size:.8rem;font-weight:500}
    .hist-time{font-size:.65rem;color:var(--soft);margin-top:.12rem}

    @media(max-width:768px){
      body{overflow:auto}
      .workspace{height:auto;overflow:visible;position:relative}
      .left-col{position:fixed;top:var(--nav-h);left:0;bottom:0;z-index:200;transform:translateX(-105%);box-shadow:6px 0 30px rgba(0,0,0,.3);}
      .left-col.open{transform:translateX(0)}
      .nav-hamburger{display:flex !important}
      .admin-tabs{flex:1}
      .right-col,.tab-content{padding:1rem 1rem 6rem;min-height:calc(100vh - var(--nav-h));overflow-y:auto}
      .form-grid{grid-template-columns:1fr}
      .field-full{grid-column:1}
      .dash-grid{grid-template-columns:repeat(2,1fr)}
      .editor-empty{height:50vh}
      .cc-grid{grid-template-columns:1fr}
    }
    @media(max-width:380px){
      .dash-grid{grid-template-columns:1fr 1fr}
      .admin-logo span{display:none}
    }
  </style>
</head>
<body>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-card">
    <div class="login-logo">Nuditos<em style="color:#6d28d9">.</em></div>
    <div class="login-sub">Panel de administración</div>
    <input class="login-input" type="email" id="loginEmail" placeholder="tu@correo.com"
      style="letter-spacing:0;margin-bottom:.6rem"
      onkeydown="if(event.key==='Enter')doLogin()">
    <input class="login-input" type="password" id="loginPwd" placeholder="••••••••"
      onkeydown="if(event.key==='Enter')doLogin()">
    <button class="login-btn" onclick="doLogin()">Entrar</button>
    <div class="login-err" id="loginErr">Email o contraseña incorrectos</div>
  </div>
</div>

<!-- PANEL -->
<div id="adminPanel">
  <nav class="admin-nav">
    <button class="nav-hamburger" id="navHamburger" onclick="toggleSidebar()">
      <i class="ri-menu-line"></i>
    </button>
    <div class="admin-logo">Nuditos <span>Admin</span></div>
    <div class="admin-tabs">
      <button class="a-tab active" onclick="showTab('productos',this)">🌸 Productos</button>
      <button class="a-tab" onclick="showTab('dashboard',this)">📊 Dashboard</button>
      <button class="a-tab" onclick="showTab('pedidos',this)">📦 Pedidos</button>
      <button class="a-tab" onclick="showTab('vitrina',this)">⭐ Vitrina</button>
      <button class="a-tab" onclick="showTab('banners',this)">🖼️ Banners</button>
      <button class="a-tab" onclick="showTab('descuentos',this)">🏷️ Descuentos</button>
      <button class="a-tab" onclick="showTab('tienda',this)">⚙️ Tienda</button>
    </div>
    <div class="nav-right-actions">
      <button class="preview-btn" onclick="window.open('/','_blank')">
        <i class="ri-eye-line"></i> <span class="hide-xs">Ver tienda</span>
      </button>
      <button class="logout-btn" onclick="doLogout()">Salir</button>
    </div>
  </nav>

  <div class="workspace" id="workspace">
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- SIDEBAR -->
    <div class="left-col" id="leftCol">
      <div class="left-header">
        <div class="left-title">🌸 Mis ramos</div>
        <input class="left-search" type="text" id="sideSearch" placeholder="Buscar ramo..." oninput="renderSidebar()">
        <div class="left-filters" id="sideFilters"></div>
      </div>
      <div class="left-stats" id="sideStats"></div>
      <button class="btn-add-prod" onclick="newProduct()">
        <i class="ri-add-line"></i> Agregar ramo nuevo
      </button>
      <div class="prod-list-scroll" id="sideList"></div>
    </div>

    <!-- ÁREA DERECHA -->
    <div id="rightArea" style="flex:1;overflow:hidden;display:flex;flex-direction:column">
      <div class="right-col tab-content active" id="tab-productos"></div>

      <!-- DASHBOARD -->
      <div class="tab-content" id="tab-dashboard">
        <div class="dash-grid" id="dashStats"></div>
        <div class="dash-chart">
          <div class="dash-chart-title">📈 Productos por precio</div>
          <div id="viewsChart"></div>
        </div>
        <div class="dash-chart">
          <div class="dash-chart-title">🛒 Más pedidos</div>
          <div id="cartChart"></div>
        </div>
        <div class="t-card">
          <div class="t-title" style="margin-bottom:.6rem">📋 Historial de cambios</div>
          <div id="histList"></div>
        </div>
      </div>

      <!-- PEDIDOS -->
      <div class="tab-content" id="tab-pedidos">
        <div class="pedidos-toolbar">
          <button class="pedido-filter active" onclick="filterPedidos('todos',this)">Todos</button>
          <button class="pedido-filter" onclick="filterPedidos('pendiente',this)">⏳ Pendientes</button>
          <button class="pedido-filter" onclick="filterPedidos('proceso',this)">🔄 En proceso</button>
          <button class="pedido-filter" onclick="filterPedidos('entregado',this)">✅ Entregados</button>
          <button class="btn-new-pedido" onclick="openNewPedido()">
            <i class="ri-add-line"></i> Nuevo pedido
          </button>
        </div>
        <div id="pedidosList"></div>
      </div>

      <!-- VITRINA -->
      <div class="tab-content" id="tab-vitrina">
        <div class="t-card">
          <div class="t-title">⭐ Ramo del momento</div>
          <div class="t-sub">Se muestra destacado justo debajo del carrusel.</div>
          <div id="momentoSelected" class="selected-tag"></div>
          <input class="v-search" type="text" id="searchMomento" placeholder="Buscar ramo..." oninput="searchMomentoProducts()">
          <div class="v-prod-list" id="momentoList"></div>
        </div>
        <div class="t-card">
          <div class="t-title">🎠 Carrusel principal</div>
          <div class="t-sub">Elige hasta 5 ramos para el carrusel de portada.</div>
          <div class="hero-slots" id="heroSlots"></div>
          <input class="v-search" type="text" id="searchHero" placeholder="Buscar ramo..." oninput="searchHeroProducts()">
          <div class="v-prod-list" id="heroList"></div>
        </div>
      </div>

      <!-- BANNERS -->
      <div class="tab-content" id="tab-banners">
        <div class="t-card">
          <div class="t-title">🖼️ Banners entre categorías</div>
          <div class="t-sub">Aparecen entre secciones del catálogo.</div>
          <div id="bannerList"></div>
          <button class="btn-add-banner" onclick="addBanner()" style="margin-top:.65rem">
            <i class="ri-add-line"></i> Agregar banner
          </button>
        </div>
      </div>

      <!-- DESCUENTOS -->
      <div class="tab-content" id="tab-descuentos">
        <div class="t-card">
          <div class="t-title">🏷️ Código de descuento</div>
          <div class="t-sub">Activa un código para tus clientas.</div>
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Descuento activo</div>
              <div class="toggle-desc">Muestra el banner y permite usar el código en el carrito</div>
            </div>
            <button class="toggle" id="toggleDescuento" onclick="this.classList.toggle('on')"></button>
          </div>
          <div style="margin-top:1rem;display:flex;flex-direction:column;gap:.65rem">
            <div class="t-field"><label>Código</label><input type="text" id="descCodigo" placeholder="NUDITOS10" style="text-transform:uppercase"></div>
            <div class="t-field"><label>Porcentaje (%)</label><input type="number" id="descPorcentaje" min="1" max="90" placeholder="10"></div>
            <div class="t-field"><label>Texto del banner</label><input type="text" id="descTexto" placeholder="10% de descuento en tu primer pedido"></div>
          </div>
        </div>
      </div>

      <!-- TIENDA -->
      <div class="tab-content" id="tab-tienda">
        <div class="t-card">
          <div class="t-title">☁️ Cloudinary — Subida de imágenes</div>
          <div class="t-sub">Configura tu cuenta para subir fotos directamente desde el admin.</div>
          <div class="cloudinary-config">
            <div class="cc-title"><i class="ri-settings-3-line"></i> Credenciales de Cloudinary</div>
            <div class="cc-grid">
              <div class="cc-field"><label>Cloud Name</label><input type="text" id="ccCloudName" placeholder="mi-cuenta"></div>
              <div class="cc-field"><label>Upload Preset</label><input type="text" id="ccPreset" placeholder="nuditos_unsigned"></div>
            </div>
            <button class="cc-save" onclick="saveCloudinaryConfig()"><i class="ri-save-line"></i> Guardar configuración</button>
          </div>
        </div>
        <div class="t-card">
          <div class="t-title">💳 Wompi — Pasarela de pago</div>
          <div class="t-sub">Activa el botón de pago con tarjeta y PSE en el carrito.</div>
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Mostrar botón "Pagar con Wompi"</div>
              <div class="toggle-desc">Si está apagado, solo aparece el botón de WhatsApp</div>
            </div>
            <button class="toggle" id="toggleWompi" onclick="this.classList.toggle('on')"></button>
          </div>
          <div class="t-field" style="margin-top:.9rem">
            <label>Llave pública Wompi</label>
            <input type="text" id="wompiKey" placeholder="pub_prod_xxxxxxxxxxxx">
          </div>
        </div>
        <div class="t-card">
          <div class="t-title">📊 Meta Pixel</div>
          <div class="t-sub">Activa el seguimiento para medir tus anuncios.</div>
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Meta Pixel activo</div>
              <div class="toggle-desc">Registra visitas y eventos de compra</div>
            </div>
            <button class="toggle" id="toggleMetaPixel" onclick="this.classList.toggle('on')"></button>
          </div>
          <div class="t-field" style="margin-top:.9rem">
            <label>Pixel ID</label>
            <input type="text" id="metaPixelId" placeholder="123456789012345">
          </div>
        </div>
        <div class="t-card">
          <div class="t-title">🖼️ Vista por categoría</div>
          <div class="t-sub">Elige cómo se muestran los productos de cada categoría.</div>
          <div id="catViewsList"></div>
        </div>
        <div class="t-card">
          <div class="t-title">🗄️ Supabase</div>
          <div id="sbStatus" style="background:var(--mint-light);border-radius:10px;padding:.75rem 1rem;font-size:.78rem;color:#065f46;display:flex;align-items:center;gap:.5rem">
            <span style="font-size:1rem">✅</span>
            <span>Conectado · Los cambios se guardan automáticamente</span>
          </div>
        </div>
        <div class="t-card">
          <div class="t-title">📤 Exportar datos.js</div>
          <div class="t-sub">Descarga el archivo actualizado como respaldo.</div>
          <button class="btn-save" onclick="exportDatos()"><i class="ri-download-line"></i> Descargar datos.js</button>
        </div>
      </div>
    </div>
  </div>

  <div class="save-bar">
    <div class="save-bar-msg">Recuerda <strong style="color:var(--lila)">guardar cambios</strong> para aplicarlos en la tienda</div>
    <button class="btn-save" id="globalSaveBtn" onclick="saveConfig()">
      <i class="ri-save-line"></i> Guardar cambios
    </button>
  </div>
</div>

<!-- CONFIRM DELETE -->
<div class="confirm-overlay" id="confirmOverlay">
  <div class="confirm-box">
    <div class="confirm-icon">🗑️</div>
    <div class="confirm-title">¿Eliminar producto?</div>
    <div class="confirm-msg" id="confirmMsg">Esta acción no se puede deshacer.</div>
    <div class="confirm-btns">
      <button class="conf-cancel" onclick="closeConfirm()">Cancelar</button>
      <button class="conf-ok" onclick="confirmDelete()">Sí, eliminar</button>
    </div>
  </div>
</div>

<!-- MODAL PEDIDO -->
<div class="modal-overlay" id="pedidoModal">
  <div class="modal-box">
    <div class="modal-title" id="pedidoModalTitle">Nuevo pedido</div>
