/* ── CLOUDINARY ── */
function getCloudinaryConfig(){
  const DEFAULT={cloudName:'dzxgu27wr',preset:'ssjghh9e'};
  try{const s=localStorage.getItem('nuditos_cloudinary');const saved=s?JSON.parse(s):{};
    return{cloudName:saved.cloudName||DEFAULT.cloudName,preset:saved.preset||DEFAULT.preset};}
  catch{return DEFAULT;}
}
function saveCloudinaryConfig(){
  const cfg={cloudName:document.getElementById('ccCloudName').value.trim(),preset:document.getElementById('ccPreset').value.trim()};
  localStorage.setItem('nuditos_cloudinary',JSON.stringify(cfg));
  showToast('✓ Cloudinary configurado');
}

async function uploadToCloudinary(file){
  showUploadProgress(0);
  try{
    const signRes=await fetch('/.netlify/functions/cloudinary-sign',{method:'POST'});
    if(!signRes.ok)throw new Error('No se pudo obtener la firma');
    const{signature,timestamp,apiKey,cloudName,uploadPreset,folder}=await signRes.json();
    const fd=new FormData();
    fd.append('file',file);fd.append('upload_preset',uploadPreset);
    fd.append('folder',folder);fd.append('timestamp',timestamp);
    fd.append('api_key',apiKey);fd.append('signature',signature);
    showUploadProgress(30);
    const res=await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/image/upload`,{method:'POST',body:fd});
    if(!res.ok)throw new Error('Error al subir');
    const data=await res.json();
    const url=data.secure_url.replace('/upload/','/upload/w_1200,q_auto,f_auto/');
    showUploadProgress(100);setTimeout(()=>hideUploadProgress(),800);
    addToHistory(`📸 Foto subida: ${data.original_filename||'imagen'}`);
    return url;
  }catch(e){hideUploadProgress();showToast('❌ Error subiendo imagen');return null;}
}
function showUploadProgress(pct){const p=document.getElementById('uploadProgress');const b=document.getElementById('uploadProgressBar');if(p)p.style.display='block';if(b)b.style.width=pct+'%';}
function hideUploadProgress(){const p=document.getElementById('uploadProgress');if(p)p.style.display='none';}

/* ── LOAD ALL ── */
async function loadAll(){
  showToast('⏳ Cargando datos...');
  try{
    const sbProds=await sbAdminGetProducts();
    if(sbProds&&sbProds.length>0){adminProducts=sbProds;}
    else{
      adminProducts=products.map(p=>({...p}));
      showToast('⬆️ Subiendo productos a Supabase...');
      for(const p of adminProducts){try{await sbAdminSaveProduct({...p,_isNew:true});}catch(e){}}
    }
    const sbCfg=await sbAdminGetConfig_();adminCfg=sbCfg||{...CONFIG_DEFAULT};
    try{const rows=await sbAdminGetBanners_();editorialBannersAdmin=rows&&rows.length?rows:[
      {id:1,afterCat:'rosas',emoji:'🌸',title:'Flores que <em>jamás se marchitan</em>',imgUrl:''},
      {id:2,afterCat:'noche',emoji:'🌙',title:'Arte tejido <em>puntada a puntada</em>',imgUrl:''},
      {id:3,afterCat:'especial',emoji:'✨',title:'Regalos que <em>dejan huella</em>',imgUrl:''},
    ];}catch{editorialBannersAdmin=[];}
    try{pedidos=await sbAdminGetPedidos();}catch{pedidos=[];}
    try{const sh=localStorage.getItem('nuditos_history');changeHistory=sh?JSON.parse(sh):[];}catch{changeHistory=[];}
  }catch(e){
    showToast('⚠️ Error de conexión — usando datos locales');
    adminProducts=products.map(p=>({...p}));adminCfg={...CONFIG_DEFAULT};editorialBannersAdmin=[];pedidos=[];
  }
  heroSelection=[...(adminCfg.carruselHero||[])];momentoSelection=adminCfg.ramoDestacado;
  document.getElementById('descCodigo').value=adminCfg.descuentoCodigo||'';
  document.getElementById('descPorcentaje').value=adminCfg.descuentoPorcentaje||10;
  document.getElementById('descTexto').value=adminCfg.descuentoTexto||'';
  if(adminCfg.descuentoActivo)document.getElementById('toggleDescuento').classList.add('on');
  if(adminCfg.wompiActivo)document.getElementById('toggleWompi').classList.add('on');
  if(adminCfg.wompiKey)document.getElementById('wompiKey').value=adminCfg.wompiKey;
  if(adminCfg.metaPixelActivo)document.getElementById('toggleMetaPixel').classList.add('on');
  if(adminCfg.metaPixelId)document.getElementById('metaPixelId').value=adminCfg.metaPixelId;
  const cc=getCloudinaryConfig();
  if(cc.cloudName)document.getElementById('ccCloudName').value=cc.cloudName;
  if(cc.preset)document.getElementById('ccPreset').value=cc.preset;
  buildSideFilters();renderSidebar();renderStats();showEditorEmpty();
  renderHeroSlots();renderMomentoSelected();renderMomentoList(adminProducts);
  renderHeroList(adminProducts);renderCatViewsList();renderBannerList();
  showToast('✅ Todo cargado');
}

async function sbAdminGetConfig_(){
  try{const rows=await fetch(`${SB_URL}/rest/v1/config?select=clave,valor`,{headers:_h(true)}).then(r=>r.json());return sbToConfig(rows);}
  catch{return null;}
}
async function sbAdminGetBanners_(){
  try{const rows=await fetch(`${SB_URL}/rest/v1/banners?order=orden.asc`,{headers:_h(true)}).then(r=>r.json());return rows.map(sbToBanner);}
  catch{return[];}
}

/* ── SIDEBAR FILTERS ── */
function buildSideFilters(){
  const opts=[{id:'',name:'Todos',icon:'🌸'},...categories.filter(c=>c.id!=='todos')];
  document.getElementById('sideFilters').innerHTML=opts.map(c=>
    `<span class="lf-chip ${sideFilterCat===c.id?'active':''}" onclick="setSideFilter('${c.id}',this)">${c.icon} ${c.name}</span>`
  ).join('');
}
function setSideFilter(id,el){sideFilterCat=id;document.querySelectorAll('.lf-chip').forEach(c=>c.classList.remove('active'));el.classList.add('active');renderSidebar();}

/* ── STATS ── */
function renderStats(){
  const t=adminProducts.length,v=adminProducts.filter(p=>p.activo!==false).length;
  const f=adminProducts.filter(p=>p.img&&p.img.trim()).length,o=t-v;
  document.getElementById('sideStats').innerHTML=`
    <div class="ls-stat"><div class="ls-num">${t}</div><div class="ls-label">Total</div></div>
    <div class="ls-stat"><div class="ls-num green">${v}</div><div class="ls-label">Visibles</div></div>
    <div class="ls-stat"><div class="ls-num ${(t-f)>0?'red':'green'}">${f}</div><div class="ls-label">Con foto</div></div>
    <div class="ls-stat"><div class="ls-num red">${o}</div><div class="ls-label">Ocultos</div></div>`;
}

/* ── SIDEBAR LIST ── */
function renderSidebar(){
  const q=document.getElementById('sideSearch').value.toLowerCase();
  let list=adminProducts.filter(p=>{
    const mQ=!q||p.name.toLowerCase().includes(q)||(categories.find(c=>c.id===p.cat)?.name.toLowerCase().includes(q));
    const mC=!sideFilterCat||p.cat===sideFilterCat;return mQ&&mC;
  });
  const groups={};list.forEach(p=>{if(!groups[p.cat])groups[p.cat]=[];groups[p.cat].push(p);});
  let html='';
  Object.entries(groups).forEach(([catId,items])=>{
    if(!sideFilterCat){const cat=categories.find(c=>c.id===catId);html+=`<div class="cat-group-label">${cat?.icon||''} ${cat?.name||catId}</div>`;}
    items.forEach(p=>{
      const isActive=p.activo!==false;
      const tags=[];
      if(!isActive)tags.push(`<span class="pi-tag pit-oculto">Oculto</span>`);
      if(p.badge)tags.push(`<span class="pi-tag pit-badge">${p.badge}</span>`);
      if(p.oferta)tags.push(`<span class="pi-tag pit-oferta">Oferta</span>`);
      if(p.envioGratis)tags.push(`<span class="pi-tag pit-envio">Envío</span>`);
      html+=`
        <div class="prod-item ${selectedId===p.id?'selected':''} ${isActive?'':'inactive'}" onclick="selectProduct(${p.id})">
          <div class="pi-thumb">${p.img?`<img src="${p.img}" onerror="this.parentNode.innerHTML='${p.emoji}'">`:p.emoji}</div>
          <div class="pi-info">
            <div class="pi-name">${p.name}</div>
            <div class="pi-meta">${p.price>0?'$'+p.price.toLocaleString('es-CO')+' COP':'Consultar'}</div>
            ${tags.length?`<div class="pi-tags">${tags.join('')}</div>`:''}
          </div>
          <div class="pi-dot ${isActive?'on':'off'}"></div>
        </div>`;
    });
  });
  document.getElementById('sideList').innerHTML=html||`<div style="padding:1.5rem;text-align:center;color:rgba(255,255,255,.3);font-size:.76rem">No hay ramos</div>`;
}

