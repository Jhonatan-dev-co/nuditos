---
import Icon from '../Icon.astro';
---
<!-- BANNERS -->
<div class="tab-content" id="tab-banners">
  <!-- Banners de Inicio (Editorial) -->
  <div class="t-card" style="margin-bottom: 2rem;">
    <div class="t-title">🚀 Banners de Impacto (Pestaña Inicio)</div>
    <div class="t-sub">Son los banners principales con títulos en cursiva (Ej: Pétalos que guardan historias).</div>
    <p style="font-size: 0.75rem; color: #666; margin: 0.5rem 0;">* Usa <b>home1</b> o <b>home2</b> en la categoría para fijarlos en la página principal.</p>
    <div id="editorialBannersList"></div>
  </div>

  <!-- Banners de Categoría -->
  <div class="t-card">
    <div class="t-title">🖼️ Banners de Colección (Entre Categorías)</div>
    <div class="t-sub">Aparecen cuando el usuario navega por las categorías del catálogo.</div>
    <div id="bannerList"></div>
    <button class="btn-add-banner" onclick="addNewBanner()" style="margin-top: 1rem; background: var(--lila); color: white; border: none; padding: 12px 20px; border-radius: 12px; cursor: pointer; font-weight: bold; width: 100%;">
      <Icon name="add"  /> Agregar nuevo banner
    </button>
  </div>
</div>

<script is:inline>
  window.renderBannerList = function() { 
    if (!window.editorialBannersAdmin) return;
    const editorialList = window.editorialBannersAdmin.filter(b => b.afterCat === 'home1' || b.afterCat === 'home2');
    const collectionsList = window.editorialBannersAdmin.filter(b => b.afterCat !== 'home1' && b.afterCat !== 'home2');

    const buildCard = (b, i) => {
      const realIdx = window.editorialBannersAdmin.findIndex(x => x === b);
      return `
        <div class="banner-admin-card" style="margin-bottom:1rem; border:1px solid #ddd; padding:1rem; border-radius:12px;">
          <div style="display:flex; justify-content:space-between; margin-bottom:0.5rem;">
            <span style="font-weight:bold; font-size:0.8rem; color:var(--lila)">${b.afterCat}</span>
            <button onclick="window.removeBanner(${realIdx})" style="color:red; border:none; background:none; cursor:pointer">🗑️</button>
          </div>
          <input type="text" value="${b.title||''}" oninput="window.updateBanner(${realIdx},'title',this.value)" placeholder="Título" style="width:100%; margin-bottom:0.4rem; padding:6px; border-radius:6px; border:1px solid #eee;">
          <input type="text" value="${b.imgUrl||''}" oninput="window.updateBanner(${realIdx},'imgUrl',this.value)" placeholder="URL Imagen" style="width:100%; padding:6px; border-radius:6px; border:1px solid #eee;">
        </div>`;
    };

    document.getElementById('editorialBannersList').innerHTML = editorialList.map(b => buildCard(b)).join('') || 'No hay banners';
    document.getElementById('bannerList').innerHTML = collectionsList.map(b => buildCard(b)).join('') || 'No hay banners de categoría';
  };

  window.removeBanner = function(i) {
    if (confirm('¿Eliminar banner?')) {
      window.editorialBannersAdmin.splice(i, 1);
      window.renderBannerList();
    }
  };

  window.updateBanner = function(i, key, val) {
    window.editorialBannersAdmin[i][key] = val;
  };

  window.addNewBanner = function() {
    window.editorialBannersAdmin.push({ title: '', afterCat: 'nuevo', imgUrl: '' });
    window.renderBannerList();
  };
</script>

<style>
  .banner-admin-card { background: #fff; transition: scale 0.2s; }
  .banner-admin-card:hover { scale: 1.01; }
</style>
