---
import Icon from '../Icon.astro';
---
<div class="right-col tab-content" id="tab-pedidos" style="display:none">
  <div class="orders-header">
    <div class="oh-title">
      <h3>Seguimiento de Pedidos</h3>
      <p>Gestión de ventas y estados de envío</p>
    </div>
    <div class="oh-filters">
      <select id="pedFilter" onchange="window.filterPedidos(this.value)">
        <option value="todos">Todos los estados</option>
        <option value="pendiente">🕒 Pendientes</option>
        <option value="pagado">✅ Pagados / Por enviar</option>
        <option value="enviado">🚚 Enviados</option>
        <option value="entregado">🎁 Entregados</option>
        <option value="cancelado">❌ Cancelados</option>
      </select>
    </div>
  </div>

  <div class="orders-list" id="pedidosList">
    <!-- Rendered via renderPedidos() -->
  </div>
</div>

<script is:inline>
  window.renderPedidos = function() {
    const listEl = document.getElementById('pedidosList');
    if (!listEl || !window.pedidos) return;
    
    // Si no hay pedidos
    if (window.pedidos.length === 0) {
      listEl.innerHTML = `
        <div style="padding:4rem 2rem; text-align:center; color:#999;">
          <div style="font-size:3rem; margin-bottom:1rem;">📦</div>
          <div style="font-weight:700; color:#1a1220; margin-bottom:0.5rem;">Aún no hay pedidos</div>
          <div style="font-size:0.8rem;">Cuando un cliente compre algo, aparecerá aquí.</div>
        </div>`;
      return;
    }

    const filter = window.pedidoFilter || 'todos';
    const filtered = filter === 'todos' 
      ? window.pedidos 
      : window.pedidos.filter(p => p.estado === filter);

    listEl.innerHTML = [...filtered].reverse().map(p => {
      const date = new Date(p.creado_en).toLocaleString('es-CO', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
      const statusClass = `status-${p.estado || 'pendiente'}`;
      
      return `
        <div class="order-card">
          <div class="oc-header">
            <div>
              <div class="oc-id">PEDIDO #${p.id}</div>
              <div class="oc-date">${date}</div>
            </div>
            <div class="oc-status ${statusClass}">${p.estado?.toUpperCase() || 'PENDIENTE'}</div>
          </div>
          
          <div class="oc-body">
            <div class="oc-customer">
              <div class="oc-name">👤 ${p.cliente_nombre}</div>
              <div class="oc-contact">${p.cliente_email} · ${p.cliente_telefono}</div>
            </div>
            <div class="oc-items">📦 ${p.items}</div>
            ${p.notas ? `<div class="oc-notes">📝 ${p.notas}</div>` : ''}
          </div>
          
          <div class="oc-footer">
            <div class="oc-total">$${(p.total || 0).toLocaleString('es-CO')}</div>
            <div class="oc-actions">
              <select onchange="window.updateOrderStatus(${p.id}, this.value)" style="padding:6px; border-radius:8px; font-size:0.7rem; font-weight:700; border:1px solid #ddd;">
                <option value="pendiente" ${p.estado==='pendiente'?'selected':''}>Pendiente</option>
                <option value="pagado" ${p.estado==='pagado'?'selected':''}>Pagado</option>
                <option value="enviado" ${p.estado==='enviado'?'selected':''}>Enviado</option>
                <option value="entregado" ${p.estado==='entregado'?'selected':''}>Entregado</option>
                <option value="cancelado" ${p.estado==='cancelado'?'selected':''}>Cancelado</option>
              </select>
            </div>
          </div>
        </div>
      `;
    }).join('');
  };

  window.filterPedidos = function(val) {
    window.pedidoFilter = val;
    window.renderPedidos();
  };

  window.updateOrderStatus = async function(id, status) {
    if (!confirm('¿Cambiar el estado del pedido?')) {
      window.renderPedidos(); // Reset UI
      return;
    }
    
    window.showToast('⏳ Actualizando pedido...');
    try {
      await window.sbAdminUpdatePedidoStatus(id, status);
      const idx = window.pedidos.findIndex(p => p.id === id);
      if (idx !== -1) window.pedidos[idx].estado = status;
      window.renderPedidos();
      window.showToast('✅ Pedido actualizado');
    } catch (e) {
      window.showToast('❌ Error al actualizar');
    }
  };
</script>
