<!-- VITRINA -->
<div class="tab-content" id="tab-vitrina">
  
  <div class="t-card">
    <div class="t-title">🏬 Estructura de la Tienda</div>
    <div class="t-sub">Controla qué categorías son visibles en el Inicio y el orden en que aparecen.</div>
    
    <div id="vitrinaCategoriesList" class="cat-admin-grid" style="margin-top:1.5rem; gap: 0.8rem;">
      <!-- Se llena dinámicamente -->
    </div>
  </div>
  <div class="t-card">
    <div style="display:flex; justify-content:space-between; align-items:center;">
      <div>
        <div class="t-title">🔀 Ordenar Catálogo Público</div>
        <div class="t-sub">Arrastra los productos para decidir en qué orden se muestran en la tienda. El catálogo primero organizará por productos "Destacados" y luego respetará este orden custom.</div>
      </div>
      <div>
         <button class="btn-save" onclick="saveCatalogOrder()" id="saveOrderBtn" style="padding:0.4rem 1rem;font-size:0.75rem;">💾 Guardar Orden</button>
      </div>
    </div>
    <div style="margin: 1rem 0;">
      <select id="sortCatFilter" onchange="renderSortableList()" style="width:100%; max-width:300px; padding:0.5rem; border-radius:6px; border:1px solid var(--border);">
        <option value="todos">Todas las categorías</option>
      </select>
    </div>
    <div class="v-prod-list" id="sortableCatalogList" style="max-height:400px;overflow-y:auto;background:var(--bg-card);border:1px solid var(--border);border-radius:8px;padding:0.5rem;"></div>
  </div>
  <div class="t-card">
    <div class="t-title">⭐ Ramo del momento</div>
    <div class="t-sub">Se muestra destacado justo debajo del carrusel.</div>
    <div id="momentoSelected" class="selected-tag"></div>
    <input class="v-search" type="text" id="searchMomento" placeholder="Buscar ramo..." oninput="searchMomentoProducts()">
    <div class="v-prod-list" id="momentoList"></div>
  </div>
  <div class="t-card">
    <div class="t-title">🎠 Carrusel principal</div>
    <div class="t-sub">Elige hasta 5 ramos para el carrusel de portada.</div>
    <div class="hero-slots" id="heroSlots"></div>
    <input class="v-search" type="text" id="searchHero" placeholder="Buscar ramo..." oninput="searchHeroProducts()">
    <div class="v-prod-list" id="heroList"></div>
  </div>

  <div class="t-card">
    <div class="t-title">⭐ Selección Nuditos (Sección Superior)</div>
    <div class="t-sub">Estructura de 4 productos que aparece al inicio después del carrusel.</div>
    <div class="hero-slots" id="seleccionSlots"></div>
    <input class="v-search" type="text" id="searchSeleccion" placeholder="Buscar ramo..." oninput="searchSeleccionProducts()">
    <div class="v-prod-list" id="seleccionList"></div>
  </div>
</div>
