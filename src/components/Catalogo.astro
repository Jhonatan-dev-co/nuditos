---
import Icon from './Icon.astro';
import { products as fallbackProducts, CONFIG_DEFAULT as FALLBACK_CONFIG } from '../data/datos';
import ProductCard from './ProductCard.astro';
import ProductListItem from './ProductListItem.astro';

const { products: propProducts, config: propConfig, categories: propCategories, banners: propBanners } = Astro.props;

const activeProducts = (propProducts || fallbackProducts).filter(p => p.activo !== false);
const config = propConfig || FALLBACK_CONFIG;
const categories = propCategories || [];
const banners = propBanners || [];

function getCatView(catId: string) {
  // @ts-ignore
  if (config.catViews && config.catViews[catId]) return config.catViews[catId];
  return 'carousel';
}

const catsToRender = categories.filter(c => c.id !== 'todos').map(cat => {
  const cid = cat.id?.toLowerCase();
  const items = activeProducts.filter(p => (p.cats || []).includes(cid) || p.cat?.toLowerCase() === cid);
  return { cat, items };
}).filter(c => c.items.length > 0);

// Índice global para los primeros productos (carga eager para evitar blank en primera visita)
let globalIdx = 0;

---

{catsToRender.map(({ cat, items }) => {
  const view = getCatView(cat.id);
  const catBanners = banners.filter(b => b.afterCat === cat.id);
  
  return (
    <>
      <div class="cat-section pb-4 pt-6 px-6 border-b border-stone-100 last:border-0" id={`cat-${cat.id}`} data-view={view}>
        <div class="max-w-[1200px] mx-auto flex items-center justify-between mb-0">
          <h3 class="font-sans text-xs font-bold tracking-[0.4em] text-stone-400 uppercase flex items-center gap-2">
            <span class="text-xs leading-none opacity-60">{cat.icon}</span> {cat.name}
          </h3>
          <a href="#" class="text-[9px] font-bold uppercase tracking-[0.2em] text-stone-500 hover:text-stone-800 transition-all flex items-center gap-1.5" onclick={`filterCatByName('${cat.id}');return false;`}>
            VER TODO <Icon name="arrow-right-s"  />
          </a>
        </div>
        
        <div class="max-w-[1200px] mx-auto">
          <!-- View: List -->
          <div class="view-content view-list hidden grid-cols-1 md:grid-cols-2 gap-4 animate-in fade-in slide-in-from-bottom-2 duration-500">
            {items.map(p => <ProductListItem p={p} />)}
          </div>
          
          <!-- View: Grid (Mosaic) -->
          <div class="view-content view-grid hidden grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 animate-in fade-in slide-in-from-bottom-2 duration-500">
            {items.map(p => <ProductCard p={p} parentView="grid" idScope={cat.id} eager={globalIdx++ < 6} />)}
          </div>
          
          <!-- View: Carousel -->
          <div class="view-content view-carousel hidden animate-in fade-in slide-in-from-bottom-2 duration-500">
            <div class="swiper cat-swiper !overflow-visible" id={`catSwiper-${cat.id}`}>
              <div class="swiper-wrapper">
                {items.map(p => (
                  <div class="swiper-slide h-auto pb-4">
                    <ProductCard p={p} parentView="carousel" idScope={cat.id} eager={globalIdx++ < 6} />
                  </div>
                ))}
              </div>
              <div class="swiper-pagination !-bottom-2" id={`catPag-${cat.id}`}></div>
            </div>
          </div>
        </div>
      </div>

      {catBanners.map(banner => (
        <div class="relative overflow-hidden my-4 md:my-6 rounded-[2.5rem] mx-4 md:mx-8 group shadow-xl">
          <div class="absolute inset-0 bg-stone-100 transition-transform duration-1000 group-hover:scale-105" style={(banner as any).imgUrl ? `background-image: url(${(banner as any).imgUrl}); background-size: cover; background-position: center;` : ''}>
            {!(banner as any).imgUrl && <div class="w-full h-full flex items-center justify-center text-8xl opacity-10">{banner.emoji || '🌸'}</div>}
          </div>
          <div class="absolute inset-0 bg-gradient-to-r from-black/50 via-black/20 to-transparent"></div>
          <div class="relative z-10 py-6 md:py-10 px-8 md:px-16 max-w-2xl">
            <div class="text-[10px] uppercase font-bold tracking-[0.4em] text-white/70 mb-4">Colección Especial</div>
            <div class="text-white text-3xl md:text-5xl font-serif leading-tight mb-6" set:html={banner.title || ''}></div>
            <a href="/catalogo" class="inline-flex items-center gap-2 text-white text-[10px] uppercase font-bold tracking-widest border-b border-white/30 pb-1 hover:border-white transition-all">
              Explorar ahora <Icon name="arrow-right"  />
            </a>
          </div>
        </div>
      ))}
    </>
  );
})}

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    /* ── Swiper init ── */
    function initSwipers() {
      if (typeof Swiper === 'undefined') return;
      const catSwiperEls = document.querySelectorAll('.cat-swiper');
      catSwiperEls.forEach(el => {
        const id = el.id.replace('catSwiper-', '');
        // Destroy existing if any
        if (el.swiper) el.swiper.destroy(true, true);
        
        new Swiper(`#catSwiper-${id}`, {
          slidesPerView: 'auto', // Cambiado de 1.3 fijo para mejor adaptabilidad
          spaceBetween: 16,
          slidesOffsetBefore: 24, // Espacio boutique al inicio
          slidesOffsetAfter: 24,
          grabCursor: true,
          freeMode: { 
            enabled: true, 
            momentum: true, 
            momentumRatio: 1.2, // Más elástico
            momentumVelocityRatio: 1.2
          },
          touchStartPreventDefault: false,
          touchMoveStopPropagation: false,
          passiveListeners: true,
          pagination: { el: `#catPag-${id}`, clickable: true, dynamicBullets: true },
          breakpoints: {
            480:  { slidesPerView: 2.3, spaceBetween: 16 },
            768:  { slidesPerView: 3.3, spaceBetween: 20 },
            1024: { slidesPerView: 4.3, spaceBetween: 22 },
            1280: { slidesPerView: 5.2, spaceBetween: 24 },
          },
        });
      });
    }

    window.initCatSwipersGlobal = initSwipers;
    initSwipers();

    const toggles = document.querySelectorAll('.vtoggle');
    const sections = document.querySelectorAll('.cat-section');
    
    const savedView = localStorage.getItem('nuditos_cat_view') || 'carousel';
    applyView(savedView);
    
    function applyView(view) {
      sections.forEach(s => s.setAttribute('data-view', view));
      toggles.forEach(t => {
        const isActive = t.dataset.view === view;
        t.classList.toggle('active', isActive);
      });
      
      if (view === 'carousel') {
        // Diferir init para evitar reflow forzado en el hilo principal
        setTimeout(initSwipers, 60);
      }

      // CRÍTICO: forzar carga de imágenes lazy que estaban en display:none
      // El navegador no descarga imágenes lazy dentro de elementos ocultos
      requestAnimationFrame(() => {
        document.querySelectorAll('#catalogRows img[loading="lazy"]').forEach(img => {
          if (!img.src && img.dataset.src) {
            img.src = img.dataset.src;
          } else if (img.src) {
            // Forzar re-evaluación del IntersectionObserver
            const src = img.src;
            img.src = '';
            img.src = src;
          }
        });
      });
    }
    
    toggles.forEach(btn => {
      btn.addEventListener('click', () => {
        const view = btn.dataset.view;
        localStorage.setItem('nuditos_cat_view', view);
        applyView(view);
      });
    });



  });
</script>

<style>
  /* Visibilidad mejorada: Mostrar carrusel por defecto mientras carga el JS */
  .view-content { display: none; }
  .view-carousel { display: block; } /* Visible por defecto */
  
  .cat-swiper {
    touch-action: pan-y !important; /* Vital para fluidez en Android/Chrome */
  }

  .cat-section[data-view="carousel"] .view-carousel { display: block !important; }
  .cat-section[data-view="grid"]     .view-grid     { display: grid !important; }
  .cat-section[data-view="grid"]     .view-carousel { display: none !important; }
  .cat-section[data-view="list"]     .view-list     { display: grid !important; }
  .cat-section[data-view="list"]     .view-carousel { display: none !important; }
</style>
