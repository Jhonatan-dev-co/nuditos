---
import { clUrl } from '../data/datos';
import Icon from './Icon.astro';

interface Props {
  title?: string;
  subtitle?: string;
  img?: string; 
  video?: string;
  mobileImg?: string;
  mobileVideo?: string;
  ctaText?: string;
  ctaUrl?: string;
}

const { title, subtitle, img, video: rawVideo, mobileImg, mobileVideo: rawMobileVideo, ctaUrl, ctaText: rawCtaText } = Astro.props;

// Texto por defecto "Ver" para que sea minimalista
const ctaText = (!rawCtaText && ctaUrl) ? 'Ver' : rawCtaText;

function cleanVideoUrl(url: string): string {
  if (!url) return '';
  let clean = url;
  clean = clean.replace(/,vc_auto/g, '').replace(/vc_auto,/g, '').replace(/vc_auto/g, '');
  clean = clean.replace(/,q_auto/g, '').replace(/q_auto,/g, '').replace(/q_auto/g, '');
  clean = clean.replace(/\/upload\/\/+/g, '/upload/');
  clean = clean.replace(/\/upload\/,/g, '/upload/');
  return clean;
}

const video = cleanVideoUrl(rawVideo);
const mobileVideo = cleanVideoUrl(rawMobileVideo) || video;
const isVideo = !!video.trim();
const isMobileVideo = !!mobileVideo.trim();
const fallbackImg = img || mobileImg || '';

const hasContent = !!(title || subtitle || ctaText);
---

<div class="cover-wrapper">
  <div class="cover-container">
    {/* Media Layer */}
    {isVideo ? (
      <div class="video-wrapper">
        <video src={video} autoplay muted loop playsinline class="cover-vid-desktop"></video>
        <video src={isMobileVideo ? mobileVideo : video} autoplay muted loop playsinline class="cover-vid-mobile"></video>
      </div>
    ) : fallbackImg ? (
      <img src={clUrl(fallbackImg, 1400)} alt="" class="cover-img" />
    ) : (
      <div class="h-20 bg-stone-900"></div>
    )}

    {/* Content Overlay */}
    {hasContent && (
      <div class="cover-overlay">
        <div class="cover-content">
          <div class="cover-inner">
            {title && <h1 class="cover-title" set:html={title}></h1>}
            {subtitle && <p class="cover-subtitle">{subtitle}</p>}
            
            {ctaText && ctaUrl && (
              <div class="cover-cta">
                <a href={ctaUrl} class="cover-btn">
                  {ctaText}
                  <Icon name="arrow-right" class="w-4 h-4" />
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    )}
  </div>
</div>

<style>
  .cover-wrapper { width: 100%; background: #000; }
  .cover-container { position: relative; width: 100%; overflow: hidden; }
  .video-wrapper { width: 100%; line-height: 0; }
  video, .cover-img { width: 100%; height: auto; display: block; }
  
  .cover-vid-desktop { display: none; }
  .cover-vid-mobile { display: block; }
  @media (min-width: 768px) {
    .cover-vid-desktop { display: block; }
    .cover-vid-mobile { display: none; }
  }

  /* === CAPA DE CONTENIDO === */
  .cover-overlay {
    position: absolute;
    inset: 0;
    z-index: 30;
    display: flex;
    flex-direction: column;
    /* Móvil: Contenido abajo a la derecha */
    justify-content: flex-end;
    align-items: flex-end;
    padding: 1rem;
    pointer-events: none;
    background: radial-gradient(circle, transparent 40%, rgba(0,0,0,0.4) 100%);
  }

  .cover-content {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-end;
  }

  .cover-inner {
    text-align: right;
    width: 100%;
  }

  @media (min-width: 768px) {
    .cover-overlay {
      justify-content: center;
      align-items: center;
      padding: 0;
    }
    .cover-content {
      justify-content: center;
      align-items: center;
    }
    .cover-inner {
      text-align: center;
    }
  }

  .cover-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 6vw, 6rem);
    font-weight: 300;
    color: white;
    line-height: 1;
    margin-bottom: 0.5rem;
    pointer-events: auto;
    text-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  .cover-subtitle {
    color: white;
    font-size: clamp(0.75rem, 1.2vw, 1rem);
    margin-bottom: 1.5rem;
    font-weight: 300;
    pointer-events: auto;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }

  /* === BOTÓN GLASS === */
  .cover-cta {
    pointer-events: auto;
    opacity: 1;
    transition: all 0.5s ease;
  }

  @media (min-width: 768px) {
    .cover-cta {
      opacity: 0;
      transform: translateY(20px);
      margin-top: 2rem;
    }
    .cover-container:hover .cover-cta {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .cover-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    padding: 0.6rem 1.2rem;
    border-radius: 0.75rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    transition: all 0.3s ease;
  }

  @media (min-width: 768px) {
    .cover-btn {
      padding: 1rem 2.5rem;
      border-radius: 1.25rem;
      font-size: 0.8rem;
      letter-spacing: 0.2em;
      gap: 1rem;
    }
    .cover-btn:hover {
      background: white;
      color: black;
      transform: scale(1.05);
    }
  }
</style>
