---
import { clUrl } from '../data/datos';
import Icon from './Icon.astro';

interface Props {
  title: string;
  subtitle?: string;
  img: string;
  video?: string;
  ctaText?: string;
  ctaUrl?: string;
  reverse?: boolean;
}

const { title, subtitle, img, video: rawVideo, ctaText = 'Ver Colección', ctaUrl = '/catalogo', reverse = false } = Astro.props;
// Limpieza Extrema (Forzamos /video/upload/ y .mp4)
let video = rawVideo ? rawVideo.replace('/image/upload/', '/video/upload/').replace(/w_\d+,q_auto,f_auto\//, 'f_auto,q_auto/') : '';
if (video && !video.toLowerCase().endsWith('.mp4')) video += '.mp4';
const poster = video ? video.replace(/\/v\d+\//, '/so_0/').replace(/\.mp4$/, '.jpg') : '';
const isVideo = !!(video && video.trim());
---

<div class="relative w-full h-[85vh] md:h-[90vh] overflow-hidden bg-stone-900 flex flex-col justify-end">
  <!-- Bg Media (GIF Behavior) -->
  <div class="absolute inset-0 z-0">
    {isVideo ? (
      <video 
        src={video}
        poster={poster}
        autoplay 
        muted 
        loop 
        playsinline
        preload="auto"
        class="w-full h-full object-cover"
        onloadeddata="console.log('✅ Video portada cargado:', this.src)"
        onerror="console.error('❌ Error video portada:', this.src)"
      ></video>
    ) : (
      <img 
        src={clUrl(img, 1200)} 
        alt="Cover Portada"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
    )}
  </div>

  <!-- Overlay para oscurecer el fondo y mejorar legibilidad -->
  <div class="absolute inset-0 bg-black/30 z-10 pointer-events-none"></div>

  <!-- Contenido -->
  <div class="relative z-20 p-8 md:p-16 pb-16 md:pb-24 text-center md:text-left max-w-[1400px] mx-auto w-full">
    {ctaUrl && !ctaText && (
      <a href={ctaUrl} class="absolute inset-0 z-20 pointer-events-auto" aria-label={title.replace(/<[^>]*>/g, '')}></a>
    )}

    <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-light text-white leading-[1.05] tracking-tight mb-4 drop-shadow-md" set:html={title}></h1>
    
    {subtitle && (
      <p class="text-white/80 text-sm md:text-lg max-w-md mx-auto md:mx-0 mb-8 font-light tracking-wide">
        {subtitle}
      </p>
    )}

    {ctaText && ctaUrl && (
      <div class="relative z-30">
        <a href={ctaUrl} class="inline-flex items-center gap-3 bg-white text-black px-8 py-4 rounded-full text-xs font-bold uppercase tracking-widest hover:bg-stone-200 transition-colors group">
          {ctaText}
          <Icon name="arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
        </a>
      </div>
    )}
  </div>
</div>
