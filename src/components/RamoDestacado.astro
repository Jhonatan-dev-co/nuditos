---
import { products as fallbackProducts, CONFIG_DEFAULT, slugify, clUrl } from '../data/datos';

const { p: propProduct } = Astro.props;

const ramoId = CONFIG_DEFAULT.ramoDestacado;
const p = propProduct || fallbackProducts.find(x => x.id === ramoId);
---
{p && (
  <div class="momento-card" id="ramoMomento">
    <div class="momento-img">
      {p.img ? (
        <img src={clUrl(p.img, 600)} alt={p.name} loading="lazy" />
      ) : (
        <span class="momento-emoji">{p.emoji}</span>
      )}
    </div>
    <div class="momento-info">
      <div class="momento-eyebrow"><i class="ri-fire-line"></i> Ramo del momento</div>
      <div class="momento-name">{p.name}</div>
      <div class="momento-desc">{p.desc}</div>
    </div>
    <div class="momento-actions">
      <div class="momento-price">
        {p.price > 0 ? (
          <>${p.price.toLocaleString('es-CO')}<span> COP</span></>
        ) : (
          <span>Consultar</span>
        )}
      </div>
      {p.price > 0 && (
        <button class="btn-momento" onclick={`addToCart(${p.id})`}>
          <i class="ri-shopping-bag-line"></i> Agregar
        </button>
      )}
      <a href={`/ramo/${slugify(p.name)}`} class="btn-momento-ghost">
        <i class="ri-eye-line"></i> Ver detalle
      </a>
    </div>
  </div>
)}
