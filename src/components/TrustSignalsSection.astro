---
import Icon from './Icon.astro';

interface Props {
  isLanding?: boolean;
}

const { isLanding = false } = Astro.props as Props;

// Simplificamos a 3 señales clave para que quepan horizontalmente sin scroll
const trustItems = [
  { icon: 'plant',     title: 'Hecho a mano' },
  { icon: 'truck',     title: 'Envío Gratis' },
  { icon: 'bank-card', title: 'Compra Segura' },
];
---

<section class={`${isLanding ? 'bg-white py-6' : 'bg-stone-50 py-8'} border-t border-stone-100`} id="confianza">
  <div class="max-w-[1200px] mx-auto px-4 md:px-6">
    <div class="flex justify-around items-center gap-2 md:gap-8">
      {trustItems.map((item) => (
        <div class="flex flex-col md:flex-row items-center gap-1.5 md:gap-3 text-center md:text-left">
          <div class="w-7 h-7 rounded-full bg-violet-50 text-violet-600 flex items-center justify-center flex-shrink-0">
            <Icon name={item.icon} class="w-3.5 h-3.5" />
          </div>
          <span class="text-[9px] md:text-[11px] font-bold uppercase tracking-widest text-stone-700 whitespace-nowrap">
            {item.title}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
