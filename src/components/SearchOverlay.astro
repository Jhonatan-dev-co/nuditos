---
import Icon from './Icon.astro';
// Overlay de búsqueda global. La lógica reside en src/scripts/search-ui.ts
---
<div class="fixed inset-0 z-[2005] bg-[#1a1220]/50 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300 [&.open]:opacity-100 [&.open]:pointer-events-auto flex flex-col items-center pt-14 md:pt-20 px-4" id="searchOverlay">
  <div class="w-full max-w-xl bg-white rounded-[2rem] shadow-2xl overflow-hidden border border-stone-100 transform -translate-y-8 transition-transform duration-500 ease-out" id="searchBoxWrapper">
    
    <!-- Campo de búsqueda -->
    <div class="flex items-center gap-3 px-5 py-4 border-b border-stone-100">
      <Icon name="search" class="text-stone-400 flex-shrink-0" />
      <input
        type="text"
        id="searchInput"
        class="flex-1 bg-transparent border-none outline-none text-sm text-[#1a1220] placeholder-stone-400 font-sans"
        placeholder="Busca ramos, rosas, amigurumis..."
        autocomplete="off"
      />
      <button id="closeSearchBtn" class="w-8 h-8 rounded-full flex items-center justify-center hover:bg-stone-100 transition-colors flex-shrink-0" aria-label="Cerrar búsqueda">
        <Icon name="close" class="text-stone-500" />
      </button>
    </div>

    <!-- Resultados -->
    <div class="max-h-[55vh] overflow-y-auto" id="searchResults"></div>
  </div>
</div>

<style>
  #searchOverlay.open #searchBoxWrapper {
    transform: translateY(0);
  }
</style>

<script src="../scripts/search-ui.ts"></script>
