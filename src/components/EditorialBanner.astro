---
import Icon from './Icon.astro';
import { clUrl } from '../data/datos';

interface Props {
  title: string;
  subtitle?: string;
  img: string;
  ctaText?: string;
  ctaUrl?: string;
  reverse?: boolean;
}

const { title, subtitle, img, ctaText, ctaUrl, reverse = false } = Astro.props;
---

<section class="bg-white py-12 md:py-24 px-6 overflow-hidden border-b border-stone-50">
  <div class="max-w-[1400px] mx-auto">
    <div class={`grid md:grid-cols-2 gap-12 md:gap-20 items-center ${reverse ? 'md:flex-row-reverse' : ''}`}>
      
      <!-- Lado Imagen -->
      <div class={`relative group ${reverse ? 'md:order-2' : ''}`}>
         <div class="aspect-square rounded-[3rem] overflow-hidden bg-stone-100 shadow-2xl relative">
            <img 
               src={clUrl(img, 1000)} 
               alt={title.replace(/<[^>]*>/g, '')}
               class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
               loading="lazy"
            />
            <div class="absolute inset-0 bg-violet-900/10 mix-blend-overlay"></div>
         </div>
         
         <!-- Elemento decorativo -->
         <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-violet-100/50 rounded-full blur-3xl -z-10 group-hover:bg-violet-200/50 transition-colors"></div>
      </div>

      <!-- Lado Texto -->
      <div class={`${reverse ? 'md:order-1' : ''} text-center md:text-left`}>
        <div class="text-[10px] tracking-[0.4em] uppercase text-violet-500 font-bold mb-4 flex items-center justify-center md:justify-start gap-3">
          <span class="h-px w-8 bg-violet-200"></span>
          Nuditos Experience
        </div>
        
        <h2 class="font-serif text-4xl md:text-6xl font-light text-stone-800 leading-[1.1] mb-6 tracking-tight" set:html={title}>
        </h2>
        
        {subtitle && (
          <p class="text-stone-500 text-base md:text-lg leading-snug mb-10 max-w-md mx-auto md:mx-0">
            {subtitle}
          </p>
        )}
        
        {ctaText && ctaUrl && (
          <a 
            href={ctaUrl} 
            class="inline-flex items-center gap-4 bg-stone-900 text-white px-10 py-4 rounded-2xl font-bold shadow-xl hover:bg-violet-700 hover:-translate-y-1 transition-all uppercase text-[10px] tracking-widest group"
          >
            {ctaText} 
            <Icon name="arrow-right" class="transition-transform group-hover:translate-x-1" />
          </a>
        )}
      </div>

    </div>
  </div>
</section>
