---
import Icon from './Icon.astro';
import { clUrl } from '../data/datos';

interface Props {
  title?: string;
  subtitle?: string;
  img?: string;
  video?: string;
  mobileImg?: string;
  mobileVideo?: string;
  ctaText?: string;
  ctaUrl?: string;
  reverse?: boolean;
}

const { title, subtitle, img, video: rawVideo, mobileImg, mobileVideo: rawMobileVideo, ctaUrl, reverse = false, ctaText: rawCtaText } = Astro.props;

// Texto por defecto "Ver" para móvil
const ctaText = (!rawCtaText && ctaUrl) ? 'Ver' : rawCtaText;

function cleanVideoUrl(url: string): string {
  if (!url) return '';
  let clean = url;
  clean = clean.replace(/,vc_auto/g, '').replace(/vc_auto,/g, '').replace(/vc_auto/g, '');
  clean = clean.replace(/,q_auto/g, '').replace(/q_auto,/g, '').replace(/q_auto/g, '');
  clean = clean.replace(/\/upload\/\/+/g, '/upload/');
  clean = clean.replace(/\/upload\/,/g, '/upload/');
  return clean;
}

const video = cleanVideoUrl(rawVideo);
const mobileVideo = cleanVideoUrl(rawMobileVideo) || video;
const isVideo = !!video.trim();
const isMobileVideo = !!mobileVideo.trim();
const fallbackImg = img || mobileImg || '';

const hasContent = !!(title || subtitle || ctaText);
---

<section class="ed-section">
  <div class={`ed-container ${reverse ? 'ed-reverse' : ''}`}>
    {/* Media Layer */}
    <div class="ed-media-wrapper">
      {isVideo ? (
        <>
          <video src={video} autoplay muted loop playsinline class="ed-vid-desktop"></video>
          <video src={isMobileVideo ? mobileVideo : video} autoplay muted loop playsinline class="ed-vid-mobile"></video>
        </>
      ) : fallbackImg ? (
        <img src={clUrl(fallbackImg, 1400)} alt="" class="ed-img" />
      ) : null}
    </div>

    {/* Content Overlay */}
    {hasContent && (
      <div class="ed-overlay">
        <div class="ed-content">
          {title && <h2 class="ed-title" set:html={title}></h2>}
          {subtitle && <p class="ed-subtitle">{subtitle}</p>}
          
          {ctaText && ctaUrl && (
            <div class="ed-cta">
              <a href={ctaUrl} class="ed-btn">
                {ctaText} <Icon name="arrow-right" class="w-2.5 h-2.5" />
              </a>
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .ed-section { width: 100%; background: #000; }
  .ed-container { position: relative; width: 100%; overflow: hidden; }
  .ed-media-wrapper { width: 100%; line-height: 0; }
  video, .ed-img { width: 100%; height: auto; display: block; }
  
  .ed-vid-desktop { display: none; }
  .ed-vid-mobile { display: block; }
  @media (min-width: 768px) {
    .ed-vid-desktop { display: block; }
    .ed-vid-mobile { display: none; }
  }

  /* === CAPA DE CONTENIDO === */
  .ed-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    /* Móvil: Abajo Derecha */
    justify-content: flex-end;
    align-items: flex-end;
    padding: 1rem;
    pointer-events: none;
    background: radial-gradient(circle, transparent 40%, rgba(0,0,0,0.3) 100%);
  }

  .ed-content {
    text-align: right;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  @media (min-width: 768px) {
    .ed-overlay {
      justify-content: center;
      align-items: center;
      padding: 0;
    }
    .ed-content {
      text-align: center;
      align-items: center;
    }
  }

  .ed-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 4vw, 3.5rem);
    font-weight: 300;
    color: white;
    line-height: 1.1;
    margin-bottom: 0.5rem;
    pointer-events: auto;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }

  .ed-subtitle {
    color: rgba(255,255,255,0.9);
    font-size: clamp(0.7rem, 1vw, 0.9rem);
    line-height: 1.4;
    margin-bottom: 1rem;
    max-width: 20rem;
    pointer-events: auto;
    text-shadow: 0 1px 10px rgba(0,0,0,0.5);
  }

  /* === BOTÓN === */
  .ed-cta {
    pointer-events: auto;
    opacity: 1;
    transition: all 0.4s ease;
  }

  @media (min-width: 768px) {
    .ed-cta {
      opacity: 0;
      transform: translateY(10px);
    }
    .ed-container:hover .ed-cta {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ed-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 0.75rem;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: all 0.3s;
  }

  @media (min-width: 768px) {
    .ed-btn {
      padding: 0.9rem 2rem;
      border-radius: 1rem;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
    }
    .ed-btn:hover {
      background: white;
      color: black;
      transform: translateY(-2px) scale(1.05);
    }
  }
</style>
