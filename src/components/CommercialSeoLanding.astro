---
import Layout from '../layouts/Layout.astro';
import ProductCard from './ProductCard.astro';
import Icon from './Icon.astro';
import type { CommercialLandingConfig } from '../data/seo-landings';

interface ProductLike {
  id: number;
  name: string;
  desc?: string;
  cat?: string;
  cats?: string[];
  activo?: boolean;
}

interface Props {
  config: CommercialLandingConfig;
  products: ProductLike[];
}

const { config, products } = Astro.props as Props;

function scoreProduct(p: ProductLike, hints: string[]): number {
  const bag = `${p.name || ''} ${p.desc || ''} ${p.cat || ''} ${(p.cats || []).join(' ')}`.toLowerCase();
  return hints.reduce((acc, hint) => acc + (bag.includes(hint.toLowerCase()) ? 1 : 0), 0);
}

const activeProducts = (products || []).filter((p: any) => p.activo !== false);
const sortedProducts = [...activeProducts]
  .map((p) => ({ p, score: scoreProduct(p, config.productHints || []) }))
  .sort((a, b) => b.score - a.score);
const featuredProducts = sortedProducts.slice(0, 8).map((x) => x.p);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: config.faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<Layout title={config.title} description={config.description} keywords={config.keywords}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="bg-gradient-to-br from-stone-50 via-white to-emerald-50/30 pt-24 pb-20 px-6 border-b border-stone-100">
    <div class="max-w-5xl mx-auto text-center">
      <div class="text-[10px] uppercase tracking-[4px] font-bold text-emerald-600 mb-4">{config.eyebrow}</div>
      <h1 class="font-serif text-[clamp(2.1rem,6vw,4.4rem)] leading-[1.05] text-stone-900 mb-6">{config.h1}</h1>
      <p class="max-w-3xl mx-auto text-stone-600 text-base md:text-lg leading-relaxed mb-8">{config.heroCopy}</p>
      <div class="flex justify-center gap-3 flex-wrap">
        <a href="/catalogo" class="px-7 py-3 rounded-full bg-stone-900 text-white text-xs uppercase tracking-widest font-bold hover:bg-emerald-600 transition-colors">
          Ver catalogo
        </a>
        <a href="https://wa.me/573144931525" class="px-7 py-3 rounded-full border border-stone-300 text-stone-700 text-xs uppercase tracking-widest font-bold hover:border-emerald-500 hover:text-emerald-700 transition-colors">
          {config.ctaLabel}
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-[1200px] mx-auto px-6 py-14">
    <div class="grid md:grid-cols-2 gap-8">
      <article class="bg-white border border-stone-100 rounded-3xl p-7 shadow-sm">
        <h2 class="font-serif text-3xl text-stone-900 mb-4">{config.whyTitle}</h2>
        <p class="text-stone-600 leading-relaxed text-sm md:text-base">{config.whyCopy}</p>
      </article>
      <article class="bg-white border border-stone-100 rounded-3xl p-7 shadow-sm">
        <h2 class="font-serif text-3xl text-stone-900 mb-4">{config.occasionBlockTitle}</h2>
        <p class="text-stone-600 leading-relaxed text-sm md:text-base">{config.occasionBlockCopy}</p>
        <div class="mt-5 text-xs text-emerald-700 bg-emerald-50 rounded-xl px-3 py-2 inline-flex items-center gap-2">
          <Icon name="check" />
          <span>{config.audience}</span>
        </div>
      </article>
    </div>
  </section>

  <section class="max-w-[1200px] mx-auto px-6 pb-16">
    <div class="flex items-end justify-between mb-7 border-b border-stone-200 pb-3">
      <div>
        <h2 class="font-serif text-3xl text-stone-900">Favoritos recomendados</h2>
        <p class="text-xs text-stone-500 mt-1">Seleccion pensada para {config.primaryKeyword}.</p>
      </div>
      <a href="/catalogo" class="text-[10px] uppercase tracking-widest font-bold text-stone-500 hover:text-stone-900">Ver todo</a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {featuredProducts.map((p: any) => <ProductCard p={p} />)}
    </div>
  </section>

  <section class="bg-stone-50 py-16 px-6 border-y border-stone-100">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-4xl text-center text-stone-900 mb-10">Preguntas frecuentes</h2>
      <div class="grid gap-4">
        {config.faq.map((item) => (
          <article class="bg-white border border-stone-100 rounded-2xl p-6">
            <h3 class="font-bold text-stone-800 mb-2 text-sm md:text-base">{item.q}</h3>
            <p class="text-stone-600 text-sm leading-relaxed">{item.a}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 py-14 text-center">
    <h2 class="font-serif text-4xl text-stone-900 mb-4">Explora mas rutas de compra</h2>
    <div class="flex flex-wrap justify-center gap-3 mb-8">
      {config.relatedLinks.map((l) => (
        <a href={l.href} class="px-5 py-2 rounded-full border border-stone-200 text-xs uppercase tracking-widest font-bold text-stone-600 hover:border-emerald-500 hover:text-emerald-700 transition-colors">
          {l.label}
        </a>
      ))}
    </div>
    <a href="https://wa.me/573144931525" class="inline-flex items-center gap-2 px-8 py-3 rounded-full bg-emerald-600 text-white uppercase tracking-widest text-xs font-bold hover:bg-emerald-700 transition-colors">
      <Icon name="whatsapp" />
      Asesoria por WhatsApp
    </a>
  </section>
</Layout>

