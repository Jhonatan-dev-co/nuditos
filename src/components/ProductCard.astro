---
import { categories, slugify, clUrl } from '../data/datos';

const { p } = Astro.props;

function badgeIcon(badge: string) {
  if (badge === 'Nuevo')    return '<i class="ri-sparkling-line"></i>';
  if (badge === 'Popular')  return '<i class="ri-fire-line"></i>';
  if (badge === 'Especial') return '<i class="ri-award-line"></i>';
  return '';
}

const cat = categories.find(c => c.id === p.cat);
const productSlug = slugify(p.name);
---
<a class="product-card" href={`/ramo/${productSlug}`} style="text-decoration:none;color:inherit;display:block">
  <div class="product-img-wrap">
    {p.badge ? (
      <div class={`p-badge ${p.badgeClass || ''} ${p.badge === 'Nuevo' ? 'badge-pulse' : ''}`}>
        <span set:html={badgeIcon(p.badge)}></span> {p.badge}
      </div>
    ) : p.oferta ? (
      <div class="p-badge p-badge-oferta"><i class="ri-price-tag-3-fill"></i> Oferta</div>
    ) : null}

    {p.img ? (
      <img src={clUrl(p.img, 500)} alt={`${p.name} - Ramo tejido a mano`} loading="lazy" />
    ) : (
      <span class="card-emoji">{p.emoji}</span>
    )}
    
    <div class="card-overlay">
      <span class="card-overlay-btn">
        <i class="ri-eye-line"></i> Ver detalle
      </span>
    </div>
    
    {p.price > 0 ? (
      <button class="p-add-btn" id={`padd-${p.id}`} onclick={`event.preventDefault(); event.stopPropagation(); addToCart(${p.id})`} aria-label="Agregar al carrito">
        <i class="ri-shopping-bag-3-line"></i>
      </button>
    ) : (
      <a class="p-add-btn p-wa-btn" href={`https://wa.me/573144931525?text=Hola!%20Me%20interesa%20${encodeURIComponent(p.name)}`} target="_blank" onclick="event.stopPropagation()" aria-label="Consultar por WhatsApp">
        <i class="ri-whatsapp-line"></i>
      </a>
    )}
  </div>
  
  <div class="p-info">
    <div class="p-category"><i class="ri-price-tag-3-line"></i> {cat ? cat.name : ''}</div>
    <div class="p-name">{p.name}</div>
    
    <div class="p-price-row">
      <div class="p-price">
       {p.price > 0 ? (
          p.oferta && p.precioOriginal && p.precioOriginal > 0 ? (
            <><span class="p-price-original">${p.precioOriginal.toLocaleString('es-CO')}</span> ${p.price.toLocaleString('es-CO')}</>
          ) : (
            <>${p.price.toLocaleString('es-CO')}</>
          )
        ) : (
          <span class="price-consultar">Consultar</span>
        )}
      </div>
      {p.envioGratis && <div class="p-envio-gratis-icon" title="Envío gratis"><i class="ri-truck-line"></i></div>}
    </div>
  </div>
</a>

