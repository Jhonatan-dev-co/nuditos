---
import Icon from './Icon.astro';
import { slugify, clUrl } from '../data/datos';

interface Props {
  p: any;
  catName?: string;
  class?: string;
  parentView?: 'carousel' | 'grid' | 'list';
  eager?: boolean;
}

const { p, catName = 'Nuditos', class: className, parentView = 'grid', eager = false } = Astro.props;
const imgLoading = eager ? 'eager' : 'lazy';

const productSlug = slugify(p.name);
const allImgs = [p.img, ...(p.imgs || [])].filter((u, i, arr) => u && arr.indexOf(u) === i);
const hasMultiple = allImgs.length > 1;

const searchStr = `${p.name} ${catName} ${p.badge || ''} ${p.desc || ''}`.replace(/<[^>]*>?/gm, '').toLowerCase();
const allCats = [...new Set([p.cat, ...(p.cats || [])].filter(Boolean))].join(',');

// Normalización de seguridad para p.price (si viene de Supabase directamente sin pasar por getLiveProducts)
const displayPrice = p.price || p.precio || 0;
---

<article 
  class:list={[
    "product-card group", 
    className,
    { "has-carousel": hasMultiple }
  ]}
  data-cat={p.cat}
  data-cats={allCats}
  data-price={p.price}
  data-search={searchStr}
  id={`pcard-${p.id}`}
>
  <div class="card-media">
    <div class="media-viewport">
      <a 
        href={`/ramo/${productSlug}`} 
        class="media-link" 
        data-astro-prefetch="hover"
        data-product-id={p.id}
        onclick={`this.querySelector('.main-img').style.viewTransitionName = 'p-img-' + this.dataset.productId`}
      >
        <div class="img-track" data-imgs={allImgs.map(img => clUrl(img, 480)).join('|')}>
          <img 
            src={clUrl(allImgs[0], 480)} 
            alt={p.name}
            class="main-img"
            loading={imgLoading}
            width="400" height="500"
            style={`view-transition-name: p-img-${p.id}-card-${Math.random().toString(36).substr(2, 4)}`}
          />
          {hasMultiple && (
            <img 
              src={clUrl(allImgs[1], 480)} 
              alt={p.name}
              class="hover-img"
              loading="lazy"
              width="400" height="500"
            />
          )}
        </div>
      </a>
    </div>

    {/* Flechas Flotantes (Solo si hay varias fotos) */}
    {hasMultiple && (
      <div class="media-controls">
        <button class="pcard-nav pcard-prev" aria-label="Anterior">
          <Icon name="arrow-left-s" class="w-8 h-8" />
        </button>
        <button class="pcard-nav pcard-next" aria-label="Siguiente">
          <Icon name="arrow-right-s" class="w-8 h-8" />
        </button>
        
        <div class="pcard-dots">
          {allImgs.map((_, i) => (
            <span class={`dot ${i === 0 ? 'active' : ''}`}></span>
          ))}
        </div>
      </div>
    )}

    {/* Badges */}
    <div class="badges-overlay">
      {p.badge && <span class="badge">{p.badge}</span>}
      {p.oferta && <span class="badge-off">Oferta</span>}
    </div>

    {/* Quick Add icon */}
    {displayPrice > 0 && (
      <button class="quick-add" id={`padd-${p.id}`} onclick={`event.preventDefault(); event.stopPropagation(); window.addToCart(${p.id})`}>
        <Icon name="shopping-bag-3" class="w-5 h-5" />
      </button>
    )}
  </div>

  <div class="card-info">
    <div class="cat-label">{catName}</div>
    <a href={`/ramo/${productSlug}`}>
      <h3 class="product-name">{p.name}</h3>
    </a>
    <div class="price-container">
      <span class="price">${displayPrice.toLocaleString('es-CO')}</span>
    </div>
  </div>
</article>

<style>
  .product-card {
    position: relative;
    background: white;
    border-radius: 1.5rem;
    overflow: hidden;
    transition: all 0.4s ease;
  }

  .card-media {
    position: relative;
    aspect-ratio: 4/5;
    background: #fdfdfc;
    overflow: hidden;
    border-radius: 1.5rem;
  }

  .media-viewport { width: 100%; height: 100%; }
  .media-link { display: block; width: 100%; height: 100%; position: relative; }
  .img-track { width: 100%; height: 100%; position: relative; }

  .main-img, .hover-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: opacity 0.5s ease;
  }
  .hover-img { position: absolute; inset: 0; opacity: 0; }

  /* HOVER EFFECT (SOLO PC) - Solo si no estamos interactuando con las flechas */
  @media (hover: hover) {
    .has-carousel:not(.user-navigating):hover .hover-img { opacity: 1; }
    .has-carousel:not(.user-navigating):hover .main-img { opacity: 0; }
  }

  /* FLECHAS FLOTANTES */
  .media-controls {
    position: absolute; inset: 0;
    pointer-events: none; z-index: 20;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 0.5rem;
    color: white;
    text-shadow: 0 0 10px rgba(0,0,0,0.5);
  }

  /* Visibilidad de flechas */
  @media (min-width: 768px) {
    .media-controls { opacity: 0; transition: opacity 0.3s ease; }
    .product-card:hover .media-controls { opacity: 1; }
  }

  .pcard-nav {
    background: transparent; border: none; color: white; cursor: pointer;
    pointer-events: auto; padding: 0.5rem; display: flex; align-items: center; justify-content: center;
    transition: transform 0.2s, opacity 0.2s; opacity: 0.8;
  }
  .pcard-nav:hover { transform: scale(1.2); opacity: 1; }

  .pcard-dots {
    position: absolute; bottom: 0.75rem; left: 50%;
    transform: translateX(-50%); display: flex; gap: 4px;
  }
  .dot { width: 4px; height: 4px; border-radius: 50%; background: rgba(255,255,255,0.4); transition: all 0.3s; }
  .dot.active { width: 12px; border-radius: 4px; background: #fff; }

  /* QUICK ADD */
  .quick-add {
    position: absolute; bottom: 0.75rem; right: 0.75rem;
    background: white; color: black; border-radius: 0.75rem;
    width: 2.5rem; height: 2.5rem;
    display: flex; align-items: center; justify-content: center;
    border: none; cursor: pointer; z-index: 30;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    transition: all 0.3s;
  }
  @media (min-width: 768px) {
    .quick-add { opacity: 0; transform: translateY(10px); }
    .product-card:hover .quick-add { opacity: 1; transform: translateY(0); }
  }
  .quick-add:hover { background: #000; color: #fff; transform: scale(1.1); }

  .card-info { padding: 1rem 0.5rem; }
  .cat-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: #a8a29e; font-weight: 700; }
  .product-name { font-family: 'Cormorant Garamond', serif; font-size: 1rem; color: #1c1917; margin: 2px 0; }
  .price { font-weight: 700; color: #1c1917; font-size: 0.9rem; }
</style>

<script>
  function initProductCards() {
    const cards = document.querySelectorAll('.product-card.has-carousel:not([data-initialized])');
    
    cards.forEach(card => {
      const track = card.querySelector('.img-track');
      if (!track) return;
      
      const imgs = track.dataset.imgs?.split('|') || [];
      const mainImg = track.querySelector('.main-img') as HTMLImageElement;
      const hoverImg = track.querySelector('.hover-img') as HTMLImageElement;
      const dots = card.querySelectorAll('.dot');
      let currentIdx = 0;

      function update(idx: number) {
        currentIdx = (idx + imgs.length) % imgs.length;
        
        if (mainImg) mainImg.src = imgs[currentIdx];
        if (hoverImg) {
          hoverImg.src = imgs[(currentIdx + 1) % imgs.length];
        }
        
        dots.forEach((d, i) => d.classList.toggle('active', i === currentIdx));

        card.classList.add('user-navigating');
        const existingTimer = (card as any)._navTimer;
        clearTimeout(existingTimer);
        (card as any)._navTimer = setTimeout(() => card.classList.remove('user-navigating'), 2000);
      }

      card.querySelector('.pcard-prev')?.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation(); update(currentIdx - 1);
      });
      card.querySelector('.pcard-next')?.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation(); update(currentIdx + 1);
      });

      card.setAttribute('data-initialized', 'true');
    });
  }

  // Ejecutar en cada carga de página (soporta View Transitions)
  document.addEventListener('astro:page-load', initProductCards);
</script>
