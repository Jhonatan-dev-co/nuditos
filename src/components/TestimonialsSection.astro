---
import Icon from './Icon.astro';
import { getLiveTestimonios } from '../lib/supabase';

const sbTestimonios = await getLiveTestimonios();

// Testimonios de respaldo por si la DB está vacía
const fallbackTestimonios = [
  {
    tipo: 'texto',
    nombre: "Carlos M.",
    ciudad: "Medellín, Antioquia",
    texto: "Me daba susto pagar por adelantado, pero el ramo para mi mamá llegó divino. La atención por WhatsApp fue muy profesional.",
    stars: 5,
    avatar: "CM",
    producto: "Ramo Oliva",
    tiempo: "Hace 2 días",
    color: "rose"
  },
  {
    tipo: 'texto',
    nombre: "Juan Pablo V.",
    ciudad: "Bogotá, D.C.",
    texto: "Tenía miedo de que llegara diferente a la foto, pero es tal cual. La caja rígida lo protege perfecto. Mi esposa quedó encantada.",
    stars: 5,
    avatar: "JP",
    producto: "Cesta Girasoles",
    time: "Hace 5 días",
    color: "violet"
  }
];

let list = sbTestimonios.length > 0 ? sbTestimonios : fallbackTestimonios;

// Mezclar (aleatorizar) y luego intercalar (Texto -> Foto -> Texto -> Foto)
const whatsapp = list.filter((t: any) => t.tipo === 'whatsapp').sort(() => Math.random() - 0.5);
const texto = list.filter((t: any) => t.tipo !== 'whatsapp').sort(() => Math.random() - 0.5);

list = [];
const maxLength = Math.max(whatsapp.length, texto.length);
for(let i = 0; i < maxLength; i++) {
  if (texto[i]) list.push(texto[i]);
  if (whatsapp[i]) list.push(whatsapp[i]);
}

const colors: any = {
  rose: { bg: 'bg-rose-100', text: 'text-rose-700', badge: 'bg-rose-50 text-rose-600 border-rose-100' },
  violet: { bg: 'bg-violet-100', text: 'text-violet-700', badge: 'bg-violet-50 text-violet-600 border-violet-100' },
  emerald: { bg: 'bg-emerald-100', text: 'text-emerald-700', badge: 'bg-stone-50 text-stone-600 border-emerald-100' }
};

const getColors = (c: string) => colors[c] || colors.rose;
---

<section class="bg-stone-50 py-16 px-6 border-t border-stone-100 overflow-hidden">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-12">
      <div class="inline-flex items-center justify-center bg-rose-50 text-rose-600 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-[2px] mb-4 border border-rose-100 shadow-sm gap-2">
        <Icon name="heart-3" class="text-xs" /> Clientes enamorados en toda Colombia
      </div>
      <h2 class="font-serif text-3xl md:text-5xl font-light text-stone-800 mb-4 leading-tight">Historias <em class="italic text-rose-500 font-normal">Reales</em></h2>
      <p class="text-stone-500 text-sm md:text-base max-w-lg mx-auto">Lo que dicen las personas que decidieron confiar en Nuditos para un momento especial.</p>
    </div>

    <div class="flex md:grid md:grid-cols-2 lg:grid-cols-4 gap-6 overflow-x-auto md:overflow-x-visible pb-8 md:pb-0 snap-x snap-mandatory scrollbar-hide scroll-pl-6 -mx-6 px-6 md:mx-0 md:px-0 after:content-[''] after:w-1 after:flex-shrink-0 md:after:hidden">
      {list.map((t: any, i: number) => (
        <div class="min-w-[300px] md:min-w-0 snap-start bg-white rounded-[2.5rem] border border-stone-100 shadow-sm hover:shadow-md transition-all flex flex-col group overflow-hidden">
          
          {t.tipo === 'whatsapp' ? (
            <div class="flex flex-col h-full">
              <div onclick={`openTestimonioModal('${t.img_url}')`} class="aspect-[9/12] relative overflow-hidden bg-stone-200 block cursor-zoom-in group/img">
                <img src={t.img_url} alt={`Chat con ${t.nombre}`} class="w-full h-full object-cover group-hover/img:scale-105 transition-transform duration-500" />
                
                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover/img:opacity-100 transition-opacity duration-300 flex items-center justify-center z-10">
                  <div class="bg-white/90 text-stone-900 rounded-full px-4 py-2 text-[10px] font-bold uppercase tracking-widest transform scale-90 group-hover/img:scale-100 transition-all duration-300 shadow-xl flex items-center gap-2">
                    <Icon name="search-eye" class="text-[12px] -mt-px" /> Ampliar
                  </div>
                </div>

                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent pointer-events-none z-0"></div>
                
                <div class="absolute bottom-4 left-6 right-6 text-white pointer-events-none z-10">
                  <div class="flex items-center gap-2 mb-1">
                    <Icon name="whatsapp" class="text-green-400" />
                    <span class="text-[10px] font-bold uppercase tracking-widest opacity-80">Compra Verificada</span>
                  </div>
                  <div class="font-bold text-sm">{t.nombre}</div>
                </div>
              </div>
              <div class="p-5 bg-white border-t border-stone-50 flex items-center justify-between">
                 <span class="text-[10px] text-stone-400 uppercase tracking-widest">{t.ciudad}</span>
                 <span class="text-[10px] text-stone-300">{t.tiempo || t.time || 'Reciente'}</span>
              </div>
            </div>
          ) : (
            /* Card de Texto */
            <div class="p-7 md:p-8 flex flex-col h-full">
              <div class="flex items-center gap-4 mb-6">
                <div class={`w-12 h-12 rounded-full ${getColors(t.color || 'rose').bg} flex items-center justify-center ${getColors(t.color || 'rose').text} font-bold text-lg flex-shrink-0`}>
                  {t.avatar || (t.nombre?.[0] || 'U')}
                </div>
                <div>
                  <div class="font-bold text-stone-800 text-[14px]">{t.nombre}</div>
                  <div class="text-[10px] text-stone-400 uppercase tracking-widest">{t.ciudad}</div>
                </div>
              </div>

              <div class="flex gap-1 mb-5">
                {[...Array(t.stars || 5)].map(() => (
                  <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-amber-400 flex-shrink-0">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>

              <p class="text-stone-600 text-[13px] leading-relaxed italic mb-8 flex-grow">
                "{t.texto || t.text}"
              </p>

              <div class="flex items-center justify-between mt-auto pt-5 border-t border-stone-50">
                <span class={`px-3 py-1 rounded-full text-[9px] font-bold tracking-widest uppercase border ${getColors(t.color || 'rose').badge}`}>
                  {t.producto || t.product || 'Ramo Nuditos'}
                </span>
                <span class="text-[10px] text-stone-300 font-medium">{t.tiempo || t.time || 'Reciente'}</span>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
    </div>


  </div>
</section>

<style>
  .snap-start {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  .snap-start:nth-child(1) { animation-delay: 0.1s; }
  .snap-start:nth-child(2) { animation-delay: 0.2s; }
  .snap-start:nth-child(3) { animation-delay: 0.3s; }
  .snap-start:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<!-- Modal Nativo para Reseñas WhatsApp -->
<dialog id="testimonioModal" class="bg-transparent m-auto p-0 border-none backdrop:bg-black/80 backdrop:backdrop-blur-sm w-full max-w-2xl overflow-visible">
  <div class="relative w-full p-4 flex flex-col items-center justify-center" onclick="event.stopPropagation()">
    <form method="dialog" class="w-full relative flex justify-center">
      <button class="absolute -top-14 right-0 md:-right-8 bg-white/20 hover:bg-white/30 text-white rounded-full w-10 h-10 flex items-center justify-center backdrop-blur-md border border-white/30 transition-colors z-10 cursor-pointer text-lg shadow-lg">
        ✕
      </button>
      <img id="testimonioModalImg" src="" class="max-w-full max-h-[85vh] object-contain rounded-2xl shadow-2xl" />
    </form>
  </div>
</dialog>

<script is:inline>
  window.openTestimonioModal = function(url) {
    const modal = document.getElementById('testimonioModal');
    const img = document.getElementById('testimonioModalImg');
    if(modal && img) {
      img.src = url;
      modal.showModal();
      document.body.style.overflow = 'hidden'; // Evitar scroll de fondo
    }
  }

  const modal = document.getElementById('testimonioModal');
  if (modal) {
    // Cerrar al hacer click fuera de la imagen
    modal.addEventListener('click', function(e) {
      if (e.target === this) {
        this.close();
      }
    });

    // Restaurar scroll al cerrar
    modal.addEventListener('close', () => {
      document.body.style.overflow = 'auto';
    });
  }
</script>
