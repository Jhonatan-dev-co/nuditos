    --font-serif:  'Cormorant Garamond', serif;
    --font-sans:   'Jost', sans-serif;
  }
  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-serif);
    font-weight: 400;
  }
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 100;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-bottom: 1px solid var(--glass-border);
  }
  .nav-wrap.nav-scrolled {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
  }
  .nav-wrap.nav-hidden {
    transform: translateY(-100%);
  }
  
  @keyframes cartBump {
    0% { transform: scale(1); }
    50% { transform: scale(1.2) translateY(-2px); }
    100% { transform: scale(1); }
  }
  .cart-bump-animation {
    animation: cartBump 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
  }
  @media (max-width: 768px) {
    :root {
      /* OPTIMIZACIÓN EXTREMA MÓVIL: Reducir blur para no asfixiar la GPU de celulares antiguos */
      --glass-blur: 8px;
      --glass-bg: rgba(255, 255, 255, 0.92);
    }
    .nav-center .logo {
      font-size: 1.2rem;
      letter-spacing: 3px;
    }
    /* Forzar al celular a preparar la memoria gráfica para que el menú no laguee al iniciar */
    .menu-panel, .cart-panel {
      will-change: transform;
    }
  }
  /* Estilos para el Acordeón del Menú */
  .menu-submenu-collapsible {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(0,0,0,0.02);
    border-radius: 1rem;
  }
  .menu-accordion-item.open .menu-submenu-collapsible {
    max-height: 500px;
    margin-bottom: 1rem;
    padding: 0.5rem 0;
  }
  .menu-accordion-item.open .acc-arrow {
    transform: rotate(180deg);
    color: var(--accent);
  }
  .accordion-trigger {
    border: none;
    width: 100%;
    text-align: left;
    background: none;
    cursor: pointer;
  }
  
  body.scroll-lock {
    overflow: hidden !important;
    height: 100vh !important;
    touch-action: none;
    position: fixed;
    width: 100%;
  }
</style>

  {!hideNav && (
