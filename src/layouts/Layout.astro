---
import Icon from '../components/Icon.astro';
import '../styles/main.css';
import SearchOverlay from '../components/SearchOverlay.astro';
import BoutiqueHighlights from '../components/BoutiqueHighlights.astro';
import { ViewTransitions } from 'astro:transitions';
import { categories as FALLBACK_CATEGORIES, clUrl } from '../data/datos';
import { getLiveConfig, getPublicConfig, getLiveCategories } from '../lib/supabase';

// Fetch live configuration and categories in parallel
const [config, publicConfig, rawCategories] = await Promise.all([
  getLiveConfig(),
  getPublicConfig(),
  getLiveCategories()
]);

const categories = rawCategories && rawCategories.length > 0 ? rawCategories : FALLBACK_CATEGORIES;
const siteTitle = config?.seoTitle || 'Nuditos Tejidos — Ramos de Crochet, Regalos y Detalles Originales';
const siteDesc = config?.seoDescription || 'Ramos de crochet hechos a mano y amigurumis. El regalo eterno perfecto para detalles inolvidables en Colombia. Envíos a todo el país.';
const siteOgImg = config?.seoOgImage || 'https://nuditos.com.co/og-default.jpg';
const instaUrl = config?.socialInstagram || 'https://www.instagram.com/nuditos_tejidos/';
const whatsappNum = config?.socialWhatsapp || '573144931525';
const whatsappLink = `https://wa.me/${whatsappNum}`;

/**
 * Layout base de Nuditos Tejidos
 * Incluye: navbar, footer, fuentes, meta SEO básico
 * Props: title, description, ogImage, ogType, canonical
 */
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  noIndex?: boolean;
  preloadImage?: string;
  hideNav?: boolean;
  hideFooter?: boolean;
}

const {
  title,
  description = siteDesc,
  ogImage = siteOgImg,
  ogType = 'website',
  canonical,
  noIndex = false,
  preloadImage,
  hideNav = false,
  hideFooter = false
} = Astro.props;

// Combinar título de la página con el título del sitio
const fullTitle = title === 'Nuditos' ? siteTitle : `${title} | Nuditos`;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="facebook-domain-verification" content="klq9w8ypl5a07xxn6pwjtni92v2afa" />

  <!-- SEO básico -->
  <title>{fullTitle}</title>
  <ViewTransitions />
  
  <!-- Barra de Carga Premium -->
  <style is:global>
    #loading-bar {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: var(--accent);
      z-index: 1000;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.4s ease-out;
      pointer-events: none;
    }
    #loading-bar.loading {
      transform: scaleX(0.7);
      transition: transform 2s cubic-bezier(0.1, 0, 0, 1);
    }
    #loading-bar.done {
      transform: scaleX(1);
      opacity: 0;
      transition: transform 0.3s ease-out, opacity 0.3s 0.3s;
    }
  </style>
  <script>
    document.addEventListener('astro:before-preparation', () => {
      const bar = document.getElementById('loading-bar');
      if (bar) {
        bar.style.transform = 'scaleX(0)';
        bar.style.opacity = '1';
        bar.classList.remove('done');
        bar.classList.add('loading');
      }
    });

    document.addEventListener('astro:page-load', () => {
      const bar = document.getElementById('loading-bar');
      if (bar) {
        bar.classList.add('done');
        setTimeout(() => {
          bar.classList.remove('loading', 'done');
          bar.style.transform = 'scaleX(0)';
        }, 600);
      }
      
      // Global helpers
      (window as any).closeSearch = () => {
        const searchOverlay = document.getElementById('searchOverlay');
        searchOverlay?.classList.remove('open');
        const scrollLockFn = (window as any).toggleScrollLock;
        if (scrollLockFn) scrollLockFn(false);
      };

      (window as any).toggleMenuAccordion = (btn) => {
        const item = btn.closest('.menu-accordion-item');
        item.classList.toggle('open');
      };
    });
  </script>

  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}
  {!noIndex && <meta name="robots" content="index, follow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="es_CO" />
  <meta property="og:site_name" content="Nuditos Tejidos" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
