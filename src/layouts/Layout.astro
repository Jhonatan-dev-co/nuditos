---
import Icon from '../components/Icon.astro';
import '../styles/main.css';
import SearchOverlay from '../components/SearchOverlay.astro';
import NewsletterOverlay from '../components/NewsletterOverlay.astro';
import BoutiqueHighlights from '../components/BoutiqueHighlights.astro';
import Footer from '../components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import { categories as FALLBACK_CATEGORIES, clUrl } from '../data/datos';
import { getLiveConfig, getPublicConfig, getLiveCategories } from '../lib/supabase';

// Fetch live configuration and categories in parallel
const [config, publicConfig, rawCategories] = await Promise.all([
  getLiveConfig(),
  getPublicConfig(),
  getLiveCategories()
]);

const categories = rawCategories && rawCategories.length > 0 ? rawCategories : FALLBACK_CATEGORIES;
const siteTitle = config?.seoTitle || 'Nuditos Tejidos — Ramos de Crochet, Regalos y Detalles Originales';
const siteDesc = config?.seoDescription || 'Ramos de crochet hechos a mano y amigurumis. El regalo eterno perfecto para detalles inolvidables en Colombia. Envíos a todo el país.';
const siteOgImg = config?.seoOgImage || 'https://nuditos.com.co/og-default.jpg';
const instaUrl = config?.socialInstagram || 'https://www.instagram.com/nuditos_tejidos/';
const whatsappNum = config?.socialWhatsapp || '573144931525';
const whatsappLink = `https://wa.me/${whatsappNum}`;

/**
 * Layout base de Nuditos Tejidos
 * Incluye: navbar, footer, fuentes, meta SEO básico
 * Props: title, description, ogImage, ogType, canonical
 */
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  noIndex?: boolean;
  preloadImage?: string;
  hideNav?: boolean;
  hideFooter?: boolean;
  keywords?: string;
}

const {
  title,
  description = siteDesc,
  ogImage = siteOgImg,
  ogType = 'website',
  canonical,
  noIndex = false,
  preloadImage,
  hideNav = false,
  hideFooter = false,
  keywords = ''
} = Astro.props;

// Combinar título de la página con el título del sitio
const fullTitle = title === 'Nuditos' ? siteTitle : `${title} | Nuditos`;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="facebook-domain-verification" content="klq9w8ypl5a07xxn6pwjtni92v2afa" />

  <!-- SEO básico -->
  <title>{fullTitle}</title>
  <ViewTransitions />
  
  <!-- Barra de Carga Premium -->
  <style is:global>
    #loading-bar {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: var(--accent);
      z-index: 1000;
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.4s ease-out;
      pointer-events: none;
    }
    #loading-bar.loading {
      transform: scaleX(0.7);
      transition: transform 2s cubic-bezier(0.1, 0, 0, 1);
    }
    #loading-bar.done {
      transform: scaleX(1);
      opacity: 0;
      transition: transform 0.3s ease-out, opacity 0.3s 0.3s;
    }
    
    /* Overlay premium de carga */
    #page-transition-overlay {
      position: fixed; inset: 0; z-index: 9999;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 1.25rem;
      opacity: 0; pointer-events: none;
      transition: opacity 0.25s ease;
    }
    #page-transition-overlay.active {
      opacity: 1; pointer-events: all;
    }
    /* Icono flor crochet SVG animado */
    .loader-icon {
      width: 64px;
      height: 64px;
      animation: loaderSpin 2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
      filter: drop-shadow(0 4px 16px rgba(167, 139, 250, 0.35));
    }
    .loader-icon .petal {
      transform-origin: 50% 50%;
      animation: petalPulse 2s ease-in-out infinite;
    }
    .loader-icon .petal:nth-child(1) { animation-delay: 0s; }
    .loader-icon .petal:nth-child(2) { animation-delay: 0.16s; }
    .loader-icon .petal:nth-child(3) { animation-delay: 0.33s; }
    .loader-icon .petal:nth-child(4) { animation-delay: 0.5s; }
    .loader-icon .petal:nth-child(5) { animation-delay: 0.66s; }
    .loader-icon .petal:nth-child(6) { animation-delay: 0.83s; }
    @keyframes loaderSpin {
      0%   { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    @keyframes petalPulse {
      0%, 100% { opacity: 0.55; }
      50%       { opacity: 1; }
    }
    /* Puntos de carga tipo "yarn" */
    .loader-dots {
      display: flex;
      gap: 6px;
      align-items: center;
    }
    .loader-dots span {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #a78bfa;
      animation: dotBounce 1.2s ease-in-out infinite;
    }
    .loader-dots span:nth-child(1) { animation-delay: 0s; }
    .loader-dots span:nth-child(2) { animation-delay: 0.15s; background: #c084fc; }
    .loader-dots span:nth-child(3) { animation-delay: 0.3s; background: #f0abfc; }
    @keyframes dotBounce {
      0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }
      40%           { transform: scale(1.2); opacity: 1; }
    }
    .loading-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: #a78bfa;
      animation: pulse-text 1.8s ease-in-out infinite;
    }
    @keyframes pulse-text {
      0%, 100% { opacity: 0.5; }
      50%       { opacity: 1; }
    }
  </style>
  <script>
    document.addEventListener('astro:before-preparation', () => {
      const bar = document.getElementById('loading-bar');
      const overlay = document.getElementById('page-transition-overlay');
      if (bar) {
        bar.style.transform = 'scaleX(0)';
        bar.style.opacity = '1';
        bar.classList.remove('done');
        bar.classList.add('loading');
      }
      if (overlay) {
        overlay.classList.add('active');
        document.body.style.overflow = 'hidden'; // Evita scrollear mientras carga
      }
    });

    document.addEventListener('astro:page-load', () => {
      const bar = document.getElementById('loading-bar');
      const overlay = document.getElementById('page-transition-overlay');
      if (bar) {
        bar.classList.add('done');
        setTimeout(() => {
          bar.classList.remove('loading', 'done');
          bar.style.transform = 'scaleX(0)';
        }, 600);
      }
      if (overlay) {
        overlay.classList.remove('active');
        document.body.style.overflow = '';
      }
      
      // Global helpers
      (window as any).closeSearch = () => {
        const searchOverlay = document.getElementById('searchOverlay');
        searchOverlay?.classList.remove('open');
        const scrollLockFn = (window as any).toggleScrollLock;
        if (scrollLockFn) scrollLockFn(false);
      };

      (window as any).toggleMenuAccordion = (btn) => {
        const item = btn.closest('.menu-accordion-item');
        item.classList.toggle('open');
      };
    });
  </script>

  <meta name="description" content={description} />
  {keywords && <meta name="keywords" content={keywords} />}
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" type="text/plain" title="Datos para IAs" href="/llms.txt" />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}
  {!noIndex && <meta name="robots" content="index, follow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="es_CO" />
  <meta property="og:site_name" content="Nuditos Tejidos" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@nuditos_tejidos" />
  <meta name="twitter:creator" content="@nuditos_tejidos" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Facebook Pixel (Meta Pixel) -->
  {config?.metaPixelActivo && (
    <>
      <script is:inline define:vars={{ pixelId: config.metaPixelId || '919518317518571' }}>
        !(function (f, b, e, v, n, t, s) {
          if (f.fbq) return;
          n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
          if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0';
          n.queue = []; t = b.createElement(e); t.async = !0; t.src = v;
          s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
        })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
        fbq('init', pixelId);
        fbq('track', 'PageView');

        document.addEventListener('astro:after-swap', () => {
          fbq('track', 'PageView');
        });
      </script>
      <noscript><img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${config.metaPixelId || '919518317518571'}&ev=PageView&noscript=1`} /></noscript>
    </>
  )}

  <!-- TikTok Pixel -->
  {(config?.tiktokPixelActivo || !config?.tiktokPixelId) && (
    <>
      <script is:inline define:vars={{ ttPixelId: config.tiktokPixelId || 'D8992LJC77UDFA3HK540' }}>
        !(function (w, d, t) {
          w.TiktokAnalyticsObject = t;
          var ttq = (w[t] = w[t] || []);
          (ttq.methods = [
            'page',
            'track',
            'identify',
            'instances',
            'debug',
            'on',
            'off',
            'once',
            'ready',
            'alias',
            'group',
            'enableCookie',
            'disableCookie',
          ]),
            (ttq.setAndDefer = function (t, e) {
              t[e] = function () {
                t.push([e].concat(Array.prototype.slice.call(arguments, 0)));
              };
            });
          for (var e = 0; e < ttq.methods.length; e++) ttq.setAndDefer(ttq, ttq.methods[e]);
          (ttq.instance = function (t) {
            for (var e = ttq._i[t] || [], n = 0; n < ttq.methods.length; n++) ttq.setAndDefer(e, ttq.methods[n]);
            return e;
          }),
            (ttq.load = function (e, n) {
              var i = 'https://analytics.tiktok.com/i18n/pixel/events.js';
              (ttq._i = ttq._i || {}),
                (ttq._i[e] = []),
                (ttq._i[e]._u = i),
                (ttq._t = ttq._t || {}),
                (ttq._t[e] = +new Date()),
                (ttq._o = ttq._o || {}),
                (ttq._o[e] = n || {});
              var o = d.createElement('script');
              (o.type = 'text/javascript'), (o.async = !0), (o.src = i + '?sdkid=' + e + '&lib=' + t);
              var a = d.getElementsByTagName('script')[0];
              a.parentNode.insertBefore(o, a);
            });

          if (ttPixelId) {
            ttq.load(ttPixelId);
            ttq.page();
          }

          document.addEventListener('astro:after-swap', () => {
            if (ttPixelId) {
              ttq.page();
            }
          });
        })(window, document, 'ttq');
      </script>
    </>
  )}



  <!-- Google Analytics -->
  {config?.gaActive && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${config.gaId || 'G-KWMVM0GSZM'}`}></script>
      <script is:inline define:vars={{ gaId: config.gaId || 'G-KWMVM0GSZM' }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);

        document.addEventListener('astro:after-swap', () => {
          gtag('config', gaId, { page_path: window.location.pathname });
        });
      </script>
    </>
  )}

  <!-- Preconexiones críticas para acelerar terceros y base de datos -->
  <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  


  <!-- Fuentes (Carga optimizada) -->
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap" /></noscript>



  <!-- CSS global gestionado por Astro -->
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#b794cc" />

  <!-- Global Structured Data -->
  {Astro.url.pathname === '/' && (
    <>
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Nuditos Tejidos",
      "url": "https://nuditos.com.co",
      "logo": "https://nuditos.com.co/logo.png",
      "sameAs": [
        "https://www.instagram.com/nuditos_tejidos/",
        "https://wa.me/573144931525"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+57-314-493-1525",
        "contactType": "customer service",
        "areaServed": "CO",
        "availableLanguage": "Spanish"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Nuditos Tejidos",
      "image": "https://nuditos.com.co/og-default.jpg",
      "url": "https://nuditos.com.co",
      "telephone": "+573144931525",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "El Dorado",
        "addressLocality": "El Dorado",
        "addressRegion": "Meta",
        "postalCode": "500010",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 4.1900,
        "longitude": -73.5400
      },
      "priceRange": "$$",
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
        "opens": "08:00",
        "closes": "20:00"
      },
      "sameAs": [
        "https://www.instagram.com/nuditos_tejidos/"
      ]
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "https://nuditos.com.co",
      "name": "Nuditos Tejidos",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://nuditos.com.co/catalogo?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />
    </>
  )}

  <!-- Slot para head extra (meta producto, schema.org, etc.) -->
  <slot name="head" />
</head>

<body>
  <div id="loading-bar"></div>
  
  <!-- Overlay Premium de Carga — Flor Crochet SVG Animada -->
  <div id="page-transition-overlay">
    <svg class="loader-icon" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id="lg-p" cx="50%" cy="30%" r="70%">
          <stop offset="0%" stop-color="#e9d5ff"/>
          <stop offset="100%" stop-color="#a855f7"/>
        </radialGradient>
        <radialGradient id="lg-c" cx="50%" cy="50%" r="55%">
          <stop offset="0%" stop-color="#fde68a"/>
          <stop offset="100%" stop-color="#f59e0b"/>
        </radialGradient>
      </defs>
      <g transform="translate(50,50)">
        <ellipse class="petal" cx="0" cy="-21" rx="9" ry="17" fill="url(#lg-p)" transform="rotate(0)"/>
        <ellipse class="petal" cx="0" cy="-21" rx="9" ry="17" fill="url(#lg-p)" transform="rotate(60)"/>
        <ellipse class="petal" cx="0" cy="-21" rx="9" ry="17" fill="url(#lg-p)" transform="rotate(120)"/>
        <ellipse class="petal" cx="0" cy="-21" rx="9" ry="17" fill="url(#lg-p)" transform="rotate(180)"/>
        <ellipse class="petal" cx="0" cy="-21" rx="9" ry="17" fill="url(#lg-p)" transform="rotate(240)"/>
        <ellipse class="petal" cx="0" cy="-21" rx="9" ry="17" fill="url(#lg-p)" transform="rotate(300)"/>
        <path d="M-3,-14 Q0,-7 3,-14" stroke="#c084fc" stroke-width="1.5" fill="none" opacity="0.7" transform="rotate(0)"/>
        <path d="M-3,-14 Q0,-7 3,-14" stroke="#c084fc" stroke-width="1.5" fill="none" opacity="0.7" transform="rotate(60)"/>
        <path d="M-3,-14 Q0,-7 3,-14" stroke="#c084fc" stroke-width="1.5" fill="none" opacity="0.7" transform="rotate(120)"/>
        <path d="M-3,-14 Q0,-7 3,-14" stroke="#c084fc" stroke-width="1.5" fill="none" opacity="0.7" transform="rotate(180)"/>
        <path d="M-3,-14 Q0,-7 3,-14" stroke="#c084fc" stroke-width="1.5" fill="none" opacity="0.7" transform="rotate(240)"/>
        <path d="M-3,-14 Q0,-7 3,-14" stroke="#c084fc" stroke-width="1.5" fill="none" opacity="0.7" transform="rotate(300)"/>
        <circle cx="0" cy="0" r="11" fill="url(#lg-c)"/>
        <circle cx="0" cy="0" r="7.5" fill="none" stroke="#fcd34d" stroke-width="1.8" stroke-dasharray="3 2"/>
        <circle cx="0" cy="0" r="3.5" fill="#f59e0b"/>
        <circle cx="0" cy="0" r="1.5" fill="#fde68a"/>
      </g>
    </svg>
    <div class="loading-text">Nuditos</div>
    <div class="loader-dots">
      <span></span><span></span><span></span>
    </div>
  </div>

  <!-- ════════ NAVBAR ════════ -->
<style is:global>
  :root {
    --nav-h:       56px;
    --nav-h-mob:   50px;
    --nav-h-mini:  48px;
    --nav-h-mini-mob: 42px;
    --glass-bg:    rgba(255, 255, 255, 0.7);
    --glass-border: rgba(255, 255, 255, 0.3);
    --glass-blur:  25px;
    --font-serif:  'Cormorant Garamond', serif;
    --font-sans:   'Jost', sans-serif;
  }
  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
    padding-top: var(--nav-h);
  }
  @media (max-width: 768px) {
    body {
      padding-top: var(--nav-h-mob);
    }
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-serif);
    font-weight: 400;
  }
  .nav-wrap {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    height: var(--nav-h);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border-bottom: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
  }
  @media (max-width: 768px) {
    .nav-wrap { height: var(--nav-h-mob); }
  }
  .nav-wrap.nav-scrolled {
    height: var(--nav-h-mini);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
  }
  @media (max-width: 768px) {
    .nav-wrap.nav-scrolled { height: var(--nav-h-mini-mob); }
  }
  .nav-wrap nav { height: 100%; width: 100%; }

  .nav-wrap.nav-scrolled .logo {
    font-size: 1.1rem;
    letter-spacing: 4px;
  }
  @media (max-width: 768px) {
    .nav-wrap.nav-scrolled .logo {
      font-size: 1rem;
      letter-spacing: 2px;
    }
    .nav-wrap.nav-scrolled .nav-icon-btn {
      transform: scale(0.85);
    }
  }

  /* Ajuste para la barra de categorías sticky si existe en la página */
  .nav-wrap.nav-scrolled + * .cat-sticky,
  .nav-wrap.nav-scrolled ~ .cat-sticky,
  .nav-wrap.nav-scrolled ~ * .cat-sticky {
    top: var(--nav-h-mini) !important;
  }
  @media (max-width: 768px) {
    .nav-wrap.nav-scrolled + * .cat-sticky,
    .nav-wrap.nav-scrolled ~ .cat-sticky,
    .nav-wrap.nav-scrolled ~ * .cat-sticky {
      top: var(--nav-h-mini-mob) !important;
    }
  }

  
  @keyframes cartBump {
    0% { transform: scale(1); }
    50% { transform: scale(1.2) translateY(-2px); }
    100% { transform: scale(1); }
  }
  .cart-bump-animation {
    animation: cartBump 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
  }
  @media (max-width: 768px) {
    :root {
      /* OPTIMIZACIÓN EXTREMA MÓVIL: Reducir blur para no asfixiar la GPU de celulares antiguos */
      --glass-blur: 8px;
      --glass-bg: rgba(255, 255, 255, 0.92);
    }
    .nav-center .logo {
      font-size: 1.2rem;
      letter-spacing: 3px;
    }
    /* Forzar al celular a preparar la memoria gráfica para que el menú no laguee al iniciar */
    .menu-panel, .cart-panel {
      will-change: transform;
    }
  }
  /* Estilos para el Acordeón del Menú */
  .menu-submenu-collapsible {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    background: rgba(0,0,0,0.02);
    border-radius: 1rem;
  }
  .menu-accordion-item.open .menu-submenu-collapsible {
    max-height: 500px;
    margin-bottom: 1rem;
    padding: 0.5rem 0;
  }
  .menu-accordion-item.open .acc-arrow {
    transform: rotate(180deg);
    color: var(--accent);
  }
  .accordion-trigger {
    border: none;
    width: 100%;
    text-align: left;
    background: none;
    cursor: pointer;
  }
  
  body.scroll-lock {
    overflow: hidden !important;
    height: 100vh !important;
    touch-action: none;
    position: fixed;
    width: 100%;
  }
