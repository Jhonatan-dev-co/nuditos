<body>
  <div id="loading-bar"></div>

  <!-- ════════ NAVBAR ════════ -->
<style is:global>
  :root {
    --nav-h:       72px;
    --nav-h-mob:   64px;
    --glass-bg:    rgba(255, 255, 255, 0.7);
    --glass-border: rgba(255, 255, 255, 0.3);
