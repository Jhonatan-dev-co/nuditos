---
import '../styles/main.css';
import SearchOverlay from '../components/SearchOverlay.astro';
import { ViewTransitions } from 'astro:transitions';
import { categories } from '../data/datos';
import { getLiveConfig } from '../lib/supabase';

// Fetch live configuration for SEO and Social
const config = await getLiveConfig();
const siteTitle = config?.seoTitle || 'Nuditos Tejidos — Ramos de Crochet y Flores Eternas';
const siteDesc = config?.seoDescription || 'Ramos de crochet hechos a mano en El Dorado, Meta. Flores eternas tejidas con amor. Envíos a todo Colombia.';
const siteOgImg = config?.seoOgImage || 'https://nuditos.com.co/og-default.jpg';
const instaUrl = config?.socialInstagram || 'https://www.instagram.com/nuditos_tejidos/';
const whatsappNum = config?.socialWhatsapp || '573144931525';
const whatsappLink = `https://wa.me/${whatsappNum}`;

/**
 * Layout base de Nuditos Tejidos
 * Incluye: navbar, footer, fuentes, meta SEO básico
 * Props: title, description, ogImage, ogType, canonical
 */
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  noIndex?: boolean;
}

const {
  title,
  description = siteDesc,
  ogImage = siteOgImg,
  ogType = 'website',
  canonical,
  noIndex = false,
} = Astro.props;

// Combinar título de la página con el título del sitio
const fullTitle = title === 'Nuditos' ? siteTitle : `${title} | Nuditos`;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO básico -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}
  {!noIndex && <meta name="robots" content="index, follow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="es_CO" />
  <meta property="og:site_name" content="Nuditos Tejidos" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@nuditos_tejidos" />
  <meta name="twitter:creator" content="@nuditos_tejidos" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Facebook Pixel (Meta Pixel) -->
  {config?.metaPixelActivo && config?.metaPixelId && (
    <script is:inline define:vars={{ id: config.metaPixelId }}>
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () { n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments); };
        if (!f._fbq) f._fbq = n; n.push = n; n.loaded = !0; n.version = '2.0';
        n.queue = []; t = b.createElement(e); t.async = !0; t.src = v;
        s = b.getElementsByTagName(e)[0]; s.parentNode.insertBefore(t, s);
      })(window, document, 'script', 'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', id);
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" src={`https://www.facebook.com/tr?id=${config.metaPixelId}&ev=PageView&noscript=1`} /></noscript>
  )}

  <!-- Google Analytics -->
  {config?.gaActive && config?.gaId && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${config.gaId}`}></script>
    <script is:inline define:vars={{ id: config.gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', id);
    </script>
  )}

  <!-- Preconexiones críticas para acelerar terceros y base de datos -->
  <link rel="preconnect" href="https://fpyhkxikxdwjhukltmqf.supabase.co" crossorigin />
  <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
  <!-- Fuentes (Carga diferida y optimizada) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap" /></noscript>

  <!-- Iconos (Carga diferida para no bloquear renderizado inicial) -->
  <link rel="preload" href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet" /></noscript>

  <!-- CSS global gestionado por Astro -->
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#b794cc" />

  <ViewTransitions />

  <!-- Global Structured Data -->
  {Astro.url.pathname === '/' && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Nuditos Tejidos",
      "url": "https://nuditos.com.co",
      "logo": "https://nuditos.com.co/logo.png",
      "sameAs": [
        "https://www.instagram.com/nuditos_tejidos/",
        "https://wa.me/573144931525"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+57-314-493-1525",
        "contactType": "customer service",
        "areaServed": "CO",
        "availableLanguage": "Spanish"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "url": "https://nuditos.com.co",
      "name": "Nuditos Tejidos",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://nuditos.com.co/catalogo?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    })} />
  )}

  <!-- Slot para head extra (meta producto, schema.org, etc.) -->
  <slot name="head" />
</head>

<body>

  <!-- ════════ NAVBAR ════════ -->
<style is:global>
  :root {
    --nav-h:       64px;
    --nav-h-mob:   56px;
    --glass-bg:    rgba(255, 255, 255, 0.72);
    --glass-border: rgba(255, 255, 255, 0.4);
    --font-serif:  'Outfit', sans-serif;
    --font-sans:   'Inter', sans-serif;
  }
  body {
    font-family: var(--font-sans);
  }
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-serif);
    font-weight: 300;
    letter-spacing: -0.02em;
  }
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 100;
    background: white;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-bottom: 1px solid transparent;
  }
  .nav-wrap.nav-scrolled {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    padding: 2px 0;
  }
  .nav-wrap.nav-hidden {
    transform: translateY(-100%);
  }
  @media (max-width: 768px) {
    .nav-center .logo {
      font-size: 1.1rem;
      letter-spacing: 2px;
    }
    .nav-wrap nav {
      padding: 0 0.75rem;
    }
    .nav-icon-btn {
      width: 40px;
      height: 40px;
      font-size: 1.1rem;
    }
  }
</style>
  <div class="nav-wrap" transition:persist>
    <nav>
      <div class="nav-left">
        <button class="nav-icon-btn nav-hamburger" onclick="toggleMenu()" aria-label="Menú">
          <i class="ri-menu-line"></i>
        </button>
        <ul class="nav-desktop-links">
          <li><a href="/catalogo">Catálogo</a></li>
          <li><a href="/#personalizado">Personalizado</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/sobre-nosotros">Nosotros</a></li>
          <li><a href="/#resenas">Reseñas</a></li>
        </ul>
      </div>
      <div class="nav-center">
        <a href="/" class="logo">NUDITOS<em>.</em></a>
      </div>
      <div class="nav-right hide-mobile">
        <button class="nav-icon-btn" onclick="toggleSearch()" aria-label="Buscar">
          <i class="ri-search-line"></i>
        </button>
        <button class="nav-icon-btn" onclick="toggleCart()" aria-label="Carrito">
          <i class="ri-shopping-bag-line"></i>
          <span class="cart-badge hidden" id="cartCount">0</span>
        </button>
      </div>
    </nav>
  </div>

  <!-- ════════ MENÚ LATERAL ════════ -->
  <div class="menu-overlay" id="menuOverlay" onclick="toggleMenu()"></div>
  <div class="menu-panel" id="menuPanel">
    <div class="menu-head">
      <span class="menu-logo">NUDITOS<em>.</em></span>
      <button class="menu-close" onclick="toggleMenu()" aria-label="Cerrar menú">
        <i class="ri-close-line"></i>
      </button>
    </div>
    <div class="menu-nav">
      <a class="menu-nav-item" href="/catalogo" onclick="toggleMenu()">
        Catálogo <i class="ri-arrow-right-line"></i>
      </a>
      <a class="menu-nav-item" href="/#personalizado" onclick="toggleMenu()">
        Personalizado <i class="ri-arrow-right-line"></i>
      </a>
      <a class="menu-nav-item" href="/sobre-nosotros" onclick="toggleMenu()">
        Nosotros <i class="ri-arrow-right-line"></i>
      </a>
      <a class="menu-nav-item" href="/blog" onclick="toggleMenu()">
        Blog <i class="ri-arrow-right-line"></i>
      </a>
      <a class="menu-nav-item" href="/#resenas" onclick="toggleMenu()">
        Reseñas <i class="ri-arrow-right-line"></i>
      </a>

      <!-- Submenu Categorías -->
      <div class="menu-divider">Categorías</div>
      <div class="menu-submenu">
        {categories.filter(c => c.id !== 'todos').map(cat => (
          <a class="menu-sub-item" href={`/catalogo?categoria=${cat.id}`} onclick="toggleMenu()">
            <span class="sub-item-icon">{cat.icon}</span> {cat.name}
          </a>
        ))}
      </div>

      <div class="menu-divider">Ayuda</div>
      <a class="menu-nav-item" href="/preguntas-frecuentes">
        Preguntas frecuentes <i class="ri-arrow-right-line"></i>
      </a>
      <a class="menu-nav-item wa-item" href={whatsappLink} target="_blank">
        WhatsApp <i class="ri-whatsapp-line"></i>
      </a>
    </div>
    <div class="menu-footer">
      <a class="menu-footer-link" href="/sobre-nosotros">Sobre la marca</a>
      <a class="menu-footer-link" href="/politicas">Políticas</a>
      <a class="menu-footer-link" href="https://wa.me/573144931525" target="_blank">Contacto</a>
    </div>
  </div>

  <!-- ════════ CONTENIDO DE CADA PÁGINA ════════ -->
  <slot />

  <!-- ════════ MOBILE BOTTOM NAV ════════ -->
  <nav class="mobile-bottom-nav" transition:persist>
    <a href="/catalogo" class="mb-nav-item" id="nav-catalogo" aria-label="Ir al Catálogo">
      <i class="ri-store-2-line"></i>
      <span>Catálogo</span>
    </a>
    <button class="mb-nav-item" onclick="toggleSearch()" aria-label="Buscar productos">
      <i class="ri-search-line"></i>
      <span>Buscar</span>
    </button>
    <a href="/#personalizado" class="mb-nav-item" id="nav-personalizado" aria-label="Ramos Personalizados">
      <i class="ri-magic-line"></i>
      <span>Ramos</span>
    </a>
    <button class="mb-nav-item" onclick="toggleCart()" aria-label="Ver carrito de compras">
      <div class="mb-cart-icon-wrap">
        <i class="ri-shopping-bag-3-line"></i>
        <span class="mb-cart-badge hidden" id="mbCartCount">0</span>
      </div>
      <span>Carrito</span>
    </button>
  </nav>

  <script is:inline>
    // Lógica Simple de Active State para Mobile Nav
    function updateActiveNav() {
      const path = window.location.pathname;
      const hash = window.location.hash;
      const navCatalogo = document.getElementById('nav-catalogo');
      const navPersonalizado = document.getElementById('nav-personalizado');

      if (!navCatalogo || !navPersonalizado) return;

      navCatalogo.classList.remove('active');
      navPersonalizado.classList.remove('active');

      if (path.includes('/catalogo')) {
        navCatalogo.classList.add('active');
      } else if (hash === '#personalizado') {
        navPersonalizado.classList.add('active');
      }
    }

    // Lógica de Cabecera Inteligente
    (function() {
      let lastScroll = window.pageYOffset;

      function handleSmartHeader() {
        const nav = document.querySelector('.nav-wrap');
        if (!nav) return;
        
        const currentScroll = window.pageYOffset;

        if (currentScroll <= 15) {
          nav.classList.remove('nav-hidden');
          nav.classList.remove('nav-scrolled');
          lastScroll = currentScroll;
          return;
        }

        nav.classList.add('nav-scrolled');

        if (currentScroll > lastScroll) {
          if (currentScroll > 80) nav.classList.add('nav-hidden');
        } else {
          nav.classList.remove('nav-hidden');
        }
        
        lastScroll = currentScroll;
      }

      document.addEventListener('astro:page-load', () => {
        updateActiveNav();
        // Resetear scroll al cambiar de página
        lastScroll = window.pageYOffset;
        window.addEventListener('scroll', handleSmartHeader, { passive: true });
      });
      window.addEventListener('hashchange', updateActiveNav);
    })();
  </script>

  <!-- ════════ FOOTER ════════ -->

  <footer>
    <div class="footer-logo-wrap">
      <div class="footer-logo">NUDITOS<em>.</em></div>
      <div class="footer-social">
        <a href={instaUrl} target="_blank" aria-label="Instagram">
          <i class="ri-instagram-line"></i>
        </a>
        <a href="#" aria-label="TikTok"><i class="ri-tiktok-line"></i></a>
        <a href={whatsappLink} aria-label="WhatsApp">
          <i class="ri-whatsapp-line"></i>
        </a>
        <a href="#" aria-label="Facebook"><i class="ri-facebook-line"></i></a>
      </div>
    </div>
    <div class="footer-accordion">
      <div class="footer-acc-item">
        <button class="footer-acc-btn" onclick="toggleAcc(this)">
          Sobre la marca <i class="ri-add-line"></i>
        </button>
        <div class="footer-acc-content">
          <a class="footer-acc-link" href="/sobre-nosotros">Nuestra historia</a>
          <a class="footer-acc-link" href="/blog">Blog</a>
          <a class="footer-acc-link" href="/#personalizado">Ramos personalizados</a>
          <a class="footer-acc-link" href="/#resenas">Reseñas</a>
        </div>
      </div>
      <div class="footer-acc-item">
        <button class="footer-acc-btn" onclick="toggleAcc(this)">
          Contacto <i class="ri-add-line"></i>
        </button>
        <div class="footer-acc-content">
          <a class="footer-acc-link" href={whatsappLink} target="_blank">WhatsApp</a>
          <a class="footer-acc-link" href={instaUrl} target="_blank">Instagram</a>
        </div>
      </div>
      <div class="footer-acc-item">
        <button class="footer-acc-btn" onclick="toggleAcc(this)">
          Ayuda <i class="ri-add-line"></i>
        </button>
        <div class="footer-acc-content">
          <a class="footer-acc-link" href="/politicas">Envíos y entregas</a>
          <a class="footer-acc-link" href="/preguntas-frecuentes">Preguntas frecuentes</a>
          <a class="footer-acc-link" href="/politicas">Política de privacidad</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-copy">© 2025 Nuditos Tejidos · Hecho con 💜 en El Dorado, Meta 🇨🇴</div>
    </div>
  </footer>

  <!-- ════════ CARRITO PREMIUM GLASS ════════ -->
  <div class="cart-overlay fixed inset-0 z-[200] bg-stone-900/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300" id="cartOverlay" onclick="toggleCart()"></div>
  <div class="cart-panel fixed top-0 right-0 w-full max-w-[100vw] md:max-w-md bg-white/70 backdrop-blur-2xl border-l border-white/50 z-[201] translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] flex flex-col shadow-2xl" id="cartPanel">
    <div class="p-4 md:p-6 border-b border-stone-200/60 flex items-center justify-center shrink-0 relative z-10 min-h-[60px] md:min-h-[80px]">
      <span class="font-sans text-xl md:text-2xl font-bold tracking-[0.1em] text-stone-800 uppercase">Carrito</span>
      <button class="absolute right-4 md:right-6 w-10 h-10 rounded-2xl border border-stone-200/60 bg-white/40 shadow-sm flex items-center justify-center hover:bg-white transition-colors" onclick="toggleCart()" aria-label="Cerrar carrito">
        <i class="ri-close-line text-lg flex"></i>
      </button>
    </div>
    
    <div class="flex-1 overflow-y-auto w-full pb-4" id="cartBody"></div>
    
    <div class="p-6 md:p-8 bg-white/40 border-t border-stone-200/50 shrink-0 hidden relative z-10" id="cartFoot">
      <div class="flex flex-col gap-2 mb-6" id="discountWrapper">
        <button class="text-[10px] uppercase tracking-widest text-stone-500 font-bold self-start hover:text-violet-600 transition-colors pb-1 border-b border-dotted border-stone-300/50" onclick="document.getElementById('discountInputContainer').classList.toggle('hidden');">
          ¿Tienes código de descuento?
        </button>
        <div class="hidden flex gap-2 w-full mt-2" id="discountInputContainer">
          <input class="flex-1 bg-white/70 border border-stone-200/60 rounded-2xl px-4 py-3 text-[11px] font-bold focus:border-violet-500 focus:bg-white focus:outline-none uppercase transition-all shadow-sm" id="discountInput" placeholder="INGRESAR CÓDIGO" maxlength="20" />
          <button class="bg-stone-900 text-white px-5 rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:bg-violet-600 transition-all shadow-md active:scale-95" onclick="applyDiscount()">Aplicar</button>
        </div>
        <div class="text-[10px] uppercase font-bold tracking-widest hidden mt-1" id="discountMsg"></div>
      </div>
      
      <div class="hidden flex justify-between text-[11px] font-bold tracking-widest uppercase text-emerald-600 mb-2" id="discSaved">
        <span>Descuento aplicado:</span><span id="discAmount"></span>
      </div>
      
      <div class="flex justify-between items-baseline mb-6">
        <span class="text-[10px] uppercase tracking-[0.2em] font-bold text-stone-500">Total a pagar</span>
        <span class="font-serif text-3xl font-medium text-stone-900" id="cartTotal">$0</span>
      </div>
      
      <div class="flex flex-col gap-3">
        <button class="w-full bg-[#25d366] text-white rounded-2xl py-4 flex items-center justify-center gap-3 hover:bg-[#1da851] hover:scale-[1.02] active:scale-[0.98] transition-all shadow-lg" onclick="checkoutWA()">
          <i class="ri-whatsapp-line text-xl leading-none"></i>
          <span class="text-[11px] font-bold uppercase tracking-[0.1em]">Comprar por WhatsApp</span>
        </button>
        <button class="w-full bg-stone-900 text-white rounded-2xl py-4 flex items-center justify-center gap-3 hover:bg-violet-700 hover:scale-[1.02] active:scale-[0.98] transition-all shadow-lg" onclick="checkoutWompi()">
          <i class="ri-bank-card-line text-lg leading-none"></i>
          <span class="text-[11px] font-bold uppercase tracking-[0.1em]">Pagar con Tarjeta / PSE</span>
        </button>
      </div>
    </div>
    
    <!-- Grabber móvil invisible en la cabecera -->
    <div class="absolute top-0 left-0 w-full h-10 z-[202] md:hidden" id="cartHeaderDrag" style="touch-action: none;"></div>
  </div>

  <style>
    .cart-overlay.open { opacity: 1; pointer-events: auto; }
    .cart-panel.open { transform: translateX(0); }
    .cart-panel { height: calc(100dvh - 68px - env(safe-area-inset-bottom, 0px)); }
    @media (min-width: 768px) { .cart-panel { height: 100dvh; } }

    @keyframes cart-item-in {
      from { opacity: 0; transform: translateY(15px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-cart-item {
      animation: cart-item-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      opacity: 0; /* starts hidden */
    }
  </style>

  <!-- ════════ MODAL PRODUCTO ════════ -->
  <div class="modal-overlay" id="modalOverlay" onclick="closeModal()"></div>
  <div class="modal-panel" id="modalPanel">
    <div class="modal-handle"></div>
    <div class="modal-head">
      <button class="modal-close" onclick="closeModal()" aria-label="Cerrar ventana"><i class="ri-close-line"></i></button>
    </div>
    <div class="modal-body" id="modalBody"></div>
  </div>

  <SearchOverlay />

  <!-- ════════ WHATSAPP FLOTANTE ════════ -->
  <div class="wa-float-wrap">
    <div class="wa-bubble" id="waBubble">¿Tienes dudas? ¡Escríbenos! 🌸</div>
    <a
      href={`${whatsappLink}?text=Hola%20Nuditos!%20Tengo%20una%20pregunta%20🌸`}
      class="wa-float"
      target="_blank"
      aria-label="WhatsApp"
    >
      <i class="ri-whatsapp-line"></i>
    </a>
  </div>

  <div class="toast" id="toast"></div>


  <!-- ════════ SCRIPTS (Diferidos) ════════ -->
  <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" /></noscript>
  <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.css" /></noscript>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Swiper/11.0.5/swiper-bundle.min.js" defer></script>

  <!-- Scripts propios -->
  <script src="/scripts/datos.js" is:inline></script>
  <script src="/scripts/supabase.js" is:inline></script>
  <script src="/scripts/emails.js" is:inline></script>
  <script src="/scripts/app.js" is:inline></script>
  <script src="../scripts/cart-ui.ts"></script>

  <!-- Lógica de Swipe Down para el carrito en Mobile -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const cartDrag = document.getElementById('cartHeaderDrag');
      const cartPanel = document.getElementById('cartPanel');
      if (!cartDrag || !cartPanel) return;

      let startY = 0;
      let currentY = 0;
      let isDragging = false;

      cartDrag.addEventListener('touchstart', (e) => {
        if (window.innerWidth >= 768) return; // Solo móvil
        startY = e.touches[0].clientY;
        isDragging = true;
        cartPanel.style.transition = 'none'; // Quitar transición durante arrastre
      }, {passive: true});

      cartDrag.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        currentY = Math.max(0, e.touches[0].clientY - startY); // Solo arrastre hacia abajo
        cartPanel.style.transform = `translateY(${currentY}px)`;
        e.preventDefault();
      }, {passive: false});

      cartDrag.addEventListener('touchend', () => {
        if (!isDragging) return;
        isDragging = false;
        cartPanel.style.transition = ''; // Restaurar transición CSS

        if (currentY > 80) { // Umbral para cerrar
          // Resetear translateY y cerrar normalmente
          cartPanel.style.transform = ''; 
          if(typeof toggleCart === 'function') toggleCart();
        } else {
          // Rebotar a posición original
          cartPanel.style.transform = '';
        }
        currentY = 0;
      });
    });
  </script>

  <!-- Slot para scripts extra de cada página -->
  <slot name="scripts" />

  <script is:inline define:vars={{ liveConfig: config }}>
    window.NUDITOS_CONFIG = liveConfig;
  </script>
</body>
</html>
