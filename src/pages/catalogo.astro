---
/**
 * Nuditos — Catálogo premium optimizado
 * URL: /catalogo
 * SSR · Cache-Control · Filtros dinámicos · Componentes optimizados
 */
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getLiveProducts, getLiveCategories } from '../lib/supabase';

// Cache-Control para velocidad máxima (1 min fresca, 10 min stale)
Astro.response.headers.set('Cache-Control', 'public, max-age=60, stale-while-revalidate=600');

const SITE_URL  = Astro.site?.toString().replace(/\/$/, '') || Astro.url.origin;

// Pedir datos en paralelo para máxima velocidad
const [allProducts, categories] = await Promise.all([
  getLiveProducts(),
  getLiveCategories()
]);

// Helper para nombres de categoría en tarjetas
const catMap = Object.fromEntries(categories.map(c => [c.id, c.name]));

// Categoría inicial desde URL
const urlCat = Astro.url.searchParams.get('categoria') || 'todos';

const totalProducts = allProducts.length;
const seoTitle   = 'Catálogo Nuditos | Ramos Eternos y Amigurumis';
const seoDesc    = `Explora nuestra colección de ${totalProducts} productos tejidos a mano. Ramos de flores eternas, amigurumis y regalos únicos con envío a toda Colombia.`;
const canonical  = `${SITE_URL}/catalogo`;

// Schema ItemList para SEO
const schemaItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Catálogo Nuditos Tejidos',
  description: seoDesc,
  numberOfItems: totalProducts,
  itemListElement: allProducts.slice(0, 30).map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.name,
      description: p.desc,
      image: p.img || '',
      url: `${SITE_URL}/ramo/${p.slug || ''}`,
      brand: { '@type': 'Brand', name: 'Nuditos Tejidos' },
      offers: {
        '@type': 'Offer',
        priceCurrency: 'COP',
        price: p.price || 0,
        availability: 'https://schema.org/InStock',
      },
    },
  })),
};
---

<Layout
  title={seoTitle}
  description={seoDesc}
  canonical={canonical}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
    <meta name="robots" content="index, follow" />
    <script is:inline set:html={`window.NUDITOS_LIVE_PRODUCTS = ${JSON.stringify(allProducts)};`}></script>
  </Fragment>

  <!-- ══════════════ HEADER COMPACTO ══════════════ -->
  <header class="bg-stone-50 border-b border-stone-200">
    <div class="max-w-[1400px] mx-auto px-4 md:px-8 py-5 md:py-6 flex flex-col md:flex-row items-center justify-between gap-3">
      <div class="text-center md:text-left">
        <nav class="flex items-center justify-center md:justify-start gap-2 text-[9px] uppercase tracking-[0.3em] text-stone-400 font-bold mb-1">
          <a href="/" class="hover:text-stone-800 transition-colors">Inicio</a>
          <span class="opacity-50">/</span>
          <span class="text-stone-700">Catálogo</span>
        </nav>
        <h1 class="font-serif text-2xl md:text-3xl text-stone-900 font-medium tracking-tight">Catálogo Completo</h1>
      </div>
      
      <div class="inline-flex items-center gap-2 bg-white px-4 py-1.5 rounded-full border border-stone-200 shadow-sm text-[9px] font-bold uppercase tracking-widest text-stone-500" id="heroStat">
        <span class="w-1.5 h-1.5 rounded-full bg-violet-500 animate-pulse"></span>
        <span class="text-stone-900" id="heroCount">{totalProducts}</span> Productos
      </div>
    </div>
  </header>

  <!-- ══════════════ BARRA DE FILTROS PREMIUM ══════════════ -->
  <div class="sticky top-[var(--nav-h)] z-[90] bg-white border-b border-stone-100 shadow-sm" id="filterSection">
    <div class="max-w-[1400px] mx-auto px-4 md:px-8">
      <div class="flex flex-col md:flex-row items-stretch md:items-center gap-4 py-3 md:py-4">
        
        <div class="flex items-center gap-2 overflow-x-auto scrollbar-hide py-1 flex-1 -mx-4 px-4 md:mx-0 md:px-0" id="categoryNav">
          <button 
            class:list={["cat-pill", { active: urlCat === 'todos' }]} 
            data-cat="todos"
          >
            Todos
          </button>
          {categories.map(c => (
            <button 
              class:list={["cat-pill", { active: urlCat === c.id }]} 
              data-cat={c.id}
            >
              <span class="text-base mr-1 drop-shadow-sm">{c.icon}</span> 
              <span class="truncate max-w-[120px]">{c.name}</span>
            </button>
          ))}
        </div>

        <div class="flex items-center gap-3 border-t md:border-t-0 border-stone-100 pt-3 md:pt-0">
          <div class="relative group flex-1 md:w-48">
            <i class="ri-search-line absolute left-3 top-1/2 -translate-y-1/2 text-stone-400 text-sm group-focus-within:text-violet-500 transition-colors"></i>
            <input
              type="text"
              id="catSearch"
              placeholder="¿Qué buscas?"
              class="w-full bg-stone-50 border border-stone-200 rounded-full py-2 pl-9 pr-4 text-xs font-sans focus:bg-white focus:border-stone-300 focus:outline-none transition-all shadow-inner"
            />
          </div>

          <div class="relative">
            <select id="catSort" class="appearance-none bg-stone-900 text-white rounded-full py-2 pl-4 pr-9 text-[9px] font-bold uppercase tracking-widest cursor-pointer hover:bg-stone-800 transition-colors focus:outline-none shadow-sm">
              <option value="default">Relevancia</option>
              <option value="price-asc">Precio: Bajo a Alto</option>
              <option value="price-desc">Precio: Alto a Bajo</option>
              <option value="name-asc">Nombre: A-Z</option>
            </select>
            <i class="ri-arrow-down-s-line absolute right-3 top-1/2 -translate-y-1/2 text-white/50 pointer-events-none text-sm"></i>
          </div>
        </div>
      </div>

      <div id="activeFilters" class="hidden py-3 flex-wrap gap-2 border-t border-stone-50">
        <span class="text-[9px] uppercase tracking-widest text-stone-400 font-bold mr-2 self-center">Filtros:</span>
        <div id="chipsContainer" class="flex flex-wrap gap-2"></div>
        <button id="clearAll" class="text-[9px] uppercase tracking-widest text-violet-600 font-bold hover:underline ml-auto">
          Limpiar Todo
        </button>
      </div>
    </div>
  </div>

  <!-- ══════════════ GRID DE PRODUCTOS ══════════════ -->
  <main class="max-w-[1400px] mx-auto px-4 md:px-8 py-8 md:py-12">
    <div class="flex items-center justify-between mb-6" id="gridHeader">
      <h2 class="text-[10px] uppercase tracking-[0.4em] text-stone-400 font-bold">
        Mostrando <span class="text-stone-800" id="resultCount">{totalProducts}</span> Productos
      </h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 md:gap-6" id="catalogGrid">
      {allProducts.map(p => (
        <ProductCard p={p} catName={catMap[p.cat]} class="product-item" />
      ))}
    </div>

    <div id="emptyState" class="hidden py-16 text-center space-y-6">
      <div class="text-6xl grayscale opacity-20">🧶</div>
      <div class="space-y-2">
        <h3 class="font-serif text-2xl text-stone-800 font-light">No encontramos coincidencia</h3>
        <p class="text-stone-400 text-sm">Prueba borrando los filtros activos.</p>
      </div>
      <button onclick="resetFilters()" class="bg-stone-900 text-white px-8 py-3 rounded-full text-[10px] font-bold uppercase tracking-widest hover:bg-violet-700 transition-all shadow-lg active:scale-95">
        Quitar Filtros
      </button>
    </div>
  </main>
</Layout>

<style>
  /* Ocultar barra de scroll en contedores específicos */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }

  /* Nuevos Chips de Categoria */
  .cat-pill {
    @apply flex-shrink-0 flex items-center justify-center px-4 py-2 rounded-full text-[11px] font-medium tracking-wide text-stone-500 bg-stone-50 border border-stone-200/60 shadow-sm transition-all whitespace-nowrap select-none;
  }
  .cat-pill:hover {
    @apply bg-white text-stone-800 border-stone-300 shadow-md transform -translate-y-px;
  }
  .cat-pill.active {
    @apply bg-stone-900 text-white border-stone-900 shadow-md px-5 font-bold;
  }

  .active-chip {
    @apply flex items-center gap-2 bg-stone-50 text-stone-700 px-3 py-1.5 rounded-full text-[10px] font-medium border border-stone-200 transition-all;
  }
  
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .product-item {
    animation: fadeUp 0.6s cubic-bezier(0.23, 1, 0.32, 1) forwards;
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    // Remove accents and lowercase
    function normalizeStr(str) {
      if (!str) return '';
      return String(str).normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase().trim();
    }

    let catActive   = normalizeStr(new URLSearchParams(window.location.search).get('categoria') || 'todos');
    let searchQuery = '';
    let sortMode    = 'default';

    const grid      = document.getElementById('catalogGrid');
    const items     = grid?.querySelectorAll('.product-item');
    const empty     = document.getElementById('emptyState');
    const countEl   = document.getElementById('resultCount');
    const heroCount = document.getElementById('heroCount');
    const chipsBox  = document.getElementById('chipsContainer');
    const chipsWrap = document.getElementById('activeFilters');

    function applyFilters() {
      if (!grid || !items) return;
      let visibleCount = 0;
      
      const q = normalizeStr(searchQuery);
      // Dividimos la búsqueda en palabras sueltas "Ramo oso" -> ["ramo", "oso"]
      const queryTokens = q.split(/\s+/).filter(Boolean);

      const visibleItems = [];

      items.forEach(item => {
        const cat  = normalizeStr(item.dataset.cat);
        // data-search fue pre-compilado con nombre + descripcion + categoria
        const searchPool = normalizeStr(item.dataset.search);
        
        let show = true;
        if (catActive !== 'todos' && cat !== catActive) show = false;
        
        // Algoritmo: Cada palabra escrita debe existir en la tarjeta de alguna forma
        if (show && queryTokens.length > 0) {
          show = queryTokens.every(token => searchPool.includes(token));
        }
        
        // FOOLPROOF DISPLAY MANIPULATION OVERRIDING TAILWIND FLEX
        if (show) {
          item.style.display = '';
          visibleCount++;
          visibleItems.push(item);
        } else {
          item.style.display = 'none';
        }
      });

      if (sortMode === 'price-asc') {
        visibleItems.sort((a, b) => (parseFloat(a.dataset.price) || 0) - (parseFloat(b.dataset.price) || 0));
      } else if (sortMode === 'price-desc') {
        visibleItems.sort((a, b) => (parseFloat(b.dataset.price) || 0) - (parseFloat(a.dataset.price) || 0));
      } else if (sortMode === 'name-asc') {
        visibleItems.sort((a, b) => (a.dataset.name || '').localeCompare(b.dataset.name || ''));
      }

      visibleItems.forEach(i => grid.appendChild(i));
      
      if (countEl) countEl.textContent = visibleCount;
      if (heroCount) heroCount.textContent = visibleCount;
      if (empty) empty.style.display = visibleCount === 0 ? 'block' : 'none';
      if (grid) grid.style.display = visibleCount === 0 ? 'none' : 'grid';
      
      updateChips();
    }

    function updateChips() {
      if (!chipsBox || !chipsWrap) return;
      const active = [];
      if (catActive !== 'todos') {
        const pill = document.querySelector(`.cat-pill[data-cat="${catActive}"]`);
        active.push({ id: 'cat', label: (pill ? pill.textContent.trim() : catActive).toUpperCase() });
      }
      if (searchQuery) active.push({ id: 'search', label: `"${searchQuery}"` });
      
      chipsWrap.style.display = active.length === 0 ? 'none' : 'flex';
      chipsBox.innerHTML = active.map(a => `
        <span class="active-chip">
          ${a.label}
          <button onclick="window.removeFilter('${a.id}')" class="hover:text-rose-500 transition-colors px-1"><i class="ri-close-line"></i></button>
        </span>
      `).join('');
    }

    window.removeFilter = (id) => {
      if (id === 'cat') { catActive = 'todos'; syncPills(); history.replaceState(null, '', location.pathname); }
      if (id === 'search') { searchQuery = ''; document.getElementById('catSearch').value = ''; }
      applyFilters();
    };

    window.resetFilters = () => {
      catActive = 'todos'; searchQuery = ''; sortMode = 'default';
      const sInput = document.getElementById('catSearch');
      if (sInput) sInput.value = '';
      const sSort = document.getElementById('catSort');
      if (sSort) sSort.value = 'default';
      syncPills();
      history.replaceState(null, '', location.pathname);
      applyFilters();
    };

    function syncPills() {
      document.querySelectorAll('.cat-pill').forEach(p => {
        const isAct = normalizeStr(p.dataset.cat) === catActive;
        p.classList.toggle('active', isAct);
      });
    }

    document.querySelectorAll('.cat-pill').forEach(p => {
      p.addEventListener('click', () => {
        catActive = normalizeStr(p.dataset.cat || 'todos');
        syncPills();
        applyFilters();
        const url = catActive === 'todos' ? location.pathname : `${location.pathname}?categoria=${catActive}`;
        history.replaceState(null, '', url);
        window.scrollTo({ top: document.getElementById('filterSection').offsetTop - 100, behavior: 'smooth' });
      });
    });

    let searchTimeout;
    const catSearchNode = document.getElementById('catSearch');
    if (catSearchNode) {
      catSearchNode.addEventListener('input', (e) => { 
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          searchQuery = e.target.value; 
          applyFilters(); 
        }, 150); 
      });
      if (catSearchNode.value) { searchQuery = catSearchNode.value; }
    }

    document.getElementById('catSort')?.addEventListener('change', (e) => { sortMode = e.target.value; applyFilters(); });
    document.getElementById('clearAll')?.addEventListener('click', resetFilters);

    /* ── Lógica de Carrusel Dots y Drag-to-Scroll ── */
    const carousels = document.querySelectorAll('[id^="carousel-"]');
    carousels.forEach(car => {
      car.addEventListener('scroll', () => {
        const idx = Math.round(car.scrollLeft / car.offsetWidth);
        const dots = car.parentElement.querySelectorAll('[data-idx]');
        dots.forEach(d => {
          const isAct = parseInt(d.dataset.idx) === idx;
          d.classList.toggle('bg-white', isAct);
          d.classList.toggle('bg-white/40', !isAct);
          d.classList.toggle('w-4', isAct);
          d.classList.toggle('w-1', !isAct);
        });
      }, { passive: true });

      car.querySelectorAll('img').forEach(img => img.setAttribute('draggable', 'false'));

      let isDown = false;
      let startX;
      let scrollLeft;
      let dragged = false;

      car.addEventListener('mousedown', (e) => {
        isDown = true;
        dragged = false;
        car.classList.add('cursor-grabbing');
        startX = e.pageX - car.offsetLeft;
        scrollLeft = car.scrollLeft;
      });
      
      car.addEventListener('mouseleave', () => {
        isDown = false;
        car.classList.remove('cursor-grabbing');
      });
      
      car.addEventListener('mouseup', () => {
        isDown = false;
        car.classList.remove('cursor-grabbing');
      });
      
      car.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - car.offsetLeft;
        const walk = (x - startX) * 1.5;
        if (Math.abs(walk) > 5) dragged = true;
        car.scrollLeft = scrollLeft - walk;
      });
      
      car.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', (e) => {
          if (dragged) {
            e.preventDefault();
            e.stopPropagation();
          }
        });
      });
    });

    if (catActive !== 'todos' || searchQuery) { applyFilters(); syncPills(); }
  });
</script>

<script is:inline define:vars={{ allProducts }}>
  // Asegurar que el carrito conozca todos los productos del catálogo
  window.NUDITOS_LIVE_PRODUCTS = [
    ...(allProducts || []),
    ...(window.NUDITOS_LIVE_PRODUCTS || [])
  ];
</script>
