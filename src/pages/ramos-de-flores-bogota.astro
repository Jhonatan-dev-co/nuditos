---
import PremiumLanding from '../components/PremiumLanding.astro';
import { CITY_LANDINGS } from '../data/seo-landings';
export const prerender = false;

const config = CITY_LANDINGS['ramos-de-flores-bogota'];
---
<PremiumLanding
  seoTitle={config.title}
  seoDesc={config.description}
  seoKeywords={config.keywords}
  eyebrow={`Flores Eternas en ${config.city}`}
  h1={config.h1.split(' en ')[0]}
  h1Em={`en ${config.city}`}
  heroCopy={config.heroCopy}
  ctaWaText={`Hola Nuditos! 🌸 Quiero un ramo de flores en ${config.city}`}
  productKeywords={["ramo", "rosa", "flor", "crochet"]}
  collectionTitle={`Flores Disponibles en ${config.city}`}
  isCityPage={true}
  city={config.city}
  relatedLinks={config.relatedLinks}
  faq={config.localFaq}
  ctaFinalTitle={`¿Te enviamos flores a <em class='italic text-violet-600 font-normal'>${config.city}?</em>`}
  ctaFinalCopy="Escríbenos y coordinamos tu detalle hecho a mano ahora mismo."
  ctaTags={[`📍 ${config.city}`, "🌸 Ramos tejidos", "🎁 Empaque especial", "🚚 Envío coordinado"]}
/>