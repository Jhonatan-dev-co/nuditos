    window.toggleCatHome = async function(id) {
      const idx = adminCategories.findIndex(c => c.id === id);
      if (idx === -1) return;
      adminCategories[idx].showInHome = (adminCategories[idx].showInHome === false ? true : false);
      showToast(`${adminCategories[idx].showInHome ? '✅ Visible' : '🙈 Oculto'} en Home`);
      renderVitrinaCategories();
      await sbAdminSaveCategory(adminCategories[idx], false);
      renderBannerList(); // Para actualizar los dropdows de banners
    }

    window.moveCat = async function(id, direction) {
      const sorted = [...adminCategories].filter(c => c.id !== 'todos').sort((a,b) => (a.orden||0) - (b.orden||0));
      const idx = sorted.findIndex(c => c.id === id);
      if (idx === -1) return;
      const targetIdx = idx + direction;
      if (targetIdx < 0 || targetIdx >= sorted.length) return;
      
      const current = sorted[idx];
      const target = sorted[targetIdx];
      
      // Swap orden values
      const temp = current.orden;
      current.orden = target.orden;
      target.orden = temp;
      
      // Si son iguales o faltan, forzar correlativo
      if (current.orden === target.orden) {
        current.orden = idx + direction + 1;
        target.orden = idx + 1;
      }

      showToast('⏳ Sincronizando orden...');
      renderVitrinaCategories();
      
      await sbAdminSaveCategory(current, false);
      await sbAdminSaveCategory(target, false);
      
      renderVitrinaCategories();
      renderBannerList();
    }

