    function openNewPedido(){document.getElementById('pedidoEditId').value='';document.getElementById('pedidoModalTitle').textContent='Nuevo pedido';['pCliente','pEmail','pTel','pItems','pTotal','pNotas','pTrans','pGuia'].forEach(id=>document.getElementById(id).value='');document.getElementById('pEstado').value='pendiente';document.getElementById('pedidoModal').classList.add('open');}
    function openEditPedido(id){const p=pedidos.find(x=>x.id===id);if(!p)return;document.getElementById('pedidoEditId').value=p.id;document.getElementById('pCliente').value=p.cliente||'';document.getElementById('pEmail').value=p.clienteEmail||'';document.getElementById('pTel').value=p.tel||'';document.getElementById('pItems').value=p.items||'';document.getElementById('pTotal').value=p.total||'';document.getElementById('pEstado').value=p.estado||'pendiente';document.getElementById('pNotas').value=p.notas||'';document.getElementById('pTrans').value=p.transportadora||'';document.getElementById('pGuia').value=p.guia||'';document.getElementById('pedidoModal').classList.add('open');}
    function closePedidoModal(){document.getElementById('pedidoModal').classList.remove('open');}
    async function savePedido(){
      const editId=document.getElementById('pedidoEditId').value;
      const data={cliente:document.getElementById('pCliente').value.trim(),clienteEmail:document.getElementById('pEmail').value.trim(),tel:document.getElementById('pTel').value.trim(),items:document.getElementById('pItems').value.trim(),total:parseInt(document.getElementById('pTotal').value)||0,estado:document.getElementById('pEstado').value,notas:document.getElementById('pNotas').value.trim(),transportadora:document.getElementById('pTrans').value.trim(),guia:document.getElementById('pGuia').value.trim()};
      if(!data.cliente)return;
      const oldPedido = editId ? pedidos.find(x=>x.id===parseInt(editId)) : null;
      try{
        if(editId){
          await sbAdminSavePedido({...data,id:parseInt(editId),_isNew:false});
          const idx=pedidos.findIndex(p=>p.id===parseInt(editId));
          if(idx!==-1)pedidos[idx]={...pedidos[idx],...data,id:parseInt(editId)};
          
          if (data.estado === 'entregado' && data.guia && oldPedido?.estado !== 'entregado') {
             triggerEnvioEmail(pedidos[idx]);
          }
        }
        else{const saved=await sbAdminSavePedido({...data,_isNew:true});if(saved)pedidos.unshift(saved);}
        closePedidoModal();renderPedidosList();showToast('✓ Pedido guardado');
      }catch{showToast('❌ Error');}
    }
    async function cambiarEstadoPedido(id,estado){
      const idx=pedidos.findIndex(p=>p.id===id);if(idx===-1)return;
      const p = pedidos[idx];
      try{
        await sbAdminUpdateEstadoPedido(id,estado);
        const oldEstado = p.estado;
        p.estado=estado;
        renderPedidosList();
        showToast('✓ Estado actualizado');
        
        if (estado === 'entregado' && p.guia && oldEstado !== 'entregado') {
          triggerEnvioEmail(p);
        }
      }catch{showToast('❌ Error');}
    }

    async function triggerEnvioEmail(p) {
      if (!p.clienteEmail) {
        showToast('ℹ️ El pedido no tiene email del cliente');
        return;
      }
      showToast('📧 Enviando notificación de envío...');
      const success = await typeof correoPedidoEnviado === 'function' && correoPedidoEnviado({
        clienteEmail: p.clienteEmail,
        clienteNombre: p.cliente,
        guia: p.guia,
        transportadora: p.transportadora
      });
      if (success) showToast('✅ Correo de envío enviado');
    }

    function copyCustomerEmails() {
      const emails = [...new Set(pedidos.map(p => p.clienteEmail).filter(e => e && e.includes('@')))];
      if (emails.length === 0) { showToast('No hay emails guardados'); return; }
      const blob = emails.join(', ');
      navigator.clipboard.writeText(blob).then(() => {
        showToast(`📋 ${emails.length} emails copiados para Remarketing`);
      });
    }
