        `;
      };

      document.getElementById('editorialBannersList').innerHTML = editorialList.map(b => buildCard(b)).join('') || '<div style="padding:1rem; text-align:center; color:#999; font-size: 0.8rem;">No hay banners de inicio</div>';
      document.getElementById('bannerList').innerHTML = collectionsList.map(b => buildCard(b)).join('') || '<div style="padding:1rem; text-align:center; color:#999; font-size: 0.8rem;">No hay banners de categoría — ¡Agrega uno!</div>';
    }
    window.updateBanner = function(i,key,val){ 
      editorialBannersAdmin[i][key]=val; 
    };
    window.updateBannerMedia = function(i, val, type = 'desktop') {
      console.log(`[Banner] Intento de actualización de media en banner ${i} (${type}): ${val}`);
      
      const imgKey = type === 'desktop' ? 'imgUrl' : 'mobileImgUrl';
      const videoKey = type === 'desktop' ? 'videoUrl' : 'mobileVideoUrl';

      if (!val) {
        editorialBannersAdmin[i][videoKey] = '';
        editorialBannersAdmin[i][imgKey] = '';
        renderBannerList();
        return;
      }

      const isVideo = val.toLowerCase().endsWith('.mp4') || val.includes('/video/') || val.includes('video-upload');
      
      if (isVideo) {
        let cleanVideo = val.replace('/image/upload/', '/video/upload/');
        if (!cleanVideo.toLowerCase().endsWith('.mp4') && cleanVideo.includes('cloudinary')) {
          cleanVideo += '.mp4';
        }
        editorialBannersAdmin[i][videoKey] = cleanVideo;
        editorialBannersAdmin[i][imgKey] = '';
      } else {
        editorialBannersAdmin[i][imgKey] = val;
        if (!editorialBannersAdmin[i][videoKey]) {
           editorialBannersAdmin[i][videoKey] = '';
        }
      }
      renderBannerList();
    };
    window.removeBanner = function(i){ 
      editorialBannersAdmin.splice(i,1); 
      renderBannerList(); 
    };
    window.uploadBannerImg = async function(i, files, type = 'desktop') {
      if(!files.length) return;
      const file = files[0];
      const imgKey = type === 'desktop' ? 'imgUrl' : 'mobileImgUrl';
      const videoKey = type === 'desktop' ? 'videoUrl' : 'mobileVideoUrl';
      const bTitle = slugify(editorialBannersAdmin[i].title) || 'fondo-portada';
      const url = await uploadToCloudinary(file, bTitle + (type === 'mobile' ? '-movil' : '-web'), 0);
      if(url) {
        if (file.type.startsWith('video/')) {
          editorialBannersAdmin[i][videoKey] = url;
          editorialBannersAdmin[i][imgKey] = '';
          showToast(`🎬 Video (${type}) subido`);
        } else {
          editorialBannersAdmin[i][imgKey] = url;
          editorialBannersAdmin[i][videoKey] = '';
        }
        renderBannerList();
      }
    };
    window.addNewBanner = function() {
      editorialBannersAdmin.push({ title: '', afterCat: '', imgUrl: '', videoUrl: '', mobileImgUrl: '', mobileVideoUrl: '', subtitle: '', ctaText: '', ctaUrl: '/catalogo' });
      renderBannerList();
    };
    function renderCatViewsList(){ document.getElementById('catViewsList').innerHTML=categories.filter(c=>c.id!=='todos').map(c=>`<div>${c.name}</div>`).join(''); }

    /* ── D&D ORDEN CUSTOM ── */
    let draggedRow = null;
    window.renderSortableList = function() {
      const cat = document.getElementById('sortCatFilter')?.value || 'todos';
      const list = document.getElementById('sortableCatalogList');
      if(!list) return;

      const items = [...adminProducts]
        .filter(p => p.activo !== false && (cat === 'todos' || (p.cats||[]).includes(cat) || p.cat === cat))
        .sort((a,b) => (a.orden||0) - (b.orden||0) || (b.id - a.id));

      if (items.length === 0) {
        list.innerHTML = '<div style="padding:10px;text-align:center;color:#999;font-size:0.8rem;">No hay productos en esta categoría</div>';
        return;
      }

      list.innerHTML = items.map((p, i) => `
        <div class="v-prod-row sortable-item" draggable="true" data-id="${p.id}" data-orden="${i}" style="cursor:grab; background:#fff; margin-bottom:4px; padding:8px; border-radius:6px; border:1px solid var(--border); display:flex; align-items:center;">
          <div style="margin-right:10px; opacity:0.3; cursor:grab;">☰</div>
          <img src="${p.img||''}" style="width:30px;height:30px;border-radius:4px;object-fit:cover;margin-right:10px;background:#eee">
          <div class="v-info" style="flex:1;">
            <div style="font-weight:600; font-size:0.85rem">${p.name}</div>
            <div style="font-size:0.65rem; color:#999; text-transform:uppercase">${p.cats?.join(', ') || p.cat || 'General'}</div>
          </div>
          <div style="font-size:0.7rem; color:var(--lila); font-weight:bold">Orden: ${p.orden||0}</div>
        </div>
      `).join('');

      // Add Native Drag Events
      const rows = list.querySelectorAll('.sortable-item');
      rows.forEach(row => {
        row.addEventListener('dragstart', function(e) {
          draggedRow = this;
          e.dataTransfer.effectAllowed = 'move';
          setTimeout(() => this.style.opacity = '0.4', 0);
        });
        row.addEventListener('dragover', function(e) {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
        });
        row.addEventListener('dragenter', function(e) { this.style.border = '1px dashed var(--lila)'; });
        row.addEventListener('dragleave', function(e) { this.style.border = '1px solid var(--border)'; });
        row.addEventListener('drop', function(e) {
          e.stopPropagation();
          this.style.border = '1px solid var(--border)';
          if (draggedRow !== this) {
            const allItems = Array.from(list.children);
            const draggedIdx = allItems.indexOf(draggedRow);
            const thisIdx = allItems.indexOf(this);
            if (draggedIdx < thisIdx) {
              list.insertBefore(draggedRow, this.nextSibling);
            } else {
              list.insertBefore(draggedRow, this);
            }
          }
          return false;
        });
        row.addEventListener('dragend', function() {
          this.style.opacity = '1';
          rows.forEach(r => r.style.border = '1px solid var(--border)');
          draggedRow = null;
        });
      });
    }

    window.saveCatalogOrder = async function() {
      const btn = document.getElementById('saveOrderBtn');
      if(btn) { btn.disabled = true; btn.textContent = '⏳ Guardando...'; }
      const items = Array.from(document.querySelectorAll('#sortableCatalogList .sortable-item'));
      let err=0;
      
      showToast(`⏳ Guardando orden de ${items.length} productos...`);
      for (let i = 0; i < items.length; i++) {
        const item = items[i];
        const id = parseInt(item.dataset.id);
        const newOrden = i + 1; // 1-based order
        const pIdx = adminProducts.findIndex(p => p.id === id);
        if (pIdx !== -1 && adminProducts[pIdx].orden !== newOrden) {
           adminProducts[pIdx].orden = newOrden;
           try {
             await sbAdminSaveProduct({ ...adminProducts[pIdx], _isNew: false });
           } catch { err++; }
        }
      }
      showToast(err ? `⚠️ Guardado con ${err} errores` : '✅ Orden guardado con éxito');
      if(btn) { btn.disabled = false; btn.textContent = '💾 Guardar Orden'; }
      renderSortableList(); // refresh UI
    }

    async function saveConfig(){
      const pixelId = document.getElementById('seoMetaPixelId')?.value.trim() || document.getElementById('metaPixelId')?.value.trim();
      const pixelActivo = document.getElementById('toggleMetaPixelSEO')?.classList.contains('on') || document.getElementById('toggleMetaPixel')?.classList.contains('on');

      const newCfg={
        ramoDestacado:momentoSelection,
        carruselHero:heroSelection,
        seleccionNuditos:seleccionSelection,
        descuentoActivo:document.getElementById('toggleDescuento').classList.contains('on'),

        descuentoCodigo:document.getElementById('descCodigo').value.trim(),
        descuentoPorcentaje:parseInt(document.getElementById('descPorcentaje').value)||10,
        descuentoTexto:document.getElementById('descTexto').value.trim(),
        wompiActivo:document.getElementById('toggleWompi').classList.contains('on'),
        wompiKey:document.getElementById('wompiKey').value.trim(),
        wompiIntegrity:document.getElementById('wompiIntegrity').value.trim(),
        wompiEvents:document.getElementById('wompiEvents').value.trim(),
        metaPixelActivo: pixelActivo,
        metaPixelId: pixelId,
        socialProofMode: document.getElementById('socialProofMode')?.value || 'trust_badges',
        catViews:{},
        seoTitle: document.getElementById('seoTitle')?.value.trim() || '',
        seoDescription: document.getElementById('seoDescription')?.value.trim() || '',
        seoOgImage: document.getElementById('seoOgImage')?.value.trim() || '',
        socialInstagram: document.getElementById('socialInsta')?.value.trim() || '',
        socialWhatsapp: document.getElementById('socialWhasapp')?.value.trim() || '',
        gaId: document.getElementById('seoGAId')?.value.trim() || '',
        gaActive: !!document.getElementById('toggleGASEO')?.classList.contains('on')
      };
      try{ await sbAdminSaveConfig(newCfg); await sbAdminSaveBanners(editorialBannersAdmin); showToast('✅ Guardado'); }catch{ showToast('❌ Error');}
    }
    function showToast(msg){ const t=document.getElementById('toastAdmin'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2000); }

    /* ══════════════════════════════════════════
       SISTEMA DE CAMPAÑAS TEMPORALES
       Usa localStorage para persistencia ligera.
       No requiere tabla nueva en Supabase.
       ══════════════════════════════════════════ */

    function loadCampaigns() {
      try {
        const saved = localStorage.getItem('nuditos_campaigns');
        adminCampaigns = saved ? JSON.parse(saved) : [];
      } catch { adminCampaigns = []; }
    }

    function saveCampaignsToStorage() {
      localStorage.setItem('nuditos_campaigns', JSON.stringify(adminCampaigns));
    }

    function getCampaignStatus(camp) {
      if (!camp.fechaInicio && !camp.fechaFin) return 'draft';
      const now = new Date();
      const start = camp.fechaInicio ? new Date(camp.fechaInicio + 'T00:00:00') : null;
      const end   = camp.fechaFin   ? new Date(camp.fechaFin   + 'T23:59:59') : null;
      if (start && now < start) return 'upcoming';
      if (end && now > end) return 'expired';
      return 'active';
    }

    function getActiveCampaign() {
      return adminCampaigns.find(c => getCampaignStatus(c) === 'active') || null;
    }

    function renderCampaignsList() {
      loadCampaigns();
      const active = getActiveCampaign();

      // Estado actual
      const statusEl = document.getElementById('activeCampaignStatus');
      if (statusEl) {
        if (active) {
          statusEl.innerHTML = `
            <div style="display:flex; align-items:center; gap:10px; justify-content:center; flex-wrap:wrap;">
              <span style="font-size:1.5rem">${active.emoji || '🎪'}</span>
              <div style="text-align:left;">
                <div style="font-weight:700; color: ${active.color || '#6d28d9'}; font-size:0.9rem;">${active.nombre}</div>
                <div style="color:#666; font-size:0.75rem;">Activa hasta: ${active.fechaFin || 'sin fin'} · ${active.bannerMsg ? '"' + active.bannerMsg + '"' : 'Sin banner'}</div>
              </div>
              <span style="background:#d1fae5; color:#065f46; font-size:0.65rem; font-weight:700; padding:4px 12px; border-radius:99px;">✅ ACTIVA AHORA</span>
            </div>`;
        } else {
          statusEl.innerHTML = `<span style="color:#aaa;">⚡ No hay campaña activa en este momento.</span>`;
        }
      }

      // Poblar select de categorías en el editor
      const catSel = document.getElementById('campCatDestacada');
      if (catSel && catSel.options.length <= 1) {
        adminCategories.filter(c => c.id !== 'todos').forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.id;
          opt.textContent = `${c.icon || '🌸'} ${c.nombre || c.name}`;
          catSel.appendChild(opt);
        });
      }

      // Lista de campañas
      const listEl = document.getElementById('campaignsList');
      if (!listEl) return;

      const statusLabels = {
        active:   { text: '✅ Activa', cls: 'camp-status-active' },
        upcoming: { text: '⏰ Próxima', cls: 'camp-status-upcoming' },
        expired:  { text: '⌛ Expirada', cls: 'camp-status-expired' },
        draft:    { text: '📝 Borrador', cls: 'camp-status-draft' },
      };

      if (!adminCampaigns.length) {
        listEl.innerHTML = `
          <div style="text-align:center; padding:3rem; color:#bbb;">
            <div style="font-size:3rem; margin-bottom:1rem;">🎪</div>
            <div style="font-weight:600; margin-bottom:0.5rem;">Aún no tienes campañas</div>
            <div style="font-size:0.8rem;">Crea tu primera campaña para el Día de la Madre, Black Friday, etc.</div>
          </div>`;
        return;
      }

      listEl.innerHTML = adminCampaigns.map((camp, i) => {
        const status = getCampaignStatus(camp);
        const lbl = statusLabels[status];
        return `
          <div class="campaign-card ${status === 'active' ? 'active-camp' : ''}">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:0.75rem;">
              <div style="display:flex; align-items:center; gap:12px;">
                <div style="font-size:2rem; width:48px; height:48px; border-radius:50%; background: ${camp.color || '#6d28d9'}22; display:flex; align-items:center; justify-content:center;">${camp.emoji || '🎪'}</div>
                <div>
                  <div style="font-weight:700; font-size:0.9rem; margin-bottom:2px;">${camp.nombre}</div>
                  <div style="font-size:0.72rem; color:#888;">${camp.fechaInicio || '—'} → ${camp.fechaFin || '—'}</div>
                  ${camp.descCodigo ? `<div style="font-size:0.7rem; color:#6d28d9; font-weight:600; margin-top:3px;">🏷️ ${camp.descCodigo} (${camp.descPct || 0}% OFF)</div>` : ''}
                </div>
              </div>
              <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                <span class="camp-badge-status ${lbl.cls}">${lbl.text}</span>
                <button onclick="editCampaign(${i})" style="background:#f3f4f6; border:none; padding:7px 14px; border-radius:10px; cursor:pointer; font-size:0.8rem; font-weight:600;">✏️ Editar</button>
                <button onclick="deleteCampaign(${i})" style="background:#fee2e2; color:#dc2626; border:none; padding:7px 14px; border-radius:10px; cursor:pointer; font-size:0.8rem; font-weight:600;">🗑️</button>
              </div>
            </div>
            ${camp.bannerMsg ? `<div style="margin-top:0.8rem; background:#f8f9fa; border-radius:0.8rem; padding:0.6rem 1rem; font-size:0.78rem; color:#444; border-left:3px solid ${camp.color || '#6d28d9'};">📢 ${camp.bannerMsg}</div>` : ''}
          </div>`;
      }).join('');
    }

    function newCampaign() {
      document.getElementById('campEditId').value = '';
      document.getElementById('campaignEditorTitle').textContent = 'Nueva Campaña';
      document.getElementById('campNombre').value = '';
      document.getElementById('campEmoji').value = '🌸';
      document.getElementById('campColor').value = '#ec4899';
      document.getElementById('campFechaInicio').value = '';
      document.getElementById('campFechaFin').value = '';
      document.getElementById('campBannerMsg').value = '';
      document.getElementById('campDescCodigo').value = '';
      document.getElementById('campDescPct').value = '10';
      document.getElementById('campBadge').value = '';
      document.getElementById('campCatDestacada').value = '';
      document.getElementById('campBannerTitle').value = '';
      document.getElementById('campBannerSubtitle').value = '';
      document.getElementById('campBannerImg').value = '';
      document.getElementById('campBannerCta').value = '/catalogo';
      document.querySelectorAll('.color-chip').forEach(b => b.classList.remove('active'));
      document.querySelector('.color-chip[data-color="#ec4899"]')?.classList.add('active');
      updateCampPreview();
      document.getElementById('campaignEditor').style.display = 'block';
      document.getElementById('campaignEditor').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function editCampaign(idx) {
      const camp = adminCampaigns[idx];
      if (!camp) return;
      document.getElementById('campEditId').value = idx;
      document.getElementById('campaignEditorTitle').textContent = 'Editar Campaña';
      document.getElementById('campNombre').value = camp.nombre || '';
      document.getElementById('campEmoji').value = camp.emoji || '🌸';
      document.getElementById('campColor').value = camp.color || '#ec4899';
      document.getElementById('campFechaInicio').value = camp.fechaInicio || '';
      document.getElementById('campFechaFin').value = camp.fechaFin || '';
      document.getElementById('campBannerMsg').value = camp.bannerMsg || '';
      document.getElementById('campDescCodigo').value = camp.descCodigo || '';
      document.getElementById('campDescPct').value = camp.descPct || 10;
      document.getElementById('campBadge').value = camp.badge || '';
      document.getElementById('campCatDestacada').value = camp.catDestacada || '';
      document.getElementById('campBannerTitle').value = camp.bannerTitle || '';
      document.getElementById('campBannerSubtitle').value = camp.bannerSubtitle || '';
      document.getElementById('campBannerImg').value = camp.bannerImg || '';
      document.getElementById('campBannerCta').value = camp.bannerCta || '/catalogo';
      // Seleccionar el color correcto
      document.querySelectorAll('.color-chip').forEach(b => {
        b.classList.toggle('active', b.dataset.color === (camp.color || '#ec4899'));
        b.style.setProperty('--c-color', b.dataset.color);
      });
      updateCampPreview();
      document.getElementById('campaignEditor').style.display = 'block';
      document.getElementById('campaignEditor').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function deleteCampaign(idx) {
      const camp = adminCampaigns[idx];
      if (!confirm(`¿Eliminar la campaña "${camp?.nombre}"?`)) return;
      adminCampaigns.splice(idx, 1);
      saveCampaignsToStorage();
      renderCampaignsList();
      showToast('🗑️ Campaña eliminada');
    }

    function closeCampaignEditor() {
      document.getElementById('campaignEditor').style.display = 'none';
    }

    function saveCampaign() {
      const nombre = document.getElementById('campNombre').value.trim();
      if (!nombre) { showToast('⚠️ El nombre es obligatorio'); return; }

      const camp = {
        nombre,
        emoji:          document.getElementById('campEmoji').value.trim() || '🎪',
        color:          document.getElementById('campColor').value || '#ec4899',
        fechaInicio:    document.getElementById('campFechaInicio').value || '',
        fechaFin:       document.getElementById('campFechaFin').value || '',
        bannerMsg:      document.getElementById('campBannerMsg').value.trim(),
        descCodigo:     document.getElementById('campDescCodigo').value.trim().toUpperCase(),
        descPct:        parseInt(document.getElementById('campDescPct').value) || 0,
        badge:          document.getElementById('campBadge').value,
        catDestacada:   document.getElementById('campCatDestacada').value,
        bannerTitle:    document.getElementById('campBannerTitle').value.trim(),
        bannerSubtitle: document.getElementById('campBannerSubtitle').value.trim(),
        bannerImg:      document.getElementById('campBannerImg').value.trim(),
        bannerCta:      document.getElementById('campBannerCta').value.trim() || '/catalogo',
        creadaEn:       new Date().toISOString(),
      };

      const editIdx = document.getElementById('campEditId').value;
      if (editIdx !== '') {
        adminCampaigns[parseInt(editIdx)] = camp;
        showToast('✓ Campaña actualizada');
        addToHistory(`✏️ Campaña editada: ${nombre}`);
      } else {
        adminCampaigns.push(camp);
        showToast('✅ Campaña creada');
        addToHistory(`🎪 Campaña creada: ${nombre}`);
      }

      saveCampaignsToStorage();
      closeCampaignEditor();
      renderCampaignsList();

      // Si la campaña está activa, aplicar el banner al admin también
      const active = getActiveCampaign();
      if (active && active.bannerMsg) {
        const bannerEl = document.getElementById('bannerText');
        if (bannerEl) bannerEl.textContent = active.bannerMsg;
      }
    }

    function selectCampColor(color, btn) {
      document.getElementById('campColor').value = color;
      document.querySelectorAll('.color-chip').forEach(b => {
        b.classList.remove('active');
        b.style.removeProperty('--c-color');
      });
      btn.classList.add('active');
      btn.style.setProperty('--c-color', color);
      updateCampPreview();
    }

    function updateCampPreview() {
      const msg = document.getElementById('campBannerMsg')?.value || '(escribe el mensaje del banner arriba)';
      const color = document.getElementById('campColor')?.value || '#ec4899';
      const el = document.getElementById('campPreviewInner');
      if (el) {
        el.style.color = color;
        el.textContent = '🎁 ' + msg;
      }
    }

    // Conectar preview en tiempo real
    document.addEventListener('DOMContentLoaded', () => {
      const msgInput = document.getElementById('campBannerMsg');
      if (msgInput) msgInput.addEventListener('input', updateCampPreview);
    });

    // Inyectar campañas en loadAll al final de su ejecución
    // Hacemos esto de forma segura sin romper el flujo existente
    window._applyCampaigns = function() {
      loadCampaigns();
      const active = getActiveCampaign();
      if (active) {
        // Aplicar banner superior en la tienda (via localStorage que lee la tienda)
        if (active.bannerMsg) {
          localStorage.setItem('nuditos_active_campaign_banner', active.bannerMsg);
        }
        if (active.descCodigo && active.descPct > 0) {
          localStorage.setItem('nuditos_active_campaign_discount', JSON.stringify({
            code: active.descCodigo,
            pct: active.descPct
          }));
        }
      } else {
        localStorage.removeItem('nuditos_active_campaign_banner');
        localStorage.removeItem('nuditos_active_campaign_discount');
      }
    };

  </script>
</AdminLayout>
