---
/**
 * Panel de administración — Nuditos Tejidos v2 (Refactored)
 * URL: /admin
 * No usa el Layout principal — tiene su propio diseño modular
 * noindex para que Google no lo indexe
 */
export const prerender = false;

import AdminLayout from '../layouts/AdminLayout.astro';
import AdminNav from '../components/admin/AdminNav.astro';
import AdminSidebar from '../components/admin/AdminSidebar.astro';
import ProductsTab from '../components/admin/ProductsTab.astro';
import DashboardTab from '../components/admin/DashboardTab.astro';
import OrdersTab from '../components/admin/OrdersTab.astro';
import CategoriesTab from '../components/admin/CategoriesTab.astro';
import VitrinaTab from '../components/admin/VitrinaTab.astro';
import BannersTab from '../components/admin/BannersTab.astro';
import DiscountsTab from '../components/admin/DiscountsTab.astro';
import SettingsTab from '../components/admin/SettingsTab.astro';
import Modals from '../components/admin/Modals.astro';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
---

<AdminLayout title="Nuditos — Panel Admin">
  <!-- LOGIN SECTION -->
  <div id="loginScreen">
    <div class="login-card">
      <div class="login-logo">Nuditos<em style="color:#6d28d9">.</em></div>
      <div class="login-sub">Panel de administración</div>
      <input class="login-input" type="email" id="loginEmail" placeholder="tu@correo.com"
        style="letter-spacing:0;margin-bottom:.6rem"
        onkeydown="if(event.key==='Enter')doLogin()">
      <input class="login-input" type="password" id="loginPwd" placeholder="••••••••"
        onkeydown="if(event.key==='Enter')doLogin()">
      <button class="login-btn" onclick="doLogin()">Entrar</button>
      <div class="login-err" id="loginErr">Email o contraseña incorrectos</div>
    </div>
  </div>

  <!-- MAIN ADMIN PANEL -->
  <div id="adminPanel">
    <AdminNav />

    <div class="workspace" id="workspace">
      <AdminSidebar />

      <div id="rightArea" style="flex:1;overflow:hidden;display:flex;flex-direction:column">
        <ProductsTab />
        <DashboardTab />
        <OrdersTab />
        <CategoriesTab />
        <VitrinaTab />
        <BannersTab />
        <DiscountsTab />
        <SettingsTab />
      </div>
    </div>

    <!-- GLOBAL SAVE BAR -->
    <div class="save-bar">
      <div class="save-bar-msg">Recuerda <strong style="color:var(--lila)">guardar cambios</strong> para aplicarlos en la tienda</div>
      <button class="btn-save" id="globalSaveBtn" onclick="saveConfig()">
        <i class="ri-save-line"></i> Guardar cambios
      </button>
    </div>
  </div>

  <!-- MODALS & FEEDBACK -->
  <Modals />

  <!-- ══════════════════════════════════════════
       NUDITOS Admin Logic — Core JS
       ══════════════════════════════════════════ -->
  <script is:inline>
    let adminCfg={}, heroSelection=[], momentoSelection=null;
    let adminProducts=[], selectedId=null, pendingDeleteId=null;
    let editorialBannersAdmin=[], sideFilterCat='';
    let pedidos=[], pedidoFilter='todos';
    let adminCategories=[];
    let uploadedImgs=[], currentEditingImgs=[];
    let changeHistory=[];

    /* ── AUTH / LOGIN ── */
    async function doLogin(){
      const email=document.getElementById('loginEmail').value.trim();
      const pwd=document.getElementById('loginPwd').value;
      const errEl=document.getElementById('loginErr');
      errEl.style.display='none';
      if(!email||!pwd){errEl.textContent='Completa email y contraseña';errEl.style.display='block';return;}
      const btn=document.querySelector('.login-btn');
      btn.textContent='Entrando...';btn.disabled=true;
      try{
        await sbSignIn(email,pwd);
        document.getElementById('loginScreen').style.display='none';
        const p=document.getElementById('adminPanel');p.style.display='flex';
        loadAll();
      }catch(e){
        errEl.textContent='Email o contraseña incorrectos';errEl.style.display='block';
      }finally{btn.textContent='Entrar';btn.disabled=false;}
    }

    async function doLogout(){
      await sbSignOut();
      document.getElementById('loginScreen').style.display='flex';
      document.getElementById('adminPanel').style.display='none';
      document.getElementById('loginPwd').value='';
      document.getElementById('loginEmail').value='';
    }

    window.addEventListener('DOMContentLoaded',()=>{
      if(sbRestoreSession()){
        document.getElementById('loginScreen').style.display='none';
        const p=document.getElementById('adminPanel');p.style.display='flex';
        loadAll();
      }
    });

    /* ── UI HELPERS ── */
    function toggleSidebar(){
      document.getElementById('leftCol').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('open');
    }

    function showTab(name,btn){
      document.getElementById('leftCol').classList.remove('open');
      document.getElementById('sidebarOverlay').classList.remove('open');
      const leftVisible=(name==='productos');
      document.getElementById('leftCol').style.display=window.innerWidth>768?(leftVisible?'flex':'none'):'';
      document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
      document.querySelectorAll('.a-tab').forEach(el=>el.classList.remove('active'));
      document.getElementById('tab-'+name).classList.add('active');
      if(btn)btn.classList.add('active');
      if(name==='dashboard')renderDashboard();
      if(name==='pedidos')renderPedidosList();
    }

    /* ── CLOUDINARY ── */
    function getCloudinaryConfig(){
      const DEFAULT={cloudName:'dzxgu27wr',preset:'ssjghh9e'};
      try{const s=localStorage.getItem('nuditos_cloudinary');const saved=s?JSON.parse(s):{};
        return{cloudName:saved.cloudName||DEFAULT.cloudName,preset:saved.preset||DEFAULT.preset};}
      catch{return DEFAULT;}
    }
    function saveCloudinaryConfig(){
      const cfg={cloudName:document.getElementById('ccCloudName').value.trim(),preset:document.getElementById('ccPreset').value.trim()};
      localStorage.setItem('nuditos_cloudinary',JSON.stringify(cfg));
      showToast('✓ Cloudinary configurado');
    }
    async function uploadToCloudinary(file){
      showUploadProgress(0);
      try{
        const signRes=await fetch('/api/cloudinary-sign',{method:'POST'});
        if(!signRes.ok)throw new Error('No se pudo obtener la firma');
        const{signature,timestamp,apiKey,cloudName,uploadPreset,folder}=await signRes.json();
        const fd=new FormData();
        fd.append('file',file);fd.append('upload_preset',uploadPreset);
        fd.append('folder',folder);fd.append('timestamp',timestamp);
        fd.append('api_key',apiKey);fd.append('signature',signature);
        showUploadProgress(30);
        const res=await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/image/upload`,{method:'POST',body:fd});
        if(!res.ok)throw new Error('Error al subir');
        const data=await res.json();
        const url=data.secure_url.replace('/upload/','/upload/w_1200,q_auto,f_auto/');
        showUploadProgress(100);setTimeout(()=>hideUploadProgress(),800);
        addToHistory(`📸 Foto subida: ${data.original_filename||'imagen'}`);
        return url;
      }catch(e){hideUploadProgress();showToast('❌ Error subiendo imagen');return null;}
    }
    function showUploadProgress(pct){const p=document.getElementById('uploadProgress');const b=document.getElementById('uploadProgressBar');if(p)p.style.display='block';if(b)b.style.width=pct+'%';}
    function hideUploadProgress(){const p=document.getElementById('uploadProgress');if(p)p.style.display='none';}

    /* ── INITIAL LOAD ── */
    async function loadAll(){
      showToast('⏳ Cargando datos...');
      try{
        const sbProds=await sbAdminGetProducts();
        if(sbProds&&sbProds.length>0){adminProducts=sbProds;}
        else{
          adminProducts=products.map(p=>({...p}));
          showToast('⬆️ Subiendo productos a Supabase...');
          for(const p of adminProducts){try{await sbAdminSaveProduct({...p,_isNew:true});}catch(e){}}
        }
        const sbCfg=await sbAdminGetConfig_();adminCfg=sbCfg||{...CONFIG_DEFAULT};
        try{const rows=await sbAdminGetBanners_();editorialBannersAdmin=rows&&rows.length?rows:[
          {id:1,afterCat:'rosas',emoji:'🌸',title:'Flores que <em>jamás se marchitan</em>',imgUrl:''},
          {id:2,afterCat:'noche',emoji:'🌙',title:'Arte tejido <em>puntada a puntada</em>',imgUrl:''},
          {id:3,afterCat:'especial',emoji:'✨',title:'Regalos que <em>dejan huella</em>',imgUrl:''},
        ];}catch{editorialBannersAdmin=[];}
        try{pedidos=await sbAdminGetPedidos();}catch{pedidos=[];}
        try{adminCategories=await sbAdminGetCategories();if(!adminCategories.length)adminCategories=[...categories];}catch{adminCategories=[...categories];}
        try{const sh=localStorage.getItem('nuditos_history');changeHistory=sh?JSON.parse(sh):[];}catch{changeHistory=[];}
      }catch(e){
        showToast('⚠️ Error de conexión — usando datos locales');
        adminProducts=products.map(p=>({...p}));adminCfg={...CONFIG_DEFAULT};editorialBannersAdmin=[];pedidos=[];
      }
      
      heroSelection=[...(adminCfg.carruselHero||[])];momentoSelection=adminCfg.ramoDestacado;
      document.getElementById('descCodigo').value=adminCfg.descuentoCodigo||'';
      document.getElementById('descPorcentaje').value=adminCfg.descuentoPorcentaje||10;
      document.getElementById('descTexto').value=adminCfg.descuentoTexto||'';
      if(adminCfg.descuentoActivo)document.getElementById('toggleDescuento').classList.add('on');
      if(adminCfg.wompiActivo)document.getElementById('toggleWompi').classList.add('on');
      if(adminCfg.wompiKey)document.getElementById('wompiKey').value=adminCfg.wompiKey;
      if(adminCfg.metaPixelActivo)document.getElementById('toggleMetaPixel').classList.add('on');
      if(adminCfg.metaPixelId)document.getElementById('metaPixelId').value=adminCfg.metaPixelId;
      
      const cc=getCloudinaryConfig();
      if(cc.cloudName)document.getElementById('ccCloudName').value=cc.cloudName;
      if(cc.preset)document.getElementById('ccPreset').value=cc.preset;
      
      buildSideFilters();renderSidebar();renderStats();showEditorEmpty();renderCategoriasList();
      renderHeroSlots();renderMomentoSelected();renderMomentoList(adminProducts);renderHeroList(adminProducts);
      renderCatViewsList();renderBannerList();
      showToast('✅ Todo cargado');
    }

    async function sbAdminGetConfig_(){
      try{const rows=await fetch(`${SB_URL}/rest/v1/config?select=clave,valor`,{headers:_h(true)}).then(r=>r.json());return sbToConfig(rows);}
      catch{return null;}
    }
    async function sbAdminGetBanners_(){
      try{const rows=await fetch(`${SB_URL}/rest/v1/banners?order=orden.asc`,{headers:_h(true)}).then(r=>r.json());return rows.map(sbToBanner);}
      catch{return[];}
    }

    function buildSideFilters(){
      const opts=[{id:'',name:'Todos',icon:'🌸'},...categories.filter(c=>c.id!=='todos')];
      document.getElementById('sideFilters').innerHTML=opts.map(c=>
        `<span class="lf-chip ${sideFilterCat===c.id?'active':''}" onclick="setSideFilter('${c.id}',this)">${c.icon} ${c.name}</span>`
      ).join('');
    }
    function setSideFilter(id,el){sideFilterCat=id;document.querySelectorAll('.lf-chip').forEach(c=>c.classList.remove('active'));el.classList.add('active');renderSidebar();}

    function renderStats(){
      const t=adminProducts.length,v=adminProducts.filter(p=>p.activo!==false).length;
      const f=adminProducts.filter(p=>p.img&&p.img.trim()).length,o=t-v;
      document.getElementById('sideStats').innerHTML=`
        <div class="ls-stat"><div class="ls-num">${t}</div><div class="ls-label">Total</div></div>
        <div class="ls-stat"><div class="ls-num green">${v}</div><div class="ls-label">Visibles</div></div>
        <div class="ls-stat"><div class="ls-num ${(t-f)>0?'red':'green'}">${f}</div><div class="ls-label">Con foto</div></div>
        <div class="ls-stat"><div class="ls-num red">${o}</div><div class="ls-label">Ocultos</div></div>`;
    }

    function renderSidebar(){
      const q=document.getElementById('sideSearch').value.toLowerCase();
      let list=adminProducts.filter(p=>{
        const mQ=!q||p.name.toLowerCase().includes(q)||(categories.find(c=>c.id===p.cat)?.name.toLowerCase().includes(q));
        const mC=!sideFilterCat||p.cat===sideFilterCat;return mQ&&mC;
      });
      const groups={};list.forEach(p=>{if(!groups[p.cat])groups[p.cat]=[];groups[p.cat].push(p);});
      let html='';
      Object.entries(groups).forEach(([catId,items])=>{
        if(!sideFilterCat){const cat=categories.find(c=>c.id===catId);html+=`<div class="cat-group-label">${cat?.icon||''} ${cat?.name||catId}</div>`;}
        items.forEach(p=>{
          const isActive=p.activo!==false;
          const tags=[];
          if(!isActive)tags.push(`<span class="pi-tag pit-oculto">Oculto</span>`);
          if(p.badge)tags.push(`<span class="pi-tag pit-badge">${p.badge}</span>`);
          if(p.oferta)tags.push(`<span class="pi-tag pit-oferta">Oferta</span>`);
          if(p.envioGratis)tags.push(`<span class="pi-tag pit-envio">Envío</span>`);
          html+=`
            <div class="prod-item ${selectedId===p.id?'selected':''} ${isActive?'':'inactive'}" onclick="selectProduct(${p.id})">
              <div class="pi-thumb">${p.img?`<img src="${p.img}" onerror="this.parentNode.innerHTML='${p.emoji}'">`:p.emoji}</div>
              <div class="pi-info">
                <div class="pi-name">${p.name}</div>
                <div class="pi-meta">${p.price>0?'$'+p.price.toLocaleString('es-CO')+' COP':'Consultar'}</div>
                ${tags.length?`<div class="pi-tags">${tags.join('')}</div>`:''}
              </div>
              <div class="pi-dot ${isActive?'on':'off'}"></div>
            </div>`;
        });
      });
      document.getElementById('sideList').innerHTML=html||`<div style="padding:1.5rem;text-align:center;color:rgba(255,255,255,.3);font-size:.76rem">No hay ramos</div>`;
    }

    function selectProduct(id){
      selectedId=id;renderSidebar();
      const p=adminProducts.find(x=>x.id===id);
      if(p)renderEditor(p);
      if(window.innerWidth<=768){document.getElementById('leftCol').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('open');}
    }
    function newProduct(){
      selectedId=null;renderSidebar();clearEditor();
      document.getElementById('tab-productos').innerHTML=buildEditorHTML(null);
      document.getElementById('editingId').value='';
      if(window.innerWidth<=768){document.getElementById('leftCol').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('open');}
    }

    function showEditorEmpty(){
      document.getElementById('tab-productos').innerHTML=`
        <div class="editor-empty">
          <div class="editor-empty-icon">🌸</div>
          <h3>Selecciona un ramo</h3>
          <p>Elige un ramo de la lista para editar sus detalles, precio o fotos.</p>
        </div>`;
    }
    function clearEditor(){uploadedImgs=[];currentEditingImgs=[];}

    function buildEditorHTML(p){
      const isNew=!p;
      const cats=categories.filter(c=>c.id!=='todos').map(c=>`<option value="${c.id}" ${p?.cat===c.id?'selected':''}>${c.icon} ${c.name}</option>`).join('');
      return `
        <input type="hidden" id="editingId" value="${p?.id||''}">
        <div class="editor-card">
          <div class="ec-header">
            <div>
              <div class="ec-title">${isNew?'Nuevo ramo':'Editando ramo'}</div>
              <div class="ec-sub" id="editorSub">${p?p.name:''}</div>
            </div>
            <div class="ec-actions">
              ${!isNew?`
                <button class="btn-vis ${p.activo!==false?'on':'off'}" id="visBtn" onclick="quickToggleVis(${p?.id})">${p.activo!==false?'👁 Visible':'🚫 Oculto'}</button>
                <button class="btn-delete" onclick="askDeleteId(${p?.id})">🗑️ Eliminar</button>
              `:''}
            </div>
          </div>
          <div class="form-grid">
            <div class="field field-full"><label>Nombre del producto *</label><input type="text" id="fNombre" value="${p?.name||''}" oninput="updatePreview()" placeholder="Ramo de rosas con mariposas"></div>
            <div class="field"><label>Precio (COP)</label><input type="number" id="fPrecio" value="${p?.price||0}" oninput="updatePreview()" min="0"></div>
            <div class="field"><label>Categoría *</label><select id="fCat" onchange="updatePreview()">${cats}</select></div>
            <div class="field"><label>Emoji (si no hay foto)</label><input type="text" id="fEmoji" value="${p?.emoji||'🌸'}" oninput="updatePreview()"></div>
            <div class="field field-full"><label>Descripción / detalles</label><textarea id="fDesc" oninput="updatePreview()" rows="2" placeholder="Envío gratis · 3 rosas + margaritas">${p?.desc||''}</textarea></div>
            <div class="field field-full"><label>Estado</label>
              <select id="fActivo" onchange="updatePreview()">
                <option value="true" ${p?.activo!==false?'selected':''}>✅ Visible en tienda</option>
                <option value="false" ${p?.activo===false?'selected':''}>🚫 Oculto</option>
              </select>
            </div>
          </div>
          <div class="img-upload-section">
            <div class="img-upload-header"><span class="img-upload-title">📸 Fotos del producto</span></div>
            <div class="upload-zone" onclick="document.getElementById('fileInput').click()">
              <input type="file" id="fileInput" accept="image/*" style="display:none" onchange="handleFileUpload(this.files)">
              <div class="upload-zone-icon">📤</div>
              <div class="upload-zone-text">Clic para subir foto</div>
              <div class="upload-zone-sub">JPG, PNG, WEBP · Se optimiza automáticamente</div>
            </div>
            <div class="upload-progress" id="uploadProgress"><div class="upload-progress-bar" id="uploadProgressBar"></div></div>
            <div class="img-preview-row" id="imgPreviewRow"></div>
            <label style="font-size:.65rem;font-weight:600;color:var(--soft);text-transform:uppercase;letter-spacing:.5px;display:block;margin:.5rem 0 .25rem">O pega links de Cloudinary</label>
            <textarea class="img-url-input" id="fImgs" rows="3" placeholder="https://res.cloudinary.com/... (uno por línea)">${(p?.imgs||[]).join('\n')}</textarea>
            <div class="field" style="margin-top:.5rem"><label>Foto principal (URL)</label><input type="text" id="fImg" value="${p?.img||''}" oninput="updatePreview()" placeholder="https://res.cloudinary.com/..."></div>
          </div>
          <div class="stock-row">
            <span class="stock-icon">📦</span>
            <div class="stock-info"><div class="stock-label">Stock</div><div class="stock-sub">Cuántas unidades disponibles</div></div>
            <div class="stock-input-wrap">
              <input class="stock-num" type="number" id="fStock" value="${p?.stock??99}" min="0" max="999">
              <label class="stock-unlimited"><input type="checkbox" id="fStockUnlimited" ${p?.stock===undefined||p?.stock===null?'checked':''}> Sin límite</label>
            </div>
          </div>
          <div class="tags-label">Etiquetas</div>
          <div class="chips-row">
            <label class="chip-check"><input type="checkbox" id="fTagNuevo" ${p?.badge==='Nuevo'?'checked':''}> 🟢 Nuevo</label>
            <label class="chip-check chip-popular"><input type="checkbox" id="fTagPopular" ${p?.badge==='Popular'?'checked':''}> 🔥 Popular</label>
            <label class="chip-check chip-especial"><input type="checkbox" id="fTagEspecial" ${p?.badge==='Especial'?'checked':''}> ⭐ Especial</label>
            <label class="chip-check chip-oferta"><input type="checkbox" id="fTagOferta" ${p?.oferta?'checked':''} onchange="toggleOfertaFields()"> 🏷️ Oferta</label>
            <label class="chip-check chip-envio"><input type="checkbox" id="fTagEnvio" ${p?.envioGratis?'checked':''}> 🚚 Envío gratis</label>
          </div>
          <div id="ofertaFields" style="${p?.oferta?'display:block':''}">
            <div class="form-grid">
              <div class="field"><label>Precio original (tachado)</label><input type="number" id="fPrecioOriginal" value="${p?.precioOriginal||0}" min="0"></div>
              <div class="field"><label>Precio con oferta</label><input type="number" id="fPrecioOferta" value="${p?.precioOferta||0}" min="0"></div>
            </div>
          </div>
          <div class="preview-panel">
            <div class="preview-label">Vista previa en tienda</div>
            <div class="preview-card-wrap"><div class="preview-card" id="livePreview"></div></div>
          </div>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.3rem">
            <button class="btn-save" id="saveProdBtn" onclick="saveProduct()">
              <i class="ri-save-line"></i> <span>${isNew?'Crear producto':'Guardar cambios'}</span>
            </button>
            <button class="btn-cancel" onclick="showEditorEmpty()">Cancelar</button>
          </div>
        </div>`;
    }

    function renderEditor(p){
      currentEditingImgs=p.imgs?[...p.imgs]:[];uploadedImgs=[];
      document.getElementById('tab-productos').innerHTML=buildEditorHTML(p);
      renderImgPreviews();updatePreview();
    }
    function toggleOfertaFields(){document.getElementById('ofertaFields').style.display=document.getElementById('fTagOferta').checked?'block':'none';}

    async function handleFileUpload(files){
      if(!files.length)return;
      for(const file of files){
        const url=await uploadToCloudinary(file);
        if(url){currentEditingImgs.push(url);if(!document.getElementById('fImg').value)document.getElementById('fImg').value=url;renderImgPreviews();updatePreview();}
      }
    }
    function syncImgsFromTextarea(){const ta=document.getElementById('fImgs');if(!ta)return;const lines=ta.value.split('\n').map(l=>l.trim()).filter(l=>l.startsWith('http'));lines.forEach(url=>{if(!currentEditingImgs.includes(url))currentEditingImgs.push(url);});}
    function updateImgsTextarea(){const ta=document.getElementById('fImgs');if(ta)ta.value=currentEditingImgs.join('\n');}
    function renderImgPreviews(){
      const row=document.getElementById('imgPreviewRow');if(!row)return;
      row.innerHTML=currentEditingImgs.map((url,i)=>`
        <div class="img-thumb-wrap">
          <img class="img-thumb" src="${url}">
          <button class="img-thumb-rm" onclick="removeImg(${i})">×</button>
        </div>`).join('');
    }
    function removeImg(i){currentEditingImgs.splice(i,1);renderImgPreviews();updateImgsTextarea();updatePreview();}

    function updatePreview(){
      const name=document.getElementById('fNombre')?.value||'Nombre';
      const price=parseInt(document.getElementById('fPrecio')?.value)||0;
      const emoji=document.getElementById('fEmoji')?.value||'🌸';
      const img=document.getElementById('fImg')?.value||'';
      const isNew=document.getElementById('fTagNuevo')?.checked;
      const isPopular=document.getElementById('fTagPopular')?.checked;
      const isEspecial=document.getElementById('fTagEspecial')?.checked;
      const isOferta=document.getElementById('fTagOferta')?.checked;
      const precioOrig=parseInt(document.getElementById('fPrecioOriginal')?.value)||0;
      const catId=document.getElementById('fCat')?.value;
      const cat=categories.find(c=>c.id===catId);
      const isActive=document.getElementById('fActivo')?.value==='true';
      const badge=isNew?'Nuevo':isPopular?'Popular':isEspecial?'Especial':'';
      const badgeCls=isNew?'nuevo':isPopular?'popular':isEspecial?'especial':'';
      let origHtml='';
      if(isOferta&&precioOrig>0&&price>0)origHtml=`<span class="orig">$${precioOrig.toLocaleString('es-CO')}</span>`;
      const preview=document.getElementById('livePreview');if(!preview)return;
      preview.innerHTML=`
        <div class="preview-img">
          ${img?`<img src="${img}" onerror="this.remove()">`:`<span>${emoji}</span>`}
          ${badge?`<div class="preview-badge ${badgeCls}">${badge}</div>`:''}
          ${!isActive?`<div class="preview-badge agotado">Oculto</div>`:''}
        </div>
        <div class="preview-info">
          <div class="preview-cat">${cat?.icon||''} ${cat?.name||'Cat'}</div>
          <div class="preview-name">${name}</div>
          <div class="preview-price">${origHtml}${price>0?'$'+price.toLocaleString('es-CO')+' COP':'Consultar'}</div>
        </div>`;
    }

    async function saveProduct(){
      const nombre=document.getElementById('fNombre')?.value.trim();
      const precio=parseInt(document.getElementById('fPrecio')?.value)||0;
      const cat=document.getElementById('fCat')?.value;
      const emoji=document.getElementById('fEmoji')?.value.trim()||'🌸';
      const desc=document.getElementById('fDesc')?.value.trim()||'';
      const img=document.getElementById('fImg')?.value.trim()||'';
      syncImgsFromTextarea();const imgs=[...currentEditingImgs];
      const activo=document.getElementById('fActivo')?.value==='true';
      const editId=document.getElementById('editingId')?.value;
      const tagNuevo=document.getElementById('fTagNuevo')?.checked;
      const tagPopular=document.getElementById('fTagPopular')?.checked;
      const tagEspecial=document.getElementById('fTagEspecial')?.checked;
      const tagOferta=document.getElementById('fTagOferta')?.checked;
      const tagEnvio=document.getElementById('fTagEnvio')?.checked;
      const stockUnlimited=document.getElementById('fStockUnlimited')?.checked;
      const stockVal=parseInt(document.getElementById('fStock')?.value);
      const stock=stockUnlimited?undefined:(isNaN(stockVal)?undefined:stockVal);
      let badge='',badgeClass='';
      if(tagNuevo){badge='Nuevo';badgeClass='nuevo';}else if(tagPopular){badge='Popular';}else if(tagEspecial){badge='Especial';}
      const precioOriginal=parseInt(document.getElementById('fPrecioOriginal')?.value)||0;
      const precioOferta=parseInt(document.getElementById('fPrecioOferta')?.value)||0;
      if(!nombre){showToast('⚠️ Nombre obligatorio');return;}
      const data={name:nombre,price:precio,cat,emoji,desc,img,imgs,badge,badgeClass,activo,oferta:tagOferta,envioGratis:tagEnvio,stock,precioOriginal:tagOferta?precioOriginal:0,precioOferta:tagOferta?precioOferta:0};
      const btn=document.getElementById('saveProdBtn');
      if(btn){btn.disabled=true;btn.querySelector('span').textContent='...';}
      try{
        if(editId&&editId!==''){
          data.id=parseInt(editId);
          await sbAdminSaveProduct({...data,_isNew:false});
          const idx=adminProducts.findIndex(p=>p.id===parseInt(editId));
          if(idx!==-1)adminProducts[idx]={...adminProducts[idx],...data};
          showToast(`✓ Actualizado`);addToHistory(`✏️ Editado: ${nombre}`);
        }else{
          const saved=await sbAdminSaveProduct({...data,_isNew:true});
          if(saved){adminProducts.push({...data,id:saved.id});selectedId=saved.id;}
          showToast(`✓ Creado`);addToHistory(`➕ Agregado: ${nombre}`);
        }
        renderSidebar();renderStats();renderMomentoList(adminProducts);renderHeroList(adminProducts);
      }catch(e){showToast('❌ Error');}
      finally{if(btn)btn.disabled=false;if(btn)btn.querySelector('span').textContent='Guardar cambios';}
    }

    async function quickToggleVis(id){
      const idx=adminProducts.findIndex(p=>p.id===id);if(idx===-1)return;
      adminProducts[idx].activo=!(adminProducts[idx].activo!==false);
      try{await sbAdminSaveProduct({...adminProducts[idx],_isNew:false});renderSidebar();renderStats();const p=adminProducts[idx];const btn=document.getElementById('visBtn');if(btn){btn.className=`btn-vis ${p.activo!==false?'on':'off'}`;btn.textContent=p.activo!==false?'👁 Visible':'🚫 Oculto';}showToast(p.activo!==false?'✓ Visible':'🚫 Oculto');}catch{showToast('❌ Error');}
    }
    function askDeleteId(id){pendingDeleteId=id;const p=adminProducts.find(x=>x.id===id);document.getElementById('confirmMsg').textContent=`¿Eliminar "${p?.name||''}"?`;document.getElementById('confirmOverlay').classList.add('open');}
    function closeConfirm(){document.getElementById('confirmOverlay').classList.remove('open');}
    async function confirmDelete(){
      if(!pendingDeleteId)return;
      const idx=adminProducts.findIndex(p=>p.id===pendingDeleteId);const name=adminProducts[idx]?.name;
      try{await sbAdminDeleteProduct(pendingDeleteId);if(idx!==-1)adminProducts.splice(idx,1);selectedId=null;renderSidebar();renderStats();showEditorEmpty();closeConfirm();showToast(`🗑️ Eliminado`);}catch{showToast('❌ Error');}
    }

    /* ── PEDIDOS ── */
    function openNewPedido(){document.getElementById('pedidoEditId').value='';document.getElementById('pedidoModalTitle').textContent='Nuevo pedido';['pCliente','pTel','pItems','pTotal','pNotas'].forEach(id=>document.getElementById(id).value='');document.getElementById('pEstado').value='pendiente';document.getElementById('pedidoModal').classList.add('open');}
    function openEditPedido(id){const p=pedidos.find(x=>x.id===id);if(!p)return;document.getElementById('pedidoEditId').value=p.id;document.getElementById('pCliente').value=p.cliente||'';document.getElementById('pTel').value=p.tel||'';document.getElementById('pItems').value=p.items||'';document.getElementById('pTotal').value=p.total||'';document.getElementById('pEstado').value=p.estado||'pendiente';document.getElementById('pNotas').value=p.notas||'';document.getElementById('pedidoModal').classList.add('open');}
    function closePedidoModal(){document.getElementById('pedidoModal').classList.remove('open');}
    async function savePedido(){
      const editId=document.getElementById('pedidoEditId').value;
      const data={cliente:document.getElementById('pCliente').value.trim(),tel:document.getElementById('pTel').value.trim(),items:document.getElementById('pItems').value.trim(),total:parseInt(document.getElementById('pTotal').value)||0,estado:document.getElementById('pEstado').value,notas:document.getElementById('pNotas').value.trim()};
      if(!data.cliente)return;
      try{
        if(editId){await sbAdminSavePedido({...data,id:parseInt(editId),_isNew:false});const idx=pedidos.findIndex(p=>p.id===parseInt(editId));if(idx!==-1)pedidos[idx]={...pedidos[idx],...data,id:parseInt(editId)};}
        else{const saved=await sbAdminSavePedido({...data,_isNew:true});if(saved)pedidos.unshift(saved);}
        closePedidoModal();renderPedidosList();showToast('✓ Pedido guardado');
      }catch{showToast('❌ Error');}
    }
    async function cambiarEstadoPedido(id,estado){const idx=pedidos.findIndex(p=>p.id===id);if(idx===-1)return;try{await sbAdminUpdateEstadoPedido(id,estado);pedidos[idx].estado=estado;renderPedidosList();showToast('✓ Estado actualizado');}catch{showToast('❌ Error');}}
    async function deletePedido(id){try{await sbAdminDeletePedido(id);pedidos=pedidos.filter(p=>p.id!==id);renderPedidosList();showToast('🗑️ Eliminado');}catch{showToast('❌ Error');}}
    function filterPedidos(f,btn){pedidoFilter=f;document.querySelectorAll('.pedido-filter').forEach(b=>b.classList.remove('active'));btn.classList.add('active');renderPedidosList();}
    function renderPedidosList(){
      const list=pedidoFilter==='todos'?pedidos:pedidos.filter(p=>p.estado===pedidoFilter);
      const eLabels={pendiente:'⏳ Pendiente',proceso:'🔄 En proceso',entregado:'✅ Entregado',cancelado:'❌ Cancelado'};
      const eCls={pendiente:'estado-pendiente',proceso:'estado-proceso',entregado:'estado-entregado',cancelado:'estado-cancelado'};
      document.getElementById('pedidosList').innerHTML=list.length?list.map(p=>`
        <div class="pedido-card">
          <div class="pedido-top"><div class="pedido-id">#${String(p.id).slice(-6)}</div><span class="pedido-estado ${eCls[p.estado]||'estado-pendiente'}">${eLabels[p.estado]||p.estado}</span></div>
          <div class="pedido-cliente">${p.cliente}</div>
          <div class="pedido-items">${p.items||'—'}</div>
          <div class="pedido-bottom"><div class="pedido-total">${p.total>0?'$'+p.total.toLocaleString('es-CO'):''}</div><div class="pedido-fecha">${p.fecha||''}</div></div>
          <div class="pedido-actions">
            <button class="p-action-btn" onclick="openEditPedido(${p.id})">✏️ Editar</button>
            <button class="p-action-btn" onclick="cambiarEstadoPedido(${p.id},'entregado')">✅ Entregado</button>
            <button class="p-action-btn" style="color:var(--red)" onclick="deletePedido(${p.id})">🗑️</button>
          </div>
        </div>`).join(''):`<div style="text-align:center;padding:2rem;color:var(--soft)">No hay pedidos</div>`;}

    /* ── CATEGORÍAS ── */
    function renderCategoriasList() {
      document.getElementById('catAdminList').innerHTML = adminCategories.length ? adminCategories.map(c => `
        <div class="cat-admin-card">
          <div class="ca-icon">${c.icon}</div>
          <div class="ca-info"><div class="ca-name">${c.nombre}</div><div class="ca-slug">ID: ${c.id}</div></div>
          <div class="ca-actions"><button class="ca-btn" onclick="editCategory('${c.id}')"><i class="ri-edit-line"></i></button></div>
        </div>`).join('') : '';
    }
    function newCategory() { document.getElementById('catModalTitle').textContent = 'Nueva categoría'; document.getElementById('catEditId').value = ''; document.getElementById('catId').value = ''; document.getElementById('catId').disabled = false; document.getElementById('catNombre').value = ''; document.getElementById('catIcon').value = '🌸'; document.getElementById('catModal').classList.add('open'); }
    function editCategory(id) { const c = adminCategories.find(x => x.id === id); if (!c) return; document.getElementById('catEditId').value = id; document.getElementById('catId').value = id; document.getElementById('catId').disabled = true; document.getElementById('catNombre').value = c.nombre; document.getElementById('catIcon').value = c.icon; document.getElementById('catModal').classList.add('open'); }
    function closeCatModal() { document.getElementById('catModal').classList.remove('open'); }
    async function saveCategory() { const id = document.getElementById('catId').value.trim().toLowerCase(); const data = { id, nombre: document.getElementById('catNombre').value.trim(), icon: document.getElementById('catIcon').value.trim() || '🌸', activo: true }; try { await sbAdminSaveCategory(data, !document.getElementById('catEditId').value); loadAll(); closeCatModal(); showToast(`✓ Guardada`); } catch { showToast('❌ Error'); } }

    /* ── DASHBOARD ── */
    function renderDashboard(){
      const total=adminProducts.length,visibles=adminProducts.filter(p=>p.activo!==false).length;
      document.getElementById('dashStats').innerHTML=`
        <div class="dash-stat"><div class="dash-num">${total}</div><div class="dash-label">Ramos</div></div>
        <div class="dash-stat"><div class="dash-num green">${visibles}</div><div class="dash-label">Visibles</div></div>
        <div class="dash-stat"><div class="dash-num">${pedidos.length}</div><div class="dash-label">Pedidos</div></div>`;
      document.getElementById('histList').innerHTML=changeHistory.length?[...changeHistory].reverse().slice(0,10).map(h=>`
        <div class="hist-item"><div class="hist-dot"></div><div><div class="hist-action">${h.action}</div><div class="hist-time">${h.time}</div></div></div>`).join(''):'';
    }
    function addToHistory(action){ changeHistory.push({action,time:new Date().toLocaleString('es-CO')}); if(changeHistory.length>50)changeHistory.shift(); localStorage.setItem('nuditos_history',JSON.stringify(changeHistory)); }

    /* ── VITRINA & METADATA ── */
    function renderMomentoSelected(){ const p=momentoSelection?adminProducts.find(x=>x.id===momentoSelection):null; document.getElementById('momentoSelected').textContent=p?`✅: ${p.name}`:'Sin seleccionar'; }
    function renderMomentoList(list){ document.getElementById('momentoList').innerHTML=list.slice(0,10).map(p=>`<div class="v-prod-row"><div class="v-info">${p.name}</div><button class="btn-select" onclick="selectMomento(${p.id})">Seleccionar</button></div>`).join(''); }
    function selectMomento(id){ momentoSelection=id; renderMomentoSelected(); }
    function renderHeroSlots(){ document.getElementById('heroSlots').innerHTML=heroSelection.map(id=>{ const p=adminProducts.find(x=>x.id===id); return `<div class="hero-slot filled">${p?.name.slice(0,10)}</div>`; }).join(''); }
    function renderHeroList(list){ document.getElementById('heroList').innerHTML=list.slice(0,10).map(p=>`<div class="v-prod-row"><div class="v-info">${p.name}</div><button class="btn-select" onclick="toggleHero(${p.id})">+ Agregar</button></div>`).join(''); }
    function toggleHero(id){ if(!heroSelection.includes(id))heroSelection.push(id); renderHeroSlots(); }
    function renderBannerList(){ document.getElementById('bannerList').innerHTML=editorialBannersAdmin.map((b,i)=>`<div class="banner-item">${b.afterCat}: ${b.title} <button onclick="removeBanner(${i})">✕</button></div>`).join(''); }
    function updateBanner(i,key,val){ editorialBannersAdmin[i][key]=val; }
    function removeBanner(i){ editorialBannersAdmin.splice(i,1); renderBannerList(); }
    function renderCatViewsList(){ document.getElementById('catViewsList').innerHTML=categories.filter(c=>c.id!=='todos').map(c=>`<div>${c.name}</div>`).join(''); }

    async function saveConfig(){
      const newCfg={ramoDestacado:momentoSelection,carruselHero:heroSelection,descuentoActivo:document.getElementById('toggleDescuento').classList.contains('on'),descuentoCodigo:document.getElementById('descCodigo').value.trim(),descuentoPorcentaje:parseInt(document.getElementById('descPorcentaje').value)||10,descuentoTexto:document.getElementById('descTexto').value.trim(),wompiActivo:document.getElementById('toggleWompi').classList.contains('on'),wompiKey:document.getElementById('wompiKey').value.trim(),metaPixelActivo:document.getElementById('toggleMetaPixel').classList.contains('on'),metaPixelId:document.getElementById('metaPixelId').value.trim(),catViews:{}};
      try{ await sbAdminSaveConfig(newCfg); await sbAdminSaveBanners(editorialBannersAdmin); showToast('✅ Guardado'); }catch{ showToast('❌ Error');}
    }
    function showToast(msg){ const t=document.getElementById('toastAdmin'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2000); }
  </script>
</AdminLayout>
