---
/**
 * Panel de administración — Nuditos Tejidos
 * URL: /admin
 * No usa el Layout principal — tiene su propio diseño
 * noindex para que Google no lo indexe
 */
export const prerender = false;
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
---

<!DOCTYPE html>
<html lang="es">
<head>
  <link rel="stylesheet" href="/styles/admin.css">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nuditos — Panel Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/remixicon/fonts/remixicon.css" rel="stylesheet" />
  </head>
<body>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-card">
    <div class="login-logo">Nuditos<em style="color:#6d28d9">.</em></div>
    <div class="login-sub">Panel de administración</div>
    <input class="login-input" type="email" id="loginEmail" placeholder="tu@correo.com"
      style="letter-spacing:0;margin-bottom:.6rem"
      onkeydown="if(event.key==='Enter')doLogin()">
    <input class="login-input" type="password" id="loginPwd" placeholder="••••••••"
      onkeydown="if(event.key==='Enter')doLogin()">
    <button class="login-btn" onclick="doLogin()">Entrar</button>
    <div class="login-err" id="loginErr">Email o contraseña incorrectos</div>
  </div>
</div>

<!-- PANEL -->
<div id="adminPanel">
  <nav class="admin-nav">
    <button class="nav-hamburger" id="navHamburger" onclick="toggleSidebar()">
      <i class="ri-menu-line"></i>
    </button>
    <div class="admin-logo">Nuditos <span>Admin</span></div>
    <div class="admin-tabs">
      <button class="a-tab active" onclick="showTab('productos',this)">🌸 Productos</button>
      <button class="a-tab" onclick="showTab('dashboard',this)">📊 Dashboard</button>
      <button class="a-tab" onclick="showTab('pedidos',this)">📦 Pedidos</button>
      <button class="a-tab" onclick="showTab('vitrina',this)">⭐ Vitrina</button>
      <button class="a-tab" onclick="showTab('banners',this)">🖼️ Banners</button>
      <button class="a-tab" onclick="showTab('descuentos',this)">🏷️ Descuentos</button>
      <button class="a-tab" onclick="showTab('tienda',this)">⚙️ Tienda</button>
    </div>
    <div class="nav-right-actions">
      <button class="preview-btn" onclick="window.open('/','_blank')">
        <i class="ri-eye-line"></i> <span class="hide-xs">Ver tienda</span>
      </button>
      <button class="logout-btn" onclick="doLogout()">Salir</button>
    </div>
  </nav>

  <div class="workspace" id="workspace">
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- SIDEBAR -->
    <div class="left-col" id="leftCol">
      <div class="left-header">
        <div class="left-title">🌸 Mis ramos</div>
        <input class="left-search" type="text" id="sideSearch" placeholder="Buscar ramo..." oninput="renderSidebar()">
        <div class="left-filters" id="sideFilters"></div>
      </div>
      <div class="left-stats" id="sideStats"></div>
      <button class="btn-add-prod" onclick="newProduct()">
        <i class="ri-add-line"></i> Agregar ramo nuevo
      </button>
      <div class="prod-list-scroll" id="sideList"></div>
    </div>

    <!-- ÁREA DERECHA -->
    <div id="rightArea" style="flex:1;overflow:hidden;display:flex;flex-direction:column">
      <div class="right-col tab-content active" id="tab-productos"></div>

      <!-- DASHBOARD -->
      <div class="tab-content" id="tab-dashboard">
        <div class="dash-grid" id="dashStats"></div>
        <div class="dash-chart">
          <div class="dash-chart-title">📈 Productos por precio</div>
          <div id="viewsChart"></div>
        </div>
        <div class="dash-chart">
          <div class="dash-chart-title">🛒 Más pedidos</div>
          <div id="cartChart"></div>
        </div>
        <div class="t-card">
          <div class="t-title" style="margin-bottom:.6rem">📋 Historial de cambios</div>
          <div id="histList"></div>
        </div>
      </div>

      <!-- PEDIDOS -->
      <div class="tab-content" id="tab-pedidos">
        <div class="pedidos-toolbar">
          <button class="pedido-filter active" onclick="filterPedidos('todos',this)">Todos</button>
          <button class="pedido-filter" onclick="filterPedidos('pendiente',this)">⏳ Pendientes</button>
          <button class="pedido-filter" onclick="filterPedidos('proceso',this)">🔄 En proceso</button>
          <button class="pedido-filter" onclick="filterPedidos('entregado',this)">✅ Entregados</button>
          <button class="btn-new-pedido" onclick="openNewPedido()">
            <i class="ri-add-line"></i> Nuevo pedido
          </button>
        </div>
        <div id="pedidosList"></div>
      </div>

      <!-- VITRINA -->
      <div class="tab-content" id="tab-vitrina">
        <div class="t-card">
          <div class="t-title">⭐ Ramo del momento</div>
          <div class="t-sub">Se muestra destacado justo debajo del carrusel.</div>
          <div id="momentoSelected" class="selected-tag"></div>
          <input class="v-search" type="text" id="searchMomento" placeholder="Buscar ramo..." oninput="searchMomentoProducts()">
          <div class="v-prod-list" id="momentoList"></div>
        </div>
        <div class="t-card">
          <div class="t-title">🎠 Carrusel principal</div>
          <div class="t-sub">Elige hasta 5 ramos para el carrusel de portada.</div>
          <div class="hero-slots" id="heroSlots"></div>
          <input class="v-search" type="text" id="searchHero" placeholder="Buscar ramo..." oninput="searchHeroProducts()">
          <div class="v-prod-list" id="heroList"></div>
        </div>
      </div>

      <!-- BANNERS -->
      <div class="tab-content" id="tab-banners">
        <div class="t-card">
          <div class="t-title">🖼️ Banners entre categorías</div>
          <div class="t-sub">Aparecen entre secciones del catálogo.</div>
          <div id="bannerList"></div>
          <button class="btn-add-banner" onclick="addBanner()" style="margin-top:.65rem">
            <i class="ri-add-line"></i> Agregar banner
          </button>
        </div>
      </div>

      <!-- DESCUENTOS -->
      <div class="tab-content" id="tab-descuentos">
        <div class="t-card">
          <div class="t-title">🏷️ Código de descuento</div>
          <div class="t-sub">Activa un código para tus clientas.</div>
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Descuento activo</div>
              <div class="toggle-desc">Muestra el banner y permite usar el código en el carrito</div>
            </div>
            <button class="toggle" id="toggleDescuento" onclick="this.classList.toggle('on')"></button>
          </div>
          <div style="margin-top:1rem;display:flex;flex-direction:column;gap:.65rem">
            <div class="t-field"><label>Código</label><input type="text" id="descCodigo" placeholder="NUDITOS10" style="text-transform:uppercase"></div>
            <div class="t-field"><label>Porcentaje (%)</label><input type="number" id="descPorcentaje" min="1" max="90" placeholder="10"></div>
            <div class="t-field"><label>Texto del banner</label><input type="text" id="descTexto" placeholder="10% de descuento en tu primer pedido"></div>
          </div>
        </div>
      </div>

      <!-- TIENDA -->
      <div class="tab-content" id="tab-tienda">
        <div class="t-card">
          <div class="t-title">☁️ Cloudinary — Subida de imágenes</div>
          <div class="t-sub">Configura tu cuenta para subir fotos directamente desde el admin.</div>
          <div class="cloudinary-config">
            <div class="cc-title"><i class="ri-settings-3-line"></i> Credenciales de Cloudinary</div>
            <div class="cc-grid">
              <div class="cc-field"><label>Cloud Name</label><input type="text" id="ccCloudName" placeholder="mi-cuenta"></div>
              <div class="cc-field"><label>Upload Preset</label><input type="text" id="ccPreset" placeholder="nuditos_unsigned"></div>
            </div>
            <button class="cc-save" onclick="saveCloudinaryConfig()"><i class="ri-save-line"></i> Guardar configuración</button>
          </div>
        </div>
        <div class="t-card">
          <div class="t-title">💳 Wompi — Pasarela de pago</div>
          <div class="t-sub">Activa el botón de pago con tarjeta y PSE en el carrito.</div>
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Mostrar botón "Pagar con Wompi"</div>
              <div class="toggle-desc">Si está apagado, solo aparece el botón de WhatsApp</div>
            </div>
            <button class="toggle" id="toggleWompi" onclick="this.classList.toggle('on')"></button>
          </div>
          <div class="t-field" style="margin-top:.9rem">
            <label>Llave pública Wompi</label>
            <input type="text" id="wompiKey" placeholder="pub_prod_xxxxxxxxxxxx">
          </div>
        </div>
        <div class="t-card">
          <div class="t-title">📊 Meta Pixel</div>
          <div class="t-sub">Activa el seguimiento para medir tus anuncios.</div>
          <div class="toggle-row">
            <div>
              <div class="toggle-label">Meta Pixel activo</div>
              <div class="toggle-desc">Registra visitas y eventos de compra</div>
            </div>
            <button class="toggle" id="toggleMetaPixel" onclick="this.classList.toggle('on')"></button>
          </div>
          <div class="t-field" style="margin-top:.9rem">
            <label>Pixel ID</label>
            <input type="text" id="metaPixelId" placeholder="123456789012345">
          </div>
        </div>
        <div class="t-card">
          <div class="t-title">🖼️ Vista por categoría</div>
          <div class="t-sub">Elige cómo se muestran los productos de cada categoría.</div>
          <div id="catViewsList"></div>
        </div>
        <div class="t-card">
          <div class="t-title">🗄️ Supabase</div>
          <div id="sbStatus" style="background:var(--mint-light);border-radius:10px;padding:.75rem 1rem;font-size:.78rem;color:#065f46;display:flex;align-items:center;gap:.5rem">
            <span style="font-size:1rem">✅</span>
            <span>Conectado · Los cambios se guardan automáticamente</span>
          </div>
        </div>
        <div class="t-card">
          <div class="t-title">📤 Exportar datos.js</div>
          <div class="t-sub">Descarga el archivo actualizado como respaldo.</div>
          <button class="btn-save" onclick="exportDatos()"><i class="ri-download-line"></i> Descargar datos.js</button>
        </div>
      </div>
    </div>
  </div>

  <div class="save-bar">
    <div class="save-bar-msg">Recuerda <strong style="color:var(--lila)">guardar cambios</strong> para aplicarlos en la tienda</div>
    <button class="btn-save" id="globalSaveBtn" onclick="saveConfig()">
      <i class="ri-save-line"></i> Guardar cambios
    </button>
  </div>
</div>

<!-- CONFIRM DELETE -->
<div class="confirm-overlay" id="confirmOverlay">
  <div class="confirm-box">
    <div class="confirm-icon">🗑️</div>
    <div class="confirm-title">¿Eliminar producto?</div>
    <div class="confirm-msg" id="confirmMsg">Esta acción no se puede deshacer.</div>
    <div class="confirm-btns">
      <button class="conf-cancel" onclick="closeConfirm()">Cancelar</button>
      <button class="conf-ok" onclick="confirmDelete()">Sí, eliminar</button>
    </div>
  </div>
</div>

<!-- MODAL PEDIDO -->
<div class="modal-overlay" id="pedidoModal">
  <div class="modal-box">
    <div class="modal-title" id="pedidoModalTitle">Nuevo pedido</div>
    <div class="modal-sub">Registra el pedido recibido por WhatsApp</div>
    <input type="hidden" id="pedidoEditId">
    <div class="modal-field"><label>Nombre cliente</label><input type="text" id="pCliente" placeholder="Valentina García"></div>
    <div class="modal-field"><label>Teléfono / WhatsApp</label><input type="text" id="pTel" placeholder="+57 300 000 0000"></div>
    <div class="modal-field"><label>Productos pedidos</label><textarea id="pItems" placeholder="1x Ramo noche estrellada&#10;1x Maceta girasol"></textarea></div>
    <div class="modal-field"><label>Total (COP)</label><input type="number" id="pTotal" placeholder="135000" min="0"></div>
    <div class="modal-field"><label>Estado</label>
      <select id="pEstado">
        <option value="pendiente">⏳ Pendiente</option>
        <option value="proceso">🔄 En proceso</option>
        <option value="entregado">✅ Entregado</option>
        <option value="cancelado">❌ Cancelado</option>
      </select>
    </div>
    <div class="modal-field"><label>Notas</label><textarea id="pNotas" placeholder="Dirección de entrega, color preferido, etc."></textarea></div>
    <div class="modal-btns">
      <button class="btn-cancel" onclick="closePedidoModal()">Cancelar</button>
      <button class="btn-save" onclick="savePedido()"><i class="ri-save-line"></i> Guardar</button>
    </div>
  </div>
</div>

<div class="toast-admin" id="toastAdmin"></div>

<!-- Scripts — orden importante -->
<script src="/scripts/datos.js" is:inline></script>
<script src="/scripts/supabase.js" is:inline></script>
<script src="/scripts/emails.js" is:inline></script>

<script is:inline>
/* ══════════════════════════════════════════
   NUDITOS Admin v3 — Panel completo (Supabase)
   ══════════════════════════════════════════ */

let adminCfg={}, heroSelection=[], momentoSelection=null;
let adminProducts=[], selectedId=null, pendingDeleteId=null;
let editorialBannersAdmin=[], sideFilterCat='';
let pedidos=[], pedidoFilter='todos';
let uploadedImgs=[], currentEditingImgs=[];
let changeHistory=[];

/* ── LOGIN / AUTH ── */
async function doLogin(){
  const email=document.getElementById('loginEmail').value.trim();
  const pwd=document.getElementById('loginPwd').value;
  const errEl=document.getElementById('loginErr');
  errEl.style.display='none';
  if(!email||!pwd){errEl.textContent='Completa email y contraseña';errEl.style.display='block';return;}
  const btn=document.querySelector('.login-btn');
  btn.textContent='Entrando...';btn.disabled=true;
  try{
    await sbSignIn(email,pwd);
    document.getElementById('loginScreen').style.display='none';
    const p=document.getElementById('adminPanel');p.style.display='flex';
    loadAll();
  }catch(e){
    errEl.textContent='Email o contraseña incorrectos';errEl.style.display='block';
  }finally{btn.textContent='Entrar';btn.disabled=false;}
}

async function doLogout(){
  await sbSignOut();
  document.getElementById('loginScreen').style.display='flex';
  document.getElementById('adminPanel').style.display='none';
  document.getElementById('loginPwd').value='';
  document.getElementById('loginEmail').value='';
}

window.addEventListener('DOMContentLoaded',()=>{
  if(sbRestoreSession()){
    document.getElementById('loginScreen').style.display='none';
    const p=document.getElementById('adminPanel');p.style.display='flex';
    loadAll();
  }
});

/* ── SIDEBAR MÓVIL ── */
function toggleSidebar(){
  document.getElementById('leftCol').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('open');
}

/* ── TABS ── */
function showTab(name,btn){
  document.getElementById('leftCol').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('open');
  const leftVisible=(name==='productos');
  document.getElementById('leftCol').style.display=window.innerWidth>768?(leftVisible?'flex':'none'):'';
  document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.a-tab').forEach(el=>el.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  if(btn)btn.classList.add('active');
  if(name==='dashboard')renderDashboard();
  if(name==='pedidos')renderPedidosList();
}

/* ── CLOUDINARY ── */
function getCloudinaryConfig(){
  const DEFAULT={cloudName:'dzxgu27wr',preset:'ssjghh9e'};
  try{const s=localStorage.getItem('nuditos_cloudinary');const saved=s?JSON.parse(s):{};
    return{cloudName:saved.cloudName||DEFAULT.cloudName,preset:saved.preset||DEFAULT.preset};}
  catch{return DEFAULT;}
}
function saveCloudinaryConfig(){
  const cfg={cloudName:document.getElementById('ccCloudName').value.trim(),preset:document.getElementById('ccPreset').value.trim()};
  localStorage.setItem('nuditos_cloudinary',JSON.stringify(cfg));
  showToast('✓ Cloudinary configurado');
}

async function uploadToCloudinary(file){
  showUploadProgress(0);
  try{
    const signRes=await fetch('/api/cloudinary-sign',{method:'POST'});
    if(!signRes.ok)throw new Error('No se pudo obtener la firma');
    const{signature,timestamp,apiKey,cloudName,uploadPreset,folder}=await signRes.json();
    const fd=new FormData();
    fd.append('file',file);fd.append('upload_preset',uploadPreset);
    fd.append('folder',folder);fd.append('timestamp',timestamp);
    fd.append('api_key',apiKey);fd.append('signature',signature);
    showUploadProgress(30);
    const res=await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/image/upload`,{method:'POST',body:fd});
    if(!res.ok)throw new Error('Error al subir');
    const data=await res.json();
    const url=data.secure_url.replace('/upload/','/upload/w_1200,q_auto,f_auto/');
    showUploadProgress(100);setTimeout(()=>hideUploadProgress(),800);
    addToHistory(`📸 Foto subida: ${data.original_filename||'imagen'}`);
    return url;
  }catch(e){hideUploadProgress();showToast('❌ Error subiendo imagen');return null;}
}
function showUploadProgress(pct){const p=document.getElementById('uploadProgress');const b=document.getElementById('uploadProgressBar');if(p)p.style.display='block';if(b)b.style.width=pct+'%';}
function hideUploadProgress(){const p=document.getElementById('uploadProgress');if(p)p.style.display='none';}

/* ── LOAD ALL ── */
async function loadAll(){
  showToast('⏳ Cargando datos...');
  try{
    const sbProds=await sbAdminGetProducts();
    if(sbProds&&sbProds.length>0){adminProducts=sbProds;}
    else{
      adminProducts=products.map(p=>({...p}));
      showToast('⬆️ Subiendo productos a Supabase...');
      for(const p of adminProducts){try{await sbAdminSaveProduct({...p,_isNew:true});}catch(e){}}
    }
    const sbCfg=await sbAdminGetConfig_();adminCfg=sbCfg||{...CONFIG_DEFAULT};
    try{const rows=await sbAdminGetBanners_();editorialBannersAdmin=rows&&rows.length?rows:[
      {id:1,afterCat:'rosas',emoji:'🌸',title:'Flores que <em>jamás se marchitan</em>',imgUrl:''},
      {id:2,afterCat:'noche',emoji:'🌙',title:'Arte tejido <em>puntada a puntada</em>',imgUrl:''},
      {id:3,afterCat:'especial',emoji:'✨',title:'Regalos que <em>dejan huella</em>',imgUrl:''},
    ];}catch{editorialBannersAdmin=[];}
    try{pedidos=await sbAdminGetPedidos();}catch{pedidos=[];}
    try{const sh=localStorage.getItem('nuditos_history');changeHistory=sh?JSON.parse(sh):[];}catch{changeHistory=[];}
  }catch(e){
    showToast('⚠️ Error de conexión — usando datos locales');
    adminProducts=products.map(p=>({...p}));adminCfg={...CONFIG_DEFAULT};editorialBannersAdmin=[];pedidos=[];
  }
  heroSelection=[...(adminCfg.carruselHero||[])];momentoSelection=adminCfg.ramoDestacado;
  document.getElementById('descCodigo').value=adminCfg.descuentoCodigo||'';
  document.getElementById('descPorcentaje').value=adminCfg.descuentoPorcentaje||10;
  document.getElementById('descTexto').value=adminCfg.descuentoTexto||'';
  if(adminCfg.descuentoActivo)document.getElementById('toggleDescuento').classList.add('on');
  if(adminCfg.wompiActivo)document.getElementById('toggleWompi').classList.add('on');
  if(adminCfg.wompiKey)document.getElementById('wompiKey').value=adminCfg.wompiKey;
  if(adminCfg.metaPixelActivo)document.getElementById('toggleMetaPixel').classList.add('on');
  if(adminCfg.metaPixelId)document.getElementById('metaPixelId').value=adminCfg.metaPixelId;
  const cc=getCloudinaryConfig();
  if(cc.cloudName)document.getElementById('ccCloudName').value=cc.cloudName;
  if(cc.preset)document.getElementById('ccPreset').value=cc.preset;
  buildSideFilters();renderSidebar();renderStats();showEditorEmpty();
  renderHeroSlots();renderMomentoSelected();renderMomentoList(adminProducts);
  renderHeroList(adminProducts);renderCatViewsList();renderBannerList();
  showToast('✅ Todo cargado');
}

async function sbAdminGetConfig_(){
  try{const rows=await fetch(`${SB_URL}/rest/v1/config?select=clave,valor`,{headers:_h(true)}).then(r=>r.json());return sbToConfig(rows);}
  catch{return null;}
}
async function sbAdminGetBanners_(){
  try{const rows=await fetch(`${SB_URL}/rest/v1/banners?order=orden.asc`,{headers:_h(true)}).then(r=>r.json());return rows.map(sbToBanner);}
  catch{return[];}
}

/* ── SIDEBAR FILTERS ── */
function buildSideFilters(){
  const opts=[{id:'',name:'Todos',icon:'🌸'},...categories.filter(c=>c.id!=='todos')];
  document.getElementById('sideFilters').innerHTML=opts.map(c=>
    `<span class="lf-chip ${sideFilterCat===c.id?'active':''}" onclick="setSideFilter('${c.id}',this)">${c.icon} ${c.name}</span>`
  ).join('');
}
function setSideFilter(id,el){sideFilterCat=id;document.querySelectorAll('.lf-chip').forEach(c=>c.classList.remove('active'));el.classList.add('active');renderSidebar();}

/* ── STATS ── */
function renderStats(){
  const t=adminProducts.length,v=adminProducts.filter(p=>p.activo!==false).length;
  const f=adminProducts.filter(p=>p.img&&p.img.trim()).length,o=t-v;
  document.getElementById('sideStats').innerHTML=`
    <div class="ls-stat"><div class="ls-num">${t}</div><div class="ls-label">Total</div></div>
    <div class="ls-stat"><div class="ls-num green">${v}</div><div class="ls-label">Visibles</div></div>
    <div class="ls-stat"><div class="ls-num ${(t-f)>0?'red':'green'}">${f}</div><div class="ls-label">Con foto</div></div>
    <div class="ls-stat"><div class="ls-num red">${o}</div><div class="ls-label">Ocultos</div></div>`;
}

/* ── SIDEBAR LIST ── */
function renderSidebar(){
  const q=document.getElementById('sideSearch').value.toLowerCase();
  let list=adminProducts.filter(p=>{
    const mQ=!q||p.name.toLowerCase().includes(q)||(categories.find(c=>c.id===p.cat)?.name.toLowerCase().includes(q));
    const mC=!sideFilterCat||p.cat===sideFilterCat;return mQ&&mC;
  });
  const groups={};list.forEach(p=>{if(!groups[p.cat])groups[p.cat]=[];groups[p.cat].push(p);});
  let html='';
  Object.entries(groups).forEach(([catId,items])=>{
    if(!sideFilterCat){const cat=categories.find(c=>c.id===catId);html+=`<div class="cat-group-label">${cat?.icon||''} ${cat?.name||catId}</div>`;}
    items.forEach(p=>{
      const isActive=p.activo!==false;
      const tags=[];
      if(!isActive)tags.push(`<span class="pi-tag pit-oculto">Oculto</span>`);
      if(p.badge)tags.push(`<span class="pi-tag pit-badge">${p.badge}</span>`);
      if(p.oferta)tags.push(`<span class="pi-tag pit-oferta">Oferta</span>`);
      if(p.envioGratis)tags.push(`<span class="pi-tag pit-envio">Envío</span>`);
      html+=`
        <div class="prod-item ${selectedId===p.id?'selected':''} ${isActive?'':'inactive'}" onclick="selectProduct(${p.id})">
          <div class="pi-thumb">${p.img?`<img src="${p.img}" onerror="this.parentNode.innerHTML='${p.emoji}'">`:p.emoji}</div>
          <div class="pi-info">
            <div class="pi-name">${p.name}</div>
            <div class="pi-meta">${p.price>0?'$'+p.price.toLocaleString('es-CO')+' COP':'Consultar'}</div>
            ${tags.length?`<div class="pi-tags">${tags.join('')}</div>`:''}
          </div>
          <div class="pi-dot ${isActive?'on':'off'}"></div>
        </div>`;
    });
  });
  document.getElementById('sideList').innerHTML=html||`<div style="padding:1.5rem;text-align:center;color:rgba(255,255,255,.3);font-size:.76rem">No hay ramos</div>`;
}

/* ── SELECT / NEW ── */
function selectProduct(id){
  selectedId=id;renderSidebar();
  const p=adminProducts.find(x=>x.id===id);
  if(p)renderEditor(p);
  if(window.innerWidth<=768){document.getElementById('leftCol').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('open');}
}
function newProduct(){
  selectedId=null;renderSidebar();clearEditor();
  document.getElementById('tab-productos').innerHTML=buildEditorHTML(null);
  document.getElementById('editingId').value='';
  if(window.innerWidth<=768){document.getElementById('leftCol').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('open');}
}

/* ── EDITOR ── */
function showEditorEmpty(){
  document.getElementById('tab-productos').innerHTML=`
    <div class="editor-empty">
      <div class="editor-empty-icon">🌸</div>
      <h3>Selecciona un ramo</h3>
      <p>Elige un ramo de la lista para editar sus detalles, precio o fotos.</p>
    </div>`;
}
function clearEditor(){uploadedImgs=[];currentEditingImgs=[];}

function buildEditorHTML(p){
  const isNew=!p;
  const cats=categories.filter(c=>c.id!=='todos').map(c=>`<option value="${c.id}" ${p?.cat===c.id?'selected':''}>${c.icon} ${c.name}</option>`).join('');
  return `
    <input type="hidden" id="editingId" value="${p?.id||''}">
    <div class="editor-card">
      <div class="ec-header">
        <div>
          <div class="ec-title">${isNew?'Nuevo ramo':'Editando ramo'}</div>
          <div class="ec-sub" id="editorSub">${p?p.name:''}</div>
        </div>
        <div class="ec-actions">
          ${!isNew?`
            <button class="btn-vis ${p.activo!==false?'on':'off'}" id="visBtn" onclick="quickToggleVis(${p?.id})">${p.activo!==false?'👁 Visible':'🚫 Oculto'}</button>
            <button class="btn-delete" onclick="askDeleteId(${p?.id})">🗑️ Eliminar</button>
          `:''}
        </div>
      </div>
      <div class="form-grid">
        <div class="field field-full"><label>Nombre del producto *</label><input type="text" id="fNombre" value="${p?.name||''}" oninput="updatePreview()" placeholder="Ramo de rosas con mariposas"></div>
        <div class="field"><label>Precio (COP)</label><input type="number" id="fPrecio" value="${p?.price||0}" oninput="updatePreview()" min="0"></div>
        <div class="field"><label>Categoría *</label><select id="fCat" onchange="updatePreview()">${cats}</select></div>
        <div class="field"><label>Emoji (si no hay foto)</label><input type="text" id="fEmoji" value="${p?.emoji||'🌸'}" oninput="updatePreview()"></div>
        <div class="field field-full"><label>Descripción / detalles</label><textarea id="fDesc" oninput="updatePreview()" rows="2" placeholder="Envío gratis · 3 rosas + margaritas">${p?.desc||''}</textarea></div>
        <div class="field field-full"><label>Estado</label>
          <select id="fActivo" onchange="updatePreview()">
            <option value="true" ${p?.activo!==false?'selected':''}>✅ Visible en tienda</option>
            <option value="false" ${p?.activo===false?'selected':''}>🚫 Oculto</option>
          </select>
        </div>
      </div>
      <div class="img-upload-section">
        <div class="img-upload-header"><span class="img-upload-title">📸 Fotos del producto</span></div>
        <div class="cloudinary-config" id="cloudinaryConfig" style="display:none"></div>
        <div class="upload-zone" onclick="document.getElementById('fileInput').click()">
          <input type="file" id="fileInput" accept="image/*" style="display:none" onchange="handleFileUpload(this.files)">
          <div class="upload-zone-icon">📤</div>
          <div class="upload-zone-text">Clic para subir foto</div>
          <div class="upload-zone-sub">JPG, PNG, WEBP · Se optimiza automáticamente</div>
        </div>
        <div class="upload-progress" id="uploadProgress"><div class="upload-progress-bar" id="uploadProgressBar"></div></div>
        <div class="img-preview-row" id="imgPreviewRow"></div>
        <label style="font-size:.65rem;font-weight:600;color:var(--soft);text-transform:uppercase;letter-spacing:.5px;display:block;margin:.5rem 0 .25rem">O pega links de Cloudinary</label>
        <textarea class="img-url-input" id="fImgs" rows="3" placeholder="https://res.cloudinary.com/... (uno por línea)">${(p?.imgs||[]).join('\n')}</textarea>
        <div class="field" style="margin-top:.5rem"><label>Foto principal (URL)</label><input type="text" id="fImg" value="${p?.img||''}" oninput="updatePreview()" placeholder="https://res.cloudinary.com/..."></div>
      </div>
      <div class="stock-row">
        <span class="stock-icon">📦</span>
        <div class="stock-info"><div class="stock-label">Stock</div><div class="stock-sub">Cuántas unidades disponibles</div></div>
        <div class="stock-input-wrap">
          <input class="stock-num" type="number" id="fStock" value="${p?.stock??99}" min="0" max="999">
          <label class="stock-unlimited"><input type="checkbox" id="fStockUnlimited" ${p?.stock===undefined||p?.stock===null?'checked':''}> Sin límite</label>
        </div>
      </div>
      <div class="tags-label">Etiquetas</div>
      <div class="chips-row">
        <label class="chip-check"><input type="checkbox" id="fTagNuevo" ${p?.badge==='Nuevo'?'checked':''}> 🟢 Nuevo</label>
        <label class="chip-check chip-popular"><input type="checkbox" id="fTagPopular" ${p?.badge==='Popular'?'checked':''}> 🔥 Popular</label>
        <label class="chip-check chip-especial"><input type="checkbox" id="fTagEspecial" ${p?.badge==='Especial'?'checked':''}> ⭐ Especial</label>
        <label class="chip-check chip-oferta"><input type="checkbox" id="fTagOferta" ${p?.oferta?'checked':''} onchange="toggleOfertaFields()"> 🏷️ Oferta</label>
        <label class="chip-check chip-envio"><input type="checkbox" id="fTagEnvio" ${p?.envioGratis?'checked':''}> 🚚 Envío gratis</label>
      </div>
      <div id="ofertaFields" style="${p?.oferta?'display:block':''}">
        <div class="form-grid">
          <div class="field"><label>Precio original (tachado)</label><input type="number" id="fPrecioOriginal" value="${p?.precioOriginal||0}" min="0"></div>
          <div class="field"><label>Precio con oferta</label><input type="number" id="fPrecioOferta" value="${p?.precioOferta||0}" min="0"></div>
        </div>
      </div>
      <div class="preview-panel">
        <div class="preview-label">Vista previa en tienda</div>
        <div class="preview-card-wrap"><div class="preview-card" id="livePreview"></div></div>
      </div>
      <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.3rem">
        <button class="btn-save" id="saveProdBtn" onclick="saveProduct()">
          <i class="ri-save-line"></i> <span>${isNew?'Crear producto':'Guardar cambios'}</span>
        </button>
        <button class="btn-cancel" onclick="showEditorEmpty()">Cancelar</button>
      </div>
    </div>`;
}

function renderEditor(p){
  currentEditingImgs=p.imgs?[...p.imgs]:[];uploadedImgs=[];
  document.getElementById('tab-productos').innerHTML=buildEditorHTML(p);
  renderImgPreviews();updatePreview();
}
function toggleOfertaFields(){document.getElementById('ofertaFields').style.display=document.getElementById('fTagOferta').checked?'block':'none';}

/* ── IMG HANDLING ── */
async function handleFileUpload(files){
  if(!files.length)return;
  for(const file of files){
    const url=await uploadToCloudinary(file);
    if(url){currentEditingImgs.push(url);if(!document.getElementById('fImg').value)document.getElementById('fImg').value=url;renderImgPreviews();updatePreview();}
  }
}
function syncImgsFromTextarea(){const ta=document.getElementById('fImgs');if(!ta)return;const lines=ta.value.split('\n').map(l=>l.trim()).filter(l=>l.startsWith('http'));lines.forEach(url=>{if(!currentEditingImgs.includes(url))currentEditingImgs.push(url);});}
function updateImgsTextarea(){const ta=document.getElementById('fImgs');if(ta)ta.value=currentEditingImgs.join('\n');}
function renderImgPreviews(){
  const row=document.getElementById('imgPreviewRow');if(!row)return;
  row.innerHTML=currentEditingImgs.map((url,i)=>`
    <div class="img-thumb-wrap">
      <img class="img-thumb" src="${url}">
      <button class="img-thumb-rm" onclick="removeImg(${i})">×</button>
    </div>`).join('');
}
function removeImg(i){currentEditingImgs.splice(i,1);renderImgPreviews();updateImgsTextarea();updatePreview();}

/* ── LIVE PREVIEW ── */
function updatePreview(){
  const name=document.getElementById('fNombre')?.value||'Nombre del ramo';
  const price=parseInt(document.getElementById('fPrecio')?.value)||0;
  const emoji=document.getElementById('fEmoji')?.value||'🌸';
  const img=document.getElementById('fImg')?.value||'';
  const isNew=document.getElementById('fTagNuevo')?.checked;
  const isPopular=document.getElementById('fTagPopular')?.checked;
  const isEspecial=document.getElementById('fTagEspecial')?.checked;
  const isOferta=document.getElementById('fTagOferta')?.checked;
  const precioOrig=parseInt(document.getElementById('fPrecioOriginal')?.value)||0;
  const catId=document.getElementById('fCat')?.value;
  const cat=categories.find(c=>c.id===catId);
  const isActive=document.getElementById('fActivo')?.value==='true';
  const badge=isNew?'Nuevo':isPopular?'Popular':isEspecial?'Especial':'';
  const badgeCls=isNew?'nuevo':isPopular?'popular':isEspecial?'especial':'';
  let origHtml='';
  if(isOferta&&precioOrig>0&&price>0)origHtml=`<span class="orig">$${precioOrig.toLocaleString('es-CO')}</span>`;
  const preview=document.getElementById('livePreview');if(!preview)return;
  preview.innerHTML=`
    <div class="preview-img">
      ${img?`<img src="${img}" onerror="this.remove()">`:`<span>${emoji}</span>`}
      ${badge?`<div class="preview-badge ${badgeCls}">${badge}</div>`:''}
      ${!isActive?`<div class="preview-badge agotado">Oculto</div>`:''}
    </div>
    <div class="preview-info">
      <div class="preview-cat">${cat?.icon||''} ${cat?.name||'Categoría'}</div>
      <div class="preview-name">${name}</div>
      <div class="preview-price">${origHtml}${price>0?'$'+price.toLocaleString('es-CO')+' COP':'Consultar'}</div>
    </div>`;
}

/* ── SAVE PRODUCT ── */
async function saveProduct(){
  const nombre=document.getElementById('fNombre')?.value.trim();
  const precio=parseInt(document.getElementById('fPrecio')?.value)||0;
  const cat=document.getElementById('fCat')?.value;
  const emoji=document.getElementById('fEmoji')?.value.trim()||'🌸';
  const desc=document.getElementById('fDesc')?.value.trim()||'';
  const img=document.getElementById('fImg')?.value.trim()||'';
  syncImgsFromTextarea();const imgs=[...currentEditingImgs];
  const activo=document.getElementById('fActivo')?.value==='true';
  const editId=document.getElementById('editingId')?.value;
  const tagNuevo=document.getElementById('fTagNuevo')?.checked;
  const tagPopular=document.getElementById('fTagPopular')?.checked;
  const tagEspecial=document.getElementById('fTagEspecial')?.checked;
  const tagOferta=document.getElementById('fTagOferta')?.checked;
  const tagEnvio=document.getElementById('fTagEnvio')?.checked;
  const stockUnlimited=document.getElementById('fStockUnlimited')?.checked;
  const stockVal=parseInt(document.getElementById('fStock')?.value);
  const stock=stockUnlimited?undefined:(isNaN(stockVal)?undefined:stockVal);
  let badge='',badgeClass='';
  if(tagNuevo){badge='Nuevo';badgeClass='nuevo';}else if(tagPopular){badge='Popular';}else if(tagEspecial){badge='Especial';}
  const precioOriginal=parseInt(document.getElementById('fPrecioOriginal')?.value)||0;
  const precioOferta=parseInt(document.getElementById('fPrecioOferta')?.value)||0;
  if(!nombre){showToast('⚠️ El nombre es obligatorio');return;}
  if(!cat){showToast('⚠️ Selecciona una categoría');return;}
  const data={name:nombre,price:precio,cat,emoji,desc,img,imgs,badge,badgeClass,activo,oferta:tagOferta,envioGratis:tagEnvio,stock,precioOriginal:tagOferta?precioOriginal:0,precioOferta:tagOferta?precioOferta:0};
  const btn=document.getElementById('saveProdBtn');
  if(btn){btn.disabled=true;btn.querySelector('span').textContent='Guardando...';}
  try{
    if(editId&&editId!==''){
      data.id=parseInt(editId);
      await sbAdminSaveProduct({...data,_isNew:false});
      const idx=adminProducts.findIndex(p=>p.id===parseInt(editId));
      if(idx!==-1)adminProducts[idx]={...adminProducts[idx],...data};
      selectedId=parseInt(editId);
      showToast(`✓ "${nombre}" actualizado`);addToHistory(`✏️ Editado: ${nombre}`);
    }else{
      const saved=await sbAdminSaveProduct({...data,_isNew:true});
      if(saved){adminProducts.push({...data,id:saved.id});selectedId=saved.id;document.getElementById('editingId').value=saved.id;}
      showToast(`✓ "${nombre}" creado`);addToHistory(`➕ Agregado: ${nombre}`);
    }
    renderSidebar();renderStats();renderMomentoList(adminProducts);renderHeroList(adminProducts);
    try{localStorage.removeItem('nuditos_sb_data');localStorage.removeItem('nuditos_sb_ts');}catch{}
    if(btn){btn.classList.add('saved');btn.querySelector('span').textContent='¡Guardado!';}
    setTimeout(()=>{const b=document.getElementById('saveProdBtn');if(b){b.classList.remove('saved');b.querySelector('span').textContent='Guardar cambios';}},1800);
  }catch(e){showToast('❌ Error guardando');if(btn)btn.querySelector('span').textContent='Guardar cambios';}
  finally{if(btn)btn.disabled=false;}
}

/* ── VIS / DELETE ── */
async function quickToggleVis(id){
  const idx=adminProducts.findIndex(p=>p.id===id);if(idx===-1)return;
  adminProducts[idx].activo=!(adminProducts[idx].activo!==false);
  try{await sbAdminSaveProduct({...adminProducts[idx],_isNew:false});renderSidebar();renderStats();const p=adminProducts[idx];const btn=document.getElementById('visBtn');if(btn){btn.className=`btn-vis ${p.activo!==false?'on':'off'}`;btn.textContent=p.activo!==false?'👁 Visible':'🚫 Oculto';}addToHistory(`${p.activo!==false?'👁':'🚫'} ${p.name}`);showToast(p.activo!==false?'✓ Visible':'🚫 Oculto');}catch{showToast('❌ Error');}
}
function askDeleteId(id){pendingDeleteId=id;const p=adminProducts.find(x=>x.id===id);document.getElementById('confirmMsg').textContent=`¿Eliminar "${p?.name||''}"?`;document.getElementById('confirmOverlay').classList.add('open');}
function closeConfirm(){document.getElementById('confirmOverlay').classList.remove('open');pendingDeleteId=null;}
async function confirmDelete(){
  if(!pendingDeleteId)return;
  const idx=adminProducts.findIndex(p=>p.id===pendingDeleteId);const name=adminProducts[idx]?.name;
  try{await sbAdminDeleteProduct(pendingDeleteId);if(idx!==-1)adminProducts.splice(idx,1);heroSelection=heroSelection.filter(id=>id!==pendingDeleteId);if(momentoSelection===pendingDeleteId)momentoSelection=adminProducts[0]?.id||null;selectedId=null;renderSidebar();renderStats();renderHeroSlots();renderMomentoList(adminProducts);renderHeroList(adminProducts);addToHistory(`🗑️ Eliminado: ${name}`);showEditorEmpty();closeConfirm();showToast(`🗑️ "${name}" eliminado`);}
  catch{showToast('❌ Error eliminando');}
}

/* ── PEDIDOS ── */
function openNewPedido(){document.getElementById('pedidoEditId').value='';document.getElementById('pedidoModalTitle').textContent='Nuevo pedido';['pCliente','pTel','pItems','pTotal','pNotas'].forEach(id=>document.getElementById(id).value='');document.getElementById('pEstado').value='pendiente';document.getElementById('pedidoModal').classList.add('open');}
function openEditPedido(id){const p=pedidos.find(x=>x.id===id);if(!p)return;document.getElementById('pedidoEditId').value=p.id;document.getElementById('pedidoModalTitle').textContent='Editar pedido';document.getElementById('pCliente').value=p.cliente||'';document.getElementById('pTel').value=p.tel||'';document.getElementById('pItems').value=p.items||'';document.getElementById('pTotal').value=p.total||'';document.getElementById('pEstado').value=p.estado||'pendiente';document.getElementById('pNotas').value=p.notas||'';document.getElementById('pedidoModal').classList.add('open');}
function closePedidoModal(){document.getElementById('pedidoModal').classList.remove('open');}
async function savePedido(){
  const editId=document.getElementById('pedidoEditId').value;
  const data={cliente:document.getElementById('pCliente').value.trim(),tel:document.getElementById('pTel').value.trim(),items:document.getElementById('pItems').value.trim(),total:parseInt(document.getElementById('pTotal').value)||0,estado:document.getElementById('pEstado').value,notas:document.getElementById('pNotas').value.trim()};
  if(!data.cliente){showToast('⚠️ El nombre es obligatorio');return;}
  try{
    if(editId){const saved=await sbAdminSavePedido({...data,id:parseInt(editId),_isNew:false});const idx=pedidos.findIndex(p=>p.id===parseInt(editId));if(idx!==-1)pedidos[idx]={...pedidos[idx],...data,id:parseInt(editId)};showToast('✓ Pedido actualizado');}
    else{const saved=await sbAdminSavePedido({...data,_isNew:true});if(saved)pedidos.unshift(saved);showToast('✓ Pedido registrado');addToHistory(`📦 Pedido: ${data.cliente}`);}
    closePedidoModal();renderPedidosList();
  }catch{showToast('❌ Error guardando pedido');}
}
async function cambiarEstadoPedido(id,estado){
  const idx=pedidos.findIndex(p=>p.id===id);if(idx===-1)return;
  try{await sbAdminUpdateEstadoPedido(id,estado);pedidos[idx].estado=estado;renderPedidosList();showToast('✓ Estado actualizado');}
  catch{showToast('❌ Error');}
}
async function deletePedido(id){
  try{await sbAdminDeletePedido(id);pedidos=pedidos.filter(p=>p.id!==id);renderPedidosList();showToast('🗑️ Pedido eliminado');}
  catch{showToast('❌ Error');}
}
function filterPedidos(f,btn){pedidoFilter=f;document.querySelectorAll('.pedido-filter').forEach(b=>b.classList.remove('active'));btn.classList.add('active');renderPedidosList();}
function renderPedidosList(){
  const list=pedidoFilter==='todos'?pedidos:pedidos.filter(p=>p.estado===pedidoFilter);
  const eLabels={pendiente:'⏳ Pendiente',proceso:'🔄 En proceso',entregado:'✅ Entregado',cancelado:'❌ Cancelado'};
  const eCls={pendiente:'estado-pendiente',proceso:'estado-proceso',entregado:'estado-entregado',cancelado:'estado-cancelado'};
  document.getElementById('pedidosList').innerHTML=list.length?list.map(p=>`
    <div class="pedido-card">
      <div class="pedido-top"><div class="pedido-id">#${String(p.id).slice(-6)}</div><span class="pedido-estado ${eCls[p.estado]||'estado-pendiente'}">${eLabels[p.estado]||p.estado}</span></div>
      <div class="pedido-cliente">${p.cliente}</div>
      <div class="pedido-items">${p.items||'—'}</div>
      ${p.notas?`<div style="font-size:.7rem;color:var(--soft);margin-top:.2rem;font-style:italic">📝 ${p.notas}</div>`:''}
      <div class="pedido-bottom"><div class="pedido-total">${p.total>0?'$'+p.total.toLocaleString('es-CO')+' COP':'Sin total'}</div><div class="pedido-fecha">${p.fecha||''}</div></div>
      <div class="pedido-actions">
        ${p.tel?`<button class="p-action-btn primary" onclick="window.open('https://wa.me/${p.tel.replace(/\D/g,'')}','_blank')"><i class="ri-whatsapp-line"></i> WhatsApp</button>`:''}
        <button class="p-action-btn" onclick="openEditPedido(${p.id})">✏️ Editar</button>
        ${p.estado!=='proceso'?`<button class="p-action-btn" onclick="cambiarEstadoPedido(${p.id},'proceso')">🔄 En proceso</button>`:''}
        ${p.estado!=='entregado'?`<button class="p-action-btn" onclick="cambiarEstadoPedido(${p.id},'entregado')">✅ Entregado</button>`:''}
        <button class="p-action-btn" style="color:var(--red)" onclick="deletePedido(${p.id})">🗑️</button>
      </div>
    </div>`).join(''):`<div style="text-align:center;padding:3rem 1rem;color:var(--soft);font-size:.85rem">No hay pedidos</div>`;}

/* ── DASHBOARD ── */
function renderDashboard(){
  const total=adminProducts.length,visibles=adminProducts.filter(p=>p.activo!==false).length;
  const sinFoto=adminProducts.filter(p=>!p.img||!p.img.trim()).length;
  const totalPedidos=pedidos.length,pendientes=pedidos.filter(p=>p.estado==='pendiente').length;
  const entregados=pedidos.filter(p=>p.estado==='entregado').length;
  document.getElementById('dashStats').innerHTML=`
    <div class="dash-stat"><div class="dash-num">${total}</div><div class="dash-label">Ramos en catálogo</div></div>
    <div class="dash-stat"><div class="dash-num green">${visibles}</div><div class="dash-label">Visibles en tienda</div></div>
    <div class="dash-stat"><div class="dash-num orange">${sinFoto}</div><div class="dash-label">Sin foto</div></div>
    <div class="dash-stat"><div class="dash-num">${totalPedidos}</div><div class="dash-label">Pedidos registrados</div></div>
    <div class="dash-stat"><div class="dash-num orange">${pendientes}</div><div class="dash-label">Pendientes</div></div>
    <div class="dash-stat"><div class="dash-num green">${entregados}</div><div class="dash-label">Entregados</div></div>`;
  const topByPrice=[...adminProducts].filter(p=>p.activo!==false).sort((a,b)=>b.price-a.price).slice(0,6);
  const maxP=topByPrice[0]?.price||1;
  document.getElementById('viewsChart').innerHTML=topByPrice.map(p=>`
    <div class="bar-row"><div class="bar-name">${p.emoji} ${p.name}</div><div class="bar-track"><div class="bar-fill" style="width:${(p.price/maxP*100).toFixed(0)}%"></div></div><div class="bar-val">$${Math.round(p.price/1000)}k</div></div>`).join('');
  const counts={};pedidos.forEach(p=>{(p.items||'').split('\n').forEach(line=>{const m=line.match(/\d+x (.+)/);if(m)counts[m[1]]=(counts[m[1]]||0)+1;});});
  const topItems=Object.entries(counts).sort((a,b)=>b[1]-a[1]).slice(0,5);
  const maxC=topItems[0]?.[1]||1;
  document.getElementById('cartChart').innerHTML=topItems.length?topItems.map(([name,cnt])=>`
    <div class="bar-row"><div class="bar-name">${name}</div><div class="bar-track"><div class="bar-fill" style="width:${(cnt/maxC*100).toFixed(0)}%;background:var(--mint)"></div></div><div class="bar-val">${cnt}</div></div>`).join(''):`<div style="font-size:.78rem;color:var(--soft);padding:.5rem 0">Registra pedidos para ver estadísticas aquí</div>`;
  document.getElementById('histList').innerHTML=changeHistory.length?[...changeHistory].reverse().slice(0,20).map(h=>`
    <div class="hist-item"><div class="hist-dot"></div><div><div class="hist-action">${h.action}</div><div class="hist-time">${h.time}</div></div></div>`).join(''):`<div style="font-size:.78rem;color:var(--soft);padding:.5rem 0">Los cambios aparecerán aquí</div>`;
}

/* ── HISTORY ── */
function addToHistory(action){
  changeHistory.push({action,time:new Date().toLocaleString('es-CO',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})});
  if(changeHistory.length>50)changeHistory.shift();
  try{localStorage.setItem('nuditos_history',JSON.stringify(changeHistory));}catch{}
}

/* ── VITRINA ── */
function renderMomentoSelected(){const p=momentoSelection?adminProducts.find(x=>x.id===momentoSelection):null;document.getElementById('momentoSelected').textContent=p?`✅ Seleccionado: ${p.emoji} ${p.name}`:'Sin seleccionar';}
function renderMomentoList(list){const q=document.getElementById('searchMomento')?.value.toLowerCase()||'';const filtered=list.filter(p=>!q||p.name.toLowerCase().includes(q));document.getElementById('momentoList').innerHTML=filtered.map(p=>`<div class="v-prod-row"><div class="v-thumb">${p.img?`<img src="${p.img}">`:p.emoji}</div><div class="v-info"><div class="v-name">${p.name}</div><div class="v-price">${p.price>0?'$'+p.price.toLocaleString('es-CO')+' COP':'Consultar'}</div></div><button class="btn-select ${momentoSelection===p.id?'sel':''}" onclick="selectMomento(${p.id})">${momentoSelection===p.id?'✓ Seleccionado':'Seleccionar'}</button></div>`).join('');}
function selectMomento(id){momentoSelection=id;renderMomentoSelected();renderMomentoList(adminProducts);}
function searchMomentoProducts(){renderMomentoList(adminProducts);}

function renderHeroSlots(){document.getElementById('heroSlots').innerHTML=heroSelection.map(id=>{const p=adminProducts.find(x=>x.id===id);if(!p)return'';return`<div class="hero-slot filled" onclick="removeFromHero(${id})"><div style="font-size:1.4rem">${p.img?`<img src="${p.img}" style="width:100%;height:50px;object-fit:cover;border-radius:4px">`:p.emoji}</div><div class="hero-slot-name">${p.name.slice(0,20)}</div></div>`;}).join('')+`<div class="hero-slot" style="cursor:default">+ Agrega desde abajo</div>`;}
function renderHeroList(list){const q=document.getElementById('searchHero')?.value.toLowerCase()||'';const filtered=list.filter(p=>!q||p.name.toLowerCase().includes(q));document.getElementById('heroList').innerHTML=filtered.map(p=>`<div class="v-prod-row"><div class="v-thumb">${p.img?`<img src="${p.img}">`:p.emoji}</div><div class="v-info"><div class="v-name">${p.name}</div><div class="v-price">${p.price>0?'$'+p.price.toLocaleString('es-CO')+' COP':'Consultar'}</div></div><button class="btn-select ${heroSelection.includes(p.id)?'sel':''}" onclick="toggleHero(${p.id})">${heroSelection.includes(p.id)?'✓ En carrusel':'+ Agregar'}</button></div>`).join('');}
function toggleHero(id){if(heroSelection.includes(id)){removeFromHero(id);}else{if(heroSelection.length>=5){showToast('⚠️ Máximo 5 en el carrusel');return;}heroSelection.push(id);}renderHeroSlots();renderHeroList(adminProducts);}
function removeFromHero(id){heroSelection=heroSelection.filter(x=>x!==id);renderHeroSlots();renderHeroList(adminProducts);}
function searchHeroProducts(){renderHeroList(adminProducts);}

/* ── BANNERS ── */
function renderBannerList(){document.getElementById('bannerList').innerHTML=editorialBannersAdmin.map((b,i)=>`<div class="banner-item"><div class="banner-preview">${b.imgUrl?`<img src="${b.imgUrl}">`:`<div class="banner-preview-ph">${b.emoji}</div>`}</div><div class="banner-fields"><label class="bf-label">Después de</label><select class="bf-select" onchange="updateBanner(${i},'afterCat',this.value)">${categories.filter(c=>c.id!=='todos').map(c=>`<option value="${c.id}" ${b.afterCat===c.id?'selected':''}>${c.icon} ${c.name}</option>`).join('')}</select><label class="bf-label">Título (HTML)</label><input class="bf-input" value="${b.title||''}" oninput="updateBanner(${i},'title',this.value)"><label class="bf-label">Emoji</label><input class="bf-input" value="${b.emoji||'🌸'}" oninput="updateBanner(${i},'emoji',this.value)" style="width:60px"><label class="bf-label">Imagen fondo (URL)</label><input class="bf-input" value="${b.imgUrl||''}" oninput="updateBanner(${i},'imgUrl',this.value)" placeholder="https://..."></div><button class="btn-rm" onclick="removeBanner(${i})">✕</button></div>`).join('');}
function updateBanner(i,key,val){editorialBannersAdmin[i][key]=val;}
function addBanner(){editorialBannersAdmin.push({afterCat:'rosas',emoji:'🌸',title:'Tu mensaje aquí',imgUrl:''});renderBannerList();}
function removeBanner(i){editorialBannersAdmin.splice(i,1);renderBannerList();}

/* ── VISTAS POR CATEGORÍA ── */
function renderCatViewsList(){const views=['carousel','grid','list'];document.getElementById('catViewsList').innerHTML=categories.filter(c=>c.id!=='todos').map(c=>`<div class="toggle-row" style="align-items:center"><div><div class="toggle-label">${c.icon} ${c.name}</div></div><select class="view-select" data-cat="${c.id}">${views.map(v=>`<option value="${v}" ${(adminCfg.catViews?.[c.id]||'carousel')===v?'selected':''}>${v==='carousel'?'Carrusel':v==='grid'?'Cuadrícula':'Lista'}</option>`).join('')}</select></div>`).join('');}

/* ── GUARDAR CONFIG ── */
async function saveConfig(){
  if(heroSelection.length===0){showToast('⚠️ Agrega al menos 1 ramo al carrusel');return;}
  if(!momentoSelection){showToast('⚠️ Selecciona el ramo del momento');return;}
  const catViews={};document.querySelectorAll('.view-select').forEach(sel=>{catViews[sel.dataset.cat]=sel.value;});
  const newCfg={ramoDestacado:momentoSelection,carruselHero:heroSelection.filter(id=>adminProducts.find(p=>p.id===id)),descuentoActivo:document.getElementById('toggleDescuento').classList.contains('on'),descuentoCodigo:document.getElementById('descCodigo').value.trim().toUpperCase(),descuentoPorcentaje:parseInt(document.getElementById('descPorcentaje').value)||10,descuentoTexto:document.getElementById('descTexto').value.trim(),wompiActivo:document.getElementById('toggleWompi').classList.contains('on'),wompiKey:document.getElementById('wompiKey').value.trim(),metaPixelActivo:document.getElementById('toggleMetaPixel').classList.contains('on'),metaPixelId:document.getElementById('metaPixelId').value.trim(),catViews};
  const btn=document.getElementById('globalSaveBtn');btn.innerHTML='<i class="ri-loader-line"></i> Guardando...';btn.disabled=true;
  try{
    await sbAdminSaveConfig(newCfg);
    await sbAdminSaveBanners(editorialBannersAdmin);
    adminCfg=newCfg;
    addToHistory('💾 Config guardada en Supabase');
    btn.innerHTML='<i class="ri-check-line"></i> ¡Guardado!';btn.classList.add('saved');
    showToast('✅ Cambios guardados en Supabase');
    try{localStorage.removeItem('nuditos_sb_data');localStorage.removeItem('nuditos_sb_ts');}catch{}
  }catch(e){showToast('❌ Error guardando');btn.innerHTML='<i class="ri-save-line"></i> Guardar cambios';}
  finally{btn.disabled=false;setTimeout(()=>{const b=document.getElementById('globalSaveBtn');if(b){b.innerHTML='<i class="ri-save-line"></i> Guardar cambios';b.classList.remove('saved');}},2200);}
}

/* ── EXPORT ── */
function exportDatos(){
  const content=`/* NUDITOS — datos.js exportado ${new Date().toLocaleDateString('es-CO')} */\n\nconst CONFIG_DEFAULT = ${JSON.stringify(adminCfg,null,2)};\n\nconst categories = ${JSON.stringify(categories,null,2)};\n\nconst products = ${JSON.stringify(adminProducts,null,2)};\n`;
  const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([content],{type:'text/javascript'}));a.download='datos.js';a.click();
  showToast('📤 datos.js descargado');
}

/* ── TOAST ── */
function showToast(msg){const t=document.getElementById('toastAdmin');t.textContent=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2400);}
</script>
</body>
</html>
