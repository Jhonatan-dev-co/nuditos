    function editCategory(id) {
      const c = adminCategories.find(x => x.id === id);
      if (!c) return;
      const total   = adminProducts.filter(p=>p.cat===id).length;
      const visibles = adminProducts.filter(p=>p.cat===id&&p.activo!==false).length;
      document.getElementById('catModalTitle').textContent = 'Editar categoría';
      document.getElementById('catModalSub').textContent = `Actualizando: ${c.nombre||c.name}`;
      document.getElementById('catEditId').value = id;
      document.getElementById('catId').value = id;
      document.getElementById('catId').disabled = true;
      document.getElementById('catNombre').value = c.nombre || c.name || '';
      document.getElementById('catIcon').value = c.icon || '🌸';
      document.getElementById('catOrden').value = c.orden || 1;
      document.getElementById('catShowInHome').value = c.showInHome !== false ? 'true' : 'false';
      // Mostrar stats de productos
      document.getElementById('catStatsRow').style.display = 'flex';
      document.getElementById('catStatTotal').textContent = total;
      document.getElementById('catStatVisible').textContent = visibles;
      document.getElementById('catStatOcultos').textContent = total - visibles;
      document.getElementById('emojiPickerPanel').classList.remove('open');
      loadEmojiGrid('flores');
      document.getElementById('catModal').classList.add('open');
    }

    function closeCatModal() {
      document.getElementById('catModal').classList.remove('open');
      document.getElementById('emojiPickerPanel').classList.remove('open');
    }

    async function saveCategory() {
      const id = document.getElementById('catId').value.trim().toLowerCase().replace(/[^a-z0-9-]/g,'-');
      const nombre = document.getElementById('catNombre').value.trim();
      const icon   = document.getElementById('catIcon').value.trim();
      const orden  = parseInt(document.getElementById('catOrden').value) || adminCategories.length + 1;
      const showInHome = document.getElementById('catShowInHome').value === 'true';
      if (!id || !nombre) { showToast('⚠️ ID y nombre son obligatorios'); return; }
      const data = { id, nombre, icon, orden, showInHome, activo: true };
      const isNew = !document.getElementById('catEditId').value;
      const btn = document.getElementById('catSaveBtn');
      if(btn){btn.disabled=true;btn.textContent='⏳ Guardando...';}
      try {
        await sbAdminSaveCategory(data, isNew);
        if (isNew) {
          adminCategories.push(data);
        } else {
          const idx = adminCategories.findIndex(c=>c.id===id);
          if(idx!==-1) adminCategories[idx] = {...adminCategories[idx], ...data};
        }
        adminCategories.sort((a,b)=>(a.orden||0)-(b.orden||0));
        buildSideFilters();
        renderCategoriasList();
        closeCatModal();
        showToast(`✓ Categoría ${isNew?'creada':'actualizada'}`);
        addToHistory(`📁 Categoría ${isNew?'creada':'editada'}: ${nombre}`);
      } catch {
        showToast('❌ Error al guardar');
      } finally {
        if(btn){btn.disabled=false;btn.textContent='Guardar categoría';}
      }
    }
    async function deleteCategory(id) {
      const cat = adminCategories.find(c=>c.id===id);
      const label = cat?.nombre || cat?.name || id;
      const prods = adminProducts.filter(p=>p.cat===id);
      const msg = prods.length
        ? `¿Eliminar la categoría "${label}" y sus ${prods.length} producto${prods.length>1?'s':''}? Todo se borrará permanentemente.`
        : `¿Eliminar la categoría vacía "${label}"?`;
      if(!confirm(msg)) return;

      // Eliminar productos con progreso visible
      if(prods.length > 0){
        for(let i=0; i<prods.length; i++){
          showToast(`⏳ Eliminando productos ${i+1} de ${prods.length}...`);
          const p = prods[i];
          try{ await sbAdminDeleteProduct(p.id); adminProducts=adminProducts.filter(x=>x.id!==p.id); }catch{}
        }
      }

      // Eliminar la categoría
      try {
        await sbAdminDeleteCategory(id);
        adminCategories = adminCategories.filter(c=>c.id!==id);
        if(sideFilterCat===id) { sideFilterCat=''; selectedProducts.clear(); }
        buildSideFilters();
        renderCategoriasList();
        renderSidebar(); renderStats(); updateBulkBar();
        if(selectedId && !adminProducts.find(p=>p.id===selectedId)) { selectedId=null; showEditorEmpty(); }
        const msg2 = prods.length ? `🗑️ Categoría y ${prods.length} producto${prods.length>1?'s':''} eliminados` : '🗑️ Categoría eliminada';
        showToast(msg2);
        addToHistory(`🗑️ Eliminada: ${label} (${prods.length} productos)`);
      } catch { showToast('❌ Error al eliminar la categoría'); }
    }

