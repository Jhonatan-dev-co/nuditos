---
import Icon from '../components/Icon.astro';
/**
 * Panel de administración — Nuditos Tejidos v2 (Refactored)
 * URL: /admin
 * No usa el Layout principal — tiene su propio diseño modular
 * noindex para que Google no lo indexe
 */
export const prerender = false;

import AdminLayout from '../layouts/AdminLayout.astro';
import AdminNav from '../components/admin/AdminNav.astro';
import AdminSidebar from '../components/admin/AdminSidebar.astro';
import ProductsTab from '../components/admin/ProductsTab.astro';
import DashboardTab from '../components/admin/DashboardTab.astro';
import OrdersTab from '../components/admin/OrdersTab.astro';
// import CategoriesTab from '../components/admin/CategoriesTab.astro'; // Eliminado, ahora embebido en productos
import VitrinaTab from '../components/admin/VitrinaTab.astro';
import BannersTab from '../components/admin/BannersTab.astro';
import DiscountsTab from '../components/admin/DiscountsTab.astro';
import BlogTab from '../components/admin/BlogTab.astro';
import SEOTab from '../components/admin/SEOTab.astro';
import SettingsTab from '../components/admin/SettingsTab.astro';
import Modals from '../components/admin/Modals.astro';

Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate');
---

<AdminLayout title="Nuditos — Panel Admin">
  <!-- LOGIN SECTION -->
  <div id="loginScreen">
    <div class="login-card">
      <div class="login-logo">Nuditos<em style="color:#6d28d9">.</em></div>
      <div class="login-sub">Panel de administración</div>
      <input class="login-input" type="email" id="loginEmail" placeholder="tu@correo.com"
        style="letter-spacing:0;margin-bottom:.6rem"
        onkeydown="if(event.key==='Enter')doLogin()">
      <input class="login-input" type="password" id="loginPwd" placeholder="••••••••"
        onkeydown="if(event.key==='Enter')doLogin()">
      <button class="login-btn" onclick="doLogin()">Entrar</button>
      <div class="login-err" id="loginErr">Email o contraseña incorrectos</div>
    </div>
  </div>

  <!-- MAIN ADMIN PANEL -->
  <div id="adminPanel">
    <AdminNav />

    <div class="workspace" id="workspace">
      <AdminSidebar />

      <div id="rightArea" style="flex:1;overflow:hidden;display:flex;flex-direction:column">
        <ProductsTab />
        <DashboardTab />
        <OrdersTab />
        <!-- <CategoriesTab /> -->
        <VitrinaTab />
        <BannersTab />
        <DiscountsTab />
        <BlogTab />
        <SEOTab />
        <SettingsTab />
      </div>
    </div>

    <!-- GLOBAL SAVE BAR -->
    <div class="save-bar">
      <div class="save-bar-msg">Recuerda <strong style="color:var(--lila)">guardar cambios</strong> para aplicarlos en la tienda</div>
      <button class="btn-save" id="globalSaveBtn" onclick="saveConfig()">
        <Icon name="save"  /> Guardar cambios
      </button>
    </div>
  </div>

  <!-- MODALS & FEEDBACK -->
  <Modals />

  <!-- ══════════════════════════════════════════
       NUDITOS Admin Logic — Core JS
       ══════════════════════════════════════════ -->
  <script is:inline>
    let adminCfg={}, heroSelection=[], momentoSelection=null;
    let adminProducts=[], selectedId=null, pendingDeleteId=null;
    let editorialBannersAdmin=[], sideFilterCat='';
    let pedidos=[], pedidoFilter='todos';
    let adminCategories=[];
    let uploadedImgs=[], currentEditingImgs=[];
    let changeHistory=[];
    let selectedProducts = new Set(); // Para selección múltiple

    /* ── AUTH / LOGIN ── */
    async function doLogin(){
      const email=document.getElementById('loginEmail').value.trim();
      const pwd=document.getElementById('loginPwd').value;
      const errEl=document.getElementById('loginErr');
      errEl.style.display='none';
      if(!email||!pwd){errEl.textContent='Completa email y contraseña';errEl.style.display='block';return;}
      const btn=document.querySelector('.login-btn');
      btn.textContent='Entrando...';btn.disabled=true;
      try{
        await sbSignIn(email,pwd);
        document.getElementById('loginScreen').style.display='none';
        const p=document.getElementById('adminPanel');p.style.display='flex';
        loadAll();
      }catch(e){
        errEl.textContent='Email o contraseña incorrectos';errEl.style.display='block';
      }finally{btn.textContent='Entrar';btn.disabled=false;}
    }

    async function doLogout(){
      await sbSignOut();
      document.getElementById('loginScreen').style.display='flex';
      document.getElementById('adminPanel').style.display='none';
      document.getElementById('loginPwd').value='';
      document.getElementById('loginEmail').value='';
    }

    window.addEventListener('DOMContentLoaded',()=>{
      if(sbRestoreSession()){
        document.getElementById('loginScreen').style.display='none';
        const p=document.getElementById('adminPanel');p.style.display='flex';
        loadAll();
      }
    });

    /* ── UI HELPERS ── */
    function toggleSidebar(){
      document.getElementById('leftCol').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('open');
    }

    function showTab(name,btn){
      document.getElementById('leftCol').classList.remove('open');
      document.getElementById('sidebarOverlay').classList.remove('open');
      const leftVisible=(name==='productos');
      document.getElementById('leftCol').style.display=window.innerWidth>768?(leftVisible?'flex':'none'):'';
      document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
      document.querySelectorAll('.a-tab').forEach(el=>el.classList.remove('active'));
      document.getElementById('tab-'+name).classList.add('active');
      if(btn)btn.classList.add('active');
      if(name==='dashboard')renderDashboard();
      if(name==='pedidos')renderPedidosList();
      if(name==='blog')loadPosts();
    }

    /* ── CLOUDINARY ── */
    function getCloudinaryConfig(){
      const DEFAULT={cloudName:'dzxgu27wr',preset:'ssjghh9e'};
      try{const s=localStorage.getItem('nuditos_cloudinary');const saved=s?JSON.parse(s):{};
        return{cloudName:saved.cloudName||DEFAULT.cloudName,preset:saved.preset||DEFAULT.preset};}
      catch{return DEFAULT;}
    }
    function saveCloudinaryConfig(){
      const cfg={cloudName:document.getElementById('ccCloudName').value.trim(),preset:document.getElementById('ccPreset').value.trim()};
      localStorage.setItem('nuditos_cloudinary',JSON.stringify(cfg));
      showToast('✓ Cloudinary configurado');
    }

    function slugifyClient(text){
      return (text || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').trim() || 'nuditos-foto';
    }

    async function uploadToCloudinary(file, baseNameOverride = null, idx = 0){
      showUploadProgress(0);
      try{
        // Renombre Dinámico para SEO con inyección de palabras clave avanzadas
        const nombreInput = document.getElementById('fNombre');
        const metaTitleInput = document.getElementById('fMetaTitle');
        const keywordsInput = document.getElementById('fSeoKeywords');
        
        let baseText = (metaTitleInput && metaTitleInput.value.trim()) ? metaTitleInput.value : (nombreInput ? nombreInput.value : '');
        if (keywordsInput && keywordsInput.value.trim()) {
          // Extraemos las primeras palabras clave para no hacer el nombre de archivo excesivamente largo
          const kws = keywordsInput.value.split(',').map(s=>s.trim()).slice(0,3).join('-');
          baseText += '-' + kws;
        }
        
        const defaultBaseName = slugifyClient(baseText);
        const baseName = baseNameOverride ? slugifyClient(baseNameOverride) : defaultBaseName;
        
        // Agregamos palabras clave universales a la URL de la foto automáticamente
        const seoSuffix = 'ramo-tejido-crochet';
        const randomId = Math.random().toString(36).substring(2, 6);
        
        // Limitar tamaño final del publicId para evitar errores en SO
        let publicId = `${baseName}-${seoSuffix}-${randomId}${idx > 0 ? ('-'+idx) : ''}`;
        if (publicId.length > 200) publicId = publicId.substring(0, 200);

        const signRes=await fetch('/api/cloudinary-sign',{
          method:'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ public_id: publicId })
        });
        if(!signRes.ok) {
           const err = await signRes.json();
           throw new Error(err.error || 'Fallo en la firma del servidor');
        }
        const{signature,timestamp,apiKey,cloudName,uploadPreset,folder,publicId:signedPublicId}=await signRes.json();
        const fd=new FormData();
        fd.append('file',file);fd.append('upload_preset',uploadPreset);
        fd.append('folder',folder);fd.append('timestamp',timestamp);
        fd.append('api_key',apiKey);fd.append('signature',signature);
        if(signedPublicId) fd.append('public_id', signedPublicId);
        showUploadProgress(30);
        const res=await fetch(`https://api.cloudinary.com/v1_1/${cloudName}/image/upload`,{method:'POST',body:fd});
        if(!res.ok) {
          const cloudErr = await res.json();
          throw new Error(cloudErr.error?.message || 'Error en Cloudinary');
        }
        const data=await res.json();
        const url=data.secure_url.replace('/upload/','/upload/w_1200,q_auto,f_auto/');
        showUploadProgress(100);setTimeout(()=>hideUploadProgress(),800);
        addToHistory(`📸 Foto subida: ${data.original_filename||'imagen'}`);
        return url;
      }catch(e){
        hideUploadProgress();
        showToast(`❌ ${e.message}`);
        console.error('[Cloudinary Upload Error]', e);
        return null;
      }
    }
    function showUploadProgress(pct){const p=document.getElementById('uploadProgress');const b=document.getElementById('uploadProgressBar');if(p)p.style.display='block';if(b)b.style.width=pct+'%';}
    function hideUploadProgress(){const p=document.getElementById('uploadProgress');if(p)p.style.display='none';}

    /* ── INITIAL LOAD ── */
    async function loadAll(){
      showToast('⏳ Cargando datos...');
      try{
        const sbProds=await sbAdminGetProducts();
        adminProducts = sbProds || [];
        
        const sbCfg=await sbAdminGetConfig_();adminCfg=sbCfg||{...CONFIG_DEFAULT};
        try{
          const rows=await sbAdminGetBanners_();
          const defaults = [
            {afterCat:'home1',title:'Pétalos que <em>guardan</em> historias',subtitle:'Creamos ramos que no se marchitan para momentos que deben durar por siempre.',imgUrl:'https://images.unsplash.com/photo-1583209814683-c023dd293cc6',ctaText:'Ver Colección',ctaUrl:'/catalogo'},
            {afterCat:'home2',title:'Regala un <em>pedacito</em> de arte',subtitle:'Cada puntada es un detalle pensado en la persona que amas.',imgUrl:'https://images.unsplash.com/photo-1599307767316-776533da941c',ctaText:'Personalizar',ctaUrl:'/#personalizado'}
          ];
          
          editorialBannersAdmin = rows && rows.length ? rows : [...defaults];
          
          // Aseguramos que HOME1 y HOME2 siempre existan en la lista
          defaults.forEach(def => {
            if(!editorialBannersAdmin.find(b => b.afterCat === def.afterCat)) {
              editorialBannersAdmin.push(def);
            }
          });
        }catch{editorialBannersAdmin=[];}
        try{pedidos=await sbAdminGetPedidos();}catch{pedidos=[];}
        try{
          adminCategories=await sbAdminGetCategories();
          window._isLiveMode = true; 
        }catch(e){
          console.warn('Usando categorías locales (error conexión)');
          adminCategories=[...categories];
          window._isLiveMode = false;
        }
        try{const sh=localStorage.getItem('nuditos_history');changeHistory=sh?JSON.parse(sh):[];}catch{changeHistory=[];}
      }catch(e){
        showToast('⚠️ Error de conexión — usando datos locales');
        adminProducts=products.map(p=>({...p}));adminCfg={...CONFIG_DEFAULT};editorialBannersAdmin=[];pedidos=[];
      }
      
      heroSelection=[...(adminCfg.carruselHero||[])];momentoSelection=adminCfg.ramoDestacado;
      document.getElementById('descCodigo').value=adminCfg.descuentoCodigo||'';
      document.getElementById('descPorcentaje').value=adminCfg.descuentoPorcentaje||10;
      document.getElementById('descTexto').value=adminCfg.descuentoTexto||'';
      if(adminCfg.descuentoActivo)document.getElementById('toggleDescuento').classList.add('on');
      if(adminCfg.wompiActivo)document.getElementById('toggleWompi').classList.add('on');
      if(adminCfg.wompiKey)document.getElementById('wompiKey').value=adminCfg.wompiKey;
      if(adminCfg.wompiIntegrity)document.getElementById('wompiIntegrity').value=adminCfg.wompiIntegrity;
      if(adminCfg.wompiEvents)document.getElementById('wompiEvents').value=adminCfg.wompiEvents;
      if(adminCfg.metaPixelActivo)document.getElementById('toggleMetaPixel').classList.add('on');
      if(adminCfg.metaPixelId)document.getElementById('metaPixelId').value=adminCfg.metaPixelId;
      
      // SEO Fields initialization
      if(adminCfg.seoTitle) document.getElementById('seoTitle').value = adminCfg.seoTitle;
      if(adminCfg.seoDescription) document.getElementById('seoDescription').value = adminCfg.seoDescription;
      if(adminCfg.seoOgImage) document.getElementById('seoOgImage').value = adminCfg.seoOgImage;
      if(adminCfg.socialInstagram) document.getElementById('socialInsta').value = adminCfg.socialInstagram;
      if(adminCfg.socialWhatsapp) document.getElementById('socialWhasapp').value = adminCfg.socialWhatsapp;
      if(adminCfg.gaId) document.getElementById('seoGAId').value = adminCfg.gaId;
      if(adminCfg.gaActive) document.getElementById('toggleGASEO').classList.add('on');
      if(adminCfg.metaPixelId) document.getElementById('seoMetaPixelId').value = adminCfg.metaPixelId;
      if(adminCfg.metaPixelActivo) document.getElementById('toggleMetaPixelSEO').classList.add('on');
      if(typeof updateSEOPreview === 'function') updateSEOPreview();

      const cc=getCloudinaryConfig();
      if(cc.cloudName)document.getElementById('ccCloudName').value=cc.cloudName;
      if(cc.preset)document.getElementById('ccPreset').value=cc.preset;
      
      buildSideFilters();renderSidebar();renderStats();showEditorEmpty();renderCategoriasList();
      renderHeroSlots();renderMomentoSelected();renderMomentoList(adminProducts);renderHeroList(adminProducts);
      renderCatViewsList();renderBannerList();
      
      const statusLabel = window._isLiveMode ? '✅ Conectado a Supabase' : '⚠️ Usando datos locales (Fallback)';
      showToast(statusLabel);
      console.log(`[Admin] Modo: ${window._isLiveMode ? 'LIVE' : 'FALLBACK'}`);
    }

    async function sbAdminGetConfig_(){
      try{const rows=await fetch(`${SB_URL}/rest/v1/config?select=clave,valor`,{headers:_h(true)}).then(r=>r.json());return sbToConfig(rows);}
      catch{return null;}
    }
    async function sbAdminGetBanners_(){
      try{const rows=await fetch(`${SB_URL}/rest/v1/banners?order=orden.asc`,{headers:_h(true)}).then(r=>r.json());return rows.map(sbToBanner);}
      catch{return[];}
    }

    function buildSideFilters(){
      const src = adminCategories.length ? adminCategories : categories.filter(c=>c.id!=='todos');
      const opts=[{id:'',name:'Todos',icon:'🌸'},...src.filter(c=>c.id!=='todos')];
      document.getElementById('sideFilters').innerHTML=opts.map(c=>
        `<span class="lf-chip ${sideFilterCat===c.id?'active':''}" onclick="setSideFilter('${c.id}',this)">${c.icon} ${c.nombre||c.name}</span>`
      ).join('');
    }
    function setSideFilter(id,el){
      sideFilterCat=id;
      selectedProducts.clear();
      document.querySelectorAll('.lf-chip').forEach(c=>c.classList.remove('active'));
      el.classList.add('active');
      renderSidebar();
      updateBulkBar();
    }

    function renderStats(){
      const t=adminProducts.length,v=adminProducts.filter(p=>p.activo!==false).length;
      const f=adminProducts.filter(p=>p.img&&p.img.trim()).length,o=t-v;
      document.getElementById('sideStats').innerHTML=`
        <div class="ls-stat"><div class="ls-num">${t}</div><div class="ls-label">Total</div></div>
        <div class="ls-stat"><div class="ls-num green">${v}</div><div class="ls-label">Visibles</div></div>
        <div class="ls-stat"><div class="ls-num ${(t-f)>0?'red':'green'}">${f}</div><div class="ls-label">Con foto</div></div>
        <div class="ls-stat"><div class="ls-num red">${o}</div><div class="ls-label">Ocultos</div></div>`;
    }

    function renderSidebar(){
      const q=document.getElementById('sideSearch').value.toLowerCase();
      let list=adminProducts.filter(p=>{
        const mQ=!q||p.name.toLowerCase().includes(q)||(adminCategories.find(c=>c.id===p.cat)?.nombre?.toLowerCase().includes(q));
        const mC=!sideFilterCat||p.cat===sideFilterCat; return mQ&&mC;
      });
      const groups={};list.forEach(p=>{if(!groups[p.cat])groups[p.cat]=[];groups[p.cat].push(p);});
      let html='';
      Object.entries(groups).forEach(([catId,items])=>{
          const cat=adminCategories.find(c=>c.id===catId);
          const count = items.length;
          html+=`<div class="cat-group-label">
            <span>${cat?.icon||'📁'} ${cat?.nombre||cat?.name||catId} <strong style="opacity:0.6;font-size:0.7rem;margin-left:4px">(${count})</strong></span>
            <button class="cat-group-del" onclick="deleteCategoryFromSidebar('${catId}')" title="Eliminar esta categoría y sus productos">🗑️</button>
          </div>`;
        items.forEach(p=>{
          const isActive=p.activo!==false;
          const isSel=selectedProducts.has(p.id);
          const tags=[];
          if(!isActive)tags.push(`<span class="pi-tag pit-oculto">Oculto</span>`);
          if(p.badge)tags.push(`<span class="pi-tag pit-badge">${p.badge}</span>`);
          if(p.oferta)tags.push(`<span class="pi-tag pit-oferta">Oferta</span>`);
          if(p.envioGratis)tags.push(`<span class="pi-tag pit-envio">Envío</span>`);
          html+=`
            <div class="prod-item ${selectedId===p.id?'selected':''} ${isActive?'':'inactive'} ${isSel?'bulk-selected':''}">
              <input type="checkbox" class="prod-check" ${isSel?'checked':''}
                onclick="event.stopPropagation();toggleProductSelection(${p.id},this.checked)"
                title="Seleccionar">
              <div class="pi-thumb" onclick="selectProduct(${p.id})">${p.img?`<img src="${p.img}" onerror="this.parentNode.innerHTML='${p.emoji}'">`:(p.emoji||'🌸')}</div>
              <div class="pi-info" onclick="selectProduct(${p.id})">
                <div class="pi-name">${p.name}</div>
                <div class="pi-meta">${p.price>0?'$'+p.price.toLocaleString('es-CO')+' COP':'Consultar'}</div>
                ${tags.length?`<div class="pi-tags">${tags.join('')}</div>`:''}
              </div>
              <div class="pi-dot ${isActive?'on':'off'}" onclick="event.stopPropagation();quickToggleVis(${p.id})" title="${isActive?'Ocultar':'Mostrar'}"></div>
            </div>`;
        });
      });
      document.getElementById('sideList').innerHTML=html||`<div style="padding:1.5rem;text-align:center;color:rgba(255,255,255,.3);font-size:.76rem">No hay ramos</div>`;
    }

    // ── SELECCIÓN MÚLTIPLE (Bulk) ──
    function toggleProductSelection(id, checked){
      if(checked) selectedProducts.add(id); else selectedProducts.delete(id);
      updateBulkBar();
      renderSidebar();
    }
    function toggleSelectAll(checked){
      const q=document.getElementById('sideSearch').value.toLowerCase();
      const visible=adminProducts.filter(p=>{
        const mQ=!q||p.name.toLowerCase().includes(q);
        const mC=!sideFilterCat||p.cat===sideFilterCat; return mQ&&mC;
      });
      visible.forEach(p=>{ if(checked) selectedProducts.add(p.id); else selectedProducts.delete(p.id); });
      updateBulkBar();
      renderSidebar();
    }
    function updateBulkBar(){
      const n=selectedProducts.size;
      const bar=document.getElementById('bulkBar');
      const cnt=document.getElementById('bulkCount');
      if(n>0){ bar.classList.add('active'); cnt.textContent=`${n} seleccionado${n>1?'s':''}`; }
      else { bar.classList.remove('active'); }
      const allCheck=document.getElementById('selectAllCheck');
      if(allCheck){ const visible=adminProducts.filter(p=>!sideFilterCat||p.cat===sideFilterCat); allCheck.checked=visible.length>0&&visible.every(p=>selectedProducts.has(p.id)); }
    }
    async function bulkDeleteProducts(){
      if(!selectedProducts.size) return;
      const n=selectedProducts.size;
      if(!confirm(`¿Eliminar definitivamente ${n} ramo${n>1?'s':''}? Esta acción no se puede deshacer.`)) return;
      const btn=document.querySelector('.bulk-delete'); if(btn){btn.disabled=true;btn.textContent='⏳ Eliminando...';}
      const ids=[...selectedProducts];
      let ok=0,err=0;
      for(const id of ids){
        try{ await sbAdminDeleteProduct(id); adminProducts=adminProducts.filter(p=>p.id!==id); ok++; }
        catch{ err++; }
      }
      selectedProducts.clear();
      if(selectedId&&!adminProducts.find(p=>p.id===selectedId)){ selectedId=null; showEditorEmpty(); }
      renderSidebar(); renderStats(); updateBulkBar();
      if(btn){btn.disabled=false;btn.textContent='🗑️ Eliminar';}
      showToast(err?`✓ ${ok} eliminados, ${err} errores`:`🗑️ ${ok} eliminado${ok>1?'s':''}`);
      addToHistory(`🗑️ Eliminados: ${ok} ramos`);
    }
    async function bulkToggleVisibility(makeVisible){
      if(!selectedProducts.size) return;
      const ids=[...selectedProducts];
      const label=makeVisible?'visibles':'ocultos';
      showToast(`⏳ Procesando ${ids.length} productos...`);
      for(const id of ids){
        const idx=adminProducts.findIndex(p=>p.id===id); if(idx===-1) continue;
        try{ adminProducts[idx].activo=makeVisible; await sbAdminSaveProduct({...adminProducts[idx],_isNew:false}); }
        catch{}
      }
      selectedProducts.clear();
      renderSidebar(); renderStats(); updateBulkBar();
      showToast(`✓ ${ids.length} ramos ${label}`);
      addToHistory(`👁 ${ids.length} ramos ${label}`);
    }

    function openBulkMoveModal() {
      if(!selectedProducts.size) return;
      const moves = adminCategories.filter(c=>c.id!=='todos').map(c=>`
        <button class="move-cat-option" onclick="bulkMoveTo('${c.id}')">
          <span class="mco-icon">${c.icon||'🌸'}</span>
          <span class="mco-name">${c.nombre||c.name}</span>
        </button>
      `).join('');
      document.getElementById('moveOptionsList').innerHTML=moves;
      document.getElementById('moveModal').classList.add('open');
    }

    async function bulkMoveTo(catId) {
      if(!selectedProducts.size) return;
      const ids=[...selectedProducts];
      const cat = adminCategories.find(c=>c.id===catId);
      const catLabel = cat?.nombre || cat?.name || catId;
      
      document.getElementById('moveModal').classList.remove('open');
      showToast(`🚚 Moviendo ${ids.length} ramos a ${catLabel}...`);
      
      for(const id of ids){
        const idx=adminProducts.findIndex(p=>p.id===id); if(idx===-1) continue;
        try{ 
          adminProducts[idx].cat=catId; 
          await sbAdminSaveProduct({...adminProducts[idx],_isNew:false}); 
        } catch{}
      }
      selectedProducts.clear();
      renderSidebar(); renderStats(); updateBulkBar();
      showToast(`✓ Movid@s a ${catLabel}`);
      addToHistory(`📂 ${ids.length} ramos movidos a ${catLabel}`);
    }

    function selectProduct(id){
      selectedId=id;renderSidebar();
      const p=adminProducts.find(x=>x.id===id);
      if(p)renderEditor(p);
      if(window.innerWidth<=768){document.getElementById('leftCol').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('open');}
    }
    function newProduct(){
      selectedId=null;renderSidebar();clearEditor();
      document.getElementById('tab-productos').innerHTML=buildEditorHTML(null);
      document.getElementById('editingId').value='';
      if(window.innerWidth<=768){document.getElementById('leftCol').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('open');}
    }

    function showEditorEmpty(){
      document.getElementById('tab-productos').innerHTML=`
        <div class="editor-empty">
          <div class="editor-empty-icon">🌸</div>
          <h3>Selecciona un ramo</h3>
          <p>Elige un ramo de la lista para editar sus detalles, precio o fotos.</p>
        </div>`;
    }
    function clearEditor(){uploadedImgs=[];currentEditingImgs=[];}

    function buildEditorHTML(p){
      const isNew=!p;
      const catSource = adminCategories.length ? adminCategories : categories.filter(c=>c.id!=='todos');
      const cats=catSource.filter(c=>c.id!=='todos').map(c=>`<option value="${c.id}" ${p?.cat===c.id?'selected':''}>${c.icon||'🌸'} ${c.nombre||c.name}</option>`).join('');
      return `
        <input type="hidden" id="editingId" value="${p?.id||''}">
        <div class="editor-card">
          <div class="ec-header">
            <div>
              <div class="ec-title">${isNew?'Nuevo ramo':'Editando ramo'}</div>
              <div class="ec-sub" id="editorSub">${p?p.name:''}</div>
            </div>
            <div class="ec-actions">
              ${!isNew?`
                <button class="btn-vis ${p.activo!==false?'on':'off'}" id="visBtn" onclick="quickToggleVis(${p?.id})">${p.activo!==false?'👁 Visible':'🚫 Oculto'}</button>
                <button class="btn-delete" onclick="askDeleteId(${p?.id})">🗑️ Eliminar</button>
              `:''}
            </div>
          </div>
          <div class="form-grid">
            <div class="field field-full"><label>Nombre del producto *</label><input type="text" id="fNombre" value="${p?.name||''}" oninput="updatePreview()" placeholder="Ramo de rosas con mariposas"></div>
            <div class="field"><label>Precio (COP)</label><input type="number" id="fPrecio" value="${p?.price||0}" oninput="updatePreview()" min="0"></div>
            <div class="field"><label>Categoría *</label><select id="fCat" onchange="updatePreview()">${cats}</select></div>
            <div class="field"><label>Emoji (si no hay foto)</label><input type="text" id="fEmoji" value="${p?.emoji||'🌸'}" oninput="updatePreview()"></div>
            <div class="field field-full">
              <div style="display:flex; justify-content:space-between; align-items:flex-end; margin-bottom: .3rem">
                <label style="margin-bottom:0">Descripción / detalles</label>
                <select id="descTemplate" onchange="if(this.value){ document.getElementById('fDesc').value=getDescTemplate(this.value); updatePreview(); this.value=''; }" style="width:auto; padding:.25rem .5rem; font-size:.65rem; border-radius:6px; border:1px solid var(--lila-light); background:var(--lila-xlight); color:var(--lila-dark); cursor:pointer; font-weight:600">
                  <option value="">✨ Plantillas rápidas...</option>
                  <option value="ramo">💐 Ramo clásico</option>
                  <option value="amigurumi">🧸 Amigurumi / Personaje</option>
                  <option value="maceta">🪴 Maceta</option>
                  <option value="especial">✨ Edición Especial</option>
                </select>
              </div>
              <textarea id="fDesc" oninput="updatePreview()" rows="3" placeholder="Escribe aquí o elige una plantilla arriba...">${p?.desc||''}</textarea>
            </div>
            <div class="field field-full"><label>Estado</label>
              <select id="fActivo" onchange="updatePreview()">
                <option value="true" ${p?.activo!==false?'selected':''}>✅ Visible en tienda</option>
                <option value="false" ${p?.activo===false?'selected':''}>🚫 Oculto</option>
              </select>
            </div>
          </div>
          <div class="img-upload-section">
            <div class="img-upload-header"><span class="img-upload-title">📸 Fotos del producto</span></div>
            <div class="upload-zone" 
                 onclick="document.getElementById('fileInput').click()"
                 ondragover="event.preventDefault(); this.classList.add('dragover')"
                 ondragleave="event.preventDefault(); this.classList.remove('dragover')"
                 ondrop="event.preventDefault(); this.classList.remove('dragover'); if(event.dataTransfer.files.length) handleFileUpload(event.dataTransfer.files)">
              <input type="file" id="fileInput" accept="image/*" multiple style="display:none" onchange="handleFileUpload(this.files)">
              <div class="upload-zone-icon">📤</div>
              <div class="upload-zone-text">Arrastra fotos aquí o haz clic para subir</div>
              <div class="upload-zone-sub">JPG, PNG, WEBP · Se renombran y optimizan automáticamente para SEO</div>
            </div>
            <div class="upload-progress" id="uploadProgress"><div class="upload-progress-bar" id="uploadProgressBar"></div></div>
            <div class="img-preview-row" id="imgPreviewRow"></div>
            <label style="font-size:.65rem;font-weight:600;color:var(--soft);text-transform:uppercase;letter-spacing:.5px;display:block;margin:.5rem 0 .25rem">O pega links de Cloudinary</label>
            <textarea class="img-url-input" id="fImgs" rows="3" placeholder="https://res.cloudinary.com/... (uno por línea)">${(p?.imgs||[]).join('\n')}</textarea>
            <div class="field" style="margin-top:.5rem"><label>Foto principal (URL)</label><input type="text" id="fImg" value="${p?.img||''}" oninput="updatePreview()" placeholder="https://res.cloudinary.com/..."></div>
          </div>
          <div class="stock-row">
            <span class="stock-icon">📦</span>
            <div class="stock-info"><div class="stock-label">Stock</div><div class="stock-sub">Cuántas unidades disponibles</div></div>
            <div class="stock-input-wrap">
              <input class="stock-num" type="number" id="fStock" value="${p?.stock??99}" min="0" max="999">
              <label class="stock-unlimited"><input type="checkbox" id="fStockUnlimited" ${p?.stock===undefined||p?.stock===null?'checked':''}> Sin límite</label>
            </div>
          </div>
          <div class="tags-label">Etiquetas</div>
          <div class="chips-row">
            <label class="chip-check"><input type="checkbox" id="fTagNuevo" ${p?.badge==='Nuevo'?'checked':''}> 🟢 Nuevo</label>
            <label class="chip-check chip-popular"><input type="checkbox" id="fTagPopular" ${p?.badge==='Popular'?'checked':''}> 🔥 Popular</label>
            <label class="chip-check chip-especial"><input type="checkbox" id="fTagEspecial" ${p?.badge==='Especial'?'checked':''}> ⭐ Especial</label>
            <label class="chip-check chip-oferta"><input type="checkbox" id="fTagOferta" ${p?.oferta?'checked':''} onchange="toggleOfertaFields()"> 🏷️ Oferta</label>
            <label class="chip-check chip-envio"><input type="checkbox" id="fTagEnvio" ${p?.envioGratis?'checked':''}> 🚚 Envío gratis</label>
          </div>
          <div id="ofertaFields" style="${p?.oferta?'display:block':''}">
            <div class="form-grid">
              <div class="field"><label>Precio original (tachado)</label><input type="number" id="fPrecioOriginal" value="${p?.precioOriginal||0}" min="0"></div>
              <div class="field"><label>Precio con oferta</label><input type="number" id="fPrecioOferta" value="${p?.precioOferta||0}" min="0"></div>
            </div>
          </div>
          <details class="t-card" style="padding:1rem; margin-top: 1rem; margin-bottom: 0; border:1px solid var(--border); box-shadow:none;">
            <summary style="font-weight:700; font-size:0.75rem; cursor:pointer; color:var(--lila-dark); display:flex; align-items:center; gap:.4rem">🔍 Ajustes Avanzados de Búsqueda (SEO Google)</summary>
            <div class="form-grid" style="margin-top:0.8rem;">
              <div class="field field-full"><label>Título en Google (Meta Title)</label><input type="text" id="fMetaTitle" value="${p?.metaTitle||''}" placeholder="Ej: Ramo de Girasoles a Crochet - Sueño de Van Gogh"></div>
              <div class="field field-full"><label>Palabras clave (Keywords)</label><input type="text" id="fSeoKeywords" value="${p?.seoKeywords||''}" placeholder="Ej: girasoles amarillos, regalo novia, flores tejidas"></div>
              <div class="field field-full"><label>Descripción para Google</label><textarea id="fMetaDesc" rows="2" placeholder="Dejar vacío para que Google use la descripción principal...">${p?.metaDescription||''}</textarea></div>
              <div class="field field-full"><label>Texto foto (Alt Text)</label><input type="text" id="fAltText" value="${p?.altText||''}" placeholder="Descripción de la foto para invidentes y SEO"></div>
            </div>
          </details>
          <div class="preview-panel">
            <div class="preview-label">Vista previa en tienda</div>
            <div class="preview-card-wrap"><div class="preview-card" id="livePreview"></div></div>
          </div>
          <div style="display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.3rem">
            <button class="btn-save" id="saveProdBtn" onclick="saveProduct()">
              💾 <span>${isNew?'Crear producto':'Guardar cambios'}</span>
            </button>
            <button class="btn-cancel" onclick="showEditorEmpty()">Cancelar</button>
          </div>
        </div>`;
    }

    function renderEditor(p){
      currentEditingImgs=p.imgs?[...p.imgs]:[];uploadedImgs=[];
      document.getElementById('tab-productos').innerHTML=buildEditorHTML(p);
      renderImgPreviews();updatePreview();
    }
    
    function getDescTemplate(type) {
      const templates = {
        ramo: "Hermoso ramo tejido a mano con hilo de algodón 100% hipoalergénico. Incluye envoltura premium y tarjeta. Flores que nunca se marchitan, el detalle perfecto para sorprender.",
        amigurumi: "Adorable amigurumi tejido a mano con atención a cada detalle. Ideal para coleccionar, decorar o dar un regalo verdaderamente único y personalizado.",
        maceta: "Tierna maceta tejida a crochet. La alternativa perfecta para decorar tu escritorio o habitación con naturaleza eterna que no necesita riego ni cuidados especiales.",
        especial: "Diseño especial y exclusivo elaborado a mano. Cada puntada refleja calidad y dedicación, creando un obsequio premium verdaderamente inolvidable."
      };
      return templates[type] || '';
    }

    function toggleOfertaFields(){document.getElementById('ofertaFields').style.display=document.getElementById('fTagOferta').checked?'block':'none';}

    async function handleFileUpload(files){
      if(!files.length)return;
      for(let i=0; i<files.length; ++i){
        const file = files[i];
        const url=await uploadToCloudinary(file, null, i);
        if(url){currentEditingImgs.push(url);if(!document.getElementById('fImg').value)document.getElementById('fImg').value=url;renderImgPreviews();updatePreview();}
      }
    }
    function syncImgsFromTextarea(){const ta=document.getElementById('fImgs');if(!ta)return;const lines=ta.value.split('\n').map(l=>l.trim()).filter(l=>l.startsWith('http'));lines.forEach(url=>{if(!currentEditingImgs.includes(url))currentEditingImgs.push(url);});}
    function updateImgsTextarea(){const ta=document.getElementById('fImgs');if(ta)ta.value=currentEditingImgs.join('\n');}
    function renderImgPreviews(){
      const row=document.getElementById('imgPreviewRow');if(!row)return;
      row.innerHTML=currentEditingImgs.map((url,i)=>`
        <div class="img-thumb-wrap">
          <img class="img-thumb" src="${url}">
          <button class="img-thumb-rm" onclick="removeImg(${i})">×</button>
        </div>`).join('');
    }
    function removeImg(i){currentEditingImgs.splice(i,1);renderImgPreviews();updateImgsTextarea();updatePreview();}

    function updatePreview(){
      const name=document.getElementById('fNombre')?.value||'Nombre';
      const price=parseInt(document.getElementById('fPrecio')?.value)||0;
      const emoji=document.getElementById('fEmoji')?.value||'🌸';
      const img=document.getElementById('fImg')?.value||'';
      const isNew=document.getElementById('fTagNuevo')?.checked;
      const isPopular=document.getElementById('fTagPopular')?.checked;
      const isEspecial=document.getElementById('fTagEspecial')?.checked;
      const isOferta=document.getElementById('fTagOferta')?.checked;
      const precioOrig=parseInt(document.getElementById('fPrecioOriginal')?.value)||0;
      const catId=document.getElementById('fCat')?.value;
      const cat=categories.find(c=>c.id===catId);
      const isActive=document.getElementById('fActivo')?.value==='true';
      const badge=isNew?'Nuevo':isPopular?'Popular':isEspecial?'Especial':'';
      const badgeCls=isNew?'nuevo':isPopular?'popular':isEspecial?'especial':'';
      let origHtml='';
      if(isOferta&&precioOrig>0&&price>0)origHtml=`<span class="orig">$${precioOrig.toLocaleString('es-CO')}</span>`;
      const preview=document.getElementById('livePreview');if(!preview)return;
      preview.innerHTML=`
        <div class="preview-img">
          ${img?`<img src="${img}" onerror="this.remove()">`:`<span>${emoji}</span>`}
          ${badge?`<div class="preview-badge ${badgeCls}">${badge}</div>`:''}
          ${!isActive?`<div class="preview-badge agotado">Oculto</div>`:''}
        </div>
        <div class="preview-info">
          <div class="preview-cat">${cat?.icon||''} ${cat?.name||'Cat'}</div>
          <div class="preview-name">${name}</div>
          <div class="preview-price">${origHtml}${price>0?'$'+price.toLocaleString('es-CO')+' COP':'Consultar'}</div>
        </div>`;
    }

    async function saveProduct(){
      const nombre=document.getElementById('fNombre')?.value.trim();
      const precio=parseInt(document.getElementById('fPrecio')?.value)||0;
      const cat=document.getElementById('fCat')?.value;
      const emoji=document.getElementById('fEmoji')?.value.trim()||'🌸';
      const desc=document.getElementById('fDesc')?.value.trim()||'';
      const img=document.getElementById('fImg')?.value.trim()||'';
      syncImgsFromTextarea();const imgs=[...currentEditingImgs];
      const activo=document.getElementById('fActivo')?.value==='true';
      const editId=document.getElementById('editingId')?.value;
      const tagNuevo=document.getElementById('fTagNuevo')?.checked;
      const tagPopular=document.getElementById('fTagPopular')?.checked;
      const tagEspecial=document.getElementById('fTagEspecial')?.checked;
      const tagOferta=document.getElementById('fTagOferta')?.checked;
      const tagEnvio=document.getElementById('fTagEnvio')?.checked;
      const stockUnlimited=document.getElementById('fStockUnlimited')?.checked;
      const stockVal=parseInt(document.getElementById('fStock')?.value);
      const stock=stockUnlimited?undefined:(isNaN(stockVal)?undefined:stockVal);
      let badge='',badgeClass='';
      if(tagNuevo){badge='Nuevo';badgeClass='nuevo';}else if(tagPopular){badge='Popular';}else if(tagEspecial){badge='Especial';}
      const precioOriginal=parseInt(document.getElementById('fPrecioOriginal')?.value)||0;
      const precioOferta=parseInt(document.getElementById('fPrecioOferta')?.value)||0;
      const metaTitle=document.getElementById('fMetaTitle')?.value.trim()||'';
      const seoKeywords=document.getElementById('fSeoKeywords')?.value.trim()||'';
      const metaDesc=document.getElementById('fMetaDesc')?.value.trim()||'';
      const altText=document.getElementById('fAltText')?.value.trim()||'';
      if(!nombre){showToast('⚠️ Nombre obligatorio');return;}
      const data={name:nombre,price:precio,cat,emoji,desc,img,imgs,badge,badgeClass,activo,oferta:tagOferta,envioGratis:tagEnvio,stock,precioOriginal:tagOferta?precioOriginal:0,precioOferta:tagOferta?precioOferta:0,metaTitle,seoKeywords,metaDescription:metaDesc,altText};
      const btn=document.getElementById('saveProdBtn');
      if(btn){btn.disabled=true;btn.querySelector('span').textContent='...';}
      try{
        if(editId&&editId!==''){
          data.id=parseInt(editId);
          await sbAdminSaveProduct({...data,_isNew:false});
          const idx=adminProducts.findIndex(p=>p.id===parseInt(editId));
          if(idx!==-1)adminProducts[idx]={...adminProducts[idx],...data};
          showToast(`✓ Actualizado`);addToHistory(`✏️ Editado: ${nombre}`);
        }else{
          const saved=await sbAdminSaveProduct({...data,_isNew:true});
          if(saved){adminProducts.push({...data,id:saved.id});selectedId=saved.id;}
          showToast(`✓ Creado`);addToHistory(`➕ Agregado: ${nombre}`);
        }
        renderSidebar();renderStats();renderMomentoList(adminProducts);renderHeroList(adminProducts);
      }catch(e){showToast('❌ Error');}
      finally{if(btn)btn.disabled=false;if(btn)btn.querySelector('span').textContent='Guardar cambios';}
    }

    async function quickToggleVis(id){
      const idx=adminProducts.findIndex(p=>p.id===id);if(idx===-1)return;
      adminProducts[idx].activo=!(adminProducts[idx].activo!==false);
      try{await sbAdminSaveProduct({...adminProducts[idx],_isNew:false});renderSidebar();renderStats();const p=adminProducts[idx];const btn=document.getElementById('visBtn');if(btn){btn.className=`btn-vis ${p.activo!==false?'on':'off'}`;btn.textContent=p.activo!==false?'👁 Visible':'🚫 Oculto';}showToast(p.activo!==false?'✓ Visible':'🚫 Oculto');}catch{showToast('❌ Error');}
    }
    function askDeleteId(id){pendingDeleteId=id;const p=adminProducts.find(x=>x.id===id);document.getElementById('confirmMsg').textContent=`¿Eliminar "${p?.name||''}"?`;document.getElementById('confirmOverlay').classList.add('open');}
    function closeConfirm(){document.getElementById('confirmOverlay').classList.remove('open');}
    async function confirmDelete(){
      if(!pendingDeleteId)return;
      const idx=adminProducts.findIndex(p=>p.id===pendingDeleteId);const name=adminProducts[idx]?.name;
      try{await sbAdminDeleteProduct(pendingDeleteId);if(idx!==-1)adminProducts.splice(idx,1);selectedId=null;renderSidebar();renderStats();showEditorEmpty();closeConfirm();showToast(`🗑️ Eliminado`);}catch{showToast('❌ Error');}
    }

    /* ── PEDIDOS ── */
    function openNewPedido(){document.getElementById('pedidoEditId').value='';document.getElementById('pedidoModalTitle').textContent='Nuevo pedido';['pCliente','pTel','pItems','pTotal','pNotas'].forEach(id=>document.getElementById(id).value='');document.getElementById('pEstado').value='pendiente';document.getElementById('pedidoModal').classList.add('open');}
    function openEditPedido(id){const p=pedidos.find(x=>x.id===id);if(!p)return;document.getElementById('pedidoEditId').value=p.id;document.getElementById('pCliente').value=p.cliente||'';document.getElementById('pTel').value=p.tel||'';document.getElementById('pItems').value=p.items||'';document.getElementById('pTotal').value=p.total||'';document.getElementById('pEstado').value=p.estado||'pendiente';document.getElementById('pNotas').value=p.notas||'';document.getElementById('pedidoModal').classList.add('open');}
    function closePedidoModal(){document.getElementById('pedidoModal').classList.remove('open');}
    async function savePedido(){
      const editId=document.getElementById('pedidoEditId').value;
      const data={cliente:document.getElementById('pCliente').value.trim(),tel:document.getElementById('pTel').value.trim(),items:document.getElementById('pItems').value.trim(),total:parseInt(document.getElementById('pTotal').value)||0,estado:document.getElementById('pEstado').value,notas:document.getElementById('pNotas').value.trim()};
      if(!data.cliente)return;
      try{
        if(editId){await sbAdminSavePedido({...data,id:parseInt(editId),_isNew:false});const idx=pedidos.findIndex(p=>p.id===parseInt(editId));if(idx!==-1)pedidos[idx]={...pedidos[idx],...data,id:parseInt(editId)};}
        else{const saved=await sbAdminSavePedido({...data,_isNew:true});if(saved)pedidos.unshift(saved);}
        closePedidoModal();renderPedidosList();showToast('✓ Pedido guardado');
      }catch{showToast('❌ Error');}
    }
    async function cambiarEstadoPedido(id,estado){const idx=pedidos.findIndex(p=>p.id===id);if(idx===-1)return;try{await sbAdminUpdateEstadoPedido(id,estado);pedidos[idx].estado=estado;renderPedidosList();showToast('✓ Estado actualizado');}catch{showToast('❌ Error');}}
    async function deletePedido(id){try{await sbAdminDeletePedido(id);pedidos=pedidos.filter(p=>p.id!==id);renderPedidosList();showToast('🗑️ Eliminado');}catch{showToast('❌ Error');}}
    function filterPedidos(f,btn){pedidoFilter=f;document.querySelectorAll('.pedido-filter').forEach(b=>b.classList.remove('active'));btn.classList.add('active');renderPedidosList();}
    function renderPedidosList(){
      const list=pedidoFilter==='todos'?pedidos:pedidos.filter(p=>p.estado===pedidoFilter);
      const eLabels={pendiente:'⏳ Pendiente',proceso:'🔄 En proceso',entregado:'✅ Entregado',cancelado:'❌ Cancelado'};
      const eCls={pendiente:'estado-pendiente',proceso:'estado-proceso',entregado:'estado-entregado',cancelado:'estado-cancelado'};
      document.getElementById('pedidosList').innerHTML=list.length?list.map(p=>`
        <div class="pedido-card">
          <div class="pedido-top"><div class="pedido-id">#${String(p.id).slice(-6)}</div><span class="pedido-estado ${eCls[p.estado]||'estado-pendiente'}">${eLabels[p.estado]||p.estado}</span></div>
          <div class="pedido-cliente">${p.cliente}</div>
          <div class="pedido-items">${p.items||'—'}</div>
          <div class="pedido-bottom"><div class="pedido-total">${p.total>0?'$'+p.total.toLocaleString('es-CO'):''}</div><div class="pedido-fecha">${p.fecha||''}</div></div>
          <div class="pedido-actions">
            <button class="p-action-btn" onclick="openEditPedido(${p.id})">✏️ Editar</button>
            <button class="p-action-btn" onclick="cambiarEstadoPedido(${p.id},'entregado')">✅ Entregado</button>
            <button class="p-action-btn" style="color:var(--red)" onclick="deletePedido(${p.id})">🗑️</button>
          </div>
        </div>`).join(''):`<div style="text-align:center;padding:2rem;color:var(--soft)">No hay pedidos</div>`;}
    /* ── CATEGORY MANAGER desde el panel de Productos ── */
    function showCategoryManager(){
      document.getElementById('tab-productos').innerHTML=`
        <div class="editor-card">
          <div class="ec-header">
            <div>
              <div class="ec-title">📁 Gestionar Categorías</div>
              <div class="ec-sub">Crea, edita u elimina las categorías de tu catálogo</div>
            </div>
            <div class="ec-actions">
              <button class="btn-vis on" onclick="newCategory()">+ Nueva categoría</button>
              <button class="btn-cancel" onclick="showEditorEmpty()">Volver</button>
            </div>
          </div>
          <div class="cat-admin-grid" id="catAdminList" style="margin-top:1rem"></div>
        </div>`;
      renderCategoriasList();
    }
    async function deleteCategoryFromSidebar(id) {
      // Reutiliza la misma lógica robusta del modal
      await deleteCategory(id);
    }

    /* ── CATEGORÍAS (modal) ── */
    function renderCategoriasList() {
      const el = document.getElementById('catAdminList');
      if (!el) return;
      el.innerHTML = adminCategories.length ? adminCategories.map(c => {
        const total = adminProducts.filter(p=>p.cat===c.id).length;
        const vis   = adminProducts.filter(p=>p.cat===c.id&&p.activo!==false).length;
        return `
        <div class="cat-admin-card">
          <div class="ca-icon">${c.icon||'🌸'}</div>
          <div class="ca-info">
            <div class="ca-name">${c.nombre||c.name}</div>
            <div class="ca-slug">ID: ${c.id} · <strong style="color:var(--lila)">${total}</strong> producto${total!==1?'s':''} (${vis} visible${vis!==1?'s':''})</div>
          </div>
          <div class="ca-actions">
            <button class="ca-btn" onclick="editCategory('${c.id}')" title="Editar">✏️</button>
            <button class="ca-btn ca-del" onclick="deleteCategory('${c.id}')" title="Eliminar">🗑️</button>
          </div>
        </div>`;
      }).join('') : '<div style="padding:2rem;text-align:center;color:var(--soft)">Sin categorías. Crea una nueva.</div>';
    }

    function newCategory() {
      document.getElementById('catModalTitle').textContent = 'Nueva categoría';
      document.getElementById('catModalSub').textContent = 'Crea una nueva sección en tu catálogo';
      document.getElementById('catEditId').value = '';
      document.getElementById('catId').value = '';
      document.getElementById('catId').disabled = false;
      document.getElementById('catNombre').value = '';
      document.getElementById('catIcon').value = '🌸';
      document.getElementById('catOrden').value = adminCategories.length + 1;
      document.getElementById('catStatsRow').style.display = 'none';
      document.getElementById('emojiPickerPanel').classList.remove('open');
      loadEmojiGrid('flores');
      document.getElementById('catModal').classList.add('open');
    }

    function editCategory(id) {
      const c = adminCategories.find(x => x.id === id);
      if (!c) return;
      const total   = adminProducts.filter(p=>p.cat===id).length;
      const visibles = adminProducts.filter(p=>p.cat===id&&p.activo!==false).length;
      document.getElementById('catModalTitle').textContent = 'Editar categoría';
      document.getElementById('catModalSub').textContent = `Actualizando: ${c.nombre||c.name}`;
      document.getElementById('catEditId').value = id;
      document.getElementById('catId').value = id;
      document.getElementById('catId').disabled = true;
      document.getElementById('catNombre').value = c.nombre || c.name || '';
      document.getElementById('catIcon').value = c.icon || '🌸';
      document.getElementById('catOrden').value = c.orden || 1;
      // Mostrar stats de productos
      document.getElementById('catStatsRow').style.display = 'flex';
      document.getElementById('catStatTotal').textContent = total;
      document.getElementById('catStatVisible').textContent = visibles;
      document.getElementById('catStatOcultos').textContent = total - visibles;
      document.getElementById('emojiPickerPanel').classList.remove('open');
      loadEmojiGrid('flores');
      document.getElementById('catModal').classList.add('open');
    }

    function closeCatModal() {
      document.getElementById('catModal').classList.remove('open');
      document.getElementById('emojiPickerPanel').classList.remove('open');
    }

    async function saveCategory() {
      const id = document.getElementById('catId').value.trim().toLowerCase().replace(/[^a-z0-9-]/g,'-');
      const nombre = document.getElementById('catNombre').value.trim();
      const icon   = document.getElementById('catIcon').value.trim() || '🌸';
      const orden  = parseInt(document.getElementById('catOrden').value) || adminCategories.length + 1;
      if (!id || !nombre) { showToast('⚠️ ID y nombre son obligatorios'); return; }
      const data = { id, nombre, icon, orden, activo: true };
      const isNew = !document.getElementById('catEditId').value;
      const btn = document.getElementById('catSaveBtn');
      if(btn){btn.disabled=true;btn.textContent='⏳ Guardando...';}
      try {
        await sbAdminSaveCategory(data, isNew);
        if (isNew) {
          adminCategories.push(data);
        } else {
          const idx = adminCategories.findIndex(c=>c.id===id);
          if(idx!==-1) adminCategories[idx] = {...adminCategories[idx], ...data};
        }
        adminCategories.sort((a,b)=>(a.orden||0)-(b.orden||0));
        buildSideFilters();
        renderCategoriasList();
        closeCatModal();
        showToast(`✓ Categoría ${isNew?'creada':'actualizada'}`);
        addToHistory(`📁 Categoría ${isNew?'creada':'editada'}: ${nombre}`);
      } catch {
        showToast('❌ Error al guardar');
      } finally {
        if(btn){btn.disabled=false;btn.textContent='Guardar categoría';}
      }
    }
    async function deleteCategory(id) {
      const cat = adminCategories.find(c=>c.id===id);
      const label = cat?.nombre || cat?.name || id;
      const prods = adminProducts.filter(p=>p.cat===id);
      const msg = prods.length
        ? `¿Eliminar la categoría "${label}" y sus ${prods.length} producto${prods.length>1?'s':''}? Todo se borrará permanentemente.`
        : `¿Eliminar la categoría vacía "${label}"?`;
      if(!confirm(msg)) return;

      // Eliminar productos con progreso visible
      if(prods.length > 0){
        for(let i=0; i<prods.length; i++){
          showToast(`⏳ Eliminando productos ${i+1} de ${prods.length}...`);
          const p = prods[i];
          try{ await sbAdminDeleteProduct(p.id); adminProducts=adminProducts.filter(x=>x.id!==p.id); }catch{}
        }
      }

      // Eliminar la categoría
      try {
        await sbAdminDeleteCategory(id);
        adminCategories = adminCategories.filter(c=>c.id!==id);
        if(sideFilterCat===id) { sideFilterCat=''; selectedProducts.clear(); }
        buildSideFilters();
        renderCategoriasList();
        renderSidebar(); renderStats(); updateBulkBar();
        if(selectedId && !adminProducts.find(p=>p.id===selectedId)) { selectedId=null; showEditorEmpty(); }
        const msg2 = prods.length ? `🗑️ Categoría y ${prods.length} producto${prods.length>1?'s':''} eliminados` : '🗑️ Categoría eliminada';
        showToast(msg2);
        addToHistory(`🗑️ Eliminada: ${label} (${prods.length} productos)`);
      } catch { showToast('❌ Error al eliminar la categoría'); }
    }

    /* ── EMOJI PICKER ── */
    const EMOJI_CATS = {
      flores:     ['🌸','🌹','🌺','🌻','🌼','🌷','🏵️','🌶️','🌽','🌾','🎐','🍂','🍃','🍁','🌱','🍲','🌳','🌲','🍀','🌿'],
      animales:   ['🐶','🐱','🐇','🐼','🐻','🦚','🐦','🦋','🐝','🦊','🐄','🧿','🐔','🐪','🦧','🐠','🐟','🐈‍⬛','🐑','🦄'],
      objetos:    ['🎁','🎀','🎂','💍','💎','🎉','🥰','💖','💝','💟','🎨','😀','😍','📸','🛒','📦','🇨🇴','💌','🧧','🧶'],
      corazones:  ['❤️','🧡','💛','💚','💙','💜','🤍','🤎','🖤','💞','💕','💟','💔','💓','💖','💗','💘','💝','♥️','🇨🇴'],
      naturaleza: ['🌎','🌟','✨','💫','🌙','☀️','🌈','⚡','❄️','🌊','🏔️','🇬🏾','🌌','🏡','🌾','🏕️','🏞️','🎅','🎄','⛄'],
    };

    function toggleEmojiPicker() {
      const panel = document.getElementById('emojiPickerPanel');
      panel.classList.toggle('open');
    }

    function loadEmojiGrid(cat) {
      const grid = document.getElementById('emojiGrid');
      let list = cat === 'todos'
        ? Object.values(EMOJI_CATS).flat()
        : (EMOJI_CATS[cat] || EMOJI_CATS.flores);
      grid.innerHTML = list.map(e =>
        `<button type="button" class="ep-emoji-btn" onclick="selectEmoji('${e}')">${e}</button>`
      ).join('');
    }

    function showEmojiCat(cat) {
      document.querySelectorAll('.ep-categories button').forEach(b => b.classList.remove('active'));
      event.target.classList.add('active');
      loadEmojiGrid(cat);
    }

    function filterEmojis(q) {
      const all = Object.values(EMOJI_CATS).flat();
      const list = q ? all.filter(e => e.includes(q)) : all;
      const grid = document.getElementById('emojiGrid');
      grid.innerHTML = list.map(e =>
        `<button type="button" class="ep-emoji-btn" onclick="selectEmoji('${e}')">${e}</button>`
      ).join('');
    }

    function selectEmoji(emoji) {
      document.getElementById('catIcon').value = emoji;
      document.getElementById('emojiPickerPanel').classList.remove('open');
    }

    // Inicializar picker al cargar
    document.addEventListener('DOMContentLoaded', () => loadEmojiGrid('flores'));

    // Cerrar picker al clic fuera
    document.addEventListener('click', (e) => {
      const panel = document.getElementById('emojiPickerPanel');
      const btn   = document.querySelector('.btn-emoji-picker');
      if (panel && !panel.contains(e.target) && btn && !btn.contains(e.target)) {
        panel.classList.remove('open');
      }
    });

    /* ── DASHBOARD ── */
    function renderDashboard(){
      const total=adminProducts.length,visibles=adminProducts.filter(p=>p.activo!==false).length;
      document.getElementById('dashStats').innerHTML=`
        <div class="dash-stat"><div class="dash-num">${total}</div><div class="dash-label">Ramos</div></div>
        <div class="dash-stat"><div class="dash-num green">${visibles}</div><div class="dash-label">Visibles</div></div>
        <div class="dash-stat"><div class="dash-num">${pedidos.length}</div><div class="dash-label">Pedidos</div></div>`;
      document.getElementById('histList').innerHTML=changeHistory.length?[...changeHistory].reverse().slice(0,10).map(h=>`
        <div class="hist-item"><div class="hist-dot"></div><div><div class="hist-action">${h.action}</div><div class="hist-time">${h.time}</div></div></div>`).join(''):'';
    }
    function addToHistory(action){ changeHistory.push({action,time:new Date().toLocaleString('es-CO')}); if(changeHistory.length>50)changeHistory.shift(); localStorage.setItem('nuditos_history',JSON.stringify(changeHistory)); }

    /* ── VITRINA & METADATA ── */
    function renderMomentoSelected(){ const p=momentoSelection?adminProducts.find(x=>x.id===momentoSelection):null; document.getElementById('momentoSelected').textContent=p?`✅: ${p.name}`:'Sin seleccionar'; }
    function renderMomentoList(list){ document.getElementById('momentoList').innerHTML=list.slice(0,10).map(p=>`<div class="v-prod-row"><div class="v-info">${p.name}</div><button class="btn-select" onclick="selectMomento(${p.id})">Seleccionar</button></div>`).join(''); }
    function selectMomento(id){ momentoSelection=id; renderMomentoSelected(); }
    function renderHeroSlots(){ document.getElementById('heroSlots').innerHTML=heroSelection.map(id=>{ const p=adminProducts.find(x=>x.id===id); return `<div class="hero-slot filled">${p?.name.slice(0,10)}</div>`; }).join(''); }
    function renderHeroList(list){ document.getElementById('heroList').innerHTML=list.slice(0,10).map(p=>`<div class="v-prod-row"><div class="v-info">${p.name}</div><button class="btn-select" onclick="toggleHero(${p.id})">+ Agregar</button></div>`).join(''); }
    function toggleHero(id){ if(!heroSelection.includes(id))heroSelection.push(id); renderHeroSlots(); }
    function renderBannerList(){ 
      const editorialList = editorialBannersAdmin.filter(b => b.afterCat === 'home1' || b.afterCat === 'home2');
      const collectionsList = editorialBannersAdmin.filter(b => b.afterCat !== 'home1' && b.afterCat !== 'home2');

      const buildCard = (b, i) => {
        // Encontrar el índice real en el array original
        const realIdx = editorialBannersAdmin.findIndex(x => x === b);
        return `
          <div class="banner-admin-card" style="margin-bottom: 1rem; border: 1px solid #eee; padding: 1.2rem; border-radius: 1.2rem; background: #fff;">
            <div style="display:flex; justify-content: space-between; align-items: center; margin-bottom: 0.8rem;">
               <h4 style="margin:0; font-family:serif; font-size: 1rem; color: var(--lila-dark)">${b.afterCat.startsWith('home') ? 'Banner Inicio ' + b.afterCat.slice(-1) : 'Categoría: ' + b.afterCat}</h4>
               <button onclick="removeBanner(${realIdx})" style="background: none; color: #ef4444; border:none; padding: 5px; cursor:pointer; font-size: 1.1rem;">🗑️</button>
            </div>
            
            <div class="form-grid" style="display:grid; grid-template-columns: 1fr 1fr; gap: 0.8rem;">
              <div class="field"><label>Título (Usa &lt;em&gt; para cursiva)</label><input type="text" value="${b.title||''}" oninput="updateBanner(${realIdx},'title',this.value)"></div>
              <div class="field"><label>Aparecer después de (id o home1/2)</label><input type="text" value="${b.afterCat||''}" oninput="updateBanner(${realIdx},'afterCat',this.value)"></div>
              <div class="field field-full"><label>Subtítulo / Descripción</label><textarea style="width:100%; border-radius:10px; border:1px solid #ddd; padding:8px; font-size:0.8rem" oninput="updateBanner(${realIdx},'subtitle',this.value)">${b.subtitle||''}</textarea></div>
              <div class="field"><label>Texto del botón</label><input type="text" value="${b.ctaText||'Ver más'}" oninput="updateBanner(${realIdx},'ctaText',this.value)"></div>
              <div class="field"><label>URL del botón</label><input type="text" value="${b.ctaUrl||'/catalogo'}" oninput="updateBanner(${realIdx},'ctaUrl',this.value)"></div>
              <div class="field field-full"><label>Imagen URL o Subir</label>
                <div style="display:flex; gap: 5px;">
                  <input type="text" id="bImg-${realIdx}" value="${b.imgUrl||''}" style="flex:1; font-size: 0.7rem;" oninput="updateBanner(${realIdx},'imgUrl',this.value)">
                  <button onclick="document.getElementById('bFile-${realIdx}').click()" style="background:var(--lila); color:white; border:none; padding: 0 12px; border-radius: 10px; cursor:pointer; font-size: 0.7rem;">📸</button>
                  <input type="file" id="bFile-${realIdx}" style="display:none" onchange="uploadBannerImg(${realIdx}, this.files)">
                </div>
              </div>
            </div>
            ${b.imgUrl ? `<img src="${b.imgUrl}" style="width:100%; height: 80px; object-fit: cover; border-radius: 0.8rem; margin-top: 0.8rem; border: 1px solid #eee;">` : ''}
          </div>
        `;
      };

      document.getElementById('editorialBannersList').innerHTML = editorialList.map(b => buildCard(b)).join('') || '<div style="padding:1rem; text-align:center; color:#999; font-size: 0.8rem;">No hay banners de inicio</div>';
      document.getElementById('bannerList').innerHTML = collectionsList.map(b => buildCard(b)).join('') || '<div style="padding:1rem; text-align:center; color:#999; font-size: 0.8rem;">No hay banners de categoría</div>';
    }
    window.updateBanner = function(i,key,val){ 
      editorialBannersAdmin[i][key]=val; 
    };
    window.removeBanner = function(i){ 
      editorialBannersAdmin.splice(i,1); 
      renderBannerList(); 
    };
    window.uploadBannerImg = async function(i, files) {
      if(!files.length) return;
      const bTitle = editorialBannersAdmin[i].title.replace(/<[^>]+>/g, '') || 'banner';
      const url = await uploadToCloudinary(files[0], bTitle, 0);
      if(url) {
        editorialBannersAdmin[i].imgUrl = url;
        renderBannerList();
      }
    };
    window.addNewBanner = function() {
      editorialBannersAdmin.push({ title: 'Nuevo Banner', afterCat: '', imgUrl: '', subtitle: '', ctaText: 'Ver más', ctaUrl: '/catalogo' });
      renderBannerList();
    };
    function renderCatViewsList(){ document.getElementById('catViewsList').innerHTML=categories.filter(c=>c.id!=='todos').map(c=>`<div>${c.name}</div>`).join(''); }

    async function saveConfig(){
      const newCfg={
        ramoDestacado:momentoSelection,
        carruselHero:heroSelection,
        descuentoActivo:document.getElementById('toggleDescuento').classList.contains('on'),
        descuentoCodigo:document.getElementById('descCodigo').value.trim(),
        descuentoPorcentaje:parseInt(document.getElementById('descPorcentaje').value)||10,
        descuentoTexto:document.getElementById('descTexto').value.trim(),
        wompiActivo:document.getElementById('toggleWompi').classList.contains('on'),
        wompiKey:document.getElementById('wompiKey').value.trim(),
        wompiIntegrity:document.getElementById('wompiIntegrity').value.trim(),
        wompiEvents:document.getElementById('wompiEvents').value.trim(),
        metaPixelActivo:document.getElementById('toggleMetaPixel').classList.contains('on'),
        metaPixelId:document.getElementById('metaPixelId').value.trim(),
        catViews:{}
      };
      try{ await sbAdminSaveConfig(newCfg); await sbAdminSaveBanners(editorialBannersAdmin); showToast('✅ Guardado'); }catch{ showToast('❌ Error');}
    }
    function showToast(msg){ const t=document.getElementById('toastAdmin'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2000); }
  </script>
</AdminLayout>
