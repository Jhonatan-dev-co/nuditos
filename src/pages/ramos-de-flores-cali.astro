---
import PremiumLanding from '../components/PremiumLanding.astro';
import { CITY_LANDINGS } from '../data/seo-landings';
export const prerender = false;

const config = CITY_LANDINGS['ramos-de-flores-cali'];
---
<PremiumLanding
  seoTitle={config.title}
  seoDesc={config.description}
  seoKeywords={config.keywords}
  eyebrow={`Detalles Eternos en ${config.city}`}
  h1={config.h1.split(' en ')[0]}
  h1Em={`en ${config.city}`}
  heroCopy={config.heroCopy}
  ctaWaText={`Hola Nuditos! 🌸 Quiero enviar flores en ${config.city}`}
  productKeywords={["ramo", "tulipan", "rosa", "crochet"]}
  collectionTitle={`Ramos para ${config.city}`}
  isCityPage={true}
  city={config.city}
  relatedLinks={config.relatedLinks}
  faq={config.localFaq}
  ctaFinalTitle={`¿Llevamos flores a <em class='italic text-violet-600 font-normal'>${config.city}?</em>`}
  ctaFinalCopy="Un regalo que aguanta el ritmo y el calor de la Sucursal del Cielo."
  ctaTags={[`📍 ${config.city}`, "🌸 Tejido con amor", "🎁 Detalle duradero", "🚚 Envío directo"]}
/>