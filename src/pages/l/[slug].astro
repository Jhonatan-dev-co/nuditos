---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';
import ProductCard from '../../components/ProductCard.astro';
import TrustSignalsSection from '../../components/TrustSignalsSection.astro';
import { getLiveProducts, getPublicConfig, getLiveCategories } from '../../lib/supabase';
import { slugify } from '../../data/datos';

const liveProducts = await getLiveProducts();
const publicConfigRaw = await getPublicConfig();
const rawCategories = await getLiveCategories();

const { slug } = Astro.params;
const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL;
const SB_ANON = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
let landingData = null;

try {
  const res = await fetch(`${SB_URL}/rest/v1/landings?slug=eq.${slug}&is_active=eq.true&limit=1`, {
    headers: {
      'apikey': SB_ANON,
      'Authorization': `Bearer ${SB_ANON}`
    }
  });
  const data = await res.json();
  if (data && data.length > 0) {
    landingData = data[0];
  }
} catch (e) {
  console.error("Error fetching landing", e);
}

if (!landingData) {
  return Astro.redirect('/404');
}

const content = landingData.content || {};

const safeProducts = liveProducts.map(p => ({
  id: p.id,
  name: p.name,
  price: p.price,
  emoji: p.emoji || '🌸',
  img: p.img || '',
  cat: p.cat || '',
  desc: p.desc || ''
}));
const safeCategories = rawCategories || [];
const publicConfig = publicConfigRaw || {};

// 1. Filtramos por la categoría específica de la landing
const catSlug = (content.categorySlug || 'dia-madre').toLowerCase().trim();
let productosDiaMadre: any[] = liveProducts.filter(p => {
  const cats: string[] = [p.cat, ...(p.cats || [])].map(
    (c: string | undefined) => (c ?? '').toLowerCase().trim()
  );
  return cats.includes(catSlug) || catSlug === '';
});

// 2. Ordenamos por PRECIO (menor a mayor) para ser coherentes con el "Desde $77k"
productosDiaMadre.sort((a, b) => a.price - b.price);

// 3. Lógica de Producto de Anuncio (?hero=)
const urlHeroSlug = Astro.url.searchParams.get('hero');
let adProduct = null;

if (urlHeroSlug) {
  // Buscamos si el producto del anuncio está en nuestra lista filtrada
  const adIndex = productosDiaMadre.findIndex(p => slugify(p.name) === urlHeroSlug);
  
  if (adIndex > -1) {
    // Si existe, lo extraemos de su posición y lo ponemos de PRIMERO
    [adProduct] = productosDiaMadre.splice(adIndex, 1);
    productosDiaMadre.unshift(adProduct);
  } else {
    // Si no está en la lista filtrada, lo buscamos en todos los productos (fallback)
    adProduct = liveProducts.find(p => slugify(p.name) === urlHeroSlug);
  }
}

const ordenados = productosDiaMadre;

// Si hay un producto del anuncio, usamos su foto. Si no, usamos el primero de la categoría.
const defaultHeroImg: string  = adProduct?.img || ordenados[0]?.img || '';
const heroImg: string = content.heroImg || defaultHeroImg;
const unboxingImg: string = content.unboxingImg || ordenados[1]?.img || ordenados[0]?.img || '';

// Precio mínimo para el sticky CTA
const minPrice = ordenados.length > 0
  ? Math.min(...ordenados.map(p => p.price).filter(Boolean))
  : 0;
