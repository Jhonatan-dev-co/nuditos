    window.NUDITOS_CATEGORIES = ${JSON.stringify(safeCategories)}; 
    window.NUDITOS_LIVE_CONFIG = ${JSON.stringify(publicConfig)};
    window.LANDING_DATA = {
      targetDate: "${content.targetDate || ''}",
      heroBadge: "${content.heroBadge || ''}",
      title: "${landingData.title || ''}"
    };
  `} />

  <script is:inline>
    (function() {
      // 1. Countdown Logic
      var targetDateStr = window.LANDING_DATA.targetDate;
      if (!targetDateStr) return;
      
      var target = new Date(targetDateStr + 'T23:59:59-05:00').getTime();
      function updateCountdown() {
        var now = Date.now();
        var diff = target - now;
        var dEl = document.getElementById('cdDays');
        var hEl = document.getElementById('cdHours');
        var mEl = document.getElementById('cdMins');
        if (!dEl) return;
        if (diff <= 0) {
          var banner = document.getElementById('madreCountdown');
          if (banner) banner.parentElement.innerHTML = '<span class="text-rose-800 font-bold">' + (window.LANDING_DATA.heroBadge || window.LANDING_DATA.title) + ' — ¡Aprovecha ahora!</span>';
          return;
        }
        var days  = Math.floor(diff / (1000 * 60 * 60 * 24));
        var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        var mins  = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        dEl.textContent = String(days).padStart(2, '0');
        hEl.textContent = String(hours).padStart(2, '0');
        mEl.textContent = String(mins).padStart(2, '0');
      }
      updateCountdown();
      setInterval(updateCountdown, 60000);

      // 2. Sticky CTA visibility logic
      const stickyCTA = document.getElementById('stickyCTA');
      const showThreshold = 600; // Pixeles de scroll para mostrar
      
      window.addEventListener('scroll', () => {
        if (window.scrollY > showThreshold) {
          stickyCTA.classList.add('is-visible');
        } else {
          stickyCTA.classList.remove('is-visible');
        }
      }, { passive: true });
    })();
  </script>
