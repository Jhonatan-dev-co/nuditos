---
import PremiumLanding from '../components/PremiumLanding.astro';
import { COMMERCIAL_LANDINGS } from '../data/seo-landings';
export const prerender = false;

const config = COMMERCIAL_LANDINGS['regalos-para-novia'];
---
<PremiumLanding
  seoTitle={config.title}
  seoDesc={config.description}
  seoKeywords={config.keywords}
  eyebrow={config.eyebrow}
  h1={config.h1.split(' con ')[0]}
  h1Em="con significado"
  heroCopy={config.heroCopy}
  ctaWaText={`Hola Nuditos! 🌸 Quiero un regalo especial para mi novia`}
  productKeywords={config.productHints}
  collectionTitle="Ramos de Amor Eterno"
  relatedLinks={config.relatedLinks}
  faq={config.faq}
  ctaFinalTitle="¿Sorprendemos a tu <em class='italic text-violet-600 font-normal'>novia?</em>"
  ctaFinalCopy="Dile lo que sientes con un detalle que pueda conservar para siempre."
  ctaTags={["🌸 Hecho a mano", "💝 Detalle romántico", "🚚 Envío nacional"]}
/>
