---
import PremiumLanding from '../components/PremiumLanding.astro';
import { COMMERCIAL_LANDINGS } from '../data/seo-landings';
export const prerender = false;

const config = COMMERCIAL_LANDINGS['regalos-dia-de-la-madre'] || COMMERCIAL_LANDINGS['regalos-para-mama'];
---
<PremiumLanding
  seoTitle={config.title}
  seoDesc={config.description}
  seoKeywords={config.keywords}
  eyebrow={config.eyebrow}
  h1={config.h1.split(' con ')[0]}
  h1Em="para mamá"
  heroCopy={config.heroCopy}
  ctaWaText={`Hola Nuditos! 🌸 Quiero regalar flores a mi mamá`}
  productKeywords={config.productHints}
  collectionTitle="Ramos de Gratitud"
  relatedLinks={config.relatedLinks}
  faq={config.faq}
  ctaFinalTitle="Haz que mamá <em class='italic text-violet-600 font-normal'>sonría</em>"
  ctaFinalCopy="Un detalle artesanal que iluminará su rincón favorito por años."
  ctaTags={["🌸 Flores eternas", "🤱 Para mamá", "🚚 Envío seguro"]}
/>
