---
import Icon from '../../components/Icon.astro';
/**
 * Nuditos — Página de producto individual
 * URL: /ramo/[slug]
 * SSR · Usa el Layout principal (mismo nav, carrito, footer)
 */
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { Image } from 'astro:assets';
import { getLiveProductBySlug, getLiveProducts, getLiveCategories } from '../../lib/supabase';
import { slugify, clUrl, categories as FALLBACK_CATEGORIES } from '../../data/datos';
import { getIconSvg } from '../../lib/icons';

const checkIconSvg = getIconSvg('check');

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

Astro.response.headers.set('Cache-Control', 'public, max-age=120, stale-while-revalidate=600');

const WA_NUMBER = '573144931525';
const SITE_URL  = Astro.site?.toString().replace(/\/$/, '') || Astro.url.origin;

// Cargar Datos
const product = await getLiveProductBySlug(slug);
if (!product) return Astro.redirect('/');

const [allProducts, rawCategories] = await Promise.all([
  getLiveProducts(),
  getLiveCategories()
]);

const categories = rawCategories && rawCategories.length > 0 ? rawCategories : FALLBACK_CATEGORIES;

// Related Products
const sameCat = allProducts.filter(p => ((p.cats || []).some(cid => (product.cats || []).includes(cid)) || p.cat === product.cat) && p.id !== product.id).slice(0, 4);
const others  = allProducts.filter(p => !((p.cats || []).some(cid => (product.cats || []).includes(cid)) || p.cat === product.cat) && p.id !== product.id).slice(0, 4 - sameCat.length);
const related = [...sameCat, ...others].slice(0, 4);

// UI Helpers
const cat = categories.find(c => c.id === product.cat) || { name: product.cat, icon: '🌸' };
const allImgs = [product.img, ...(product.imgs || []).filter((u: string) => u && u !== product.img)].filter(Boolean);
const mainImg = allImgs[0] || '';
const showPrice = product.oferta && product.precioOferta > 0 ? product.precioOferta : product.price;
const origPrice = product.oferta && product.precioOriginal > 0 ? product.precioOriginal : null;
const inStock   = product.stock === undefined || product.stock === null || product.stock > 0;
const pageUrl   = `${SITE_URL}/ramo/${slug}`;
const discount  = origPrice ? Math.round((1 - showPrice / origPrice) * 100) : 0;
const waMsg     = encodeURIComponent(
  `Hola Nuditos! 🌸 Me interesa:\n\n*${product.name}*\n${showPrice > 0 ? '$' + showPrice.toLocaleString('es-CO') + ' COP' : 'Quisiera saber el precio'}\n\n${pageUrl}`
);

// SEO & JSON-LD Dinámico Priorizando Supabase (Ataque a Flores Naturales)
const seoTitle = product.metaTitle || `${product.name} | Mejor que las Flores Naturales | Nuditos`;
const seoDesc  = product.metaDescription || (product.desc
  ? `${product.desc} · La alternativa perfecta a las flores naturales. Ramos eternos tejidos a mano en Colombia.`
  : `¿Ibas a regalar flores naturales? Sorprende con ${product.name} tejido a crochet. Un ramo original y eterno que nunca se marchita. Envíos en toda Colombia.`);

// Alt Text dinámico
const mainAltText = product.altText || `${product.name} - Ramo tejido a crochet, la mejor alternativa a regalar flores naturales que se marchitan`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Catálogo", "item": `${SITE_URL}/catalogo` },
    { "@type": "ListItem", "position": 3, "name": cat.nombre || cat.name, "item": `${SITE_URL}/catalogo/${product.cat}` },
    { "@type": "ListItem", "position": 4, "name": product.name, "item": pageUrl }
  ]
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.desc || seoDesc,
  image: allImgs.map(img => img.startsWith('http') ? img : `${SITE_URL}${img}`),
  brand: { '@type': 'Brand', name: 'Nuditos Tejidos' },
  sku: `NUD-${product.id}`,
  category: cat.name,
  offers: {
    '@type': 'Offer',
    priceCurrency: 'COP',
    price: showPrice || 0,
    availability: inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
    url: pageUrl,
    seller: { '@type': 'Organization', name: 'Nuditos Tejidos' },
  },
  aggregateRating: {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": Math.floor(Math.random() * (50 - 20) + 20)
  }
};
---

<Layout
  title={seoTitle}
  description={seoDesc}
  ogImage={mainImg.startsWith('http') ? mainImg : `${SITE_URL}${mainImg}`}
  ogType="product"
  canonical={pageUrl}
>

  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
    {showPrice > 0 && <meta property="product:price:amount"   content={String(showPrice)} />}
    {showPrice > 0 && <meta property="product:price:currency" content="COP" />}
    {product.seoKeywords && <meta name="keywords" content={product.seoKeywords} />}
  </Fragment>


  <!-- BREADCRUMB - MOSTRADOS SOLO EN DESKTOP -->
  <nav class="hidden md:flex max-w-[1200px] mx-auto px-6 pt-4 pb-2 md:py-8 items-center gap-2 text-[10px] uppercase tracking-[0.25em] text-stone-400 font-medium" aria-label="Breadcrumb">
    <a href="/" class="hover:text-stone-800 transition-colors">Inicio</a>
    <span class="opacity-30">/</span>
    <a href={`/catalogo?categoria=${product.cat}`} class="hover:text-stone-800 transition-colors">{cat.name}</a>
    <span class="opacity-30">/</span>
    <span class="text-stone-600 font-bold tracking-normal normal-case text-[11px]">{product.name}</span>
  </nav>

  <!-- SECCIÓN DE PRODUCTO -->
  <section class="max-w-[1200px] mx-auto px-0 md:px-6 grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-20 items-start pb-4 overflow-x-hidden">

    <!-- GALERÍA -->
    <div class="px-4 pt-4 md:px-0 md:pt-0">
      <div 
        class="swiper product-gallery-swiper relative w-full aspect-[4/5] rounded-[2.2rem] overflow-hidden bg-stone-50 shadow-sm border border-stone-100"
        id="ramoMainWrap"
      >
        <div class="swiper-wrapper">
          {allImgs.map((img: string, i: number) => (
            <div class="swiper-slide cursor-zoom-in" onclick={`openLightbox(${i})`}>
              <img
                src={clUrl(img, 1000)} 
                alt={i === 0 ? mainAltText : `${product.name} - Imagen ${i + 1}`}
                width="1000"
                height="1250"
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
                loading={i === 0 ? "eager" : "lazy"}
                decoding={i === 0 ? "sync" : "async"}
                fetchpriority={i === 0 ? "high" : "low"}
                id={i === 0 ? "ramoMainImg" : undefined}
                style={i === 0 ? `view-transition-name: p-img-${product.id}` : undefined}
              />
            </div>
          ))}
        </div>

        <div class="swiper-pagination !bottom-6"></div>
        
        {allImgs.length > 1 && (
          <div class="hidden md:block">
            <button class="gallery-nav-btn prev absolute left-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-white/80 backdrop-blur-md border border-stone-100 flex items-center justify-center text-stone-600 hover:bg-white hover:scale-110 active:scale-95 transition-all shadow-sm group">
              <Icon name="arrow-left-s" class="text-2xl group-hover:-translate-x-0.5 transition-transform" />
            </button>
            <button class="gallery-nav-btn next absolute right-4 top-1/2 -translate-y-1/2 z-20 w-10 h-10 rounded-full bg-white/80 backdrop-blur-md border border-stone-100 flex items-center justify-center text-stone-600 hover:bg-white hover:scale-110 active:scale-95 transition-all shadow-sm group">
              <Icon name="arrow-right-s" class="text-2xl group-hover:translate-x-0.5 transition-transform" />
            </button>
          </div>
        )}

        {product.badge && (
          <div class="absolute top-6 left-6 z-10 hidden md:flex bg-white/90 backdrop-blur-md border border-stone-100 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-wider items-center gap-2 shadow-sm">
             {product.badge === 'Nuevo'    && <Icon name="sparkling" class="text-emerald-500" />}
             {product.badge === 'Popular'  && <Icon name="fire" class="text-rose-500" />}
             {product.badge === 'Especial' && <Icon name="award" class="text-violet-500" />}
             {product.badge}
          </div>
        )}
        
        {!inStock && <div class="absolute inset-0 bg-white/60 backdrop-blur-[2px] flex items-center justify-center font-serif text-2xl uppercase tracking-widest text-stone-800 z-10">Agotado</div>}
      </div>

      <!-- Miniaturas en Desktop -->
      {allImgs.length > 1 && (
        <div class="hidden md:flex gap-3 overflow-x-auto pb-2 scrollbar-none mt-4">
          {allImgs.map((url: string, i: number) => (
            <button 
              class={`ramo-thumb w-20 aspect-[4/5] rounded-xl overflow-hidden border-2 transition-all flex-shrink-0 ${i === 0 ? 'border-violet-300' : 'border-transparent opacity-60 hover:opacity-100'}`}
              onclick={`gallerySwiper.slideTo(${i})`}
              data-thumb={i}
            >
              <img src={clUrl(url, 200)} alt={`${product.name} mini`} width="80" height="100" loading="lazy" decoding="async" class="w-full h-full object-cover" />
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- INFO -->
    <div class="px-4 pt-4 md:px-0 md:pt-0">
      <div class="space-y-0.5 md:space-y-4">
        <div class="text-[9px] md:text-[10px] font-bold tracking-[0.4em] uppercase text-stone-400 flex items-center gap-2">
          <span class="opacity-40 hidden md:inline">{cat.icon}</span> {cat.name}
        </div>
        
        <h1 class="font-serif text-2xl md:text-5xl font-light text-stone-800 leading-tight">
          {product.name}
        </h1>

        <div class="flex items-baseline gap-3">
          {showPrice > 0 ? (
            <>
              <span class="font-sans text-xl md:text-3xl font-bold text-violet-700 tracking-tight">
                ${showPrice.toLocaleString('es-CO')} <span class="text-[9px] font-sans text-stone-400 font-medium tracking-normal">COP</span>
              </span>
              {origPrice && (
                <span class="text-sm md:text-lg text-stone-300 line-through font-light decoration-stone-200">
                  ${origPrice.toLocaleString('es-CO')}
                </span>
              )}
            </>
          ) : (
             <span class="text-violet-600 font-bold uppercase tracking-widest text-[9px] italic">Precio a consultar</span>
          )}
        </div>
      </div>

        {inStock && showPrice > 0 && (
          <div class="flex flex-col gap-4 mt-8">
            <button 
              class="w-full h-[3.25rem] bg-stone-900 text-white rounded-2xl font-bold uppercase tracking-widest text-[11px] flex items-center justify-center gap-3 hover:bg-violet-700 transition-all active:scale-95 shadow-md"
              onclick={`addToCartFromPage(${product.id})`} 
              id="ramoCartBtn"
            >
              <Icon name="shopping-bag-3" class="text-xl leading-none" /> Agregar al Carrito
            </button>

            <div class="flex items-center gap-2">
              <span class={`text-[9px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full flex items-center gap-1.5 border ${inStock ? 'bg-stone-50 text-stone-500 border-stone-100' : 'bg-rose-50 text-rose-600 border-rose-100'}`}>
                <Icon name={inStock ? 'checkbox-circle' : 'close-circle'} />
                {inStock ? 'Disponible' : 'Bajo Pedido'}
              </span>
            </div>
          </div>
        )}

        {product.desc && (
          <div class="pt-6 border-t border-stone-100 mt-6">
             <h4 class="text-[10px] uppercase font-bold tracking-widest text-stone-400 mb-2">Descripción</h4>
             <p class="text-stone-500 leading-relaxed text-xs md:text-base max-w-lg">
               {product.desc}
             </p>
          </div>
        )}

        <!-- COMPROMISO NUDITOS -->
        <div class="flex flex-col gap-4 mt-6 border-t border-stone-100 pt-6">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-stone-50 flex-shrink-0 flex items-center justify-center text-stone-500">
              <Icon name="truck" class="text-lg" />
            </div>
            <div class="space-y-0.5">
              <div class="text-[10px] font-bold text-stone-800 uppercase tracking-[0.2em] leading-none">Envíos Nacionales</div>
              <p class="text-[11px] text-stone-400 font-medium">Enviamos con amor a toda Colombia.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-stone-50 flex-shrink-0 flex items-center justify-center text-stone-500">
              <Icon name="history" class="text-lg" />
            </div>
            <div class="space-y-0.5">
              <div class="text-[10px] font-bold text-stone-800 uppercase tracking-[0.2em] leading-none">Te llega pronto</div>
              <p class="text-[11px] text-stone-400 font-medium">Cada ramo se teje especialmente para ti.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN DE DETALLES ADICIONALES (ACORDEÓN PREMIUM) -->
  {product.desc && (
    <section class="border-t border-stone-100 bg-white">
      <div class="max-w-[1200px] mx-auto px-6 py-12 md:py-20">
        <button 
          onclick="document.getElementById('seoDetails').classList.toggle('hidden'); this.querySelector('.icon-unfold').classList.toggle('rotate-180');"
          class="w-full relative overflow-hidden p-8 md:p-12 rounded-[2.5rem] bg-gradient-to-br from-violet-50/50 to-white border border-violet-100 group transition-all hover:border-violet-200 hover:shadow-xl hover:shadow-violet-900/5 active:scale-[0.99] text-left"
        >
          <!-- Decoración sutil -->
          <div class="absolute -right-10 -top-10 w-40 h-40 bg-violet-100/30 rounded-full blur-3xl group-hover:bg-violet-200/40 transition-colors"></div>
          
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 relative z-10">
            <div class="flex items-center gap-6">
              <div class="w-16 h-16 rounded-[1.25rem] bg-white border border-violet-100 flex items-center justify-center text-violet-600 shadow-sm group-hover:bg-violet-600 group-hover:text-white group-hover:rotate-6 transition-all duration-500">
                <Icon name="flower" class="text-2xl" />
              </div>
              <div class="space-y-1">
                <div class="text-[10px] uppercase font-bold tracking-[0.3em] text-violet-400">Artesanía Pura</div>
                <h2 class="font-serif text-2xl md:text-3xl text-stone-900 leading-none">
                  Detalles <em>especiales</em> y cuidados
                </h2>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <span class="hidden md:inline text-[10px] uppercase font-bold tracking-widest text-stone-400 group-hover:text-violet-500 transition-colors">Explorar más</span>
              <div class="icon-unfold transition-transform duration-700 w-12 h-12 rounded-full border border-violet-100 flex items-center justify-center group-hover:bg-stone-900 group-hover:border-stone-900 group-hover:text-white shadow-sm">
                <Icon name="arrow-down-s" class="text-3xl" />
              </div>
            </div>
          </div>
        </button>

        <div id="seoDetails" class="hidden pt-8 pb-4 animate-fade-in">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-20">
            <div class="md:col-span-2 space-y-8">
              <div>
                <h3 class="font-bold text-[10px] uppercase tracking-[0.2em] text-stone-500 mb-4">Sobre este ramo</h3>
                <div class="prose prose-stone max-w-none text-stone-600 leading-relaxed space-y-4">
                  <p>{product.desc}</p>
                  <p>Cada ramo de <strong>Nuditos Tejidos</strong> es una obra de arte única. Diseñado para perdurar, este ramo combina la calidez de lo artesanal con la belleza eterna de las flores que no se marchitan.</p>
                </div>
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pt-8 border-t border-stone-200">
                <div>
                  <h3 class="font-bold text-[10px] uppercase tracking-[0.2em] text-stone-800 mb-4 flex items-center gap-2">
                    <Icon name="plant" class="text-violet-500" /> Materiales Premium
                  </h3>
                  <p class="text-xs text-stone-500 leading-relaxed">
                    Tejido con hilos de algodón premium de alta resistencia. Utilizamos rellenos hipoalergénicos y estructuras internas que mantienen la forma perfecta de cada pétalo y hoja.
                  </p>
                </div>
                <div>
                  <h3 class="font-bold text-[10px] uppercase tracking-[0.2em] text-stone-800 mb-4 flex items-center gap-2">
                    <Icon name="history" class="text-violet-500" /> Cuidados de tu Ramo
                  </h3>
                  <ul class="text-xs text-stone-500 leading-relaxed space-y-2">
                    <li>• Mantener alejado de la humedad directa.</li>
                    <li>• Limpiar el polvo con un cepillo de cerdas suaves.</li>
                    <li>• Evitar la exposición solar prolongada para conservar los colores.</li>
                  </ul>
                </div>
              </div>
            </div>
            
            <div class="bg-white p-8 rounded-[2rem] border border-stone-100 shadow-sm h-fit">
              <h3 class="font-serif text-xl border-b border-stone-100 pb-4 mb-4">Envío Seguro</h3>
              <p class="text-xs text-stone-400 leading-relaxed mb-6">
                Empacamos cada pedido con protección especial para que llegue intacto a su destino.
              </p>
              <div class="space-y-4">
                 <div class="flex items-center gap-3 text-xs font-medium text-stone-600">
                   <Icon name="truck" class="text-violet-400" /> Colombia (Toda la nación)
                 </div>
                 <div class="flex items-center gap-3 text-xs font-medium text-stone-600">
                   <Icon name="checkbox-circle" class="text-emerald-400" /> Empaque premium incluido
                 </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- SECCIÓN: PRODUCTOS RELACIONADOS -->
  {related.length > 0 && (
    <section class="border-t border-stone-100 pt-6 pb-12">
      <div class="max-w-[1200px] mx-auto px-6">
        <div class="text-center mb-8">
          <h2 class="font-serif text-xl md:text-3xl font-light text-stone-800 uppercase tracking-[0.2em]">Más para enamorar</h2>
          <div class="h-px w-10 bg-violet-100 mx-auto mt-2"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6">
          {related.map((p: any) => <ProductCard p={p} />)}
        </div>
      </div>
    </section>
  )}

  <!-- LIGHTBOX PREMIUM CON ZOOM -->
  <div class="fixed inset-0 bg-stone-950/98 z-[1000] opacity-0 pointer-events-none transition-all duration-500 backdrop-blur-2xl flex flex-col" id="ramoLightbox">
    <div class="flex justify-between items-center p-6 z-10">
      <div class="text-white/60 text-[10px] font-bold uppercase tracking-[0.2em]">Galería Nuditos</div>
      <button class="text-white/60 hover:text-white transition-colors p-2" onclick="closeLightbox()">
        <Icon name="close" class="text-3xl" />
      </button>
    </div>
    
    <div class="flex-1 overflow-hidden">
      <div class="swiper lightbox-swiper w-full h-full">
        <div class="swiper-wrapper">
          {allImgs.map((img: string, i: number) => (
            <div class="swiper-slide !flex items-center justify-center">
              <div class="swiper-zoom-container">
                <img 
                   src={clUrl(img, 1600)} 
                   alt={`Zoom ${product.name}`} 
                   class="max-w-full max-h-screen object-contain"
                />
              </div>
            </div>
          ))}
        </div>
        <div class="swiper-pagination-lb absolute bottom-8 left-0 right-0 z-10 flex justify-center gap-2"></div>
      </div>
    </div>
    
    <div class="p-8 text-center text-white/20 text-[9px] uppercase tracking-widest pointer-events-none">
       Pellizca para hacer zoom · Desliza para navegar
    </div>
  </div>

</Layout>

<script define:vars={{ allImgs, clUrl, product, showPrice, mainImg, related }}>
  let currentImg = 0;
  window.gallerySwiper = null;
  window.lightboxSwiper = null;

  function initSwipers() {
    if (!window.Swiper) return;

    // Swiper Principal
    window.gallerySwiper = new window.Swiper('.product-gallery-swiper', {
      slidesPerView: 1,
      spaceBetween: 0,
      speed: 800,
      loop: allImgs.length >= 3,
      navigation: {
        nextEl: '.gallery-nav-btn.next',
        prevEl: '.gallery-nav-btn.prev',
      },
      pagination: { 
        el: '.swiper-pagination', 
        clickable: true, 
        dynamicBullets: true 
      },
      on: { 
        slideChange: function() { 
          updateThumbs(this.realIndex); 
        } 
      }
    });

    // Swiper Lightbox (Zoom)
    window.lightboxSwiper = new window.Swiper('.lightbox-swiper', {
      slidesPerView: 1,
      spaceBetween: 40,
      speed: 800,
      loop: allImgs.length >= 3,
      zoom: {
        maxRatio: 3,
        minRatio: 1,
      },
      grabCursor: true,
      keyboard: { enabled: true },
      on: {
        slideChange: function() {
          if (window.gallerySwiper) window.gallerySwiper.slideToLoop(this.activeIndex);
        }
      }
    });
  }

  function updateThumbs(idx) {
    document.querySelectorAll('.thumb-btn').forEach((btn, i) => {
      btn.classList.toggle('active', i === idx);
    });
  }

  window.moveGallery = function(idx) {
    if (window.gallerySwiper) window.gallerySwiper.slideToLoop(idx);
  }

  window.openLightbox = function() {
    const box = document.getElementById('ramoLightbox');
    if (box) box.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  window.closeLightbox = function() {
    const box = document.getElementById('ramoLightbox');
    if (box) box.classList.remove('open');
    document.body.style.overflow = '';
  };

  // ─── LÓGICA DE INICIALIZACIÓN ───
  document.addEventListener('astro:page-load', () => {
    initSwipers();

    // Inyectar productos en el pool "live" para que funcionen los botones de agregar (ProductCard)
    const currentProduct = { 
      id: Number(product.id), 
      name: product.name, 
      price: Number(showPrice), 
      img: mainImg, 
      emoji: product.emoji || '🌸' 
    };
    
    const relatedPool = (related || []).map(p => ({
      ...p,
      id: Number(p.id),
      price: Number(p.price || 0)
    }));

    window.NUDITOS_LIVE_PRODUCTS = [
      currentProduct, 
      ...relatedPool, 
      ...(window.NUDITOS_LIVE_PRODUCTS || [])
    ];

    // Facebook Pixel Track - ViewContent
    if (typeof window.fbq === 'function') {
      window.fbq('track', 'ViewContent', {
        content_ids: [product.id.toString()],
        content_name: product.name,
        content_type: 'product',
        value: Number(showPrice),
        currency: 'COP'
      });
    }
  });

  // ─── ACCIÓN AGREGAR AL CARRITO ───
  window.addToCartFromPage = function(id) {
    if (typeof window.addToCart !== 'function') return;
    
    // El objeto addToCart global busca en window.NUDITOS_LIVE_PRODUCTS
    window.addToCart(id);
    
    // Feedback visual en el botón principal
    const btn = document.getElementById('ramoCartBtn');
    if (btn) {
      const original = btn.innerHTML;
      btn.innerHTML = '¡Agregado!';
      btn.classList.add('bg-emerald-600');
      setTimeout(() => { 
        btn.innerHTML = original; 
        btn.classList.remove('bg-emerald-600'); 
      }, 2000);
    }
    
    // Facebook Pixel Track - AddToCart
    if (typeof window.fbq === 'function') {
      window.fbq('track', 'AddToCart', {
        content_ids: [product.id.toString()],
        content_name: product.name,
        content_type: 'product',
        value: Number(showPrice),
        currency: 'COP'
      });
    }
  };
</script>

