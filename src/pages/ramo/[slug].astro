---
/**
 * Nuditos — Página de producto individual
 * URL: /ramo/[slug]
 * SSR · Usa el Layout principal (mismo nav, carrito, footer)
 */
export const prerender = false;

import Layout from '../../layouts/Layout.astro';

const { slug } = Astro.params;

const SB_URL  = 'https://fpyhkxikxdwjhukltmqf.supabase.co';
const SB_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZweWhreGlreGR3amh1a2x0bXFmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI2NzE1OTIsImV4cCI6MjA4ODI0NzU5Mn0.U1fHtV23e3uTlaH9qoeibzbm1d6MEcUaFE7rDhnokgM';

const WA_NUMBER = '573144931525';
const SITE_URL  = 'https://flourishing-jalebi-c858a8.netlify.app';

function slugify(text: string) {
  return (text || '').toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').trim();
}

const catNames: Record<string, { name: string; icon: string }> = {
  rosas:      { name: 'Rosas',            icon: '🌹' },
  amarillas:  { name: 'Flores Amarillas', icon: '🌻' },
  noche:      { name: 'Noche Estrellada', icon: '🌙' },
  snoopy:     { name: 'Snoopy',           icon: '🐶' },
  macetas:    { name: 'Macetas',          icon: '🌱' },
  rapunzel:   { name: 'Rapunzel',         icon: '🌸' },
  especial:   { name: 'Especiales',       icon: '✨' },
  amigurumis: { name: 'Amigurumis',       icon: '🧸' },
};

let product: any = null;
let related: any[] = [];

try {
  const res  = await fetch(`${SB_URL}/rest/v1/productos?activo=eq.true&order=id.asc`, {
    headers: { apikey: SB_ANON, Authorization: `Bearer ${SB_ANON}` }
  });
  const rows = await res.json();

  const all = rows.map((p: any) => ({
    id:             p.id,
    name:           p.nombre           || '',
    price:          p.precio           || 0,
    precioOriginal: p.precio_original  || 0,
    precioOferta:   p.precio_oferta    || 0,
    desc:           p.descripcion      || '',
    cat:            p.categoria        || '',
    emoji:          p.emoji            || '🌸',
    img:            p.img              || '',
    imgs:           Array.isArray(p.imgs) ? p.imgs : [],
    stock:          p.stock,
    badge:          p.badge            || '',
    badgeClass:     p.badge_class      || '',
    oferta:         p.oferta           || false,
    envioGratis:    p.envio_gratis     || false,
    slug:           slugify(p.nombre   || ''),
  }));

  product = all.find((p: any) => p.slug === slug) || null;

  if (product) {
    const sameCat = all.filter((p: any) => p.cat === product.cat && p.id !== product.id).slice(0, 4);
    const others  = all.filter((p: any) => p.cat !== product.cat && p.id !== product.id).slice(0, 4 - sameCat.length);
    related = [...sameCat, ...others].slice(0, 4);
  }
} catch (e) {
  console.error('[ramo/slug]', e);
}

if (!product) return Astro.redirect('/');

const cat        = catNames[product.cat] || { name: product.cat, icon: '🌸' };
const allImgs    = [product.img, ...product.imgs.filter((u: string) => u && u !== product.img)].filter(Boolean);
const mainImg    = allImgs[0] || '';
const showPrice  = product.oferta && product.precioOferta > 0 ? product.precioOferta : product.price;
const origPrice  = product.oferta && product.precioOriginal > 0 ? product.precioOriginal : null;
const inStock    = product.stock === undefined || product.stock === null || product.stock > 0;
const pageUrl    = `${SITE_URL}/ramo/${slug}`;
const discount   = origPrice ? Math.round((1 - showPrice / origPrice) * 100) : 0;
const waMsg      = encodeURIComponent(
  `Hola Nuditos! 🌸 Me interesa:\n\n*${product.name}*\n${showPrice > 0 ? '$' + showPrice.toLocaleString('es-CO') + ' COP' : 'Quisiera saber el precio'}\n\n${pageUrl}`
);

const seoTitle = `${product.name} | Nuditos Tejidos`;
const seoDesc  = product.desc
  ? `${product.desc}${showPrice > 0 ? ' · $' + showPrice.toLocaleString('es-CO') + ' COP' : ''}`
  : `${product.name} tejido a mano · ${showPrice > 0 ? '$' + showPrice.toLocaleString('es-CO') + ' COP' : 'Consulta el precio'}`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.desc || product.name,
  image: allImgs,
  brand: { '@type': 'Brand', name: 'Nuditos Tejidos' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'COP',
    price: showPrice || 0,
    availability: inStock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
    seller: { '@type': 'Organization', name: 'Nuditos Tejidos' },
  },
};
---

<Layout
  title={seoTitle}
  description={seoDesc}
  ogImage={mainImg || undefined}
  ogType="product"
  canonical={pageUrl}
>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    {showPrice > 0 && <meta property="product:price:amount"   content={String(showPrice)} />}
    {showPrice > 0 && <meta property="product:price:currency" content="COP" />}
  </Fragment>

  <!-- BREADCRUMB -->
  <nav class="ramo-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Inicio</a>
    <span>›</span>
    <a href={`/#${product.cat}`}>{cat.icon} {cat.name}</a>
    <span>›</span>
    <span class="bc-current">{product.name}</span>
  </nav>

  <!-- PRODUCTO -->
  <section class="ramo-section">

    <!-- GALERÍA -->
    <div class="ramo-gallery">
      <div class="ramo-main-img" id="ramoMainWrap" onclick="openLightbox(currentImg)">
        {mainImg
          ? <img id="ramoMainImg" src={mainImg} alt={product.name} />
          : <div class="ramo-emoji-ph">{product.emoji}</div>
        }
        {product.badge && (
          <div class={`ramo-badge ramo-badge-${product.badge.toLowerCase()}`}>
            {product.badge === 'Nuevo'    && <i class="ri-sparkling-line"></i>}
            {product.badge === 'Popular'  && <i class="ri-fire-line"></i>}
            {product.badge === 'Especial' && <i class="ri-award-line"></i>}
            {product.badge}
          </div>
        )}
        {!inStock && (
          <div class="ramo-agotado-overlay"><span>Agotado</span></div>
        )}
        <div class="ramo-zoom-hint"><i class="ri-zoom-in-line"></i></div>
      </div>

      {allImgs.length > 1 && (
        <div class="ramo-thumbs">
          {allImgs.map((url: string, i: number) => (
            <button class={`ramo-thumb ${i === 0 ? 'active' : ''}`} onclick={`switchImg(${i})`}>
              <img src={url} alt={`${product.name} ${i + 1}`} loading="lazy" />
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- INFO -->
    <div class="ramo-info">
      <a class="ramo-cat" href={`/#${product.cat}`}>{cat.icon} {cat.name}</a>

      <h1 class="ramo-name">{product.name}</h1>

      <div class="ramo-price-block">
        {showPrice > 0 ? (
          <>
            {origPrice && <span class="ramo-price-orig">${origPrice.toLocaleString('es-CO')}</span>}
            <span class="ramo-price-main">${showPrice.toLocaleString('es-CO')} COP</span>
            {origPrice && <span class="ramo-discount-badge">-{discount}%</span>}
          </>
        ) : (
          <span class="ramo-price-consultar"><i class="ri-whatsapp-line"></i> Precio a consultar</span>
        )}
      </div>

      {product.desc && <p class="ramo-desc">{product.desc}</p>}

      <div class="ramo-tags">
        {product.envioGratis && <span class="ramo-tag ramo-tag-envio"><i class="ri-truck-line"></i> Envío gratis</span>}
        {inStock
          ? <span class="ramo-tag ramo-tag-stock"><i class="ri-checkbox-circle-line"></i> Disponible</span>
          : <span class="ramo-tag ramo-tag-agotado"><i class="ri-close-circle-line"></i> Agotado</span>
        }
        <span class="ramo-tag ramo-tag-hecho"><i class="ri-scissors-cut-line"></i> Hecho a mano</span>
      </div>

      <div class="ramo-divider"></div>

      <div class="ramo-actions">
        {inStock && showPrice > 0 && (
          <button class="ramo-btn-cart" onclick={`addToCartFromPage(${product.id})`} id="ramoCartBtn">
            <i class="ri-shopping-bag-line"></i> Agregar al carrito
          </button>
        )}
        <a class="ramo-btn-wa" href={`https://wa.me/${WA_NUMBER}?text=${waMsg}`} target="_blank" rel="noopener">
          <i class="ri-whatsapp-line"></i>
          {inStock ? 'Pedir por WhatsApp' : 'Consultar disponibilidad'}
        </a>
      </div>

      <div class="ramo-share">
        <span class="ramo-share-label">Compartir:</span>
        <button class="ramo-share-btn" onclick="copyLink()"><i class="ri-link"></i></button>
        <a class="ramo-share-btn" href={`https://wa.me/?text=${encodeURIComponent(product.name + '\n' + pageUrl)}`} target="_blank" rel="noopener"><i class="ri-whatsapp-line"></i></a>
        <a class="ramo-share-btn" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(pageUrl)}`} target="_blank" rel="noopener"><i class="ri-facebook-line"></i></a>
        <span class="ramo-copy-msg" id="copyMsg">¡Enlace copiado!</span>
      </div>
    </div>
  </section>

  <!-- RELACIONADOS -->
  {related.length > 0 && (
    <section class="ramo-related">
      <h2 class="ramo-related-title">🌸 También te puede gustar</h2>
      <div class="ramo-related-grid">
        {related.map((p: any) => (
          <a class="ramo-rel-card" href={`/ramo/${slugify(p.name)}`}>
            <div class="ramo-rel-img">
              <span>{p.emoji}</span>
              {p.img && <img src={p.img} alt={p.name} loading="lazy" />}
            </div>
            <div class="ramo-rel-body">
              <div class="ramo-rel-name">{p.name}</div>
              <div class="ramo-rel-price">{p.price > 0 ? `$${p.price.toLocaleString('es-CO')} COP` : 'Consultar'}</div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- LIGHTBOX -->
  <div class="ramo-lightbox" id="ramoLightbox" onclick="closeLightbox()">
    <button class="lb-close" onclick="closeLightbox()"><i class="ri-close-line"></i></button>
    <button class="lb-prev" onclick="lbNav(-1,event)"><i class="ri-arrow-left-s-line"></i></button>
    <img id="lbImg" src="" alt={product.name} />
    <button class="lb-next" onclick="lbNav(1,event)"><i class="ri-arrow-right-s-line"></i></button>
  </div>

</Layout>

<style is:global>
  .ramo-breadcrumb{max-width:1100px;margin:0 auto;padding:.8rem 1.5rem;font-size:.75rem;color:var(--text-soft,#7a6882);display:flex;align-items:center;gap:.4rem;flex-wrap:wrap}
  .ramo-breadcrumb a{transition:color .2s}.ramo-breadcrumb a:hover{color:#8b5cf6}
  .bc-current{color:var(--text,#1a1a1a);font-weight:500}

  .ramo-section{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:3rem;padding:1rem 1.5rem 3.5rem}

  .ramo-gallery{display:flex;flex-direction:column;gap:.75rem}
  .ramo-main-img{aspect-ratio:3/4;border-radius:24px;overflow:hidden;background:#f5f3ff;position:relative;cursor:zoom-in;box-shadow:0 12px 50px rgba(0,0,0,.1)}
  .ramo-main-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s cubic-bezier(.4,0,.2,1)}
  .ramo-main-img:hover img{transform:scale(1.04)}
  .ramo-emoji-ph{width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:8rem}
  .ramo-badge{position:absolute;top:1rem;left:1rem;padding:.25rem .75rem;border-radius:50px;font-size:.68rem;font-weight:700;display:flex;align-items:center;gap:.3rem;text-transform:uppercase;letter-spacing:.5px}
  .ramo-badge-nuevo{background:#10b981;color:#fff}
  .ramo-badge-popular{background:#ef4444;color:#fff}
  .ramo-badge-especial{background:#6d28d9;color:#fff}
  .ramo-agotado-overlay{position:absolute;inset:0;background:rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center}
  .ramo-agotado-overlay span{background:#fff;font-weight:700;font-size:.9rem;padding:.5rem 1.5rem;border-radius:50px}
  .ramo-zoom-hint{position:absolute;bottom:.8rem;right:.8rem;background:rgba(0,0,0,.4);color:#fff;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.9rem;opacity:0;transition:opacity .2s}
  .ramo-main-img:hover .ramo-zoom-hint{opacity:1}

  .ramo-thumbs{display:flex;gap:.5rem;overflow-x:auto;padding-bottom:.2rem}
  .ramo-thumbs::-webkit-scrollbar{height:3px}
  .ramo-thumbs::-webkit-scrollbar-thumb{background:#e5e0d8;border-radius:2px}
  .ramo-thumb{width:76px;height:76px;flex-shrink:0;border-radius:12px;overflow:hidden;border:2.5px solid transparent;cursor:pointer;transition:border-color .2s;background:#f5f3ff;padding:0}
  .ramo-thumb img{width:100%;height:100%;object-fit:cover}
  .ramo-thumb.active{border-color:#8b5cf6}

  .ramo-info{display:flex;flex-direction:column;gap:1.1rem;padding-top:.5rem}
  .ramo-cat{font-size:.75rem;color:#7a6882;text-transform:uppercase;letter-spacing:1px;display:flex;align-items:center;gap:.35rem;width:fit-content;text-decoration:none;transition:color .2s}
  .ramo-cat:hover{color:#8b5cf6}
  .ramo-name{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:600;line-height:1.15;color:#1a1a1a}
  .ramo-price-block{display:flex;align-items:baseline;gap:.6rem;flex-wrap:wrap}
  .ramo-price-main{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:600;color:#6d28d9}
  .ramo-price-orig{font-size:1rem;color:#9ca3af;text-decoration:line-through}
  .ramo-discount-badge{background:#fee2e2;color:#ef4444;font-size:.72rem;font-weight:700;padding:.2rem .6rem;border-radius:50px}
  .ramo-price-consultar{font-size:1rem;color:#7a6882;font-style:italic;display:flex;align-items:center;gap:.35rem}
  .ramo-desc{font-size:.9rem;color:#7a6882;line-height:1.7;background:#fdf9f4;border-radius:14px;padding:.9rem 1.1rem;border:1px solid #e5e0d8}
  .ramo-tags{display:flex;gap:.5rem;flex-wrap:wrap}
  .ramo-tag{font-size:.72rem;font-weight:600;padding:.3rem .85rem;border-radius:50px;display:flex;align-items:center;gap:.3rem;border:1.5px solid}
  .ramo-tag-envio{background:#d1fae5;color:#065f46;border-color:#6ee7b7}
  .ramo-tag-stock{background:#f0fdf4;color:#16a34a;border-color:#86efac}
  .ramo-tag-agotado{background:#fee2e2;color:#dc2626;border-color:#fca5a5}
  .ramo-tag-hecho{background:#f5f3ff;color:#6d28d9;border-color:#ddd6fe}
  .ramo-divider{height:1px;background:#e5e0d8}
  .ramo-actions{display:flex;flex-direction:column;gap:.75rem}
  .ramo-btn-cart{display:flex;align-items:center;justify-content:center;gap:.55rem;background:#1a1a1a;color:#fff;border:none;padding:1rem 2rem;border-radius:50px;font-family:'Jost',sans-serif;font-size:.95rem;font-weight:600;cursor:pointer;transition:all .25s}
  .ramo-btn-cart:hover{background:#6d28d9;transform:translateY(-2px)}
  .ramo-btn-cart.added{background:#10b981}
  .ramo-btn-wa{display:flex;align-items:center;justify-content:center;gap:.55rem;background:#25D366;color:#fff;border:none;padding:1rem 2rem;border-radius:50px;font-family:'Jost',sans-serif;font-size:.95rem;font-weight:600;cursor:pointer;transition:all .25s;text-decoration:none;box-shadow:0 4px 20px rgba(37,211,102,.3)}
  .ramo-btn-wa:hover{background:#1db954;transform:translateY(-2px)}
  .ramo-share{display:flex;align-items:center;gap:.55rem;flex-wrap:wrap}
  .ramo-share-label{font-size:.72rem;color:#7a6882;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
  .ramo-share-btn{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:1.5px solid #e5e0d8;background:#fff;cursor:pointer;font-size:.95rem;transition:all .2s;color:#7a6882;text-decoration:none}
  .ramo-share-btn:hover{border-color:#8b5cf6;color:#8b5cf6}
  .ramo-copy-msg{font-size:.72rem;color:#10b981;font-weight:600;opacity:0;transition:opacity .3s}
  .ramo-copy-msg.show{opacity:1}

  .ramo-related{max-width:1100px;margin:0 auto 5rem;padding:0 1.5rem}
  .ramo-related-title{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:600;margin-bottom:1.3rem}
  .ramo-related-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.1rem}
  .ramo-rel-card{background:#fff;border-radius:18px;overflow:hidden;border:1.5px solid #e5e0d8;text-decoration:none;color:inherit;transition:all .25s;display:block}
  .ramo-rel-card:hover{border-color:#8b5cf6;box-shadow:0 8px 30px rgba(139,92,246,.12);transform:translateY(-3px)}
  .ramo-rel-img{aspect-ratio:3/4;background:#f5f3ff;display:flex;align-items:center;justify-content:center;font-size:3.5rem;overflow:hidden;position:relative}
  .ramo-rel-img img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
  .ramo-rel-body{padding:.8rem .9rem}
  .ramo-rel-name{font-size:.82rem;font-weight:600;line-height:1.35;margin-bottom:.3rem;color:#1a1a1a}
  .ramo-rel-price{font-family:'Cormorant Garamond',serif;font-size:.95rem;color:#6d28d9;font-weight:600}

  .ramo-lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,.93);z-index:1000;align-items:center;justify-content:center;cursor:zoom-out}
  .ramo-lightbox.open{display:flex}
  .ramo-lightbox img{max-width:90vw;max-height:90vh;object-fit:contain;border-radius:8px;pointer-events:none}
  .lb-close{position:absolute;top:1.2rem;right:1.5rem;background:rgba(255,255,255,.15);border:none;color:#fff;width:42px;height:42px;border-radius:50%;font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;z-index:10}
  .lb-close:hover{background:rgba(255,255,255,.3)}
  .lb-prev,.lb-next{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.15);border:none;color:#fff;width:46px;height:46px;border-radius:50%;font-size:1.4rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;z-index:10}
  .lb-prev{left:1.2rem}.lb-next{right:1.2rem}
  .lb-prev:hover,.lb-next:hover{background:rgba(255,255,255,.3)}

  @media(max-width:900px){
    .ramo-section{grid-template-columns:1fr;gap:1.8rem;padding:1rem 1rem 2.5rem}
    .ramo-name{font-size:1.7rem}.ramo-price-main{font-size:1.6rem}
    .ramo-related-grid{grid-template-columns:repeat(2,1fr);gap:.8rem}
  }
  @media(max-width:480px){
    .ramo-name{font-size:1.4rem}
    .ramo-related-grid{grid-template-columns:repeat(2,1fr);gap:.65rem}
  }
</style>

<script define:vars={{ allImgs, pageUrl, productId: product.id }}>
  /**
   * Astro empaqueta este script como módulo: las funciones no existen en window.
   * Los atributos onclick="" del HTML solo ven window.* → exponemos todo aquí.
   */
  let currentImg = 0;
  const imgs = allImgs;

  function switchImg(i) {
    currentImg = i;
    window.currentImg = i;
    const el = document.getElementById('ramoMainImg');
    if (el) el.src = imgs[i];
    document.querySelectorAll('.ramo-thumb').forEach((t, idx) => t.classList.toggle('active', idx === i));
  }

  function openLightbox(i) {
    if (!imgs.length) return;
    const idx = typeof i === 'number' && !Number.isNaN(i) ? i : currentImg;
    currentImg = idx;
    window.currentImg = idx;
    const lb = document.getElementById('lbImg');
    const box = document.getElementById('ramoLightbox');
    if (lb) lb.src = imgs[idx];
    if (box) {
      box.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeLightbox() {
    const box = document.getElementById('ramoLightbox');
    if (box) box.classList.remove('open');
    document.body.style.overflow = '';
  }

  function lbNav(dir, e) {
    if (e && typeof e.stopPropagation === 'function') e.stopPropagation();
    if (!imgs.length) return;
    currentImg = (currentImg + dir + imgs.length) % imgs.length;
    window.currentImg = currentImg;
    const lb = document.getElementById('lbImg');
    if (lb) lb.src = imgs[currentImg];
  }

  document.addEventListener('keydown', e => {
    const lb = document.getElementById('ramoLightbox');
    if (!lb?.classList.contains('open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') lbNav(1, { stopPropagation() {} });
    if (e.key === 'ArrowLeft') lbNav(-1, { stopPropagation() {} });
  });

  function addToCartFromPage(id) {
    if (typeof addToCart !== 'function') {
      console.warn('[ramo] addToCart no está disponible aún');
      return;
    }
    addToCart(id);
    const btn = document.getElementById('ramoCartBtn');
    if (btn) {
      btn.innerHTML = '<i class="ri-check-line"></i> ¡Agregado!';
      btn.classList.add('added');
      setTimeout(() => {
        btn.innerHTML = '<i class="ri-shopping-bag-line"></i> Agregar al carrito';
        btn.classList.remove('added');
      }, 1800);
    }
    if (typeof toggleCart === 'function') toggleCart();
  }

  async function copyLink() {
    try {
      await navigator.clipboard.writeText(pageUrl);
    } catch {
      const el = Object.assign(document.createElement('textarea'), { value: pageUrl });
      document.body.appendChild(el);
      el.select();
      document.execCommand('copy');
      document.body.removeChild(el);
    }
    const msg = document.getElementById('copyMsg');
    if (msg) {
      msg.classList.add('show');
      setTimeout(() => msg.classList.remove('show'), 2000);
    }
  }

  window.currentImg = 0;
  window.switchImg = switchImg;
  window.openLightbox = openLightbox;
  window.closeLightbox = closeLightbox;
  window.lbNav = lbNav;
  window.addToCartFromPage = addToCartFromPage;
  window.copyLink = copyLink;
</script>
