---
import PremiumLanding from '../components/PremiumLanding.astro';
export const prerender = false;
---
<PremiumLanding
  seoTitle="Flores Eternas en Colombia | Ramos que No se Marchitan | Nuditos"
  seoDesc="Descubre la magia de las flores eternas. Ramos de crochet tejidos a mano que conservan su belleza por años. El regalo perfecto y sostenible con envío a toda Colombia."
  seoKeywords="flores eternas, flores de crochet, flores que no se marchitan, ramos eternos colombia, arreglos florales tejidos, regalos sostenibles"
  eyebrow="Belleza que Perdura"
  h1="Ramos de Flores Eternas que"
  h1Em="No se Marchitan"
  heroCopy="Redefinimos el concepto de floristería. Nuestras flores eternas son piezas de arte tejidas a mano en crochet, ideales para quienes buscan un regalo que dure para siempre. Sin agua, sin cuidados, solo belleza eterna."
  ctaWaText="Hola Nuditos! 🌸 Quiero conocer su colección de flores eternas"
  productKeywords={["eterna", "flor", "tejida", "crochet"]}
  collectionTitle="Colección de Flores Eternas"
  relatedLinks={[
    { label: "Regalos para Novia", href: "/regalos-para-novia" },
    { label: "Regalos Día de la Madre", href: "/regalos-dia-de-la-madre" },
    { label: "Ramos en Cali", href: "/ramos-de-flores-cali" },
    { label: "Catálogo Completo", href: "/catalogo" }
  ]}
  faq={[
    { q: "¿Qué son las flores eternas de Nuditos?", a: "Piezas únicas tejidas a mano con hilos premium. No pasan por procesos químicos y conservan su forma y color por tiempo indefinido." },
    { q: "¿Sin mantenimiento?", a: "Correcto. No requieren agua, abono ni cuidados especiales." },
    { q: "¿Son hipoalergénicas?", a: "Sí, son ideales para personas con alergias al polen." },
    { q: "¿Hacen envíos nacionales?", a: "Sí, enviamos a toda Colombia con empaque protector." },
  ]}
  ctaFinalTitle="Lleva flores que <em class='italic text-violet-600 font-normal'>nunca mueren</em>"
  ctaFinalCopy="Escríbenos por WhatsApp y te asesoramos para elegir el ramo perfecto según la ocasión."
  ctaTags={["🌸 Sin mantenimiento", "🧶 Hecho a mano", "🚚 Envío nacional", "♻️ Sostenible"]}
/>
